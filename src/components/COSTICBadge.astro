---
export interface Props {
  variant?: 'header' | 'hero' | 'card' | 'footer';
  dark?: boolean;
  class?: string;
}

const { variant = 'card', dark = false, class: cls = '' } = Astro.props;

const cfg = {
  header: { imgW: 64,  totalW: 120, px: 8,  py: 6,  gap: 8,  radius: 10 },
  hero:   { imgW: 90,  totalW: 160, px: 12, py: 10, gap: 10, radius: 12 },
  card:   { imgW: 80,  totalW: 144, px: 10, py: 8,  gap: 9,  radius: 11 },
  footer: { imgW: 110, totalW: 190, px: 12, py: 10, gap: 10, radius: 12 },
}[variant];

const borderColor = dark ? 'rgba(255,255,255,0.12)' : 'rgba(0,0,0,0.08)';
const bgColor     = dark ? 'rgba(255,255,255,0.06)' : 'rgba(255,255,255,0.80)';
---

<div
  class={cls}
  style={`display:inline-flex; align-items:center; gap:${cfg.gap}px; padding:${cfg.py}px ${cfg.px}px; border-radius:${cfg.radius}px; background:${bgColor}; border:1px solid ${borderColor};`}
  title="Sud Ramonage — Artisan certifié COSTIC (Comité Scientifique et Technique des Industries Climatiques)"
>
  <img
    src="/images/costic-logo.png"
    alt="Logo officiel COSTIC - Certification ramonage et fumisterie Sud Ramonage"
    width={cfg.imgW}
    style={`display:block; width:${cfg.imgW}px; height:auto; object-fit:contain; flex-shrink:0;`}
    loading="lazy"
    decoding="async"
  />
</div>
