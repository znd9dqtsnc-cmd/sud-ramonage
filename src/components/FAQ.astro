---
export interface FAQItem {
  q: string;
  a: string;
}
interface Props {
  items: FAQItem[];
  title?: string;
}
const { items, title = 'Questions Fréquentes' } = Astro.props;

const faqBorders = [
  'border-l-[3px] border-l-[#E65100]/40',
  'border-l-[3px] border-l-[#1A4B8F]/40',
  'border-l-[3px] border-l-[#065F46]/40',
  'border-l-[3px] border-l-[#B45309]/40',
  'border-l-[3px] border-l-[#7C3AED]/40',
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section class="py-20 px-6 md:px-10 bg-[#FAFAFA]">
  <div class="max-w-3xl mx-auto">
    <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-4">FAQ</p>
    <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-10">{title}</h2>
    <div class="space-y-3">
      {items.map(({ q, a }, i) => (
        <details class={`group bg-white border border-[#EEEEEE] rounded-xl overflow-hidden ${faqBorders[i % faqBorders.length]}`}>
          <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none select-none hover:bg-[#FFF3E0] transition-colors duration-150">
            <span class="text-sm font-semibold text-[#1A1A1A] leading-snug">{q}</span>
            <svg
              class="w-4 h-4 text-[#E65100] shrink-0 transition-transform duration-200 group-open:rotate-180"
              fill="none" stroke="currentColor" viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-5 pt-1">
            <p class="text-sm text-[#1A1A1A]/60 font-light leading-relaxed">{a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
