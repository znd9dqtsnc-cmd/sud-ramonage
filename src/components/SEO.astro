---
import { villes } from '../data/villes';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  breadcrumbs?: { name: string; url: string }[];
  pageSchema?: object;
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-image.jpg',
  type = 'website',
  breadcrumbs,
  pageSchema,
} = Astro.props;

const siteUrl = 'https://sud-ramonage.vercel.app';
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  '@id': `${siteUrl}/#business`,
  name: 'SUD RAMONAGE',
  description: 'Artisan ramoneur certifié à Martigues. Ramonage cheminée, poêle à bois et granulés. Certificat immédiat. Conforme RSD 13.',
  url: siteUrl,
  telephone: '+33664729600',
  email: 'majeo@ik.me',
  logo: `${siteUrl}/favicon.svg`,
  image: ogImageUrl,
  address: {
    '@type': 'PostalAddress',
    streetAddress: '31 chemin des tamaris',
    addressLocality: 'Martigues',
    postalCode: '13500',
    addressRegion: 'Bouches-du-Rhône',
    addressCountry: 'FR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 43.4046,
    longitude: 5.0511,
  },
  areaServed: villes.map(v => ({
    '@type': 'City',
    name: v.nom,
  })),
  openingHoursSpecification: [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
    opens: '08:00',
    closes: '18:00',
  }],
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  paymentAccepted: 'Cash, Chèque, Virement',
  sameAs: [
    'https://fr.wikipedia.org/wiki/Ramonage',
    'https://fr.wikipedia.org/wiki/R%C3%A8glement_sanitaire_d%C3%A9partemental',
    'https://www.service-public.fr/particuliers/vosdroits/F20028',
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Services de ramonage',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Ramonage certifié',
          description: 'Ramonage mécanique complet avec certificat officiel conforme RSD 13.',
          url: `${siteUrl}/ramonage`,
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Débistrage de conduit',
          description: 'Élimination des dépôts de goudron par traitement chimique et mécanique.',
          url: `${siteUrl}/debistrage`,
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Entretien poêle à bois et granulés',
          description: 'Maintenance complète de poêle à bois et à granulés.',
          url: `${siteUrl}/entretien-poele`,
        },
      },
    ],
  },
};

const breadcrumbSchema = breadcrumbs ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.name,
    item: crumb.url.startsWith('http') ? crumb.url : `${siteUrl}${crumb.url}`,
  })),
} : null;
---

<!-- Canonical -->
<link rel="canonical" href={canonicalUrl} />

<!-- Geo meta tags (ancrage physique Martigues) -->
<meta name="geo.region" content="FR-13" />
<meta name="geo.placename" content="Martigues, Bouches-du-Rhône" />
<meta name="geo.position" content="43.4046;5.0511" />
<meta name="ICBM" content="43.4046, 5.0511" />

<!-- OpenGraph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Sud Ramonage — Artisan ramoneur certifié à Martigues" />
<meta property="og:site_name" content="Sud Ramonage" />
<meta property="og:locale" content="fr_FR" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- JSON-LD Business -->
<script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />

<!-- JSON-LD Breadcrumb -->
{breadcrumbSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}

<!-- JSON-LD Page-level schema -->
{pageSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
)}
