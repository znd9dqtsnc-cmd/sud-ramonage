---
import { villes } from '../data/villes';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  breadcrumbs?: { name: string; url: string }[];
  pageSchema?: object;
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-image.jpg',
  type = 'website',
  breadcrumbs,
  pageSchema,
} = Astro.props;

const siteUrl = 'https://www.sud-ramonage.fr';
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  '@id': `${siteUrl}/#business`,
  name: 'SUD RAMONAGE',
  description: 'Artisan ramoneur certifié à Martigues. Ramonage cheminée, poêle à bois et granulés. Certificat immédiat. Conforme RSD 13.',
  url: siteUrl,
  telephone: '+33664729600',
  email: 'majeo@ik.me',
  taxID: 'FR-SIRET-A-RENSEIGNER',
  identifier: {
    '@type': 'PropertyValue',
    name: 'SIRET',
    value: 'À renseigner',
  },
  hasCredential: [
    {
      '@type': 'EducationalOccupationalCredential',
      name: 'Certification COSTIC — Fumisterie et conduits de fumée',
      credentialCategory: 'Certification professionnelle',
      recognizedBy: { '@type': 'Organization', name: 'COSTIC', url: 'https://www.costic.com' },
    },
    {
      '@type': 'EducationalOccupationalCredential',
      name: 'Qualibat 6521 — Conduits de fumée et ventilation',
      credentialCategory: 'Qualification professionnelle',
      recognizedBy: { '@type': 'Organization', name: 'Qualibat', url: 'https://www.qualibat.com' },
    },
  ],
  logo: `${siteUrl}/favicon.svg`,
  image: ogImageUrl,
  address: {
    '@type': 'PostalAddress',
    streetAddress: '31 chemin des tamaris',
    addressLocality: 'Martigues',
    postalCode: '13500',
    addressRegion: 'Bouches-du-Rhône',
    addressCountry: 'FR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 43.4046,
    longitude: 5.0511,
  },
  brand: {
    '@type': 'Brand',
    name: 'Sud Ramonage',
  },
  hasMap: 'https://www.google.com/maps/search/Sud+Ramonage+31+chemin+des+tamaris+13500+Martigues',
  serviceArea: {
    '@type': 'GeoCircle',
    geoMidpoint: {
      '@type': 'GeoCoordinates',
      latitude: 43.4046,
      longitude: 5.0511,
    },
    geoRadius: '50000',
  },
  areaServed: villes.map(v => ({
    '@type': 'City' as const,
    name: v.nom,
    containedInPlace: {
      '@type': 'AdministrativeArea',
      name: 'Bouches-du-Rhône',
      postalCode: v.codePostal,
    },
  })),
  openingHours: 'Mo-Sa 08:00-19:00',
  openingHoursSpecification: [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
    opens: '08:00',
    closes: '19:00',
  }],
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  paymentAccepted: 'Cash, Chèque, Carte bancaire',
  sameAs: [
    // ── Autorités normatives (triangulation sémantique) ──────────────────────
    'https://www.afnor.org/',
    'https://www.ademe.fr/',
    'https://www.costic.com/',
    'https://www.qualibat.com/',
    // ── Portails officiels État ───────────────────────────────────────────────
    'https://www.service-public.fr/particuliers/vosdroits/F20028',
    'https://www.ecologie.gouv.fr/renovation-energetique',
    'https://france-renov.gouv.fr/',
    // ── Références encyclopédiques ────────────────────────────────────────────
    'https://fr.wikipedia.org/wiki/Ramonage',
    'https://fr.wikipedia.org/wiki/R%C3%A8glement_sanitaire_d%C3%A9partemental',
    'https://fr.wikipedia.org/wiki/Fumisterie_(technique)',
  ],
  knowsAbout: [
    {
      '@type': 'Thing',
      name: 'Ramonage',
      description: 'Nettoyage professionnel des conduits de fumée par voie mécanique',
      url: 'https://fr.wikipedia.org/wiki/Ramonage',
    },
    {
      '@type': 'Thing',
      name: 'Fumisterie',
      description: 'Installation, entretien et contrôle des appareils à combustion et conduits de fumée',
      url: 'https://fr.wikipedia.org/wiki/Fumisterie_(technique)',
    },
    {
      '@type': 'Thing',
      name: 'Sécurité incendie',
      description: 'Prévention des incendies de conduit par entretien et ramonage régulier',
      url: 'https://fr.wikipedia.org/wiki/S%C3%A9curit%C3%A9_incendie',
    },
    {
      '@type': 'Thing',
      name: 'Intoxication au monoxyde de carbone',
      description: 'Détection et prévention des intoxications au CO par entretien des conduits de fumée',
      url: 'https://fr.wikipedia.org/wiki/Intoxication_au_monoxyde_de_carbone',
    },
    {
      '@type': 'Thing',
      name: 'Règlement Sanitaire Départemental',
      description: 'Conformité RSD 13 — obligation légale de ramonage annuel dans les Bouches-du-Rhône',
      url: 'https://fr.wikipedia.org/wiki/R%C3%A8glement_sanitaire_d%C3%A9partemental',
    },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Services de ramonage',
    itemListElement: [
      {
        '@type': 'Offer',
        price: '75',
        priceCurrency: 'EUR',
        priceSpecification: { '@type': 'PriceSpecification', minPrice: '75', maxPrice: '110', priceCurrency: 'EUR' },
        itemOffered: {
          '@type': 'Service',
          name: 'Ramonage certifié',
          description: 'Ramonage mécanique complet avec certificat officiel conforme RSD 13. À partir de 75 €.',
          url: `${siteUrl}/ramonage`,
        },
      },
      {
        '@type': 'Offer',
        price: '150',
        priceCurrency: 'EUR',
        priceSpecification: { '@type': 'PriceSpecification', minPrice: '150', maxPrice: '195', priceCurrency: 'EUR' },
        itemOffered: {
          '@type': 'Service',
          name: 'Débistrage de conduit',
          description: 'Élimination des dépôts de goudron par traitement chimique et mécanique. À partir de 150 €.',
          url: `${siteUrl}/debistrage`,
        },
      },
      {
        '@type': 'Offer',
        price: '90',
        priceCurrency: 'EUR',
        priceSpecification: { '@type': 'PriceSpecification', minPrice: '90', maxPrice: '120', priceCurrency: 'EUR' },
        itemOffered: {
          '@type': 'Service',
          name: 'Entretien poêle à bois et granulés',
          description: 'Maintenance complète de poêle à bois et à granulés. À partir de 90 €.',
          url: `${siteUrl}/entretien-poele`,
        },
      },
    ],
  },
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${siteUrl}/#gerant`,
  name: 'Le gérant — Sud Ramonage',
  jobTitle: 'Artisan ramoneur certifié COSTIC',
  worksFor: {
    '@type': 'HomeAndConstructionBusiness',
    '@id': `${siteUrl}/#business`,
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Martigues',
    postalCode: '13500',
    addressRegion: 'Bouches-du-Rhône',
    addressCountry: 'FR',
  },
  knowsAbout: [
    'Ramonage de cheminée — NF DTU 24.1 P1-1',
    'Fumisterie — NF EN 1443',
    'Conduits de fumée — NF EN 1856-1',
    'Inserts et foyers fermés — NF EN 13229',
    'Diagnostic conduit — endoscope et caméra d\'inspection',
    'Règlement Sanitaire Départemental 13 (RSD 13)',
    'Débuage et débistrage conduit de fumée',
    'Entretien poêle à bois et poêle à granulés',
  ],
  hasCredential: [
    {
      '@type': 'EducationalOccupationalCredential',
      name: 'Certification COSTIC — Fumisterie et conduits de fumée',
      credentialCategory: 'Certification professionnelle',
      recognizedBy: {
        '@type': 'Organization',
        name: 'COSTIC',
        url: 'https://www.costic.com',
      },
    },
    {
      '@type': 'EducationalOccupationalCredential',
      name: 'Qualibat 6521 — Conduits de fumée et ventilation',
      credentialCategory: 'Qualification professionnelle',
      recognizedBy: {
        '@type': 'Organization',
        name: 'Qualibat',
        url: 'https://www.qualibat.com',
      },
    },
  ],
};

const breadcrumbSchema = breadcrumbs ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.name,
    item: crumb.url.startsWith('http') ? crumb.url : `${siteUrl}${crumb.url}`,
  })),
} : null;
---

<!-- Canonical -->
<link rel="canonical" href={canonicalUrl} />

<!-- Geo meta tags (ancrage physique Martigues) -->
<meta name="geo.region" content="FR-13" />
<meta name="geo.placename" content="Martigues, Bouches-du-Rhône" />
<meta name="geo.position" content="43.4046;5.0511" />
<meta name="ICBM" content="43.4046, 5.0511" />

<!-- OpenGraph — WhatsApp, Facebook, LinkedIn -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:secure_url" content={ogImageUrl} />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Sud Ramonage — Artisan ramoneur certifié à Martigues & Côte Bleue" />
<meta property="og:site_name" content="Sud Ramonage" />
<meta property="og:locale" content="fr_FR" />

<!-- Twitter / X Card (large image) -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@sudramonage" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content="Sud Ramonage — Artisan ramoneur certifié à Martigues" />

<!-- WhatsApp préfère une description courte + image carrée en fallback -->
<meta property="og:image:url" content={ogImageUrl} />

<!-- JSON-LD Business -->
<script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />

<!-- JSON-LD Person (gérant — E-E-A-T) -->
<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

<!-- JSON-LD Breadcrumb -->
{breadcrumbSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}

<!-- JSON-LD Page-level schema -->
{pageSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
)}
