---
import { getCollection } from 'astro:content';

export interface Props {
  count?: number;
  title?: string;
}

const { count = 3, title = 'Derniers Conseils d\'Experts' } = Astro.props;

// Articles depuis la collection (markdown pipeline)
const collectionEntries = await getCollection('blog', ({ data }) => !data.draft);
const collectionArticles = collectionEntries
  .sort((a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime())
  .slice(0, count)
  .map(e => ({
    slug: e.slug,
    href: `/conseils/${e.slug}`,
    title: e.data.title,
    excerpt: e.data.description,
    category: e.data.category,
    readTime: e.data.readTime,
    datePublished: e.data.datePublished,
    tags: e.data.tags.slice(0, 3),
  }));

// Articles statiques (.astro) — fallback si la collection est vide
const staticArticles = [
  {
    slug: 'certificat-ramonage-assureur',
    href: '/conseils/certificat-ramonage-assureur',
    title: 'Certificat de ramonage : 5 points que votre assureur vérifie.',
    excerpt: 'En cas de sinistre, votre assureur peut refuser la prise en charge si votre certificat est incomplet.',
    category: 'Réglementation',
    readTime: '5 min',
    datePublished: '2025-04-18',
    tags: ['RSD 13', 'Assurance', 'Certificat'],
  },
  {
    slug: 'bistre-calcin-ramonage-ne-suffit-plus',
    href: '/conseils/bistre-calcin-ramonage-ne-suffit-plus',
    title: 'Bistre et Calcin : Pourquoi le ramonage classique ne suffit plus ?',
    excerpt: 'Le bistre — dépôt de goudron hautement inflammable — est la première cause d\'incendie de conduit en France.',
    category: 'Technique',
    readTime: '6 min',
    datePublished: '2025-04-18',
    tags: ['Bistre', 'Calcin', 'Débistrage'],
  },
  {
    slug: 'insert-fume-dans-piece-causes-solutions',
    href: '/conseils/insert-fume-dans-piece-causes-solutions',
    title: 'Mon insert fume dans la pièce : 5 causes et leurs solutions.',
    excerpt: 'Refoulement de fumée : 5 causes classées par fréquence — conduit obstrué, tirage insuffisant, dépression, vent.',
    category: 'Diagnostic',
    readTime: '6 min',
    datePublished: '2026-04-19',
    tags: ['Refoulement', 'Tirage', 'CO'],
  },
];

// Priorité aux articles de la collection, compléter avec les statiques si besoin
const allArticles = collectionArticles.length >= count
  ? collectionArticles
  : [...collectionArticles, ...staticArticles].slice(0, count);

const categoryStyles: Record<string, string> = {
  'Réglementation': 'bg-[#EEF3FF] text-[#1A4B8F]',
  'Technique':      'bg-[#FEF3C7] text-[#92400E]',
  'Diagnostic':     'bg-[#FFF3E0] text-[#C2410C]',
  'Sécurité':       'bg-[#FEE2E2] text-[#B91C1C]',
  'Actualité':      'bg-[#D1FAE5] text-[#065F46]',
  'Conseil':        'bg-[#FDF6F0] text-[#E65100]',
};
---

<section class="py-16 px-6 md:px-10 bg-[#FAFAFA]">
  <div class="max-w-6xl mx-auto">

    <div class="flex items-end justify-between mb-10">
      <div>
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-3">Guide Expert</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A]">{title}</h2>
      </div>
      <a href="/conseils" class="hidden sm:inline-flex items-center gap-2 text-xs font-semibold text-[#1A1A1A]/55 hover:text-[#E65100] transition-colors duration-200">
        Tous les articles
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {allArticles.map(article => (
        <a
          href={article.href}
          class="group bg-white border border-[#EEEEEE] rounded-xl p-6 hover:shadow-md hover:border-[#E65100]/20 hover:-translate-y-0.5 transition-all duration-300 flex flex-col"
        >
          <div class="flex items-center gap-2 mb-4">
            <span
              class={`text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full ${categoryStyles[article.category] ?? 'bg-[#F3F4F6] text-[#1A1A1A]/60'}`}
            >
              {article.category}
            </span>
            <span class="text-[11px] text-[#1A1A1A]/35 font-light">{article.readTime}</span>
          </div>

          <h3 class="text-sm font-bold text-[#1A1A1A] leading-snug mb-3 group-hover:text-[#E65100] transition-colors duration-200 flex-1">
            {article.title}
          </h3>

          <p class="text-xs text-[#1A1A1A]/50 font-light leading-relaxed line-clamp-2 mb-4">
            {article.excerpt}
          </p>

          <div class="flex flex-wrap gap-1.5 mb-4">
            {article.tags.map(tag => (
              <span class="text-[10px] font-medium border border-[#EEEEEE] text-[#1A1A1A]/45 px-2 py-0.5 rounded">
                {tag}
              </span>
            ))}
          </div>

          <div class="flex items-center gap-1.5 text-xs font-semibold text-[#E65100] mt-auto group-hover:gap-3 transition-all duration-200">
            Lire l'article
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-8 text-center sm:hidden">
      <a href="/conseils" class="inline-flex items-center gap-2 text-xs font-semibold text-[#1A1A1A]/55 hover:text-[#E65100] transition-colors duration-200">
        Tous les articles d'experts
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

  </div>
</section>
