---
/**
 * TrustBadge — Composant de réassurance multi-variante
 *
 * Variants :
 *   "hero"   → pill translucide sur fond sombre (hero section)
 *   "strip"  → bande horizontale 3 piliers (entre sections)
 *   "card"   → carte bordée sur fond clair (section contact)
 */
export interface Props {
  variant?: 'hero' | 'strip' | 'card';
  class?: string;
}
const { variant = 'card', class: className = '' } = Astro.props;

const pillars = [
  {
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    label: 'Artisan Certifié',
    sub: 'Qualification & assurance RC pro',
  },
  {
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
    label: 'Certificat RSD 13',
    sub: 'Remis sur place immédiatement',
  },
  {
    icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
    label: 'Assurance Incluse',
    sub: 'Garantie responsabilité civile',
  },
];
---

<!-- ─── VARIANT HERO : pill translucide ─── -->
{variant === 'hero' && (
  <div class={`inline-flex items-center gap-3 bg-white/8 backdrop-blur-md border border-white/15 rounded-2xl px-5 py-3 ${className}`}>
    <!-- Bouclier -->
    <div class="w-8 h-8 rounded-lg bg-[#F97316] flex items-center justify-center shrink-0">
      <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
      </svg>
    </div>
    <div class="text-left">
      <p class="text-[11px] font-bold text-white tracking-wide leading-tight">Intervention Certifiée & Assurance Incluse</p>
      <p class="text-[10px] text-white/45 font-light mt-0.5">Certificat officiel remis après chaque intervention</p>
    </div>
  </div>
)}

<!-- ─── VARIANT STRIP : 3 piliers horizontaux ─── -->
{variant === 'strip' && (
  <section class={`bg-[#1A1A1A] border-y border-white/5 ${className}`} aria-label="Garanties Sud Ramonage">
    <div class="max-w-6xl mx-auto px-6 md:px-10">
      <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-white/8">
        {pillars.map(({ icon, label, sub }) => (
          <div class="flex items-center gap-4 py-6 px-4 md:px-8">
            <div class="w-10 h-10 rounded-xl bg-[#F97316]/15 border border-[#F97316]/25 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-[#F97316]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={icon} />
              </svg>
            </div>
            <div>
              <p class="text-xs font-bold text-white tracking-tight">{label}</p>
              <p class="text-[11px] text-white/40 font-light mt-0.5">{sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- ─── VARIANT CARD : carte bordée ─── -->
{variant === 'card' && (
  <div class={`border border-[#F97316]/20 bg-white rounded-2xl overflow-hidden ${className}`}>
    <!-- Header card -->
    <div class="bg-[#F97316] px-5 py-3 flex items-center gap-2.5">
      <svg class="w-4 h-4 text-white shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
      </svg>
      <span class="text-[11px] font-bold text-white tracking-widest uppercase">Garanties Incluses</span>
    </div>
    <!-- Corps -->
    <div class="divide-y divide-[#EEEEEE]">
      {pillars.map(({ icon, label, sub }) => (
        <div class="flex items-center gap-3 px-5 py-3.5">
          <svg class="w-4 h-4 text-[#F97316] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
          </svg>
          <div>
            <p class="text-xs font-semibold text-[#1A1A1A]">{label}</p>
            <p class="text-[10px] text-[#1A1A1A]/45 font-light">{sub}</p>
          </div>
          <svg class="w-3.5 h-3.5 text-emerald-500 shrink-0 ml-auto" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
        </div>
      ))}
    </div>
  </div>
)}
