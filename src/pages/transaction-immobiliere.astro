---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroToitsImg from '../assets/images/hero-toits.jpg';
const siteUrl = 'https://www.sud-ramonage.fr';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/transaction-immobiliere#service`,
  name: 'Audit Fumisterie — Transaction Immobilière',
  description: 'Audit certifié de conduit de fumée pour toute vente immobilière. Protège le vendeur des vices cachés, rassure l\'acheteur, fournit un rapport opposable au notaire. Bouches-du-Rhône.',
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  serviceType: 'Audit fumisterie vente immobilière',
  areaServed: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
  offers: {
    '@type': 'Offer',
    priceSpecification: { '@type': 'PriceSpecification', minPrice: '120', maxPrice: '190', priceCurrency: 'EUR' },
  },
};

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Transaction Immobilière', url: '/transaction-immobiliere' },
];
---

<Layout
  title="Audit Fumisterie Transaction Immobilière — Vices Cachés & Notaire | Sud Ramonage"
  description="Audit conduit de fumée pour vente immobilière. Protège contre les vices cachés (art. 1641), rapport opposable au notaire, Carnet de Santé du Conduit. 120–190 €. Bouches-du-Rhône."
  breadcrumbs={breadcrumbs}
  pageSchema={serviceSchema}
>

  <!-- HERO -->
  <section class="bg-white border-b border-[#EEEEEE] pt-28 pb-0">
    <div class="max-w-5xl mx-auto px-6 md:px-10 pb-16">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-[#1A1A1A]/35 mb-8">
        <a href="/" class="hover:text-[#1A1A1A]/60 transition-colors">Accueil</a>
        <span>/</span>
        <span class="text-[#1A1A1A]/50">Transaction Immobilière</span>
      </nav>

      <div class="flex flex-wrap gap-2 mb-6">
        {['Vendeurs', 'Acheteurs', 'Notaires', 'Agents immobiliers', 'Diagnostiqueurs'].map(tag => (
          <span class="text-[10px] font-bold uppercase tracking-widest bg-[#FFF3E0] text-[#EA580C] border border-[#EA580C]/15 px-3 py-1.5 rounded-full">{tag}</span>
        ))}
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-end">
        <div>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight leading-[1.08] mb-5 text-[#1A1A1A]">
            Vous vendez un bien<br />avec cheminée ?<br />
            <span class="text-[#EA580C]">Ne prenez aucun risque juridique.</span>
          </h1>
          <p class="text-base text-[#1A1A1A]/60 leading-relaxed mb-8 max-w-lg">
            Un conduit non conforme peut bloquer une vente, déclencher une action en garantie des vices cachés (art. 1641 du Code civil) ou invalider la couverture incendie de l'acquéreur. L'audit de fumisterie est votre filet de sécurité — rapport remis sous 24h.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="tel:+33664729600" class="inline-flex items-center justify-center gap-2 bg-[#EA580C] text-white text-sm font-bold px-6 py-4 rounded-xl hover:bg-[#C2410C] transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Demander un audit — 06 64 72 96 00
            </a>
            <a href="mailto:contact@sud-ramonage.fr?subject=Audit%20fumisterie%20transaction%20immobilière" class="inline-flex items-center justify-center gap-2 bg-[#FAFAFA] border border-[#EEEEEE] text-[#1A1A1A] text-sm font-semibold px-6 py-4 rounded-xl hover:border-[#EA580C]/30 transition-colors">
              Par email →
            </a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3 pb-0">
          {[
            { val: 'Art. 1641', label: 'Code civil — vice caché', sub: 'Responsabilité vendeur engagée' },
            { val: '24 h', label: 'Délai rapport', sub: 'Compatible agenda notarial' },
            { val: '120 €', label: 'Audit simple', sub: '1 conduit — rapport PDF signé' },
            { val: '+15 %', label: 'Rendement retrouvé', sub: 'Argument DPE + valorisation' },
          ].map(({ val, label, sub }) => (
            <div class="bg-[#FFF3E0] border border-[#EA580C]/15 rounded-2xl p-4">
              <p class="text-lg font-extrabold text-[#EA580C] leading-none mb-1">{val}</p>
              <p class="text-[11px] font-semibold text-[#1A1A1A] mb-1">{label}</p>
              <p class="text-[10px] text-[#1A1A1A]/45">{sub}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="relative h-12 overflow-hidden">
      <svg viewBox="0 0 1440 48" class="absolute bottom-0 w-full" preserveAspectRatio="none">
        <path fill="white" d="M0,48 C360,0 1080,0 1440,48 L1440,48 L0,48 Z"/>
      </svg>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-6 md:px-10 py-10">
    <figure class="rounded-2xl overflow-hidden aspect-[21/9] relative">
      <Image src={heroToitsImg} alt="Toitures provençales avec souches de cheminée — audit fumisterie pour transaction immobilière" width={1200} height={514} class="w-full h-full object-cover object-top" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#1A1A1A]/60 to-transparent flex items-end p-8">
        <p class="text-white text-sm font-medium leading-snug">Audit fumisterie vente — rapport opposable au notaire, protection vices cachés art. 1641.</p>
      </div>
    </figure>
  </section>

  <section class="py-8">
    <div class="max-w-5xl mx-auto px-6 md:px-10 space-y-16">

      <!-- Trois profils -->
      <div>
        <h2 class="text-2xl font-bold mb-2 text-center">Trois parties protégées, un seul document</h2>
        <p class="text-sm text-[#1A1A1A]/55 text-center mb-8">L'audit de fumisterie est utile à chaque acteur de la transaction.</p>
        <div class="grid md:grid-cols-3 gap-6">
          {[
            {
              role: 'Vendeur',
              avantages: [
                'Protection légale contre le vice caché (art. 1641)',
                'Argument de vente — installation en conformité',
                'Meilleur rendement = meilleure étiquette DPE',
                'Négociation du prix sur des bases objectives',
              ],
              color: '#EA580C',
            },
            {
              role: 'Acheteur',
              avantages: [
                'État réel du conduit avant engagement',
                'Estimation des travaux éventuels',
                'Sécurité incendie & CO vérifiée dès l\'emménagement',
                'Document à jour pour l\'assurance habitation',
              ],
              color: '#1A4B8F',
            },
            {
              role: 'Notaire & Agent immobilier',
              avantages: [
                'Document technique opposable à verser au dossier',
                'Réduction du risque de contentieux post-vente',
                'Délai compatible avec le planning notarial',
                'Rapport signé par artisan qualifié',
              ],
              color: '#1A4B8F',
            },
          ].map(({ role, avantages, color }) => (
            <div class="bg-white border border-[#EEEEEE] rounded-2xl p-6">
              <h3 class="text-base font-bold text-[#1A1A1A] mb-4" style={`border-left: 3px solid ${color}; padding-left: 0.75rem;`}>{role}</h3>
              <ul class="space-y-2.5">
                {avantages.map(av => (
                  <li class="flex gap-2 text-sm text-[#1A1A1A]/65">
                    <span class="font-bold shrink-0" style={`color: ${color};`}>✓</span>
                    <span>{av}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <!-- Le Carnet de Santé -->
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-[11px] font-semibold tracking-widest uppercase text-[#EA580C] mb-3">Notre document</p>
          <h2 class="text-2xl font-bold mb-4">Le Carnet de Santé du Conduit™</h2>
          <p class="text-sm text-[#1A1A1A]/60 leading-relaxed mb-6">
            Inspiré du carnet d'entretien automobile, c'est le passeport technique de votre installation fumisterie — historique complet, état actuel, recommandations. Transmissible à l'acheteur lors de la signature.
          </p>
          <div class="space-y-3">
            {[
              { label: 'Identification complète', detail: 'Type, dimensions, matériaux, année d\'installation' },
              { label: 'État de conformité', detail: 'Vérification RSD 13, NF DTU 24.1, distances de sécurité' },
              { label: 'Photos datées', detail: 'Documentation visuelle de l\'intérieur du conduit' },
              { label: 'Travaux réalisés', detail: 'Historique des interventions avec dates et références' },
              { label: 'Préconisations', detail: 'Travaux classés par priorité : sécurité / confort / conformité' },
            ].map(({ label, detail }) => (
              <div class="flex gap-3 bg-[#FAFAFA] rounded-xl p-4 border border-[#EEEEEE]">
                <span class="text-[#EA580C] font-bold shrink-0">→</span>
                <div>
                  <p class="text-sm font-semibold text-[#1A1A1A]">{label}</p>
                  <p class="text-xs text-[#1A1A1A]/50 mt-0.5">{detail}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="space-y-5">
          <div class="border-l-4 border-[#1A4B8F] bg-[#EEF3FF] rounded-r-2xl p-8">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#1A4B8F] mb-3">Cas typique — Vente Marseille 7e</p>
            <blockquote class="text-sm text-[#1A1A1A]/70 leading-relaxed mb-4 italic">
              "L'acheteur voulait retenir 8 000 € sur le prix pour les travaux de cheminée. Après l'audit qui montrait que tout était conforme, la négociation a été close. Le rapport a été versé au dossier du notaire."
            </blockquote>
            <p class="text-xs text-[#1A1A1A]/45">Agent immobilier — Transaction 550 000 € · Marseille 7e</p>
          </div>
          <div class="bg-[#1A4B8F]/8 border border-[#1A4B8F]/15 rounded-2xl p-6">
            <p class="text-sm font-bold text-[#1A4B8F] mb-3">Ce que contient le dossier vendeur</p>
            <div class="space-y-2">
              {[
                'Certificat de ramonage conforme RSD 13',
                'Rapport technique d\'inspection du conduit',
                'Photos datées de l\'intérieur du conduit',
                'État de conformité NF DTU 24.1',
                'Carnet de Santé du Conduit™ transmissible',
              ].map(item => (
                <div class="flex gap-2 text-xs text-[#1A1A1A]/65">
                  <span class="text-[#1A4B8F] font-bold shrink-0">✓</span>
                  <span>{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Note diagnostiqueurs -->
      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6">
        <div class="flex gap-3">
          <svg class="w-5 h-5 text-amber-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <p class="text-sm font-bold text-amber-900 mb-1">Diagnostiqueurs & Experts immobiliers</p>
            <p class="text-sm text-amber-800/75 leading-relaxed">Vous avez relevé une anomalie sur un conduit lors d'un DPE et ne savez pas comment la qualifier ? Je propose un contre-audit technique sous 24h, compatible avec votre calendrier de signature. Rapport PDF signé transmissible directement au notaire. Appelez-moi directement pour un accord de partenariat.</p>
          </div>
        </div>
      </div>

      <!-- Tarifs -->
      <div>
        <h2 class="text-2xl font-bold mb-6">Tarifs</h2>
        <div class="grid md:grid-cols-3 gap-5">
          <div class="bg-white border border-[#EEEEEE] rounded-2xl p-6">
            <p class="text-[11px] font-bold uppercase tracking-widest text-[#1A1A1A]/40 mb-3">Audit simple</p>
            <p class="text-3xl font-extrabold text-[#1A1A1A] mb-1">120 €</p>
            <p class="text-xs text-[#1A1A1A]/50 mb-4">1 conduit · Rapport PDF · Certificat</p>
            <ul class="space-y-2 text-xs text-[#1A1A1A]/65">
              <li class="flex gap-2"><span class="text-[#EA580C]">✓</span> Inspection visuelle complète</li>
              <li class="flex gap-2"><span class="text-[#EA580C]">✓</span> Contrôle de tirage</li>
              <li class="flex gap-2"><span class="text-[#EA580C]">✓</span> Rapport PDF daté + signé</li>
              <li class="flex gap-2"><span class="text-[#EA580C]">✓</span> Carnet de Santé du Conduit</li>
            </ul>
          </div>
          <div class="bg-[#EEF3FF] border-2 border-[#1A4B8F] rounded-2xl p-6 relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="bg-[#1A4B8F] text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider">Recommandé</span>
            </div>
            <p class="text-[11px] font-bold uppercase tracking-widest text-[#1A4B8F]/60 mb-3">Audit complet</p>
            <p class="text-3xl font-extrabold text-[#1A1A1A] mb-1">190 €</p>
            <p class="text-xs text-[#1A1A1A]/50 mb-4">Multi-conduits · Caméra HD · Rapport assurance</p>
            <ul class="space-y-2 text-xs text-[#1A1A1A]/65">
              <li class="flex gap-2"><span class="text-[#1A4B8F] font-bold">✓</span> Tous les conduits du bien</li>
              <li class="flex gap-2"><span class="text-[#1A4B8F] font-bold">✓</span> Inspection caméra HD</li>
              <li class="flex gap-2"><span class="text-[#1A4B8F] font-bold">✓</span> Photos datées et géolocalisées</li>
              <li class="flex gap-2"><span class="text-[#1A4B8F] font-bold">✓</span> Rapport transmissible au notaire</li>
            </ul>
          </div>
          <div class="bg-[#EA580C] rounded-2xl p-6 text-white flex flex-col justify-between">
            <div>
              <p class="text-[11px] font-bold uppercase tracking-widest text-white/60 mb-3">Commander</p>
              <p class="text-sm text-white/80 leading-relaxed mb-6">Délai compatible avec votre calendrier notarial. Rapport remis sous 24h.</p>
            </div>
            <div class="space-y-3">
              <a href="tel:+33664729600" class="flex items-center justify-center gap-2 bg-white text-[#EA580C] text-sm font-bold px-5 py-3 rounded-xl hover:bg-white/90 transition-colors">06 64 72 96 00</a>
              <a href="mailto:contact@sud-ramonage.fr?subject=Audit%20fumisterie%20transaction%20immobilière" class="flex items-center justify-center bg-white/15 text-white text-sm font-semibold px-5 py-3 rounded-xl hover:bg-white/20 transition-colors border border-white/20">Par email</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Liens associés -->
      <nav aria-label="Services associés" class="pt-8 border-t border-[#EEEEEE]">
        <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-4">Voir aussi</p>
        <ul class="flex flex-wrap gap-3">
          {[
            { href: '/audit-conformite', label: 'Diagnostic de sécurité complet' },
            { href: '/vacuite', label: 'Contrôle de vacuité' },
            { href: '/bailleurs-syndics', label: 'Bailleurs & Syndics' },
            { href: '/ramonage', label: 'Ramonage certifié RSD 13' },
            { href: '/valeur-verte', label: 'Valeur Verte & DPE' },
          ].map(({ href, label }) => (
            <li><a href={href} class="text-xs text-[#1A1A1A]/50 border border-[#EEEEEE] rounded-lg px-3 py-1.5 hover:text-[#EA580C] hover:border-[#EA580C]/30 transition-colors">{label}</a></li>
          ))}
        </ul>
      </nav>

    </div>
  </section>

</Layout>
