---
// Guide printable — pas de Layout pour un rendu propre impression/PDF
const siteUrl = 'https://www.sud-ramonage.fr';
const date = new Date().toLocaleDateString('fr-FR', { year: 'numeric', month: 'long' });
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Guide : Vendre sa maison avec cheminée — 5 points de contrôle | Sud Ramonage</title>
  <meta name="description" content="Guide gratuit certifié COSTIC : les 5 points de contrôle obligatoires avant de vendre un bien immobilier avec cheminée, insert ou poêle. Conformité conduit, DPE, notaire." />
  <link rel="canonical" href={`${siteUrl}/guide-vente-cheminee`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #F8F8F8;
      color: #1A1A1A;
      line-height: 1.6;
    }

    /* ── PRINT ── */
    @media print {
      body { background: white; }
      .no-print { display: none !important; }
      .page-break { page-break-before: always; }
      .guide-wrapper { max-width: 100%; padding: 0; }
      .guide-card { break-inside: avoid; }
      @page { margin: 15mm 12mm; }
    }

    /* ── SCREEN ── */
    .guide-wrapper {
      max-width: 820px;
      margin: 0 auto;
      padding: 24px 16px 48px;
    }

    /* Boutons */
    .btn-print {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #E65100;
      color: white;
      font-weight: 700;
      font-size: 14px;
      padding: 12px 28px;
      border-radius: 12px;
      cursor: pointer;
      border: none;
      text-decoration: none;
      transition: background 150ms;
    }
    .btn-print:hover { background: #BF360C; }

    .btn-back {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: white;
      color: #1A1A1A;
      font-weight: 600;
      font-size: 13px;
      padding: 10px 20px;
      border-radius: 10px;
      border: 1.5px solid #E0E0E0;
      cursor: pointer;
      text-decoration: none;
      transition: border-color 150ms;
    }
    .btn-back:hover { border-color: #E65100; }

    /* Header guide */
    .guide-header {
      background: #1A1A1A;
      color: white;
      border-radius: 20px;
      padding: 40px 44px;
      margin-bottom: 28px;
      position: relative;
      overflow: hidden;
    }
    .guide-header::before {
      content: '';
      position: absolute;
      top: -60px; right: -60px;
      width: 200px; height: 200px;
      background: #E65100;
      border-radius: 50%;
      opacity: 0.08;
    }
    .guide-header .label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #E65100;
      margin-bottom: 12px;
      display: block;
    }
    .guide-header h1 {
      font-size: clamp(22px, 4vw, 32px);
      font-weight: 900;
      line-height: 1.15;
      color: white;
      margin-bottom: 10px;
    }
    .guide-header h1 span { color: #E65100; }
    .guide-header p {
      font-size: 13px;
      color: rgba(255,255,255,0.55);
      max-width: 480px;
      margin-bottom: 20px;
    }
    .guide-header .meta {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }
    .guide-header .meta-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: rgba(255,255,255,0.40);
    }
    .guide-header .meta-badge {
      background: rgba(26,75,143,0.25);
      border: 1px solid rgba(26,75,143,0.4);
      color: #4A90D9;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 100px;
    }

    /* Points de contrôle */
    .guide-card {
      background: white;
      border: 1.5px solid #EEEEEE;
      border-radius: 16px;
      margin-bottom: 16px;
      overflow: hidden;
    }
    .guide-card-header {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 20px 24px;
      border-bottom: 1px solid #F5F5F5;
    }
    .guide-card-num {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 900;
      font-size: 18px;
      color: white;
      flex-shrink: 0;
    }
    .guide-card-title-wrap h3 {
      font-size: 15px;
      font-weight: 800;
      color: #1A1A1A;
      line-height: 1.3;
    }
    .guide-card-title-wrap .kw {
      font-size: 9.5px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.3);
      margin-top: 2px;
    }
    .guide-card-body {
      padding: 20px 24px;
    }
    .guide-card-body p {
      font-size: 13px;
      color: rgba(26,26,26,0.65);
      line-height: 1.7;
      margin-bottom: 14px;
    }
    .check-list {
      list-style: none;
      margin-bottom: 16px;
    }
    .check-list li {
      display: flex;
      gap: 8px;
      font-size: 12.5px;
      color: rgba(26,26,26,0.60);
      padding: 4px 0;
    }
    .check-list li::before {
      content: '✓';
      color: #E65100;
      font-weight: 700;
      flex-shrink: 0;
    }
    .risk-box {
      background: #FFF3F3;
      border: 1px solid #FFCDD2;
      border-radius: 10px;
      padding: 10px 14px;
      display: flex;
      gap: 8px;
      align-items: flex-start;
    }
    .risk-box span { flex-shrink: 0; font-size: 13px; }
    .risk-box p {
      font-size: 11.5px;
      color: #C62828;
      font-weight: 500;
      margin: 0;
    }
    .risk-box p strong { font-weight: 700; }

    /* Tableau DPE vs Audit */
    .compare-table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border-radius: 16px;
      overflow: hidden;
      border: 1.5px solid #EEEEEE;
      margin-bottom: 28px;
    }
    .compare-table th {
      padding: 14px 16px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      border-bottom: 1.5px solid #EEEEEE;
    }
    .compare-table th:first-child { background: #FAFAFA; color: rgba(26,26,26,0.4); text-align: left; }
    .compare-table th:nth-child(2) { background: #FFF3E0; color: rgba(26,26,26,0.6); }
    .compare-table th:nth-child(3) { background: rgba(26,75,143,0.06); color: #1A4B8F; }
    .compare-table td {
      padding: 11px 16px;
      font-size: 12px;
      border-bottom: 1px solid #F5F5F5;
      vertical-align: middle;
    }
    .compare-table td:first-child { color: rgba(26,26,26,0.55); font-weight: 500; }
    .compare-table td:nth-child(2) { color: rgba(26,26,26,0.55); }
    .compare-table td:nth-child(3) { color: #1A4B8F; font-weight: 600; }
    .compare-table tr:last-child td { border-bottom: none; }
    td.red { color: #C62828 !important; font-weight: 600; }
    td.green { color: #2E7D32 !important; font-weight: 700; }

    /* Section checklist finale */
    .checklist-section {
      background: white;
      border: 1.5px solid #EEEEEE;
      border-radius: 20px;
      padding: 32px 36px;
      margin-bottom: 24px;
    }
    .checklist-section h2 {
      font-size: 18px;
      font-weight: 800;
      color: #1A1A1A;
      margin-bottom: 6px;
    }
    .checklist-section .sub {
      font-size: 12px;
      color: rgba(26,26,26,0.45);
      margin-bottom: 20px;
    }
    .checklist-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 0;
      border-bottom: 1px solid #F5F5F5;
    }
    .checklist-item:last-child { border-bottom: none; }
    .checkbox {
      width: 22px;
      height: 22px;
      border: 2px solid #CCCCCC;
      border-radius: 6px;
      flex-shrink: 0;
      background: #FAFAFA;
    }
    .checklist-item .ci-text { font-size: 13px; color: #1A1A1A; }
    .checklist-item .ci-sub { font-size: 11px; color: rgba(26,26,26,0.45); }

    /* Footer guide */
    .guide-footer {
      background: #1A1A1A;
      color: white;
      border-radius: 16px;
      padding: 28px 36px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 20px;
      align-items: center;
      margin-bottom: 32px;
    }
    .guide-footer h3 { font-size: 14px; font-weight: 700; margin-bottom: 4px; }
    .guide-footer p { font-size: 11.5px; color: rgba(255,255,255,0.45); }
    .guide-footer .contact-block { text-align: right; }
    .guide-footer .phone { font-size: 20px; font-weight: 900; color: #E65100; display: block; }
    .guide-footer .addr { font-size: 10.5px; color: rgba(255,255,255,0.30); }

    /* Top nav (screen only) */
    .screen-nav {
      background: white;
      border-bottom: 1px solid #EEEEEE;
      padding: 16px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      position: sticky;
      top: 0;
      z-index: 100;
    }
  </style>
</head>
<body>

  <!-- Nav screen uniquement -->
  <nav class="screen-nav no-print">
    <a href="/aide-vente-immobilier" class="btn-back">
      ← Retour
    </a>
    <p style="font-size: 12px; color: rgba(26,26,26,0.45); flex: 1; text-align: center;">Guide Vente Immobilière avec Cheminée — Sud Ramonage COSTIC</p>
    <button onclick="window.print()" class="btn-print">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      Télécharger en PDF
    </button>
  </nav>

  <div class="guide-wrapper">

    <!-- HEADER -->
    <div class="guide-header">
      <span class="label">Sud Ramonage · Guide Certifié COSTIC</span>
      <h1>Vendre sa maison avec cheminée :<br /><span>Les 5 points de contrôle obligatoires</span></h1>
      <p>Établi par un artisan certifié COSTIC + Qualibat 6521. À remettre à votre vendeur, agent immobilier ou notaire.</p>
      <div class="meta">
        <span class="meta-badge">COSTIC Certifié</span>
        <div class="meta-item">
          <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          {date}
        </div>
        <div class="meta-item">
          <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Bouches-du-Rhône · Zone 50 km Martigues
        </div>
        <div class="meta-item">
          <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          06 64 72 96 00
        </div>
      </div>
    </div>

    <!-- INTRO -->
    <div style="background: white; border-radius: 16px; padding: 24px 28px; margin-bottom: 24px; border: 1.5px solid #EEEEEE;">
      <h2 style="font-size: 15px; font-weight: 800; color: #1A1A1A; margin-bottom: 10px;">Pourquoi ce guide ?</h2>
      <p style="font-size: 13px; color: rgba(26,26,26,0.60); line-height: 1.7; margin-bottom: 12px;">
        Un bien immobilier équipé d'une cheminée, d'un insert ou d'un poêle à bois présente des enjeux spécifiques lors d'une vente. Le DPE n'examine pas les conduits de fumée. Or, un conduit non conforme peut constituer un <strong style="color:#1A1A1A;">vice caché</strong> au sens de l'article 1641 du Code civil — engageant la responsabilité du vendeur, voire annulant la vente.
      </p>
      <p style="font-size: 13px; color: rgba(26,26,26,0.60); line-height: 1.7;">
        Ce guide liste les 5 points que tout vendeur, agent immobilier ou notaire doit vérifier avant la signature. Chaque point peut faire l'objet d'une attestation COSTIC officielle, transmissible au dossier de vente.
      </p>
    </div>

    <!-- 5 POINTS -->
    {[
      {
        n: '01', color: '#E65100',
        titre: 'État général du conduit de fumée',
        kw: 'Vérification conduit vente maison Marseille · Bouches-du-Rhône',
        desc: 'Le conduit de fumée est la pièce maîtresse de toute installation de chauffage à combustion. Son état doit être documenté avant toute vente.',
        checks: [
          'Inspection visuelle complète de la partie accessible',
          'Inspection caméra HD (endoscopie) si conduit ancien',
          'Vérification de la section libre et de l\'absence d\'obstruction',
          'Détection de fissures, décollement ou perforation',
          'Contrôle des dépôts de bistre (goudron inflammable)',
        ],
        risque: 'Un conduit fissuré non déclaré = vice caché engageant la responsabilité du vendeur. Potentiel risque d\'incendie ou d\'intoxication au CO pour l\'acquéreur.',
      },
      {
        n: '02', color: '#E65100',
        titre: 'Raccordement & distances de sécurité',
        kw: 'Conformité cheminée notaire Aix-en-Provence · NF DTU 24.1',
        desc: 'La norme NF DTU 24.1 impose des distances minimales entre le conduit/l\'appareil et les matériaux combustibles. Ces distances sont souvent non respectées dans l\'habitat ancien.',
        checks: [
          'Distance entre conduit et matériaux combustibles (art. 4.2 DTU 24.1)',
          'Type de raccordement (piquage, sortie directe, tubage)',
          'Adéquation entre l\'appareil raccordé et le diamètre du conduit',
          'État de l\'entrée d\'air de combustion (7 m³/h/kW minimum)',
          'Conformité des matériaux du conduit avec l\'appareil (inox, terre cuite)',
        ],
        risque: 'Non-conformité fréquente dans l\'habitat des années 70-90. Un assureur peut refuser d\'indemniser un sinistre incendie si les distances réglementaires ne sont pas respectées.',
      },
      {
        n: '03', color: '#1A4B8F',
        titre: 'Attestation de ramonage certifié RSD 13',
        kw: 'Attestation ramonage vente immobilière · Certificat conduit Bouches-du-Rhône',
        desc: 'Le Règlement Sanitaire Départemental 13 (RSD 13) impose un ramonage annuel de tout conduit raccordé à un appareil à combustion. L\'attestation doit être récente.',
        checks: [
          'Certificat de ramonage de moins de 12 mois',
          'Réalisé par un artisan qualifié (COSTIC, Qualibat 6521)',
          'Mentionne le type d\'appareil, le conduit et la date d\'intervention',
          'Conforme aux exigences des assurances habitation',
          'Valide pour le dossier notarial',
        ],
        risque: 'Sans certificat récent, l\'assureur de l\'acquéreur peut refuser de couvrir l\'installation. La police incendie peut être invalidée en cas de sinistre.',
      },
      {
        n: '04', color: '#1A4B8F',
        titre: 'Complément DPE fumisterie — mesures réelles',
        kw: 'Complément DPE fumisterie · Audit technique conduit Bouches-du-Rhône',
        desc: 'Le DPE évalue le logement de façon théorique. L\'audit de fumisterie fournit des mesures physiques que le DPE ne peut pas produire.',
        checks: [
          'Mesure réelle du tirage (dépression dans le conduit)',
          'Test d\'étanchéité du conduit (NF DTU 24.1 art. 9.2)',
          'Rendement effectif de l\'appareil mesuré (vs. rendement théorique DPE)',
          'Température des fumées — indicateur de performance de combustion',
          'Rapport photo comparatif avant/après entretien si nécessaire',
        ],
        risque: 'Un DPE surévalue souvent les appareils à bois mal entretenus. Un insert encrassé peut afficher un rendement réel de 40 % alors que le DPE le note à 75 %. L\'acquéreur découvre la réalité après la vente.',
      },
      {
        n: '05', color: '#1A1A1A',
        titre: 'Rapport opposable transmis au notaire',
        kw: 'Rapport fumisterie notaire · Vente maison Marseille Aix conformité conduit',
        desc: 'Un rapport technique signé par un artisan certifié COSTIC constitue une preuve opposable que l\'état de l\'installation était connu à la date de la vente.',
        checks: [
          'Format PDF signé + photos datées et géolocalisées',
          'Attestation COSTIC certifiant les qualifications du rédacteur',
          'État de conformité par point (RSD 13, NF DTU 24.1)',
          'Liste des travaux recommandés avec ordre de priorité',
          'Transmissible directement au notaire pour dossier de vente',
        ],
        risque: 'Sans rapport écrit, le vendeur ne peut pas prouver qu\'il a fait vérifier l\'installation. L\'action en garantie des vices cachés (art. 1641 C.civ.) reste ouverte pendant 2 ans après la vente.',
      },
    ].map(({ n, color, titre, kw, desc, checks, risque }) => (
      <div class="guide-card">
        <div class="guide-card-header">
          <div class="guide-card-num" style={`background: ${color};`}>{n}</div>
          <div class="guide-card-title-wrap">
            <h3>{titre}</h3>
            <p class="kw">{kw}</p>
          </div>
        </div>
        <div class="guide-card-body">
          <p>{desc}</p>
          <ul class="check-list">
            {checks.map(c => <li>{c}</li>)}
          </ul>
          <div class="risk-box">
            <span>⚠</span>
            <p><strong>Risque si non vérifié : </strong>{risque}</p>
          </div>
        </div>
      </div>
    ))}

    <!-- TABLEAU DPE vs AUDIT -->
    <div style="margin-bottom: 8px; margin-top: 32px;">
      <h2 style="font-size: 17px; font-weight: 800; color: #1A1A1A; margin-bottom: 4px;">DPE vs Audit fumisterie : le tableau comparatif</h2>
      <p style="font-size: 12px; color: rgba(26,26,26,0.45); margin-bottom: 16px;">Ce que le DPE ne voit pas — et que l'audit de fumisterie révèle.</p>
    </div>
    <table class="compare-table">
      <thead>
        <tr>
          <th>Critère</th>
          <th>DPE seul</th>
          <th>Audit fumisterie COSTIC</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['Conduits de fumée examinés', '❌ Non inclus', '✓ Inspection complète'],
          ['Mesure physique du tirage', '❌ Théorique seulement', '✓ Mesure réelle'],
          ['Étanchéité du conduit', '❌ Non testée', '✓ Test disponible'],
          ['Dépôts de bistre', '❌ Non détectés', '✓ Évaluation et quantification'],
          ['Conformité RSD 13', '❌ Non vérifiée', '✓ Certificat remis'],
          ['Photos datées du conduit', '❌', '✓ Incluses dans le rapport'],
          ['Protection vice caché art. 1641', 'Partielle', '✓ Couverture complète'],
          ['Rapport transmissible au notaire', '✓ Obligatoire (DPE)', '✓ Rapport PDF signé COSTIC'],
        ].map(([critere, dpe, audit]) => (
          <tr>
            <td>{critere}</td>
            <td class={dpe.startsWith('❌') ? 'red' : ''}>{dpe}</td>
            <td class="green">{audit}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <!-- CHECKLIST VENDEUR -->
    <div class="checklist-section">
      <h2>Checklist vendeur — À cocher avant la signature</h2>
      <p class="sub">Remettez ce document complété à votre agent immobilier ou notaire.</p>
      {[
        { label: 'Ramonage certifié COSTIC de moins de 12 mois', sub: 'Certificat conforme RSD 13 — à joindre au dossier' },
        { label: 'Inspection conduit réalisée par un professionnel', sub: 'Visuelle ou caméra selon l\'ancienneté de l\'installation' },
        { label: 'Distances de sécurité NF DTU 24.1 vérifiées', sub: 'Appareil + conduit + matériaux environnants' },
        { label: 'Rapport technique signé remis au notaire', sub: 'PDF daté, photos incluses, attestation COSTIC' },
        { label: 'Travaux de mise en conformité réalisés si nécessaire', sub: 'Tubage, débistrage, réparation conduit, chemisage' },
      ].map(({ label, sub }) => (
        <div class="checklist-item">
          <div class="checkbox"></div>
          <div>
            <p class="ci-text">{label}</p>
            <p class="ci-sub">{sub}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- FOOTER CONTACT -->
    <div class="guide-footer">
      <div>
        <h3>Sud Ramonage — Artisan certifié COSTIC + Qualibat 6521</h3>
        <p>Bouches-du-Rhône · Zone 50 km autour de Martigues · Rapport remis sous 24h</p>
      </div>
      <div class="contact-block">
        <span class="phone">06 64 72 96 00</span>
        <span class="addr">majeo@ik.me · sud-ramonage.fr</span>
      </div>
    </div>

    <p style="font-size: 10px; color: rgba(26,26,26,0.30); text-align: center; line-height: 1.6;">
      Document établi à titre informatif. L'audit de fumisterie n'est pas légalement obligatoire lors d'une vente immobilière. Il est fortement recommandé pour les biens équipés d'un appareil à combustion raccordé à un conduit de fumée, dans le cadre de la protection des parties contre les vices cachés (art. 1641 Code civil) et de la conformité aux réglementations sanitaires en vigueur (RSD 13 — Bouches-du-Rhône).<br />
      © {new Date().getFullYear()} Sud Ramonage · {siteUrl}
    </p>

  </div>
</body>
</html>
