---
import Layout from '../layouts/Layout.astro';
const siteUrl = 'https://www.sud-ramonage.fr';
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Le ramonage est-il obligatoire dans les Bouches-du-Rhône ?', acceptedAnswer: { '@type': 'Answer', text: 'Oui. Le Règlement Sanitaire Départemental (RSD 13) des Bouches-du-Rhône impose le ramonage au moins une fois par an de tout conduit de fumée raccordé à un appareil à combustion. Cette obligation s\'applique aux résidences principales, secondaires, locations et copropriétés.' } },
    { '@type': 'Question', name: 'Quelle est la fréquence légale de ramonage ?', acceptedAnswer: { '@type': 'Answer', text: 'Minimum une fois par an selon le RSD 13. Pour les appareils utilisant du bois humide ou les foyers ouverts à usage intensif, deux ramonages par an sont recommandés par le COSTIC (avant et après la saison de chauffe).' } },
    { '@type': 'Question', name: 'Qui peut réaliser le ramonage légal ?', acceptedAnswer: { '@type': 'Answer', text: 'Seul un professionnel qualifié peut délivrer un certificat de ramonage valable auprès des assureurs. Le ramonage doit être réalisé par voie mécanique (hérisson) par un artisan ramoneur certifié.' } },
    { '@type': 'Question', name: 'Que risque-t-on sans certificat de ramonage ?', acceptedAnswer: { '@type': 'Answer', text: 'En cas de sinistre (incendie de conduit, intoxication au CO) sans certificat valide, l\'assurance habitation peut refuser de prendre en charge les dommages. Une amende de 1 500 € est également prévue en cas de non-respect du RSD.' } },
  ],
};
const breadcrumbs = [{ name: 'Accueil', url: '/' }, { name: 'Aide & Réglementation', url: '/reglementation' }];
---
<Layout
  title="Réglementation Ramonage RSD 13 — Guide Complet Bouches-du-Rhône | Sud Ramonage"
  description="Guide complet des obligations légales de ramonage dans les Bouches-du-Rhône. RSD 13, fréquences, sanctions, certificats. Tout ce que vous devez savoir."
  breadcrumbs={breadcrumbs}
  pageSchema={faqSchema}
>

  <section class="bg-gradient-to-br from-[#1A1A1A] to-[#1A4B8F] text-white pt-28 pb-16">
    <div class="max-w-4xl mx-auto px-6 md:px-10">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-white/40 mb-6">
        <a href="/" class="hover:text-white/70">Accueil</a><span>/</span><span class="text-white/60">Aide & Réglementation</span>
      </nav>
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 rounded-full px-3 py-1.5 text-[11px] text-white/70 mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-[#E65100]"></span>
        Savoir & Transparence
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-5">
        Aide & Réglementation<br /><span class="text-[#E65100]">Guide des Obligations RSD 13</span>
      </h1>
      <p class="text-base text-white/65 max-w-2xl leading-relaxed">
        Tout ce que vous devez savoir sur les obligations légales de ramonage dans les Bouches-du-Rhône : textes de loi, fréquences, sanctions, certificats, assurances.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-4xl mx-auto px-6 md:px-10 space-y-14">

      <!-- Textes de référence -->
      <div>
        <h2 class="text-2xl font-bold mb-6">Les textes qui s'appliquent dans les Bouches-du-Rhône</h2>
        <div class="space-y-4">
          {[
            { titre: 'RSD 13 — Règlement Sanitaire Départemental', texte: 'Le RSD des Bouches-du-Rhône impose le ramonage au moins une fois par an de tout conduit de fumée raccordé à un appareil à combustion. Il s\'applique sur tout le territoire du département 13, y compris Marseille.' },
            { titre: 'Arrêté du 22 octobre 1969', texte: 'Texte fondateur qui réglemente la construction et l\'entretien des conduits de fumée pour les chauffages à usage domestique. Il précise les caractéristiques techniques minimales des conduits.' },
            { titre: 'NF DTU 24.1 P1-1 (2006)', texte: 'Norme technique de référence pour les travaux de fumisterie. Elle définit les règles de conception, d\'installation et d\'entretien des conduits de fumée. Elle sert de base juridique en cas de litige.' },
            { titre: 'Code des assurances — Art. L.113-1', texte: 'Les polices d\'assurance habitation peuvent légalement exclure la garantie incendie en l\'absence de preuve d\'entretien régulier des conduits. Le certificat de ramonage est la preuve exigée.' },
          ].map(({ titre, texte }) => (
            <div class="flex gap-4 p-5 bg-[#FAFAFA] border border-[#EEEEEE] rounded-xl">
              <div class="w-2 h-2 rounded-full bg-[#1A4B8F] mt-2 shrink-0"></div>
              <div>
                <p class="text-sm font-bold text-[#1A1A1A] mb-2">{titre}</p>
                <p class="text-sm text-[#1A1A1A]/60 leading-relaxed">{texte}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Fréquences -->
      <div>
        <h2 class="text-2xl font-bold mb-6">Fréquences de ramonage par type d'appareil</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-[#1E293B] text-white">
                <th class="text-left p-4 text-xs font-semibold rounded-tl-xl">Type d'appareil</th>
                <th class="text-left p-4 text-xs font-semibold">Fréquence minimale</th>
                <th class="text-left p-4 text-xs font-semibold rounded-tr-xl">Recommandation COSTIC</th>
              </tr>
            </thead>
            <tbody>
              {[
                { appareil: 'Foyer ouvert (cheminée traditionnelle)', mini: '1×/an', costic: '2×/an (bois humide ou usage intensif)' },
                { appareil: 'Insert de cheminée', mini: '1×/an', costic: '2×/an' },
                { appareil: 'Poêle à bois', mini: '1×/an', costic: '1 à 2×/an' },
                { appareil: 'Poêle à granulés', mini: '1×/an', costic: '1×/an + entretien appareil' },
                { appareil: 'Chaudière gaz (tirage naturel)', mini: '1×/an', costic: '1×/an (entretien chaudière inclus)' },
                { appareil: 'Chaudière fioul', mini: '1×/an', costic: '1×/an (avant saison)' },
                { appareil: 'Four à pizza / restauration', mini: 'Trimestriel (ERP)', costic: 'Mensuel en activité soutenue' },
              ].map(({ appareil, mini, costic }, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#FAFAFA]'}>
                  <td class="p-4 text-xs text-[#1A1A1A] border-b border-[#EEEEEE]">{appareil}</td>
                  <td class="p-4 text-xs font-semibold text-[#E65100] border-b border-[#EEEEEE]">{mini}</td>
                  <td class="p-4 text-xs text-[#1A1A1A]/60 border-b border-[#EEEEEE]">{costic}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- FAQ -->
      <div>
        <h2 class="text-2xl font-bold mb-6">Questions fréquentes</h2>
        <div class="space-y-4">
          {[
            {
              q: 'Mon locataire doit-il faire le ramonage ?',
              r: 'Selon la loi du 6 juillet 1989 et la jurisprudence, le ramonage des conduits de fumée est à la charge du locataire pour l\'entretien courant. Le propriétaire reste responsable si le conduit est non conforme ou nécessite des travaux de réhabilitation (tubage, chemisage).',
            },
            {
              q: 'Un ramonage chimique remplace-t-il le ramonage mécanique ?',
              r: 'Non. Seul le ramonage mécanique par voie de hérisson permet de délivrer un certificat valable auprès des assureurs et conforme au RSD 13. Le bûche de ramonage chimique est un appoint complémentaire, pas un substitut.',
            },
            {
              q: 'Mon conduit est neuf, dois-je quand même ramoner ?',
              r: 'Oui. L\'obligation de ramonage annuel s\'applique dès la première utilisation du conduit, quelle que soit son ancienneté. Un conduit neuf peut accumuler de la suie dès la première saison de chauffe.',
            },
            {
              q: 'Je n\'utilise plus ma cheminée, dois-je la ramoner ?',
              r: 'Si l\'appareil est raccordé et le conduit accessible, le RSD 13 s\'applique. Si vous ne souhaitez plus utiliser l\'installation, la solution est de faire condamner officiellement le conduit par un professionnel qualifié — avec compte-rendu d\'intervention.',
            },
            {
              q: 'Mon assurance peut-elle refuser d\'indemniser un incendie de conduit ?',
              r: 'Oui. La plupart des polices habitation comportent une clause d\'entretien courant. En l\'absence de certificat de ramonage datant de moins de 12 mois, l\'assureur est en droit de réduire ou d\'annuler l\'indemnisation.',
            },
          ].map(({ q, r }) => (
            <details class="group border border-[#EEEEEE] rounded-xl overflow-hidden">
              <summary class="flex items-center justify-between p-5 cursor-pointer hover:bg-[#FAFAFA] transition-colors">
                <p class="text-sm font-semibold text-[#1A1A1A] pr-4">{q}</p>
                <svg class="w-4 h-4 text-[#1A1A1A]/40 shrink-0 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-5 pb-5 text-sm text-[#1A1A1A]/65 leading-relaxed border-t border-[#EEEEEE]">
                <p class="pt-4">{r}</p>
              </div>
            </details>
          ))}
        </div>
      </div>

      <div class="bg-[#E65100] rounded-2xl p-8 text-white">
        <h2 class="text-xl font-bold mb-3">Régularisez votre situation dès aujourd'hui</h2>
        <p class="text-sm text-white/75 mb-6">Certificat de ramonage RSD 13 remis le jour même. Je me déplace dans tout le département des Bouches-du-Rhône.</p>
        <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-white text-[#E65100] text-sm font-bold px-6 py-3 rounded-xl hover:bg-white/90 transition-colors">06 64 72 96 00</a>
      </div>

      <nav aria-label="Liens thématiques" class="pt-8 border-t border-[#EEEEEE]">
        <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-4">Voir aussi</p>
        <ul class="flex flex-wrap gap-3">
          {[
            { href: '/lexique', label: 'Lexique de l\'expert — 50 termes fumisterie' },
            { href: '/normes', label: 'Normes NF DTU 24.1 détaillées' },
            { href: '/ramonage', label: 'Ramonage certifié — prise de RDV' },
            { href: '/immobilier-notaires', label: 'Audit pré-vente immobilier' },
          ].map(({ href, label }) => (
            <li><a href={href} class="text-xs text-[#1A1A1A]/50 border border-[#EEEEEE] rounded-lg px-3 py-1.5 hover:text-[#E65100] hover:border-[#E65100]/30 transition-colors">{label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </section>
</Layout>
