---
import Layout from '../layouts/Layout.astro';
import COSTICBadge from '../components/COSTICBadge.astro';
const siteUrl = 'https://www.sud-ramonage.fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'À propos', url: '/a-propos' },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'À propos — Sud Ramonage, artisan ramoneur certifié à Martigues',
  url: `${siteUrl}/a-propos`,
  description: 'Qui est l\'artisan derrière Sud Ramonage ? Certifications, valeurs, zone d\'intervention et engagement qualité.',
  mainEntity: {
    '@type': 'HomeAndConstructionBusiness',
    '@id': `${siteUrl}/#business`,
  },
};
---

<Layout
  title="À propos — Votre Artisan Ramoneur Certifié COSTIC | Sud Ramonage Martigues"
  description="Artisan ramoneur certifié COSTIC basé à Martigues. Qualibat 6521, RSD 13, NF DTU 24.1. Découvrez mon parcours, mes certifications et mes valeurs."
  breadcrumbs={breadcrumbs}
  pageSchema={pageSchema}
>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-[#1A1A1A] to-[#2D2D2D] text-white pt-28 pb-16">
    <div class="max-w-4xl mx-auto px-6 md:px-10">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-white/40 mb-6">
        <a href="/" class="hover:text-white/70">Accueil</a><span>/</span><span class="text-white/60">À propos</span>
      </nav>
      <div class="flex flex-col md:flex-row items-start gap-8">
        <div class="shrink-0">
          <div class="w-24 h-24 rounded-2xl bg-[#E65100]/15 border border-[#E65100]/20 flex items-center justify-center">
            <svg class="w-12 h-12 text-[#E65100]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </div>
        </div>
        <div>
          <div class="inline-flex items-center gap-2 bg-white/8 border border-white/12 rounded-full px-3 py-1.5 text-[11px] text-white/60 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-[#E65100]"></span>
            Artisan indépendant · Martigues, Bouches-du-Rhône
          </div>
          <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-4">
            Votre artisan ramoneur,<br /><span class="text-[#E65100]">certifié et assuré.</span>
          </h1>
          <p class="text-base text-white/60 max-w-2xl leading-relaxed">
            Je suis artisan ramoneur indépendant basé à Martigues. Je travaille seul — c'est moi qui décroche le téléphone, c'est moi qui interviens chez vous, et c'est moi qui vous remet le certificat. Pas d'intermédiaire, pas de sous-traitant.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6 md:px-10">
    <div class="max-w-4xl mx-auto space-y-14">

      <!-- Citation -->
      <blockquote class="border-l-4 border-[#E65100] pl-6 py-2">
        <p class="text-lg md:text-xl font-light text-[#1A1A1A]/75 leading-relaxed italic mb-3">
          "Je travaille dans ce métier parce qu'un conduit propre, c'est une famille à l'abri. Chaque intervention, je prends le temps de vous expliquer ce que j'ai trouvé — et ce que ça aurait pu donner sans ramonage. Ce n'est pas un discours commercial : c'est ce que je vois sur le terrain, chaque semaine, dans vos maisons."
        </p>
        <cite class="text-sm font-semibold text-[#E65100] not-italic">Votre artisan — Sud Ramonage, Martigues</cite>
      </blockquote>

      <!-- Certifications -->
      <div>
        <p class="text-[10px] font-bold tracking-widest uppercase text-[#E65100] mb-6">Certifications & qualifications</p>
        <div class="grid sm:grid-cols-2 gap-4">
          {[
            {
              titre: 'Certification COSTIC',
              desc: 'Formation aux techniques de fumisterie, aux normes NF DTU 24.1 et aux méthodes de diagnostic avancées. La référence nationale pour les artisans ramoneurs.',
              badge: 'COSTIC',
              color: '#1A4B8F',
            },
            {
              titre: 'Qualibat 6521',
              desc: 'Qualification officielle pour les travaux de fumisterie et de conduits de fumée. Reconnue par les assureurs et les maîtres d\'ouvrage.',
              badge: '6521',
              color: '#1A4B8F',
            },
            {
              titre: 'Assurance RC Pro',
              desc: 'Responsabilité civile professionnelle active pour toutes mes interventions. Vous êtes couverts en toutes circonstances.',
              badge: 'RC Pro',
              color: '#E65100',
            },
            {
              titre: 'Certificat NF DTU 24.1',
              desc: 'Chaque intervention donne lieu à un certificat officiel conforme à la norme NF DTU 24.1 — valable auprès de votre assureur habitation.',
              badge: 'RSD 13',
              color: '#E65100',
            },
          ].map(({ titre, desc, badge, color }) => (
            <div class="flex gap-4 bg-[#FAFAFA] border border-[#EEEEEE] rounded-2xl p-5">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 font-extrabold text-[10px] text-white tracking-wider" style={`background: ${color};`}>{badge}</div>
              <div>
                <p class="text-sm font-bold text-[#1A1A1A] mb-1">{titre}</p>
                <p class="text-xs text-[#1A1A1A]/55 leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Valeurs -->
      <div>
        <p class="text-[10px] font-bold tracking-widest uppercase text-[#E65100] mb-6">Ce qui me distingue</p>
        <div class="grid sm:grid-cols-2 gap-4">
          {[
            { titre: 'Travail propre garanti', desc: 'Protection du sol et de vos meubles avant intervention. Aspiration complète des suies. Je repars en laissant votre intérieur impeccable.' },
            { titre: 'Artisan seul — pas de sous-traitant', desc: 'C\'est moi qui interviens, sans exception. Vous savez qui vient chez vous. Vous avez un interlocuteur unique du devis à la facture.' },
            { titre: 'Transparence sur les prix', desc: 'Tarifs annoncés avant l\'intervention. Pas de surprise sur la facture. Si le diagnostic révèle un travail supplémentaire, je vous explique pourquoi avant de continuer.' },
            { titre: 'Ponctualité', desc: 'Je m\'engage sur un créneau et je le tiens. Si un imprévu survient, je vous préviens en amont — parce que votre temps compte.' },
            { titre: 'Pédagogie', desc: 'Je vous explique ce que j\'ai trouvé, ce que j\'ai fait, et comment entretenir votre installation entre deux ramonages. Pas de jargon — des explications claires.' },
            { titre: 'Réactivité', desc: 'Devis sous 24h, intervention possible en urgence. Je couvre toute la zone de Martigues à Marseille, Aix-en-Provence et Arles.' },
          ].map(({ titre, desc }) => (
            <div class="flex gap-3 bg-white border border-[#EEEEEE] rounded-xl p-5">
              <span class="w-1.5 h-1.5 rounded-full bg-[#E65100] shrink-0 mt-1.5"></span>
              <div>
                <p class="text-sm font-semibold text-[#1A1A1A] mb-1">{titre}</p>
                <p class="text-xs text-[#1A1A1A]/55 leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Zone -->
      <div class="bg-[#1A1A1A] rounded-2xl p-8 text-white">
        <p class="text-[10px] font-bold tracking-widest uppercase text-white/40 mb-4">Zone d'intervention</p>
        <p class="text-base text-white/70 leading-relaxed mb-5">
          Basé à <strong class="text-white">Martigues</strong>, j'interviens sur tout le département des Bouches-du-Rhône dans un rayon de 50 km : <strong class="text-white">Côte Bleue</strong> (Sausset-les-Pins, Carry-le-Rouet, Ensuès), <strong class="text-white">Étang de Berre</strong> (Istres, Fos-sur-Mer, Port-de-Bouc), <strong class="text-white">Marseille</strong>, <strong class="text-white">Aix-en-Provence</strong>, <strong class="text-white">Salon-de-Provence</strong>.
        </p>
        <div class="flex flex-wrap gap-2">
          {['Martigues', 'Istres', 'Fos-sur-Mer', 'Port-de-Bouc', 'Sausset-les-Pins', 'Carry-le-Rouet', 'Châteauneuf', 'Gignac', 'Marseille', 'Aix-en-Provence', 'Salon-de-Provence', 'Miramas'].map(v => (
            <span class="text-[11px] font-medium border border-white/15 text-white/55 px-3 py-1.5 rounded-md">{v}</span>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="bg-[#E65100] rounded-2xl p-8 text-white text-center">
        <h2 class="text-xl font-bold mb-3">Prendre rendez-vous</h2>
        <p class="text-sm text-white/75 mb-6">Devis gratuit sous 24h — je vous rappelle dans la journée.</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-white text-[#E65100] font-bold text-sm px-6 py-3.5 rounded-xl hover:bg-white/90 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            06 64 72 96 00
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 bg-white/15 border border-white/25 text-white text-sm px-6 py-3.5 rounded-xl hover:bg-white/20 transition-colors">
            Formulaire de contact →
          </a>
        </div>
      </div>

    </div>
  </section>

</Layout>
