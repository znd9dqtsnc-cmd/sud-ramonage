---
import Layout from '../layouts/Layout.astro';
import ContactButton from '../components/ContactButton.astro';

const siteUrl = 'https://www.sud-ramonage.fr';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Certificat de Valeur Verte — Optimisation DPE conduit de fumée',
  description: 'Service de certification des performances environnementales du conduit de fumée. Réduction PM2.5, conformité ZFE Marseille, optimisation DPE. Certifié COSTIC.',
  provider: {
    '@type': 'HomeAndConstructionBusiness',
    name: 'Sud Ramonage',
    url: siteUrl,
    areaServed: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
  },
  serviceType: 'Certification performance environnementale appareil combustion',
  offers: [
    {
      '@type': 'Offer',
      name: 'Check-up Valeur Verte',
      description: 'Inspection conduit + mesure rendement + rapport Certificat de Valeur Verte',
      priceSpecification: { '@type': 'UnitPriceSpecification', price: '149', priceCurrency: 'EUR' },
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Qu\'est-ce que la Valeur Verte d\'un logement ?',
      acceptedAnswer: { '@type': 'Answer', text: 'La Valeur Verte désigne la plus-value qu\'un logement performant sur le plan énergétique obtient sur le marché immobilier. Un logement classé A ou B se vend en moyenne 15 à 25 % plus cher qu\'un logement F ou G de surface équivalente. Un conduit de fumée optimisé contribue directement à améliorer la note DPE et réduit les émissions polluantes, deux critères valorisés à la vente.' },
    },
    {
      '@type': 'Question',
      name: 'En quoi un conduit propre améliore-t-il la note DPE ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Un conduit encrassé augmente les pertes thermiques par mauvais tirage et abaisse le rendement de l\'appareil. Le DPE intègre le rendement des appareils de chauffage dans son calcul. Un conduit propre et étanche améliore le rendement effectif, réduit la consommation de combustible et peut faire basculer la classe énergie d\'un cran. De plus, la méthode 3CL-DPE 2021 pénalise les logements avec des appareils non conformes.' },
    },
    {
      '@type': 'Question',
      name: 'La ZFE de Marseille concerne-t-elle les cheminées et poêles ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Oui. La Zone à Faibles Émissions (ZFE) de la Métropole Aix-Marseille-Provence cible principalement les véhicules, mais les plans locaux air-énergie-climat (PLAEC) incluent aussi les émissions résidentielles. Les appareils de chauffage au bois anciens et mal entretenus sont dans le viseur réglementaire. Un appareil bien entretenu avec conduit conforme émet 40 à 65 % moins de PM2.5 qu\'un appareil encrassé.' },
    },
    {
      '@type': 'Question',
      name: 'Qu\'est-ce que le Certificat de Valeur Verte de Sud Ramonage ?',
      acceptedAnswer: { '@type': 'Answer', text: 'C\'est un document officiel établi par un artisan certifié COSTIC qui atteste des performances environnementales de votre installation de chauffage. Il certifie : la conformité du conduit (RSD 13, NF DTU 24.1), le niveau d\'émissions PM2.5 estimé, le rendement mesuré de l\'appareil, et les économies de combustible potentielles. Ce certificat est transmissible à votre diagnostiqueur DPE, notaire ou assureur.' },
    },
  ],
};
---

<Layout
  title="Valeur Verte & DPE — Certificat de Conformité Conduit — Sud Ramonage"
  description="Boostez votre DPE avec un conduit certifié. Certificat de Valeur Verte Sud Ramonage : réduction PM2.5, conformité ZFE Marseille, optimisation rendement. Certifié COSTIC."
  breadcrumbs={[
    { name: 'Accueil', url: '/' },
    { name: 'Valeur Verte & DPE', url: '/valeur-verte' },
  ]}
  pageSchema={pageSchema}
>

  <!-- ═══ HERO ═══ -->
  <section class="bg-white border-b border-[#EEEEEE] pt-32 pb-16 px-6 md:px-10">
    <div class="max-w-6xl mx-auto">
      <nav class="flex items-center gap-2 text-xs text-[#1A1A1A]/35 mb-10" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-[#1A1A1A]/60 transition-colors">Accueil</a>
        <span>/</span>
        <span class="text-[#1A1A1A]/50">Valeur Verte & DPE</span>
      </nav>

      <div class="grid lg:grid-cols-2 gap-14 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-green-50 border border-green-200 rounded-full px-3 py-1.5 mb-6">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
            <span class="text-[10px] font-bold tracking-widest uppercase text-green-700">Performance Environnementale</span>
          </div>

          <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-[#1A1A1A] leading-tight mb-6">
            Votre conduit.<br />
            <span class="text-green-600">Votre Valeur Verte.</span>
          </h1>

          <p class="text-base text-[#1A1A1A]/55 font-light leading-relaxed mb-8 max-w-lg">
            Un conduit propre et conforme améliore le rendement de votre appareil, réduit les émissions de PM2.5 de 40 à 65 %, et peut booster votre note DPE. Le <strong class="text-[#1A1A1A] font-semibold">Certificat de Valeur Verte</strong> documente ces performances pour votre vente, votre assurance, ou votre déclaration ZFE.
          </p>

          <div class="flex flex-col sm:flex-row items-start gap-4">
            <a
              href="mailto:contact@sud-ramonage.fr?subject=Certificat%20de%20Valeur%20Verte%20%E2%80%94%20demande&body=Bonjour%2C%0A%0AJe%20souhaite%20obtenir%20un%20Certificat%20de%20Valeur%20Verte%20pour%20mon%20installation.%0A%0AAdresse%20%3A%0AType%20d%27appareil%20%3A%0AObjectif%20%3A%20Vente%20%2F%20DPE%20%2F%20ZFE%20%2F%20Assurance%0A%0AMerci."
              class="inline-flex items-center gap-2 bg-green-600 text-white text-sm font-bold px-6 py-3.5 rounded-xl hover:bg-green-700 transition-colors duration-200"
            >
              Obtenir mon certificat
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <ContactButton variant="phone" class="text-[#1A1A1A]/50 hover:text-[#1A1A1A] text-sm" />
          </div>
        </div>

        <!-- KPIs environnementaux -->
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: '-65%', label: 'PM2.5', sub: 'Conduit propre vs encrassé' },
            { val: '+12%', label: 'Rendement', sub: 'Appareil optimisé' },
            { val: '1 cran', label: 'DPE possible', sub: 'Avec conduit conforme' },
            { val: 'NF DTU', label: '24.1', sub: 'Conformité certifiée' },
          ].map(k => (
            <div class="bg-green-50 border border-green-200 rounded-2xl p-5 text-center">
              <p class="text-3xl font-extrabold text-green-600 mb-1">{k.val}</p>
              <p class="text-xs font-semibold text-[#1A1A1A] mb-0.5">{k.label}</p>
              <p class="text-[10px] text-[#1A1A1A]/45">{k.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ POURQUOI LA VALEUR VERTE ═══ -->
  <section class="py-20 px-6 md:px-10 bg-white">
    <div class="max-w-6xl mx-auto">

      <div class="grid lg:grid-cols-2 gap-16 items-start">

        <div>
          <p class="text-[11px] font-semibold tracking-widest uppercase text-green-600 mb-4">Marché immobilier</p>
          <h2 class="text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-6">
            Un logement bien noté se vend mieux, plus vite, plus cher.
          </h2>
          <p class="text-sm text-[#1A1A1A]/55 font-light leading-relaxed mb-6">
            Depuis la loi Climat & Résilience (2021) et la réforme du DPE, la performance énergétique est un critère central de la valeur immobilière. Les passoires thermiques (F/G) perdent en moyenne 15 à 25 % de valeur. Chaque amélioration compte.
          </p>
          <p class="text-sm text-[#1A1A1A]/55 font-light leading-relaxed mb-6">
            Pour un bien équipé d'un appareil à bois ou à granulés, le conduit est souvent le maillon faible : un conduit encrassé ou fissuré dégrade le rendement réel de l'appareil, ce que le logiciel DPE (3CL-DPE 2021) capte.
          </p>

          <div class="space-y-4">
            {[
              { titre: 'Rendement réel vs affiché', texte: 'Un poêle à 80 % de rendement théorique chute à 55–65 % avec un conduit encrassé. La méthode 3CL intègre ce delta dans le calcul de la consommation.', icon: '📊' },
              { titre: 'Étanchéité du conduit', texte: 'Un conduit fissuré laisse entrer l\'air froid, refroidit la colonne et augmente les pertes de chaleur vers l\'extérieur. Ce défaut est détectable par inspection caméra.', icon: '🔍' },
              { titre: 'Émissions PM2.5', texte: 'Les plans PLAEC classent les émissions résidentielles bois. Un appareil entretenu émet en moyenne 40 à 65 % moins de particules fines qu\'un appareil négligé.', icon: '🌿' },
            ].map(item => (
              <div class="flex gap-4 p-4 bg-[#F9F9F9] rounded-xl border border-[#EEEEEE]">
                <span class="text-2xl shrink-0 mt-0.5">{item.icon}</span>
                <div>
                  <p class="text-sm font-bold text-[#1A1A1A] mb-1">{item.titre}</p>
                  <p class="text-xs text-[#1A1A1A]/55 font-light leading-relaxed">{item.texte}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- ZFE Marseille -->
        <div>
          <div class="border-l-4 border-[#1A4B8F] bg-[#EEF3FF] rounded-r-2xl p-8 mb-6">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 rounded-xl bg-[#1A4B8F]/10 border border-[#1A4B8F]/20 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#1A4B8F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
              </div>
              <div>
                <p class="text-xs font-bold text-[#1A4B8F] tracking-widest uppercase">ZFE Marseille</p>
                <p class="text-sm font-extrabold text-[#1A1A1A]">Zone à Faibles Émissions</p>
              </div>
            </div>
            <p class="text-xs text-[#1A1A1A]/65 font-light leading-relaxed mb-5">
              La Métropole Aix-Marseille-Provence a instauré une Zone à Faibles Émissions (ZFE) centrée sur la réduction des polluants atmosphériques. Si les véhicules sont la cible principale, les plans locaux air-énergie-climat (PLAEC) visent aussi les <strong class="text-[#1A1A1A]">émissions résidentielles de chauffage au bois</strong>.
            </p>
            <div class="space-y-3">
              {[
                { val: '80 à 100', unit: 'décès/an', texte: 'liés à la pollution aux particules fines en PACA' },
                { val: '25 %', unit: 'des PM2.5', texte: 'proviennent du chauffage résidentiel au bois en hiver' },
                { val: '40–65 %', unit: 'de réduction', texte: 'de PM2.5 après ramonage + débistrage d\'un foyer encrassé' },
              ].map(s => (
                <div class="flex gap-3 items-start">
                  <div class="shrink-0 mt-0.5">
                    <span class="text-sm font-extrabold text-green-700">{s.val}</span>
                    <span class="text-[10px] text-green-600/70 ml-1">{s.unit}</span>
                  </div>
                  <p class="text-xs text-[#1A1A1A]/55 font-light">{s.texte}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-green-50 border border-green-200 rounded-2xl p-6">
            <p class="text-sm font-bold text-green-800 mb-2">Anticipez les futures obligations</p>
            <p class="text-xs text-green-700/70 font-light leading-relaxed">
              Les réglementations ZFE évoluent vers des restrictions sur les appareils de chauffage au bois anciens et non conformes. Un conduit certifié et un appareil entretenu vous protègent des futures contraintes réglementaires — et valorisent votre bien dès aujourd'hui.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ LE CERTIFICAT DE VALEUR VERTE ═══ -->
  <section class="py-20 px-6 md:px-10 bg-[#F9F9F9]">
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-14">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-green-600 mb-3">Document officiel</p>
        <h2 class="text-3xl font-extrabold tracking-tight text-[#1A1A1A]">Le Certificat de Valeur Verte</h2>
        <p class="text-sm text-[#1A1A1A]/45 font-light mt-3 max-w-xl mx-auto">Établi par un artisan certifié COSTIC. Transmissible à votre diagnostiqueur DPE, notaire, ou assureur.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-10 items-start">

        <!-- Ce que contient le certificat -->
        <div class="bg-white border border-[#EEEEEE] rounded-2xl p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center">
              <svg class="w-5 h-5 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            </div>
            <h3 class="text-base font-extrabold text-[#1A1A1A]">Contenu du certificat</h3>
          </div>
          <ul class="space-y-3">
            {[
              'Identité et coordonnées de l\'artisan certifié COSTIC',
              'Description de l\'appareil et du conduit (type, section, matériau, hauteur)',
              'Résultat de l\'inspection visuelle et/ou caméra',
              'Conformité RSD 13 et NF DTU 24.1 documentée',
              'Rendement estimé de l\'appareil (avant / après optimisation)',
              'Niveau d\'émissions PM2.5 estimé (g/GJ)',
              'Recommandations de maintenance pour maintenir les performances',
              'Mention explicite "Certificat de Valeur Verte — Sud Ramonage"',
              'Signature et cachet artisan certifié',
            ].map(item => (
              <li class="flex items-start gap-2.5 text-xs text-[#1A1A1A]/65">
                <svg class="w-3.5 h-3.5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Processus -->
        <div class="space-y-5">
          <h3 class="text-base font-extrabold text-[#1A1A1A]">Check-up Valeur Verte — 149 €</h3>
          <p class="text-sm text-[#1A1A1A]/55 font-light leading-relaxed">
            Une intervention sur place, un rapport complet sous 24h, transmissible immédiatement à votre diagnostiqueur ou notaire.
          </p>

          <div class="space-y-4">
            {[
              { num: '01', titre: 'Prise de RDV', texte: 'Vous nous contactez avec l\'adresse du bien et le type d\'appareil. Intervention sous 48-72h.' },
              { num: '02', titre: 'Inspection sur place', texte: 'Contrôle visuel, inspection caméra si nécessaire, vérification tirage et étanchéité. Durée : 45 à 90 min.' },
              { num: '03', titre: 'Rapport et certificat', texte: 'Le Certificat de Valeur Verte est envoyé par email sous 24h en format PDF signé.' },
              { num: '04', titre: 'Transmission partenaires', texte: 'Vous pouvez le transmettre directement à votre diagnostiqueur DPE, notaire, ou l\'inclure dans votre dossier de vente.' },
            ].map(step => (
              <div class="flex gap-4">
                <div class="w-8 h-8 rounded-xl bg-green-100 flex items-center justify-center shrink-0">
                  <span class="text-[10px] font-extrabold text-green-700">{step.num}</span>
                </div>
                <div>
                  <p class="text-sm font-bold text-[#1A1A1A] mb-1">{step.titre}</p>
                  <p class="text-xs text-[#1A1A1A]/50 font-light leading-relaxed">{step.texte}</p>
                </div>
              </div>
            ))}
          </div>

          <a
            href="mailto:contact@sud-ramonage.fr?subject=Check-up%20Valeur%20Verte%20%E2%80%94%20demande&body=Bonjour%2C%0A%0AJe%20souhaite%20un%20Check-up%20Valeur%20Verte%20pour%20mon%20installation.%0A%0AAdresse%20%3A%0AType%20d%27appareil%20%3A%20Cheminee%20%2F%20Insert%20%2F%20Poele%20bois%20%2F%20Poele%20granules%0AContexte%20%3A%20Vente%20%2F%20DPE%20%2F%20ZFE%20%2F%20Assurance%0A%0AMerci."
            class="inline-flex items-center gap-2 bg-green-600 text-white text-sm font-bold px-6 py-3.5 rounded-xl hover:bg-green-700 transition-colors duration-200"
          >
            Réserver mon Check-up — 149 €
          </a>
        </div>

      </div>

    </div>
  </section>

  <!-- ═══ USAGES ═══ -->
  <section class="py-20 px-6 md:px-10 bg-white">
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-12">
        <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A]">Qui utilise le Certificat de Valeur Verte ?</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            titre: 'Vendeurs',
            icon: '🏡',
            texte: 'Documentez les performances de votre installation pour valoriser votre bien lors de la vente. Un certificat en mains, votre acheteur achète en confiance — et vous évitez la discussion sur le prix liée à l\'état du conduit.',
            cta: 'Je vends mon bien',
          },
          {
            titre: 'Diagnostiqueurs DPE',
            icon: '📋',
            texte: 'Complétez votre audit avec une certification spécifique conduit. Le Certificat de Valeur Verte est le complément technique manquant du DPE pour les biens équipés d\'un appareil à combustion. Protocole ACTS disponible.',
            cta: 'Partenariat DPE',
          },
          {
            titre: 'Propriétaires ZFE',
            icon: '🌿',
            texte: 'Anticipez les obligations de la Zone à Faibles Émissions. Un appareil certifié performant vous protège des futures contraintes réglementaires et peut vous permettre de bénéficier d\'aides à la rénovation.',
            cta: 'Conformité ZFE',
          },
        ].map(profil => (
          <div class="bg-[#F9F9F9] border border-[#EEEEEE] rounded-2xl p-7">
            <span class="text-3xl block mb-4">{profil.icon}</span>
            <h3 class="text-base font-extrabold text-[#1A1A1A] mb-3">{profil.titre}</h3>
            <p class="text-xs text-[#1A1A1A]/55 font-light leading-relaxed mb-5">{profil.texte}</p>
            <a
              href="mailto:contact@sud-ramonage.fr?subject=Valeur%20Verte%20—%20{profil.titre}"
              class="text-xs font-bold text-green-600 hover:underline"
            >
              {profil.cta} →
            </a>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="py-20 px-6 md:px-10 bg-[#F9F9F9]">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-10 text-center">Questions fréquentes</h2>
      <div class="faq-list" itemscope itemtype="https://schema.org/FAQPage">
        {faqSchema.mainEntity.map(item => (
          <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <summary itemprop="name">{item.name}</summary>
            <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text">{item.acceptedAnswer.text}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="py-16 px-6 md:px-10">
    <div class="max-w-4xl mx-auto border border-[#EEEEEE] rounded-2xl p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <div>
        <h2 class="text-xl font-extrabold tracking-tight text-[#1A1A1A] mb-2">Valorisez votre installation dès aujourd'hui.</h2>
        <p class="text-sm text-[#1A1A1A]/45 font-light">Check-up Valeur Verte — 149 € — Certificat sous 24h.</p>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 shrink-0">
        <a
          href="mailto:contact@sud-ramonage.fr?subject=Check-up%20Valeur%20Verte"
          class="inline-flex items-center gap-2 bg-green-600 text-white text-sm font-bold px-6 py-3 rounded-xl hover:bg-green-700 transition-colors duration-200"
        >
          Réserver mon Check-up
        </a>
        <ContactButton variant="phone" class="text-[#1A1A1A]/50 hover:text-[#1A1A1A] text-sm" />
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

</Layout>
