---
import Layout from '../layouts/Layout.astro';
import ContactButton from '../components/ContactButton.astro';
import FAQ from '../components/FAQ.astro';
import { Image } from 'astro:assets';

import heroBg    from '../assets/images/service-controle.jpg';
import conduitImg from '../assets/images/conduit-cheminee.jpg';
import artisanImg from '../assets/images/artisan-intervention.jpg';

const siteUrl = 'https://www.sud-ramonage.fr';

const faqItems = [
  {
    q: "Le ramonage par caméra est-il obligatoire à Martigues ?",
    a: "Non, l'inspection caméra n'est pas imposée par le RSD 13. Seul le ramonage mécanique annuel est obligatoire. En revanche, une inspection caméra HD est fortement recommandée avant tout achat immobilier, après un incendie de conduit, ou lorsque des anomalies sont suspectées (tirage insuffisant, conduit ancien). Le rapport illustré peut être joint à votre dossier d'assurance ou de vente.",
  },
  {
    q: "Quelle est la différence entre un ramonage et une inspection caméra ?",
    a: "Le ramonage mécanique nettoie le conduit (élimination des suies et dépôts) et vérifie son vacuité. L'inspection caméra va plus loin : elle permet de VOIR l'intérieur du conduit en temps réel — fissures de parois, joints déjointés, écrasement du conduit, état du tubage inox, nids d'oiseaux profonds. C'est un diagnostic visuel qui ne remplace pas le ramonage mais le complète utilement.",
  },
  {
    q: "Combien coûte une inspection caméra à Martigues ?",
    a: "L'inspection caméra HD à Martigues et sur la Côte Bleue est à partir de 120 €. Pour un rapport détaillé avec photos et vidéos, adapté à une transmission à votre assureur ou notaire, le tarif est à partir de 150 €. Pour les conduits complexes ou très longs, un devis personnalisé est établi après premier contact — appelez le 06 64 72 96 00.",
  },
  {
    q: "Puis-je utiliser le rapport d'inspection pour mon assurance ou une vente immobilière ?",
    a: "Oui. Notre rapport d'inspection caméra inclut des captures photos et une description technique de l'état du conduit. Ce document est accepté par la plupart des compagnies d'assurance pour justifier l'état de l'installation, et peut être annexé au dossier de vente immobilière. Il est particulièrement utile pour les maisons anciennes dont l'historique d'entretien est inconnu.",
  },
  {
    q: "Quand faut-il faire une inspection caméra de conduit ?",
    a: "Cinq situations déclenchent systématiquement une inspection caméra : (1) achat d'un bien immobilier avec cheminée ou poêle ; (2) après un incendie de conduit, même partiel ; (3) tirage anormalement faible malgré un ramonage récent ; (4) suintements ou taches d'humidité sur le conduit ; (5) conduit maçonné ancien avant installation d'un nouvel appareil. Dans tous ces cas, voir l'état réel du conduit est indispensable.",
  },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Inspection caméra HD conduit de cheminée',
  description: 'Diagnostic vidéo endoscopique HD de conduit de cheminée. Détection de fissures, obstructions, état du tubage. Rapport illustré avec photos pour assurance et notaire. Martigues et Côte Bleue.',
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  areaServed: { '@type': 'City', name: 'Martigues' },
  serviceType: 'Inspection caméra conduit de cheminée',
  url: `${siteUrl}/inspection-camera`,
  offers: {
    '@type': 'Offer',
    price: '120',
    priceCurrency: 'EUR',
    priceSpecification: { '@type': 'PriceSpecification', minPrice: '120', maxPrice: '150', priceCurrency: 'EUR' },
  },
};
---

<Layout
  title="Inspection Caméra HD Conduit Cheminée — Sud Ramonage Martigues"
  description="Inspection caméra HD de conduit de cheminée à Martigues. Détection fissures, état tubage, rapport pour assurance. Artisan certifié COSTIC. À partir de 120 €. Devis gratuit sous 24h."
  breadcrumbs={[
    { name: 'Accueil', url: '/' },
    { name: 'Inspection Caméra', url: '/inspection-camera' },
  ]}
  pageSchema={pageSchema}
>

  <!-- ═══ HERO ═══ -->
  <section class="relative pt-32 pb-20 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={heroBg}
        alt="Inspection caméra HD d'un conduit de cheminée à Martigues — diagnostic vidéo endoscopique"
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-[#1A1A1A]/82"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto">
      <nav class="flex items-center gap-2 text-xs text-white/30 mb-8" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-white transition-colors duration-200">Accueil</a>
        <span>/</span>
        <span class="text-white/60">Inspection Caméra</span>
      </nav>
      <p class="text-[11px] font-semibold tracking-widest uppercase text-[#2563EB] mb-4">Diagnostic avancé</p>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white leading-tight mb-6">
        Inspection Caméra HD<br />de Conduit.
      </h1>
      <p class="text-base text-white/55 font-light max-w-xl leading-relaxed mb-8">
        La seule méthode qui permet de <strong class="text-white/80 font-medium">voir</strong> l'intérieur de votre conduit en temps réel. Fissures, tubage, obstructions profondes — diagnostic précis avec rapport illustré pour votre assurance.
      </p>
      <ContactButton variant="phone" class="px-8 py-3.5" />
    </div>
  </section>

  <!-- ═══ TL;DR ═══ -->
  <section class="py-10 px-6 md:px-10 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="border-l-4 border-[#2563EB] bg-[#EFF6FF] rounded-r-xl p-6" role="note" aria-label="Résumé de la page">
        <p class="text-[10px] font-bold tracking-widest uppercase text-[#2563EB] mb-3">TL;DR — L'essentiel en 30 secondes</p>
        <ul class="space-y-2">
          {[
            'Inspection caméra HD = seule méthode de diagnostic VISUEL de l\'intérieur d\'un conduit.',
            'Révèle : fissures, effondrements partiels, dépôts profonds, nids, état du tubage inox.',
            'Rapport illustré (photos + description technique) — valable pour assurance et acte de vente.',
            'Indispensable avant achat immobilier, après incendie de conduit, ou si tirage anormal.',
            'Tarif : à partir de 120 € — durée environ 1h — Martigues et Côte Bleue.',
          ].map(point => (
            <li class="flex items-start gap-2.5 text-sm text-[#1A1A1A]/75 font-light">
              <span class="w-1.5 h-1.5 rounded-full bg-[#2563EB] mt-1.5 shrink-0"></span>
              {point}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ═══ CONTENU PRINCIPAL ═══ -->
  <section class="py-20 px-6 md:px-10">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Colonne gauche -->
        <div class="space-y-8">
          <div>
            <p class="text-[11px] font-semibold tracking-widest uppercase text-[#2563EB] mb-4">01 — Pourquoi</p>
            <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-5">
              Ce que révèle une inspection caméra.
            </h2>
            <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed mb-6">
              Un conduit peut sembler fonctionnel tout en présentant des défauts invisibles à l'œil nu. L'inspection par caméra endoscopique HD permet de diagnostiquer avec précision l'état réel des parois, des joints et du tubage — sans démolition, sans travaux préalables.
            </p>
            <div class="space-y-3">
              {[
                { titre: 'Fissures de paroi',         desc: 'Détection des fissures dans la maçonnerie ou le tubage inox — risque de CO si non traitées.' },
                { titre: 'Obstructions profondes',     desc: 'Nids d\'oiseaux ou d\'insectes, calcin accumulé, débris de maçonnerie non visibles au ramonage.' },
                { titre: 'État du tubage inox',        desc: 'Vérification de l\'intégrité du flexible ou du conduit rigide — déformation, perforation, désemboîtement.' },
                { titre: 'Dépôts de bistre',           desc: 'Identification et localisation précise des zones bistrées avant traitement chimique.' },
                { titre: 'Conformité de l\'installation', desc: 'Vérification que la section, le tracé et les jonctions respectent la norme NF DTU 24.1.' },
              ].map(({ titre, desc }) => (
                <div class="flex gap-4 bg-[#FAFAFA] rounded-xl p-4">
                  <svg class="w-4 h-4 text-[#2563EB] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.868V15.13a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z" />
                  </svg>
                  <div>
                    <p class="text-xs font-semibold text-[#1A1A1A] mb-0.5">{titre}</p>
                    <p class="text-xs text-[#1A1A1A]/50 font-light leading-relaxed">{desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Colonne droite -->
        <div class="space-y-6">
          <!-- Étapes -->
          <div class="bg-[#EFF6FF] rounded-xl p-7">
            <p class="text-sm font-bold text-[#1A1A1A] mb-5">Les 4 étapes de l'inspection</p>
            <ol class="space-y-4">
              {[
                { n: '01', t: 'Introduction de la caméra',    d: 'Sonde HD flexible introduite depuis le foyer ou la sortie en toiture selon le type de conduit.' },
                { n: '02', t: 'Progression et enregistrement', d: 'La caméra progresse sur toute la longueur — images en temps réel transmises sur écran.' },
                { n: '03', t: 'Identification des anomalies',  d: 'Chaque zone problématique est photographiée avec repérage de la position exacte dans le conduit.' },
                { n: '04', t: 'Remise du rapport',            d: 'Rapport technique illustré remis en fin d\'intervention — prêt pour assurance ou notaire.' },
              ].map(({ n, t, d }) => (
                <li class="flex gap-4">
                  <span class="text-[11px] font-bold text-[#2563EB] shrink-0 w-7 mt-0.5">{n}</span>
                  <div>
                    <p class="text-sm font-semibold text-[#1A1A1A]">{t}</p>
                    <p class="text-sm text-[#1A1A1A]/50 font-light leading-relaxed">{d}</p>
                  </div>
                </li>
              ))}
            </ol>
          </div>

          <!-- Image -->
          <figure class="rounded-xl overflow-hidden aspect-[4/3]">
            <Image
              src={conduitImg}
              alt="Préparation de l'inspection caméra HD d'un conduit de cheminée à Martigues — diagnostic endoscopique professionnel"
              width={700}
              height={525}
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <figcaption class="sr-only">Inspection caméra conduit cheminée Martigues — caméra endoscopique HD, détection fissures, état tubage inox, rapport illustré pour assurance. Artisan certifié COSTIC RSD 13.</figcaption>
          </figure>

          <!-- Rapport assurance -->
          <div class="bg-[#EFF6FF] rounded-xl p-6">
            <p class="text-xs font-semibold text-[#1A4B8F]/60 uppercase tracking-widest mb-3">Rapport d'inspection inclus</p>
            <div class="space-y-2.5">
              {[
                'Photos HD de chaque zone diagnostiquée',
                'Repérage des anomalies avec position exacte',
                'Description technique de l\'état du conduit',
                'Préconisations de travaux si nécessaire',
                'Document accepté par assureurs et notaires',
              ].map(item => (
                <div class="flex items-center gap-3">
                  <svg class="w-4 h-4 text-[#2563EB] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-xs text-white/55 font-light">{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CAS D'USAGE ═══ -->
  <section class="py-16 px-6 md:px-10 bg-[#FAFAFA]">
    <div class="max-w-6xl mx-auto">
      <p class="text-[11px] font-semibold tracking-widest uppercase text-[#2563EB] mb-4">02 — Quand</p>
      <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-8">5 situations qui imposent une inspection caméra.</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z', titre: 'Achat immobilier', desc: 'Vérifiez l\'état réel du conduit avant de signer. Une fissure non détectée = des milliers d\'euros de travaux à votre charge.' },
          { icon: 'M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z', titre: 'Après incendie de conduit', desc: 'Obligatoire avant toute remise en service. L\'incendie peut avoir fissuré les parois de façon non visible extérieurement.' },
          { icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z', titre: 'Tirage insuffisant', desc: 'Si votre tirage est faible malgré un conduit ramoné récemment, une obstruction ou fissure profonde en est souvent la cause.' },
          { icon: 'M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12', titre: 'Humidité sur le conduit', desc: 'Taches d\'humidité ou suintements sur la paroi extérieure du conduit = risque de fissure ou défaut d\'étanchéité à diagnostiquer.' },
          { icon: 'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2v-4M9 21H5a2 2 0 01-2-2v-4m0 0h18', titre: 'Conduit ancien avant tubage', desc: 'Avant d\'investir dans un tubage inox, vérifiez l\'état des parois et dimensionnez correctement l\'intervention.' },
          { icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', titre: 'Dossier assurance / sinistre', desc: 'Votre assurance exige un rapport technique ? Notre inspection caméra produit un document illustré et opposable.' },
        ].map(({ icon, titre, desc }) => (
          <div class="bg-white border border-[#EEEEEE] rounded-xl p-5">
            <div class="w-9 h-9 rounded-lg bg-[#EFF6FF] flex items-center justify-center mb-4">
              <svg class="w-4.5 h-4.5 text-[#2563EB]" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <path d={icon} />
              </svg>
            </div>
            <p class="text-sm font-bold text-[#1A1A1A] mb-2">{titre}</p>
            <p class="text-xs text-[#1A1A1A]/55 font-light leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TARIFS ═══ -->
  <section class="py-16 px-6 md:px-10">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <div>
          <p class="text-[11px] font-semibold tracking-widest uppercase text-[#2563EB] mb-4">Tarifs</p>
          <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-6">Ce que coûte une inspection caméra.</h2>
          <div class="bg-white border border-[#EEEEEE] rounded-xl overflow-hidden">
            {[
              { label: 'Inspection caméra HD standard',          prix: '120 €' },
              { label: 'Inspection + rapport détaillé (assurance/notaire)', prix: '150 €' },
              { label: 'Conduit complexe / long',                prix: 'Devis' },
            ].map(({ label, prix }, i) => (
              <div class={`flex items-center justify-between px-6 py-3.5 ${i % 2 === 0 ? 'bg-white' : 'bg-[#FAFAFA]'}`}>
                <span class="text-sm text-[#1A1A1A]/65 font-light">{label}</span>
                <span class="text-sm font-bold text-[#1A1A1A]">{prix}</span>
              </div>
            ))}
          </div>
          <p class="text-[11px] text-[#1A1A1A]/40 font-light mt-4">Tarifs indicatifs — zone Martigues et Côte Bleue. Devis gratuit sous 24h.</p>
        </div>
        <div class="bg-[#EFF6FF] rounded-xl p-7">
          <p class="text-xs font-semibold text-[#1A4B8F]/60 uppercase tracking-widest mb-5">Inclus dans chaque inspection</p>
          {[
            'Inspection HD sur toute la longueur du conduit',
            'Images en temps réel sur écran',
            'Photos de chaque anomalie détectée',
            'Rapport technique illustré remis en fin d\'intervention',
            'Préconisations de mise en conformité',
            'Devis travaux si nécessaire',
          ].map(item => (
            <div class="flex items-center gap-3 py-2.5 border-b border-[#BFDBFE]/50 last:border-0">
              <svg class="w-4 h-4 text-[#2563EB] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-[#334155] font-light">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <FAQ title="Questions sur l'Inspection Caméra." items={faqItems} />

  <!-- ═══ MAILLAGE SILO ═══ -->
  <section class="py-12 px-6 md:px-10 bg-[#FAFAFA]">
    <div class="max-w-6xl mx-auto">
      <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/35 mb-4">Services associés</p>
      <div class="flex flex-wrap gap-3">
        {[
          { href: '/ramonage',   label: 'Ramonage Certifié' },
          { href: '/debistrage', label: 'Débistrage Conduit' },
          { href: '/normes',     label: 'Normes NF DTU 24.1' },
          { href: '/villes/martigues', label: 'Intervention Martigues' },
        ].map(({ href, label }) => (
          <a href={href} class="inline-flex items-center gap-2 bg-white border border-[#EEEEEE] rounded-lg px-4 py-2.5 text-xs font-medium text-[#1A1A1A]/65 hover:border-[#2563EB]/30 hover:text-[#2563EB] transition-all duration-200">
            <span class="w-1.5 h-1.5 rounded-full bg-[#2563EB] shrink-0"></span>
            {label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="py-16 px-6 md:px-10 bg-[#EFF6FF] text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-4">Votre conduit a des secrets — découvrez-les.</h2>
      <p class="text-sm text-[#1A1A1A]/55 font-light mb-8">Inspection caméra HD à partir de 120 €. Rapport remis le jour même.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <ContactButton variant="phone" class="px-8 py-4 text-sm" />
        <ContactButton variant="email" />
      </div>
    </div>
  </section>

</Layout>
