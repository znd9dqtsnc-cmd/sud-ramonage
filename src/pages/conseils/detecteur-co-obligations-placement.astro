const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Détecteur de CO : est-il obligatoire ? Où le placer ? Quel modèle choisir ?',
  description: 'Tout sur l\'obligation légale du détecteur de monoxyde de carbone en France, les normes à respecter (NF EN 50291), les emplacements corrects et les modèles recommandés pour cheminée et poêle.',
  author: { '@type': 'Person', name: 'Sud Ramonage', url: siteUrl },
  publisher: { '@type': 'Organization', name: 'Sud Ramonage', logo: { '@type': 'ImageObject', url: `${siteUrl}/favicon.svg` } },
