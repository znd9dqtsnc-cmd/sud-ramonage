---
import Layout from '../layouts/Layout.astro';
const siteUrl = 'https://www.sud-ramonage.fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Contact', url: '/contact' },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact — Sud Ramonage Martigues',
  url: `${siteUrl}/contact`,
  description: 'Contactez Sud Ramonage pour un devis gratuit de ramonage à Martigues et Bouches-du-Rhône. Téléphone, email ou formulaire.',
  mainEntity: {
    '@type': 'HomeAndConstructionBusiness',
    '@id': `${siteUrl}/#business`,
  },
};
---

<Layout
  title="Contact — Devis Gratuit Ramonage | Sud Ramonage Martigues"
  description="Contactez votre artisan ramoneur à Martigues. Devis gratuit sous 24h. Téléphone, email ou formulaire. Intervention Bouches-du-Rhône."
  breadcrumbs={breadcrumbs}
  pageSchema={pageSchema}
>

  <!-- Hero -->
  <section class="bg-white border-b border-[#EEEEEE] pt-28 pb-12">
    <div class="max-w-4xl mx-auto px-6 md:px-10">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-[#1A1A1A]/35 mb-6">
        <a href="/" class="hover:text-[#1A1A1A]/60">Accueil</a><span>/</span><span class="text-[#1A1A1A]/50">Contact</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-4 text-[#1A1A1A]">
        Demandez votre devis <span class="text-[#C1440E]">gratuit</span>
      </h1>
      <p class="text-base text-[#1A1A1A]/55 max-w-xl leading-relaxed">
        Réponse sous 24h. Disponible du lundi au samedi, 8h–19h. Intervention sur Martigues, Côte Bleue et tout le département 13.
      </p>
    </div>
  </section>

  <!-- Contenu principal -->
  <section class="py-16 px-6 md:px-10">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12">

      <!-- Colonne gauche : coordonnées + carte -->
      <div class="space-y-8">

        <!-- Téléphone -->
        <div>
          <p class="text-[10px] font-bold tracking-widest uppercase text-[#C1440E] mb-4">Appel direct</p>
          <a href="tel:+33664729600" class="flex items-center gap-4 bg-[#E8DDD4] text-white rounded-2xl px-6 py-5 hover:bg-[#C4B5AC] transition-colors group">
            <div class="w-12 h-12 rounded-xl bg-white/15 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <p class="text-xl font-extrabold tracking-tight">06 64 72 96 00</p>
              <p class="text-sm text-white/70">Lundi–Samedi · 8h–19h</p>
            </div>
            <svg class="w-5 h-5 ml-auto opacity-60 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Email -->
        <div>
          <p class="text-[10px] font-bold tracking-widest uppercase text-[#C1440E] mb-4">Email</p>
          <a href="mailto:contact@sud-ramonage.fr" class="flex items-center gap-4 bg-[#FAFAFA] border border-[#EEEEEE] text-[#1A1A1A] rounded-2xl px-6 py-5 hover:border-[#E8DDD4]/30 transition-colors group">
            <div class="w-12 h-12 rounded-xl bg-[#E8DDD4]/8 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-[#C1440E]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <p class="text-sm font-bold">contact@sud-ramonage.fr</p>
              <p class="text-xs text-[#1A1A1A]/50">Réponse sous 24h</p>
            </div>
          </a>
        </div>

        <!-- Infos pratiques -->
        <div class="bg-[#FAFAFA] border border-[#EEEEEE] rounded-2xl p-6 space-y-4">
          <p class="text-[10px] font-bold tracking-widest uppercase text-[#1A1A1A]/40 mb-2">Infos pratiques</p>
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z', label: '31 chemin des tamaris, 13500 Martigues' },
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', label: 'Lundi au samedi · 8h00–19h00' },
            { icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7', label: 'Zone : Bouches-du-Rhône — rayon 50 km' },
            { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', label: 'Certificat officiel remis après chaque intervention' },
          ].map(({ icon, label }) => (
            <div class="flex items-start gap-3">
              <div class="w-7 h-7 rounded-lg bg-[#E8DDD4]/8 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-[#C1440E]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon}/></svg>
              </div>
              <p class="text-sm text-[#1A1A1A]/65">{label}</p>
            </div>
          ))}
        </div>

        <!-- Carte -->
        <div class="rounded-2xl overflow-hidden border border-[#EEEEEE]">
          <iframe
            title="Localisation Sud Ramonage — Martigues"
            src="https://maps.google.com/maps?q=31+chemin+des+tamaris+13500+Martigues&z=14&output=embed"
            width="100%"
            height="240"
            style="border:0; display:block;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
          <div class="bg-white px-5 py-3 flex items-center justify-between border-t border-[#EEEEEE]">
            <p class="text-xs text-[#1A1A1A]/50">31 chemin des tamaris, 13500 Martigues</p>
            <a href="https://www.google.com/maps/search/31+chemin+des+tamaris+13500+Martigues" target="_blank" rel="noopener noreferrer" class="text-[11px] font-semibold text-[#C1440E] hover:underline">Ouvrir ↗</a>
          </div>
        </div>

      </div>

      <!-- Colonne droite : formulaire -->
      <div>
        <p class="text-[10px] font-bold tracking-widest uppercase text-[#C1440E] mb-4">Formulaire de contact</p>
        <div class="bg-white border border-[#EEEEEE] rounded-2xl p-8">
          <p class="text-sm text-[#1A1A1A]/55 mb-6">Décrivez votre installation et votre besoin — je vous rappelle sous 24h avec un devis précis.</p>

          <form
            action="https://formspree.io/f/VOTRE_ID_FORMSPREE"
            method="POST"
            class="space-y-5"
          >
            <div>
              <label for="nom" class="block text-xs font-semibold text-[#1A1A1A] mb-1.5">Nom <span class="text-[#C1440E]">*</span></label>
              <input type="text" id="nom" name="nom" required placeholder="Votre nom et prénom"
                class="w-full border border-[#EEEEEE] rounded-xl px-4 py-3 text-sm text-[#1A1A1A] placeholder:text-[#1A1A1A]/30 focus:outline-none focus:border-[#E8DDD4] transition-colors" />
            </div>

            <div>
              <label for="telephone" class="block text-xs font-semibold text-[#1A1A1A] mb-1.5">Téléphone <span class="text-[#C1440E]">*</span></label>
              <input type="tel" id="telephone" name="telephone" required placeholder="06 XX XX XX XX"
                class="w-full border border-[#EEEEEE] rounded-xl px-4 py-3 text-sm text-[#1A1A1A] placeholder:text-[#1A1A1A]/30 focus:outline-none focus:border-[#E8DDD4] transition-colors" />
            </div>

            <div>
              <label for="ville" class="block text-xs font-semibold text-[#1A1A1A] mb-1.5">Ville</label>
              <input type="text" id="ville" name="ville" placeholder="Martigues, Istres, Carry…"
                class="w-full border border-[#EEEEEE] rounded-xl px-4 py-3 text-sm text-[#1A1A1A] placeholder:text-[#1A1A1A]/30 focus:outline-none focus:border-[#E8DDD4] transition-colors" />
            </div>

            <div>
              <label for="appareil" class="block text-xs font-semibold text-[#1A1A1A] mb-1.5">Type d'appareil</label>
              <select id="appareil" name="appareil"
                class="w-full border border-[#EEEEEE] rounded-xl px-4 py-3 text-sm text-[#1A1A1A] focus:outline-none focus:border-[#E8DDD4] transition-colors bg-white">
                <option value="">— Sélectionnez —</option>
                <option>Cheminée foyer ouvert</option>
                <option>Insert à bois</option>
                <option>Poêle à bois</option>
                <option>Poêle à granulés</option>
                <option>Chaudière gaz / fioul</option>
                <option>Je ne sais pas</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-xs font-semibold text-[#1A1A1A] mb-1.5">Message</label>
              <textarea id="message" name="message" rows="4" placeholder="Dernière intervention, problème constaté, urgence…"
                class="w-full border border-[#EEEEEE] rounded-xl px-4 py-3 text-sm text-[#1A1A1A] placeholder:text-[#1A1A1A]/30 focus:outline-none focus:border-[#E8DDD4] transition-colors resize-none"></textarea>
            </div>

            <button type="submit"
              class="w-full flex items-center justify-center gap-2 bg-[#E8DDD4] hover:bg-[#C4B5AC] text-white font-bold text-sm px-6 py-4 rounded-xl transition-colors shadow-lg shadow-[#E8DDD4]/20">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
              Envoyer ma demande
            </button>

            <p class="text-[11px] text-[#1A1A1A]/35 text-center">Ou appelez directement : <a href="tel:+33664729600" class="text-[#C1440E] font-semibold">06 64 72 96 00</a></p>
          </form>
        </div>
      </div>

    </div>
  </section>

  <!-- À propos de l'artisan -->
  <section class="py-16 px-6 md:px-10 bg-[#FAFAFA] border-t border-[#EEEEEE]">
    <div class="max-w-4xl mx-auto space-y-12">

      <div class="flex flex-col md:flex-row items-start gap-8">
        <div class="shrink-0">
          <div class="w-20 h-20 rounded-2xl bg-[#E8DDD4]/10 border border-[#E8DDD4]/20 flex items-center justify-center">
            <svg class="w-10 h-10 text-[#C1440E]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </div>
        </div>
        <div>
          <p class="text-[10px] font-bold tracking-widest uppercase text-[#C1440E] mb-3">Votre artisan</p>
          <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-4">
            Artisan indépendant,<br /><span class="text-[#C1440E]">certifié et assuré.</span>
          </h2>
          <p class="text-sm text-[#1A1A1A]/60 max-w-2xl leading-relaxed">
            Je travaille seul — c'est moi qui décroche le téléphone, c'est moi qui interviens chez vous, et c'est moi qui vous remet le certificat. Pas d'intermédiaire, pas de sous-traitant.
          </p>
        </div>
      </div>

      <blockquote class="border-l-4 border-[#E8DDD4] pl-6 py-2">
        <p class="text-base md:text-lg font-light text-[#1A1A1A]/70 leading-relaxed italic mb-3">
          "Je travaille dans ce métier parce qu'un conduit propre, c'est une famille à l'abri. Chaque intervention, je prends le temps de vous expliquer ce que j'ai trouvé — et ce que ça aurait pu donner sans ramonage."
        </p>
        <cite class="text-sm font-semibold text-[#C1440E] not-italic">Votre artisan — Sud Ramonage, Martigues</cite>
      </blockquote>

      <!-- Certifications -->
      <div>
        <p class="text-[10px] font-bold tracking-widest uppercase text-[#C1440E] mb-5">Certifications & qualifications</p>
        <div class="grid sm:grid-cols-2 gap-4">
          {[
            { titre: 'Certification COSTIC', desc: 'Formation aux techniques de fumisterie, aux normes NF DTU 24.1 et aux méthodes de diagnostic avancées.', badge: 'COSTIC', color: '#1A4B8F' },
            { titre: 'Qualibat 6521', desc: 'Qualification officielle pour les travaux de fumisterie et de conduits de fumée. Reconnue par les assureurs.', badge: '6521', color: '#1A4B8F' },
            { titre: 'Assurance RC Pro', desc: 'Responsabilité civile professionnelle active pour toutes mes interventions. Vous êtes couverts en toutes circonstances.', badge: 'RC Pro', color: '#E8DDD4' },
            { titre: 'Certificat NF DTU 24.1', desc: 'Chaque intervention donne lieu à un certificat officiel valable auprès de votre assureur habitation.', badge: 'RSD 13', color: '#E8DDD4' },
          ].map(({ titre, desc, badge, color }) => (
            <div class="flex gap-4 bg-white border border-[#EEEEEE] rounded-2xl p-5">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 font-extrabold text-[10px] text-white tracking-wider" style={`background: ${color};`}>{badge}</div>
              <div>
                <p class="text-sm font-bold text-[#1A1A1A] mb-1">{titre}</p>
                <p class="text-xs text-[#1A1A1A]/55 leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Valeurs -->
      <div>
        <p class="text-[10px] font-bold tracking-widest uppercase text-[#C1440E] mb-5">Ce qui me distingue</p>
        <div class="grid sm:grid-cols-2 gap-4">
          {[
            { titre: 'Travail propre garanti', desc: 'Protection du sol et de vos meubles avant intervention. Aspiration complète des suies. Je repars en laissant votre intérieur impeccable.' },
            { titre: 'Artisan seul — pas de sous-traitant', desc: 'C\'est moi qui interviens, sans exception. Vous savez qui vient chez vous.' },
            { titre: 'Transparence sur les prix', desc: 'Tarifs annoncés avant l\'intervention. Pas de surprise sur la facture.' },
            { titre: 'Ponctualité', desc: 'Je m\'engage sur un créneau et je le tiens. Si un imprévu survient, je vous préviens.' },
            { titre: 'Pédagogie', desc: 'Je vous explique ce que j\'ai trouvé, ce que j\'ai fait, et comment entretenir votre installation.' },
            { titre: 'Réactivité', desc: 'Devis sous 24h, intervention possible en urgence. Zone Martigues–Marseille–Aix-en-Provence.' },
          ].map(({ titre, desc }) => (
            <div class="flex gap-3 bg-white border border-[#EEEEEE] rounded-xl p-5">
              <span class="w-1.5 h-1.5 rounded-full bg-[#E8DDD4] shrink-0 mt-1.5"></span>
              <div>
                <p class="text-sm font-semibold text-[#1A1A1A] mb-1">{titre}</p>
                <p class="text-xs text-[#1A1A1A]/55 leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

</Layout>
