---
import Layout from '../layouts/Layout.astro';
import ContactButton from '../components/ContactButton.astro';
import { Image } from 'astro:assets';

import heroBg         from '../assets/images/hero-poele.jpg';
import poeleInstallImg from '../assets/images/poele-installation.jpg';
import controleImg    from '../assets/images/service-controle.jpg';

const siteUrl = 'https://www.sud-ramonage.fr';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Entretien poêle à bois et à granulés',
  description: 'Maintenance complète de votre poêle à bois ou à granulés. Ramonage, nettoyage, contrôle technique et certificat RSD 13.',
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  areaServed: { '@type': 'City', name: 'Martigues' },
  serviceType: 'Entretien de poêle à bois et granulés',
  url: `${siteUrl}/entretien-poele`,
};
---

<Layout
  title="Entretien Poêle à Bois & Granulés — Sud Ramonage Martigues"
  description="Entretien et maintenance de poêle à bois et à granulés à Martigues. Ramonage, nettoyage, contrôle technique. Artisan certifié. Devis gratuit sous 24h."
  breadcrumbs={[
    { name: 'Accueil', url: '/' },
    { name: 'Entretien Poêle', url: '/entretien-poele' },
  ]}
  pageSchema={pageSchema}
>

  <!-- ═══ HERO avec image de fond ═══ -->
  <section class="relative pt-32 pb-20 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={heroBg}
        alt="Poêle à bois moderne et design dans un salon provençal chaleureux à Martigues"
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-[#1A1A1A]/75"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto">
      <nav class="flex items-center gap-2 text-xs text-white/30 mb-8" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-white transition-colors duration-200">Accueil</a>
        <span>/</span>
        <span class="text-white/60">Entretien Poêle</span>
      </nav>
      <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-4">Service 03</p>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white leading-tight mb-6">
        Entretien Poêle<br />à Bois & Granulés.
      </h1>
      <p class="text-base text-white/55 font-light max-w-xl leading-relaxed mb-8">
        Un poêle bien entretenu consomme moins, chauffe mieux et dure plus longtemps. Notre prestation d'entretien annuel couvre le ramonage du conduit, le nettoyage complet de l'appareil et un contrôle technique approfondi — pour votre confort et votre sécurité.
      </p>
      <ContactButton variant="phone" class="px-8 py-3.5" />
    </div>
  </section>

  <!-- ═══ CONTENU PRINCIPAL ═══ -->
  <section class="py-20 px-6 md:px-10">
    <div class="max-w-6xl mx-auto">

      <!-- TL;DR — Résumé pour IA et lecteurs pressés -->
      <div class="border-l-4 border-[#E65100] bg-[#FFF3E0] rounded-r-xl p-6 mb-14" role="note" aria-label="Résumé de la page">
        <p class="text-[10px] font-bold tracking-widest uppercase text-[#E65100] mb-3">TL;DR — L'essentiel en 30 secondes</p>
        <ul class="space-y-2">
          {[
            'Entretien annuel obligatoire avant la saison de chauffe (idéalement septembre–octobre).',
            'Comprend : ramonage du conduit + nettoyage complet de l\'appareil + contrôle tirage + certificat RSD 13.',
            'Bois recommandé : taux d\'humidité < 20% — chêne ou hêtre séchés 2 ans minimum.',
            'Poêle à granulés : nettoyage brûleur, contrôle ventilateur et sonde — même fréquence annuelle.',
            'Un poêle bien entretenu consomme jusqu\'à 30% moins de combustible.',
          ].map(point => (
            <li class="flex items-start gap-2.5 text-sm text-[#1A1A1A]/75 font-light">
              <span class="w-1.5 h-1.5 rounded-full bg-[#E65100] mt-1.5 shrink-0"></span>
              {point}
            </li>
          ))}
        </ul>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Colonne gauche -->
        <div class="space-y-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-5">
              Poêle à Bois vs Poêle à Granulés.
            </h2>
            <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed mb-5">
              Ces deux types d'appareils n'ont pas les mêmes contraintes d'entretien. Le poêle à bois génère davantage de suies, de <strong class="font-medium text-[#1A1A1A]/80">bistre</strong> et de <strong class="font-medium text-[#1A1A1A]/80">calcin</strong>, et nécessite un ramonage annuel rigoureux avec contrôle du <strong class="font-medium text-[#1A1A1A]/80">tirage thermique</strong>. Le poêle à granulés, bien que produisant moins de cendres, possède des composants électroniques, des ventilateurs et des sondes qui requièrent une maintenance spécifique.
            </p>
            <div class="grid grid-cols-2 gap-4">
              {[
                { titre: 'Poêle à bois', items: ['Ramonage conduit', 'Nettoyage foyer', 'Joints vitre', 'Contrôle tirage'] },
                { titre: 'Poêle à granulés', items: ['Ramonage conduit', 'Nettoyage brûleur', 'Contrôle ventilateur', 'Test électronique'] },
              ].map(({ titre, items }) => (
                <div class="bg-[#FAFAFA] rounded-xl p-5">
                  <p class="text-xs font-bold text-[#1A1A1A] uppercase tracking-wider mb-3">{titre}</p>
                  {items.map(i => (
                    <p class="text-xs text-[#1A1A1A]/55 font-light py-1 border-b border-[#EEEEEE] last:border-0">{i}</p>
                  ))}
                </div>
              ))}
            </div>
          </div>

          <!-- Image illustration 1 : installation poêle -->
          <figure class="rounded-xl overflow-hidden aspect-[16/9]">
            <Image
              src={poeleInstallImg}
              alt="Entretien annuel d'un poêle à granulés à Martigues — nettoyage brûleur, contrôle tirage thermique"
              width={800}
              height={450}
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <figcaption class="sr-only">Entretien poêle à granulés Martigues — nettoyage brûleur, ramonage conduit, contrôle tirage thermique, test de vacuité, tubage inox. Artisan certifié RSD 13 Bouches-du-Rhône.</figcaption>
          </figure>

          <div>
            <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-4">
              Quand Faire Entretenir Son Poêle ?
            </h2>
            <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed">
              L'idéal est de planifier l'entretien annuel avant la saison de chauffe — en septembre ou octobre. Cela garantit que votre appareil est en parfait état de fonctionnement pour l'hiver, et que vous disposez du certificat exigé par votre assureur.
            </p>
          </div>
        </div>

        <!-- Colonne droite -->
        <div class="space-y-6">
          <div class="bg-[#FFF3E0] rounded-xl p-7">
            <p class="text-sm font-bold text-[#1A1A1A] mb-5">Entretien complet comprend</p>
            {[
              'Ramonage mécanique du conduit de fumée',
              'Nettoyage du foyer et du cendrier',
              'Vérification et remplacement des joints',
              'Nettoyage de la vitre et des parois',
              'Contrôle du tirage et de la ventilation',
              'Certificat de ramonage conforme RSD 13',
            ].map((item) => (
              <div class="flex items-center gap-3 py-2.5 border-b border-[#E65100]/10 last:border-0">
                <svg class="w-4 h-4 text-[#E65100] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm text-[#1A1A1A]/70 font-light">{item}</span>
              </div>
            ))}
            <div class="pt-5">
              <ContactButton variant="phone" class="w-full justify-center" />
            </div>
          </div>

          <!-- Image illustration 2 : contrôle technique -->
          <figure class="rounded-xl overflow-hidden aspect-[4/3]">
            <Image
              src={controleImg}
              alt="Contrôle technique complet d'un poêle à bois par un artisan certifié à Martigues — vérification tirage et joints"
              width={700}
              height={525}
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <figcaption class="sr-only">Contrôle technique poêle à bois Martigues — vérification joints vitre, tirage thermique, test de vacuité conduit, présence bistre ou calcin. Certificat entretien annuel RSD 13.</figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BIEN CHOISIR SON BOIS ═══ -->
  <section class="py-20 px-6 md:px-10 bg-[#FAFAFA]">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-4">Expertise bois</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-4">
          Bien Choisir Son Bois de Chauffage.
        </h2>
        <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed max-w-2xl">
          Le combustible que vous brûlez est directement responsable de l'état de votre conduit. Un bois trop humide est la première cause de bistrage — et donc d'incendie de cheminée. Voici les règles essentielles à connaître.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">

        <!-- Taux d'humidité -->
        <div class="bg-white border border-[#EEEEEE] rounded-xl p-6">
          <div class="w-10 h-10 rounded-xl bg-[#FFF3E0] flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-[#E65100]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <p class="text-2xl font-extrabold text-[#E65100] mb-1">&lt; 20%</p>
          <p class="text-xs font-bold text-[#1A1A1A] uppercase tracking-wider mb-3">Taux d'humidité idéal</p>
          <ul class="space-y-2">
            {[
              'Bois "vert" = 40 à 60% → condensation garantie',
              '2 ans de séchage sous abri = référence',
              'Mesurer avec un hygromètre (< 20 €)',
              'Label "bois bûche NF" = garantie qualité',
            ].map(p => (
              <li class="flex items-start gap-2 text-xs text-[#1A1A1A]/60 font-light">
                <span class="w-1 h-1 rounded-full bg-[#E65100] mt-1.5 shrink-0"></span>
                {p}
              </li>
            ))}
          </ul>
        </div>

        <!-- Types recommandés -->
        <div class="bg-white border border-[#EEEEEE] rounded-xl p-6">
          <div class="w-10 h-10 rounded-xl bg-[#FFF3E0] flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-[#E65100]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <p class="text-xs font-bold text-[#1A1A1A] uppercase tracking-wider mb-3">Essences recommandées</p>
          <ul class="space-y-2 mb-4">
            {[
              { e: 'Chêne', d: 'Dense, longue combustion, peu de résidus' },
              { e: 'Hêtre', d: 'Bon tirage, flamme propre et stable' },
              { e: 'Charme', d: 'Excellent rendement, braises durables' },
              { e: 'Frêne', d: 'Bonne densité, séchage plus rapide' },
            ].map(({ e, d }) => (
              <li class="flex gap-2 text-xs text-[#1A1A1A]/60 font-light">
                <span class="font-semibold text-[#1A1A1A]/80 shrink-0">{e}</span>
                <span>— {d}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Essences à éviter -->
        <div class="bg-white border border-[#EEEEEE] rounded-xl p-6">
          <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
          <p class="text-xs font-bold text-[#1A1A1A] uppercase tracking-wider mb-3">À éviter absolument</p>
          <ul class="space-y-2">
            {[
              { e: 'Résineux (pin, sapin)', d: 'Très riches en résines → bistrage rapide du conduit' },
              { e: 'Bois peint ou traité', d: 'Émanations toxiques, dépôts chimiques' },
              { e: 'Palettes', d: 'Souvent traitées, taux d\'humidité inconnu' },
              { e: 'Bois vert ou fraîchement coupé', d: 'Combustion incomplète → bistre systématique' },
            ].map(({ e, d }) => (
              <li class="flex gap-2 text-xs text-[#1A1A1A]/60 font-light">
                <span class="font-semibold text-amber-700 shrink-0">{e}</span>
                <span>— {d}</span>
              </li>
            ))}
          </ul>
        </div>

      </div>

      <!-- Impact sur le ramonage -->
      <div class="bg-[#1A1A1A] rounded-xl p-6 md:p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
          <div>
            <p class="text-xs font-semibold text-white/40 uppercase tracking-widest mb-3">Impact direct sur le ramonage</p>
            <h3 class="text-xl font-extrabold text-white mb-4">Bois humide = Bistre = Ramonage plus fréquent</h3>
            <p class="text-sm text-white/55 font-light leading-relaxed">
              Un bois trop humide brûle à basse température, créant une condensation de goudron dans le conduit. Un seul hiver de mauvaise combustion peut transformer un ramonage simple en débistrage complet — une intervention 2 à 3× plus longue et plus coûteuse.
            </p>
          </div>
          <div class="space-y-3">
            {[
              { label: 'Bois sec (< 20%)', detail: 'Combustion complète → peu de suie → ramonage simple annuel', ok: true },
              { label: 'Bois humide (> 30%)', detail: 'Condensation → bistre → débistrage chimique nécessaire', ok: false },
              { label: 'Résineux', detail: 'Résines → encrassement rapide → ramonage 2×/an minimum', ok: false },
            ].map(({ label, detail, ok }) => (
              <div class={`rounded-lg p-4 border ${ok ? 'border-green-500/20 bg-green-500/5' : 'border-amber-500/20 bg-amber-500/5'}`}>
                <div class="flex items-center gap-2 mb-1">
                  <span class={`w-2 h-2 rounded-full shrink-0 ${ok ? 'bg-green-400' : 'bg-amber-400'}`}></span>
                  <p class="text-xs font-semibold text-white">{label}</p>
                </div>
                <p class="text-[11px] text-white/45 font-light pl-4">{detail}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══ TARIFS ═══ -->
  <section class="py-16 px-6 md:px-10">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">

        <div>
          <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-4">Tarifs</p>
          <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-6">Ce que coûte l'entretien annuel.</h2>
          <div class="bg-white border border-[#EEEEEE] rounded-xl overflow-hidden">
            {[
              { label: 'Poêle à bois — entretien complet',      prix: '90 €'  },
              { label: 'Poêle à granulés — entretien complet',  prix: '120 €' },
              { label: 'Ramonage conduit',                      prix: 'inclus' },
              { label: 'Certificat RSD 13',                     prix: 'inclus' },
            ].map(({ label, prix }, i) => (
              <div class={`flex items-center justify-between px-6 py-3.5 ${i % 2 === 0 ? 'bg-white' : 'bg-[#FAFAFA]'}`}>
                <span class="text-sm text-[#1A1A1A]/65 font-light">{label}</span>
                <span class="text-sm font-bold text-[#1A1A1A]">{prix}</span>
              </div>
            ))}
          </div>
          <p class="text-[11px] text-[#1A1A1A]/40 font-light mt-4">
            Tarifs indicatifs — zone Martigues et Côte Bleue. Devis gratuit sous 24h.
          </p>
        </div>

        <div class="bg-[#FFF3E0] rounded-xl p-7 border border-[#E65100]/10">
          <p class="text-xs font-semibold text-[#1A1A1A]/40 uppercase tracking-widest mb-5">Inclus dans l'entretien annuel</p>
          {[
            'Ramonage mécanique complet du conduit',
            'Nettoyage du foyer et du cendrier',
            'Vérification et remplacement des joints si nécessaire',
            'Nettoyage de la vitre et des parois internes',
            'Contrôle du tirage thermique et de la ventilation',
            'Certificat de ramonage conforme RSD 13',
          ].map(item => (
            <div class="flex items-center gap-3 py-2.5 border-b border-[#E65100]/10 last:border-0">
              <svg class="w-4 h-4 text-[#E65100] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-[#1A1A1A]/65 font-light">{item}</span>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ MAILLAGE SILO ═══ -->
  <section class="py-12 px-6 md:px-10 bg-[#FAFAFA]">
    <div class="max-w-6xl mx-auto">
      <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/35 mb-4">Services associés & zones d'intervention</p>
      <div class="flex flex-wrap gap-3">
        {[
          { href: '/ramonage',                  label: 'Ramonage Certifié' },
          { href: '/villes/martigues',           label: 'Entretien Poêle Martigues' },
          { href: '/villes/sausset-les-pins',    label: 'Entretien Poêle Sausset-les-Pins' },
          { href: '/villes/carry-le-rouet',      label: 'Entretien Poêle Carry-le-Rouet' },
        ].map(({ href, label }) => (
          <a href={href} class="inline-flex items-center gap-2 bg-white border border-[#EEEEEE] rounded-lg px-4 py-2.5 text-xs font-medium text-[#1A1A1A]/65 hover:border-[#E65100]/30 hover:text-[#E65100] transition-all duration-200">
            <span class="w-1.5 h-1.5 rounded-full bg-[#E65100] shrink-0"></span>
            {label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="py-16 px-6 md:px-10 bg-[#FFF3E0] text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-4">Entretien Annuel Avant l'Hiver</h2>
      <p class="text-sm text-[#1A1A1A]/55 font-light mb-8">Disponible dès septembre pour préparer la saison de chauffe.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <ContactButton variant="phone" class="px-8 py-4 text-sm" />
        <ContactButton variant="email" />
      </div>
    </div>
  </section>

</Layout>
