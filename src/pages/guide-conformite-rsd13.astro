---
import Layout from '../layouts/Layout.astro';

const siteUrl = 'https://www.sud-ramonage.fr';
const annee = new Date().getFullYear();

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'DigitalDocument',
  name: `Guide de Conformité Ramonage Bouches-du-Rhône ${annee} — RSD 13`,
  description: 'Guide officiel des obligations de ramonage dans les Bouches-du-Rhône (RSD 13). Fréquences, normes NF DTU 24.1, certificats, risques et tarifs. Par Sud Ramonage, artisan certifié COSTIC.',
  url: `${siteUrl}/guide-conformite-rsd13`,
  inLanguage: 'fr-FR',
  keywords: 'ramonage obligatoire, RSD 13, Bouches-du-Rhône, certificat ramonage, NF DTU 24.1, fréquence ramonage, bistre, monoxyde de carbone',
  author: {
    '@type': 'HomeAndConstructionBusiness',
    '@id': `${siteUrl}/#business`,
    name: 'Sud Ramonage',
  },
  publisher: {
    '@type': 'HomeAndConstructionBusiness',
    '@id': `${siteUrl}/#business`,
  },
  about: [
    { '@type': 'Thing', name: 'Règlement Sanitaire Départemental 13 — obligation de ramonage annuel' },
    { '@type': 'Thing', name: 'NF DTU 24.1 — Travaux de fumisterie et conduits de fumée' },
    { '@type': 'Thing', name: 'Certification COSTIC — Fumisterie et conduits de fumée' },
  ],
  mentions: [
    { '@type': 'Legislation', name: 'RSD 13 — Arrêté préfectoral art. 31', url: 'https://www.service-public.fr/particuliers/vosdroits/F20028' },
    { '@type': 'Legislation', name: 'NF DTU 24.1', url: 'https://www.afnor.org/' },
  ],
  datePublished: `${annee}-01-01`,
  version: `${annee}`,
};
---

<Layout
  title={`Guide Conformité Ramonage Bouches-du-Rhône ${annee} — RSD 13 — Sud Ramonage`}
  description={`Guide complet des obligations de ramonage dans les Bouches-du-Rhône (RSD 13) — ${annee}. Fréquences par appareil, normes NF DTU 24.1, certificat, bistre, CO. Par Sud Ramonage, artisan certifié COSTIC.`}
  breadcrumbs={[
    { name: 'Accueil', url: '/' },
    { name: 'Guide Conformité RSD 13', url: '/guide-conformite-rsd13' },
  ]}
  pageSchema={pageSchema}
>

<style>
  @media print {
    #site-header, #site-footer, .no-print, .sticky { display: none !important; }
    body { font-size: 11pt; color: #000; background: #fff; }
    h1 { font-size: 20pt; }
    h2 { font-size: 14pt; page-break-after: avoid; }
    h3 { font-size: 12pt; page-break-after: avoid; }
    table { page-break-inside: avoid; width: 100%; border-collapse: collapse; }
    th, td { border: 1px solid #ccc; padding: 6pt 8pt; font-size: 9pt; }
    .page-break { page-break-before: always; }
    a { color: #000; text-decoration: none; }
    .print-url::after { content: " (" attr(href) ")"; font-size: 8pt; color: #555; }
  }
</style>

  <!-- ═══ HERO ═══ -->
  <section class="pt-32 pb-10 px-6 md:px-10 bg-[#1A1A1A] no-print">
    <div class="max-w-4xl mx-auto">
      <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-4">Document officiel</p>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white leading-tight mb-4">
        Guide de Conformité Ramonage<br />
        <span class="text-white/50">Bouches-du-Rhône {annee} — RSD&nbsp;13</span>
      </h1>
      <p class="text-sm text-white/55 font-light leading-relaxed max-w-2xl mb-8">
        Toutes les obligations légales, fréquences par appareil, normes applicables et risques liés au défaut d'entretien. Rédigé par <strong class="text-white/80">Sud Ramonage</strong>, artisan ramoneur certifié <strong class="text-white/80">COSTIC</strong> à Martigues — conforme <strong class="text-white/80">NF DTU 24.1</strong> et <strong class="text-white/80">RSD&nbsp;13</strong>.
      </p>
      <button
        onclick="window.print()"
        class="inline-flex items-center gap-2.5 bg-[#E65100] text-white text-sm font-bold px-6 py-3.5 rounded-xl hover:bg-[#BF360C] transition-colors duration-200 cursor-pointer"
      >
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Télécharger en PDF (Imprimer → Enregistrer en PDF)
      </button>
    </div>
  </section>

  <!-- ═══ CONTENU PRINCIPAL (rendu HTML + print) ═══ -->
  <article class="py-14 px-6 md:px-10">
    <div class="max-w-4xl mx-auto">

      <!-- En-tête document (visible en print) -->
      <div class="hidden print:block mb-10 pb-6 border-b border-gray-300">
        <div class="flex items-start justify-between">
          <div>
            <h1 class="text-2xl font-extrabold text-black">Guide de Conformité Ramonage — Bouches-du-Rhône {annee}</h1>
            <p class="text-sm text-gray-600 mt-1">Règlement Sanitaire Départemental 13 (RSD 13) · Norme NF DTU 24.1</p>
          </div>
          <div class="text-right text-xs text-gray-500">
            <p class="font-bold">SUD RAMONAGE</p>
            <p>31 chemin des tamaris — 13500 Martigues</p>
            <p>06 64 72 96 00 · sud-ramonage.fr</p>
            <p class="mt-1">Certifié COSTIC · Qualibat 6521</p>
          </div>
        </div>
      </div>

      <!-- Section 1 — Cadre légal -->
      <section class="mb-14">
        <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-6 pb-3 border-b border-[#EEEEEE]">
          1. Cadre Légal — Obligations de Ramonage
        </h2>

        <div class="bg-[#FFF3E0] border-l-4 border-[#E65100] rounded-r-xl p-6 mb-8">
          <p class="text-sm font-semibold text-[#1A1A1A] mb-2">Article 31 du RSD 13 — Bouches-du-Rhône</p>
          <p class="text-sm text-[#1A1A1A]/70 font-light leading-relaxed">
            <em>« Tout conduit de fumée desservant un appareil à combustion solide, liquide ou gazeuse doit être ramoné au moins une fois par an. Le ramonage doit être effectué par un professionnel qualifié qui délivre un certificat de ramonage. »</em>
          </p>
          <p class="text-[11px] text-[#1A1A1A]/40 mt-3">Source : Arrêté préfectoral RSD 13, Bouches-du-Rhône — service-public.fr/particuliers/vosdroits/F20028</p>
        </div>

        <div class="overflow-x-auto rounded-xl border border-[#EEEEEE] mb-6">
          <table class="w-full text-sm border-collapse bg-white">
            <thead>
              <tr class="bg-[#1A1A1A] text-white">
                <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Texte légal</th>
                <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Contenu</th>
                <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Portée</th>
              </tr>
            </thead>
            <tbody>
              {[
                { texte: 'RSD 13 — Art. 31', contenu: 'Ramonage annuel obligatoire de tout conduit de fumée actif', portee: 'Bouches-du-Rhône (13)' },
                { texte: 'Décret n°87-712 du 26/08/1987', contenu: 'Entretien des conduits à la charge du locataire (réparations locatives)', portee: 'France entière' },
                { texte: 'Code de la Construction Art. R131-1', contenu: 'Obligation d\'entretien des appareils à combustion', portee: 'France entière' },
                { texte: 'NF DTU 24.1 P1-1', contenu: 'Norme technique — travaux de fumisterie, conduits de fumée', portee: 'Norme française' },
                { texte: 'NF EN 1443', contenu: 'Exigences générales des conduits de fumée', portee: 'Norme européenne' },
              ].map((row, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#FAFAFA]'}>
                  <td class="px-5 py-3.5 font-mono text-xs font-bold text-[#E65100]">{row.texte}</td>
                  <td class="px-5 py-3.5 text-[#1A1A1A]/75 text-xs">{row.contenu}</td>
                  <td class="px-5 py-3.5 text-[#1A1A1A]/50 text-xs">{row.portee}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-[#FAFAFA] rounded-xl p-6">
            <p class="text-xs font-bold text-[#1A1A1A] uppercase tracking-widest mb-3">Conséquences du non-ramonage</p>
            <ul class="space-y-2">
              {[
                'Refus d\'indemnisation par l\'assureur habitation en cas de sinistre',
                'Mise en demeure préfectorale possible (RSD 13)',
                'Responsabilité civile engagée en cas de dommages causés à autrui',
                'Perte de la garantie décennale sur les travaux liés',
              ].map(item => (
                <li class="flex items-start gap-2 text-xs text-[#1A1A1A]/65 font-light">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#E65100] mt-1 shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-[#FAFAFA] rounded-xl p-6">
            <p class="text-xs font-bold text-[#1A1A1A] uppercase tracking-widest mb-3">Ce que doit contenir le certificat</p>
            <ul class="space-y-2">
              {[
                'Nom, adresse et qualification du prestataire (n° SIRET)',
                'Date d\'intervention et adresse du bien',
                'Type d\'appareil et description du conduit ramoné',
                'Mention « conforme RSD 13 » ou observations de non-conformité',
                'Signature et cachet du professionnel',
              ].map(item => (
                <li class="flex items-start gap-2 text-xs text-[#1A1A1A]/65 font-light">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#E65100] mt-1 shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <!-- Section 2 — Fréquences -->
      <section class="mb-14">
        <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-6 pb-3 border-b border-[#EEEEEE]">
          2. Fréquences de Ramonage par Type d'Appareil
        </h2>

        <div class="overflow-x-auto rounded-xl border border-[#EEEEEE]">
          <table class="w-full text-sm border-collapse bg-white">
            <thead>
              <tr class="bg-[#1A1A1A] text-white">
                <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Type d'appareil</th>
                <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Fréquence RSD 13</th>
                <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Période conseillée</th>
                <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Norme</th>
                <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Tarif Sud Ramonage</th>
              </tr>
            </thead>
            <tbody>
              {[
                { appareil: 'Cheminée à foyer ouvert', freq: '1× / an', periode: 'Septembre – Octobre', norme: 'NF DTU 24.1 P1-1', tarif: 'dès 75 €' },
                { appareil: 'Insert à bois', freq: '1× / an', periode: 'Avant saison de chauffe', norme: 'NF EN 13229 + DTU 24.1', tarif: 'dès 90 €' },
                { appareil: 'Poêle à bois', freq: '1× / an', periode: 'Avant saison de chauffe', norme: 'NF EN 13240 + DTU 24.1', tarif: 'dès 90 €' },
                { appareil: 'Poêle à granulés', freq: '1× / an', periode: 'Fin de saison (bilan)', norme: 'NF EN 14785 + DTU 24.1', tarif: 'dès 110 €' },
                { appareil: 'Chaudière à bois / biomasse', freq: '2× / an', periode: 'Avant + après saison', norme: 'NF EN 303-5 + DTU 24.1', tarif: 'Sur devis' },
                { appareil: 'Chaudière au fioul', freq: '1× / an (obligatoire)', periode: 'Au choix', norme: 'Décret 2009-649', tarif: 'Sur devis' },
              ].map((row, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#FAFAFA]'}>
                  <td class="px-5 py-3.5 font-medium text-[#1A1A1A] text-sm">{row.appareil}</td>
                  <td class="px-5 py-3.5">
                    <span class="inline-flex items-center gap-1.5 text-[#E65100] font-bold text-xs">
                      <span class="w-1.5 h-1.5 rounded-full bg-[#E65100] shrink-0"></span>
                      {row.freq}
                    </span>
                  </td>
                  <td class="px-5 py-3.5 text-[#1A1A1A]/55 text-xs">{row.periode}</td>
                  <td class="px-5 py-3.5 text-[#1A1A1A]/55 text-xs font-mono">{row.norme}</td>
                  <td class="px-5 py-3.5 font-bold text-[#1A1A1A] text-sm">{row.tarif}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-[11px] text-[#1A1A1A]/35 font-light mt-3">Tarifs indicatifs — zone Martigues & Côte Bleue 2026. Certificat RSD 13 inclus dans chaque prestation. Déplacement gratuit sur 30 km.</p>
      </section>

      <!-- Section 3 — Risques -->
      <section class="mb-14">
        <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-6 pb-3 border-b border-[#EEEEEE]">
          3. Principaux Risques — Défaut d'Entretien du Conduit
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
          {[
            {
              titre: 'Incendie de conduit',
              chiffre: '~70 000',
              unite: 'interventions / an en France',
              desc: 'Le bistre s\'enflamme à 200 °C et atteint 1 000 °C. Un dépôt de 3 mm est suffisant pour provoquer un incendie de conduit incontrôlable.',
              source: 'Source : SDIS / CNPP',
            },
            {
              titre: 'Intoxication au CO',
              chiffre: '~3 000',
              unite: 'accidents / an en France',
              desc: 'Un conduit obstrué provoque le refoulement de fumées chargées en monoxyde de carbone (CO) dans la pièce de vie — gaz inodore et mortel.',
              source: 'Source : Santé Publique France',
            },
            {
              titre: 'Sinistre non couvert',
              chiffre: '100 %',
              unite: 'des cas sans certificat',
              desc: 'Sans certificat de ramonage valide, l\'assureur peut légalement refuser toute indemnisation après un sinistre lié au conduit.',
              source: 'Source : conditions générales assurance habitation',
            },
          ].map(stat => (
            <div class="bg-[#FAFAFA] border border-[#EEEEEE] rounded-xl p-6">
              <p class="text-2xl font-extrabold text-[#E65100] mb-0.5">{stat.chiffre}</p>
              <p class="text-[10px] font-bold text-[#1A1A1A]/40 uppercase tracking-wider mb-3">{stat.unite}</p>
              <p class="text-xs font-bold text-[#1A1A1A] mb-2">{stat.titre}</p>
              <p class="text-xs text-[#1A1A1A]/60 font-light leading-relaxed mb-3">{stat.desc}</p>
              <p class="text-[10px] text-[#1A1A1A]/30 italic">{stat.source}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Section 4 — Protocole Sud Ramonage -->
      <section class="mb-14">
        <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-6 pb-3 border-b border-[#EEEEEE]">
          4. Protocole d'Intervention — Sud Ramonage
        </h2>

        <div class="overflow-x-auto rounded-xl border border-[#EEEEEE] mb-6">
          <table class="w-full text-sm border-collapse bg-white">
            <thead>
              <tr class="bg-[#1A1A1A] text-white">
                <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Étape</th>
                <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Description</th>
                <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Norme / référence</th>
              </tr>
            </thead>
            <tbody>
              {[
                { etape: '01 — Protection du chantier', desc: 'Bâches de protection au sol et autour du foyer — chantier propre garanti', norme: 'Bonne pratique professionnelle' },
                { etape: '02 — Ramonage mécanique', desc: 'Hérissons rotatifs adaptés au type de conduit (maçonnerie, inox, tuile) — montée par la souche', norme: 'NF DTU 24.1 P1-1 art. 9.1' },
                { etape: '03 — Aspiration des suies', desc: 'Aspiration professionnelle haute capacité — élimination suies, bistre et calcin', norme: 'Bonne pratique COSTIC' },
                { etape: '04 — Test de vacuité', desc: 'Vérification de l\'absence d\'obstruction (nid, calcin, effondrement) et contrôle du tirage thermique', norme: 'NF DTU 24.1 P1-1 art. 8.3' },
                { etape: '05 — Remise du certificat', desc: 'Certificat officiel de ramonage conforme RSD 13 remis sur place le jour même', norme: 'RSD 13 — Art. 31' },
              ].map((row, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#FAFAFA]'}>
                  <td class="px-5 py-3.5 font-semibold text-[#E65100] text-xs whitespace-nowrap">{row.etape}</td>
                  <td class="px-5 py-3.5 text-[#1A1A1A]/75 text-xs leading-relaxed">{row.desc}</td>
                  <td class="px-5 py-3.5 text-[#1A1A1A]/45 text-xs font-mono">{row.norme}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- Section 5 — Coordonnées (print) -->
      <section class="bg-[#1A1A1A] rounded-2xl p-8 text-white">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
          <div>
            <p class="text-[10px] font-bold tracking-widest uppercase text-[#E65100] mb-3">Artisan certifié COSTIC · Qualibat 6521</p>
            <h3 class="text-xl font-extrabold mb-2">Sud Ramonage</h3>
            <p class="text-sm text-white/55 font-light leading-relaxed mb-4">
              Ramonage certifié conforme <strong class="text-white/80">NF DTU 24.1</strong> et <strong class="text-white/80">RSD 13</strong>.<br />
              Certificat remis immédiatement · Déplacement gratuit sur 30 km.
            </p>
            <div class="space-y-1.5 text-sm text-white/55 font-light">
              <p>📍 31 chemin des tamaris — 13500 Martigues</p>
              <p>📞 <a href="tel:+33664729600" class="text-[#E65100] font-semibold print-url">06 64 72 96 00</a></p>
              <p>🌐 <a href={siteUrl} class="text-[#E65100] font-semibold print-url">www.sud-ramonage.fr</a></p>
            </div>
          </div>
          <div class="space-y-3 no-print">
            <a href="/ramonage" class="flex items-center justify-center gap-2 bg-[#E65100] text-white text-sm font-bold px-6 py-3 rounded-xl hover:bg-[#BF360C] transition-colors">
              Réserver mon ramonage certifié RSD 13
            </a>
            <a href="/statistiques-securite" class="flex items-center justify-center gap-2 bg-white/8 border border-white/15 text-white/70 text-sm font-medium px-6 py-3 rounded-xl hover:bg-white/15 transition-colors">
              Statistiques sécurité — données incendies &amp; CO
            </a>
          </div>
        </div>
      </section>

      <p class="text-[11px] text-[#1A1A1A]/30 font-light text-center mt-8">
        Document rédigé par <strong>Sud Ramonage</strong> — artisan ramoneur certifié COSTIC · Qualibat 6521 — Martigues (13500) · {siteUrl} · {annee}
      </p>

    </div>
  </article>

  <!-- ═══ SECTION TÉLÉCHARGEMENT (visible sur le site, pas en print) ═══ -->
  <section class="py-12 px-6 md:px-10 bg-[#FAFAFA] no-print">
    <div class="max-w-4xl mx-auto">
      <div class="bg-white border border-[#EEEEEE] rounded-2xl p-8 flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <div class="w-12 h-12 rounded-xl bg-[#FFF3E0] flex items-center justify-center shrink-0">
          <svg class="w-6 h-6 text-[#E65100]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div class="flex-1">
          <p class="text-sm font-bold text-[#1A1A1A] mb-1">Guide de Conformité Ramonage RSD 13 — {annee}</p>
          <p class="text-xs text-[#1A1A1A]/55 font-light">Obligations légales · Fréquences par appareil · Protocole · Tarifs — PDF gratuit, format A4</p>
        </div>
        <button
          onclick="window.print()"
          title={`Télécharger le Guide de Conformité Ramonage Bouches-du-Rhône ${annee} RSD 13 en PDF`}
          class="inline-flex items-center gap-2 bg-[#E65100] text-white text-xs font-bold px-5 py-3 rounded-xl hover:bg-[#BF360C] transition-colors duration-200 whitespace-nowrap cursor-pointer shrink-0"
        >
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Sauvegarder en PDF
        </button>
      </div>
    </div>
  </section>

  <!-- ═══ MAILLAGE SILO ═══ -->
  <section class="py-10 px-6 md:px-10 bg-[#1A1A1A] no-print">
    <div class="max-w-4xl mx-auto">
      <p class="text-[10px] font-semibold tracking-widest uppercase text-white/30 mb-4">Services liés</p>
      <div class="flex flex-wrap gap-3">
        {[
          { href: '/ramonage',              label: 'Ramonage certifié RSD 13' },
          { href: '/debistrage',             label: 'Débistrage — traitement anti-bistre' },
          { href: '/normes',                 label: 'Normes & obligations légales' },
          { href: '/statistiques-securite',  label: 'Statistiques incendies & CO' },
          { href: '/inspection-camera',      label: 'Inspection caméra endoscopique HD' },
          { href: '/',                       label: 'Accueil — Sud Ramonage' },
        ].map(({ href, label }) => (
          <a href={href} class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-xs font-medium text-white/55 hover:border-[#E65100]/50 hover:text-[#E65100] transition-all duration-200">
            <span class="w-1.5 h-1.5 rounded-full bg-[#E65100] shrink-0"></span>
            {label}
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>
