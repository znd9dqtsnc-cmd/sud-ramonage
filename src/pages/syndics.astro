---
import Layout from '../layouts/Layout.astro';
const siteUrl = 'https://www.sud-ramonage.fr';
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/syndics#service`,
  name: 'Ramonage et diagnostic conduits — Syndics & Collectifs',
  description: 'Services de ramonage et diagnostic pour syndics de copropriété et gestionnaires de parcs immobiliers. Colonnes de conduits, shunts collectifs. Bouches-du-Rhône.',
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  serviceType: 'Ramonage syndic copropriété collectif',
  areaServed: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
  offers: {
    '@type': 'Offer',
    priceSpecification: { '@type': 'PriceSpecification', description: 'Tarif dégressif selon nombre d\'appartements — devis sur demande', priceCurrency: 'EUR' },
  },
};
const breadcrumbs = [{ name: 'Accueil', url: '/' }, { name: 'Syndics & Collectifs', url: '/syndics' }];
---
<Layout
  title="Ramonage Syndics & Copropriétés — Conduits Collectifs | Sud Ramonage"
  description="Services ramonage et diagnostic pour syndics de copropriété. Colonnes de conduits, shunts VMC gaz, rapports conformité RSD 13. Bouches-du-Rhône. Devis sur demande."
  breadcrumbs={breadcrumbs}
  pageSchema={serviceSchema}
>

  <section class="bg-gradient-to-br from-[#9A3412] to-[#0D2D5A] text-white pt-28 pb-16">
    <div class="max-w-4xl mx-auto px-6 md:px-10">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-white/40 mb-6">
        <a href="/" class="hover:text-white/70">Accueil</a><span>/</span><span class="text-white/60">Syndics & Collectifs</span>
      </nav>
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 rounded-full px-3 py-1.5 text-[11px] text-white/70 mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-[#F97316]"></span>
        Espace Professionnel — Gestion de Parcs Immobiliers
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-5">
        Services Ramonage<br /><span class="text-[#F97316]">Syndics & Copropriétés</span>
      </h1>
      <p class="text-base text-white/70 max-w-2xl leading-relaxed mb-8">
        Vous gérez un parc de logements avec des conduits individuels ou collectifs ? Je propose aux syndics de copropriété et gestionnaires immobiliers une offre dédiée : intervention groupée, rapport global de conformité RSD 13, tarif dégressif selon le nombre de logements.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#F97316] text-white text-sm font-bold px-5 py-3 rounded-xl hover:bg-[#EA580C] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Devis groupé — 06 64 72 96 00
        </a>
        <a href="mailto:majeo@ik.me" class="inline-flex items-center gap-2 bg-white/10 border border-white/20 text-white/80 text-sm font-medium px-5 py-3 rounded-xl hover:bg-white/15 transition-colors">
          Envoyer un dossier par email
        </a>
      </div>
    </div>
  </section>

  <!-- Avantages -->
  <section class="py-14 bg-[#FAFAFA] border-b border-[#EEEEEE]">
    <div class="max-w-4xl mx-auto px-6 md:px-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { val: 'Dégressif', label: 'Tarif groupé', sub: 'Dès 5 logements' },
          { val: '1 RDV', label: 'Toute la colonne', sub: 'Coordination locataires' },
          { val: 'Global', label: 'Rapport conformité', sub: 'Par immeuble' },
          { val: 'Annuel', label: 'Contrat récurrent', sub: 'Sur demande' },
        ].map(({ val, label, sub }) => (
          <div class="bg-white rounded-xl border border-[#EEEEEE] p-5 text-center">
            <p class="text-xl font-extrabold text-[#9A3412]">{val}</p>
            <p class="text-xs font-semibold text-[#1A1A1A] mt-1">{label}</p>
            <p class="text-[11px] text-[#1A1A1A]/45 mt-0.5">{sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-4xl mx-auto px-6 md:px-10 space-y-12">

      <div>
        <h2 class="text-2xl font-bold mb-5">Ce que je prends en charge pour les collectifs</h2>
        <div class="grid md:grid-cols-2 gap-5">
          {[
            { titre: 'Colonnes de conduits individuels', detail: 'Chaque appartement dispose d\'un conduit indépendant. Je réalise l\'ensemble des ramonages sur une ou plusieurs journées selon le nombre de logements, en coordination avec vous ou le gardien.' },
            { titre: 'Shunts collectifs VMC gaz', detail: 'Les shunts collectifs concentrent les évacuations de plusieurs chaudières gaz individuelles dans un conduit commun. Nettoyage et contrôle de chaque clapet, rapport de conformité.' },
            { titre: 'Diagnostic colonnes dégradées', detail: 'Inspection caméra de colonnes anciennes ou suspectes. Rapport photographique avec localisation précise des anomalies. Recommandations de réhabilitation (tubage, chemisage).' },
            { titre: 'Rapport de conformité global', detail: 'Document récapitulatif par immeuble : état de chaque conduit, anomalies relevées, travaux recommandés, certificats individuels. Format exploitable pour l\'AG de copropriété.' },
            { titre: 'Suivi annuel sous contrat', detail: 'Contrat d\'entretien récurrent avec planification des interventions avant la saison de chauffe. Priorité de planning, tarif préférentiel, rappel automatique.' },
            { titre: 'Intervention d\'urgence', detail: 'En cas de signalement d\'odeur ou de problème de tirage dans un logement, intervention sous 48h. Rapport d\'urgence transmis au gestionnaire.' },
          ].map(({ titre, detail }) => (
            <div class="bg-[#FAFAFA] border border-[#EEEEEE] rounded-xl p-5">
              <p class="text-sm font-semibold text-[#1A1A1A] mb-2 flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-[#9A3412] shrink-0"></span>{titre}
              </p>
              <p class="text-xs text-[#1A1A1A]/55 leading-relaxed">{detail}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="bg-[#9A3412] rounded-2xl p-8">
        <h2 class="text-lg font-bold text-white mb-4">Spécificités techniques — immeubles collectifs</h2>
        <p class="text-sm text-white/65 leading-relaxed mb-4">
          À Marseille notamment, les immeubles haussmanniens et du début XXe siècle ont des colonnes de conduits maçonnées qui traversent 4 à 7 étages. Ces conduits souffrent souvent de modifications non conformes (fermetures partielles, piquages sauvages) réalisées lors de rénovations. J'identifie ces anomalies à l'inspection caméra et fournis un rapport technique permettant au syndic d'engager les travaux de mise en conformité.
        </p>
        <p class="text-sm text-white/65 leading-relaxed">
          Les shunts collectifs VMC gaz, très répandus dans les immeubles des années 60-80, nécessitent une attention particulière : chaque clapet doit être vérifié en position ouverte lors du tirage. Un clapet coincé = refoulement de gaz brûlés dans l'appartement.
        </p>
      </div>

      <!-- Dossier à préparer -->
      <div class="border border-[#EEEEEE] rounded-xl p-6">
        <h3 class="text-base font-bold text-[#1A1A1A] mb-4">Pour préparer votre devis groupé</h3>
        <ul class="space-y-2 text-sm text-[#1A1A1A]/65">
          {[
            'Nombre d\'appartements et de conduits à traiter',
            'Type de conduits : individuels, shunts collectifs, mixte',
            'Ancienneté de l\'immeuble et du dernier ramonage',
            'Adresse complète (commune) pour le calcul du déplacement',
            'Coordonnées du gestionnaire ou du gardien',
          ].map(item => (
            <li class="flex gap-2"><span class="text-[#9A3412] font-bold shrink-0">→</span>{item}</li>
          ))}
        </ul>
      </div>

      <div class="bg-[#9A3412] rounded-2xl p-8 text-white">
        <h2 class="text-xl font-bold mb-3">Devis syndic — réponse sous 24h</h2>
        <p class="text-sm text-white/75 mb-6">J'interviens dans l'ensemble des Bouches-du-Rhône. Rapport de conformité global par immeuble fourni après chaque campagne.</p>
        <div class="flex flex-wrap gap-3">
          <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-white text-[#9A3412] text-sm font-bold px-5 py-3 rounded-xl hover:bg-white/90 transition-colors">06 64 72 96 00</a>
          <a href="mailto:majeo@ik.me" class="inline-flex items-center gap-2 bg-white/15 border border-white/25 text-white text-sm font-medium px-5 py-3 rounded-xl hover:bg-white/20 transition-colors">majeo@ik.me</a>
        </div>
      </div>

      <nav aria-label="Services associés" class="pt-8 border-t border-[#EEEEEE]">
        <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-4">Voir aussi</p>
        <ul class="flex flex-wrap gap-3">
          {[
            { href: '/inspection-camera', label: 'Inspection caméra colonnes' },
            { href: '/chemisage', label: 'Chemisage conduits collectifs' },
            { href: '/chaudieres', label: 'Ramonage chaudières gaz' },
            { href: '/immobilier-notaires', label: 'Audit pré-vente immobilier' },
            { href: '/reglementation', label: 'Obligations RSD 13' },
          ].map(({ href, label }) => (
            <li><a href={href} class="text-xs text-[#1A1A1A]/50 border border-[#EEEEEE] rounded-lg px-3 py-1.5 hover:text-[#F97316] hover:border-[#F97316]/30 transition-colors">{label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </section>
</Layout>
