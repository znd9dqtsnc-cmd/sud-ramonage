---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import artisanImg from '../assets/images/artisan-intervention.jpg';
const siteUrl = 'https://www.sud-ramonage.fr';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/bailleurs-syndics#service`,
  name: 'Ramonage & entretien conduits — Bailleurs, Agences et Syndics',
  description: 'Services d\'entretien de conduits pour bailleurs, agences de gestion locative et syndics de copropriété. Contrat récurrent, rapport conformité RSD 13, tarif dégressif. Bouches-du-Rhône.',
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  serviceType: 'Entretien conduits bailleurs syndics copropriété',
  areaServed: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
};

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Bailleurs & Syndics', url: '/bailleurs-syndics' },
];
---

<Layout
  title="Ramonage Bailleurs & Syndics — Contrat Entretien Conduits | Sud Ramonage"
  description="Entretien de conduits pour bailleurs, agences de gestion locative et syndics de copropriété. Contrat récurrent, certificats automatiques, rapport conformité RSD 13. Bouches-du-Rhône."
  breadcrumbs={breadcrumbs}
  pageSchema={serviceSchema}
>

  <!-- HERO -->
  <section class="bg-[#FFFFFF] border-b border-[#EEEEEE] pt-32 pb-16 px-6 md:px-10">
    <div class="max-w-5xl mx-auto">
      <nav class="flex items-center gap-2 text-xs text-[#1A1A1A]/85 mb-10" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-[#1A1A1A]/80 transition-colors">Accueil</a>
        <span>/</span>
        <span class="text-[#1A1A1A]/85">Bailleurs & Syndics</span>
      </nav>

      <div class="flex flex-wrap gap-2 mb-6">
        {['Bailleurs', 'Agences de gestion', 'Syndicats de copropriété'].map(tag => (
          <span class="text-[10px] font-bold uppercase tracking-widest bg-[#FFF3E0] text-[#F39C12] border border-[#E8DDD4]/15 px-3 py-1.5 rounded-full">{tag}</span>
        ))}
      </div>

      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-[#2C3E50] leading-tight mb-6">
        Zéro gestion.<br />
        <span class="text-[#F39C12]">Conformité garantie.</span>
      </h1>
      <p class="text-base text-[#1A1A1A]/85 font-light leading-relaxed mb-10 max-w-2xl">
        Je prends en charge l'ensemble des obligations d'entretien des conduits pour votre parc — planification, intervention sur chaque lot ou colonne, certificats RSD 13, rapport pour l'AG ou l'assurance. Une seule facture, aucun appel de votre part.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#E8DDD4] text-white text-sm font-bold px-6 py-4 rounded-xl hover:bg-[#F39C12] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Devis — 06 64 72 96 00
        </a>
        <a href="mailto:contact@sud-ramonage.fr?subject=Devis%20entretien%20conduits%20parc%20immobilier" class="inline-flex items-center gap-2 bg-[#F8F9FA] border border-[#EEEEEE] text-[#1A1A1A] text-sm font-semibold px-6 py-4 rounded-xl hover:border-[#E8DDD4]/30 transition-colors">
          Envoyer un dossier par email
        </a>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="py-10 bg-[#F8F9FA] border-b border-[#EEEEEE]">
    <div class="max-w-5xl mx-auto px-6 md:px-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { val: 'Dégressif', label: 'Tarif groupé', sub: 'Dès 3 lots' },
          { val: '1 visite', label: 'Toute la colonne', sub: 'Coordination locataires' },
          { val: 'Global', label: 'Rapport conformité', sub: 'Par immeuble' },
          { val: 'Annuel', label: 'Contrat récurrent', sub: 'Sur demande' },
        ].map(({ val, label, sub }) => (
          <div class="bg-[#FFFFFF] rounded-xl border border-[#EEEEEE] p-5 text-center">
            <p class="text-xl font-extrabold text-[#1A4B8F]">{val}</p>
            <p class="text-xs font-semibold text-[#1A1A1A] mt-1">{label}</p>
            <p class="text-[11px] text-[#1A1A1A]/80 mt-0.5">{sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- IMAGE IMMERSION -->
  <section class="max-w-5xl mx-auto px-6 md:px-10 py-10">
    <figure class="rounded-2xl overflow-hidden aspect-[21/9] relative">
      <Image
        src={artisanImg}
        alt="Artisan ramoneur certifié intervenant dans un immeuble locatif — Sud Ramonage Martigues"
        width={1400}
        height={600}
        class="w-full h-full object-cover object-center"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[#1A1A1A]/65 to-[#1A1A1A]/10 flex items-end p-8">
        <p class="text-white text-sm font-medium max-w-xs leading-snug">Intervention sur un parc locatif — Martigues &amp; Côte Bleue.</p>
      </div>
    </figure>
  </section>

  <section class="py-8">
    <div class="max-w-5xl mx-auto px-6 md:px-10 space-y-16">

      <!-- BAILLEURS & AGENCES -->
      <div>
        <h2 class="text-2xl font-bold mb-2">Bailleurs & Agences de gestion locative</h2>
        <p class="text-sm text-[#1A1A1A]/80 leading-relaxed mb-6">
          Le décret n°87-712 classe le ramonage en charge récupérable — le locataire en supporte le coût in fine. Mais l'obligation de résultat pèse sur le bailleur. En cas de sinistre sans certificat conforme, c'est le bailleur qui engage sa responsabilité civile et pénale.
        </p>
        <div class="grid md:grid-cols-3 gap-5 mb-6">
          {[
            { titre: 'Décret n°87-712', texte: 'Ramonage = charge locative récupérable. Refacturable au locataire sur les charges annuelles.' },
            { titre: 'Loi n°89-462 art. 6', texte: 'Le bailleur doit maintenir un logement décent. Conduit non ramoné = logement non conforme.' },
            { titre: 'Code des assurances', texte: 'Sans certificat conforme, la responsabilité se retourne vers le bailleur en cas d\'incendie.' },
          ].map(({ titre, texte }) => (
            <div class="bg-[#F8F9FA] border border-[#EEEEEE] rounded-xl p-5">
              <p class="text-sm font-bold text-[#1A1A1A] mb-1">{titre}</p>
              <p class="text-xs text-[#1A1A1A]/85 leading-relaxed">{texte}</p>
            </div>
          ))}
        </div>

        <!-- Tarifs -->
        <div class="grid md:grid-cols-2 gap-6 max-w-2xl">
          {[
            {
              nom: 'Pack Essentiel',
              prix: '7,50 €',
              sub: '/ lot / mois — dès 3 lots',
              badge: null,
              inclus: ['Ramonage annuel par lot', 'Certificat RSD 13 conforme', 'Planification proactive', 'Facturation mensuelle unique', 'Attestation annuelle récupération de charge'],
            },
            {
              nom: 'Pack Intégral',
              prix: '14,90 €',
              sub: '/ lot / mois — dès 5 lots',
              badge: 'Recommandé agences',
              inclus: ['Ramonage annuel par lot', 'Inspection caméra tous les 3 ans', 'Rapport annuel état du parc', 'Gestion appels locataires (urgence)', 'Facturation mensuelle unique', 'Attestation annuelle récupération de charge'],
            },
          ].map(({ nom, prix, sub, badge, inclus }) => (
            <div class={`bg-[#FFFFFF] border-2 rounded-2xl p-6 relative ${badge ? 'border-[#E8DDD4]' : 'border-[#EEEEEE]'}`}>
              {badge && (
                <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                  <span class="bg-[#E8DDD4] text-white text-[10px] font-bold px-3 py-1 rounded-full">{badge}</span>
                </div>
              )}
              <p class="text-xs font-bold tracking-widest uppercase text-[#1A1A1A]/80 mb-2">{nom}</p>
              <p class="text-3xl font-extrabold text-[#1A1A1A] mb-0.5">{prix}</p>
              <p class="text-xs text-[#1A1A1A]/80 mb-5">{sub}</p>
              <ul class="space-y-2">
                {inclus.map(item => (
                  <li class="flex gap-2 text-xs text-[#1A1A1A]/80">
                    <svg class="w-3.5 h-3.5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <!-- SYNDICS -->
      <div>
        <h2 class="text-2xl font-bold mb-2">Syndics & Copropriétés</h2>
        <p class="text-sm text-[#1A1A1A]/80 leading-relaxed mb-6">
          Je prends en charge les colonnes de conduits individuels et les shunts collectifs VMC gaz. Intervention coordonnée avec le gestionnaire ou le gardien, rapport global pour l'AG.
        </p>
        <div class="grid md:grid-cols-2 gap-5 mb-6">
          {[
            { titre: 'Colonnes de conduits individuels', detail: 'Chaque appartement dispose d\'un conduit indépendant. Je réalise l\'ensemble des ramonages sur une ou plusieurs journées selon le nombre de logements, en coordination avec vous ou le gardien.' },
            { titre: 'Shunts collectifs VMC gaz', detail: 'Nettoyage de chaque clapet, contrôle en position ouverte lors du tirage. Un clapet coincé = refoulement de gaz brûlés dans l\'appartement. Rapport de conformité inclus.' },
            { titre: 'Diagnostic colonnes dégradées', detail: 'Inspection caméra des colonnes anciennes ou suspectes. Rapport photographique avec localisation des anomalies et recommandations de réhabilitation.' },
            { titre: 'Rapport pour l\'AG', detail: 'Document récapitulatif par immeuble : état de chaque conduit, anomalies relevées, travaux recommandés. Format exploitable pour la convocation d\'assemblée générale.' },
          ].map(({ titre, detail }) => (
            <div class="bg-[#F8F9FA] border border-[#EEEEEE] rounded-xl p-5">
              <p class="text-sm font-semibold text-[#1A1A1A] mb-2 flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-[#1A4B8F] shrink-0"></span>{titre}
              </p>
              <p class="text-xs text-[#1A1A1A]/85 leading-relaxed">{detail}</p>
            </div>
          ))}
        </div>

        <!-- Dossier devis -->
        <div class="border border-[#EEEEEE] rounded-xl p-6">
          <h3 class="text-sm font-bold text-[#1A1A1A] mb-4">Pour préparer votre devis groupé</h3>
          <ul class="space-y-2 text-sm text-[#1A1A1A]/80">
            {[
              'Nombre d\'appartements et de conduits à traiter',
              'Type de conduits : individuels, shunts collectifs, mixte',
              'Ancienneté de l\'immeuble et du dernier ramonage',
              'Adresse et commune pour le calcul du déplacement',
              'Coordonnées du gestionnaire ou du gardien',
            ].map(item => (
              <li class="flex gap-2"><span class="text-[#F39C12] font-bold shrink-0">→</span>{item}</li>
            ))}
          </ul>
        </div>
      </div>

      <!-- CTA -->
      <div class="border border-[#EEEEEE] rounded-2xl p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div>
          <h2 class="text-xl font-extrabold tracking-tight text-[#2C3E50] mb-2">Devis groupé — réponse sous 24h</h2>
          <p class="text-sm text-[#1A1A1A]/85 font-light">Rapport de conformité global par immeuble après chaque campagne. Tarifs dégressifs dès 3 lots.</p>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#E8DDD4] text-white text-sm font-bold px-5 py-3 rounded-xl hover:bg-[#F39C12] transition-colors">06 64 72 96 00</a>
          <a href="mailto:contact@sud-ramonage.fr?subject=Devis%20entretien%20conduits%20parc%20immobilier" class="inline-flex items-center gap-2 bg-[#F8F9FA] border border-[#EEEEEE] text-[#1A1A1A] text-sm font-medium px-5 py-3 rounded-xl hover:border-[#E8DDD4]/30 transition-colors">contact@sud-ramonage.fr</a>
        </div>
      </div>

      <!-- Liens associés -->
      <nav aria-label="Services associés" class="pt-8 border-t border-[#EEEEEE]">
        <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-4">Voir aussi</p>
        <ul class="flex flex-wrap gap-3">
          {[
            { href: '/ramonage', label: 'Ramonage certifié RSD 13' },
            { href: '/vacuite', label: 'Contrôle de vacuité' },
            { href: '/audit-conformite', label: 'Diagnostic de sécurité' },
            { href: '/transaction-immobiliere', label: 'Vente immobilière' },
            { href: '/chaudieres', label: 'Ramonage chaudières gaz' },
          ].map(({ href, label }) => (
            <li><a href={href} class="text-xs text-[#1A1A1A]/85 border border-[#EEEEEE] rounded-lg px-3 py-1.5 hover:text-[#F39C12] hover:border-[#E8DDD4]/30 transition-colors">{label}</a></li>
          ))}
        </ul>
      </nav>

    </div>
  </section>

</Layout>
