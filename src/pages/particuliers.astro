---
import Layout from '../layouts/Layout.astro';
import ContactButton from '../components/ContactButton.astro';
import FAQ from '../components/FAQ.astro';

const siteUrl = 'https://www.sud-ramonage.fr';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/particuliers#service`,
  name: 'Ramonage et entretien pour particuliers — cheminée, insert, poêle, chaudière',
  description: 'Ramonage certifié cheminée, insert, poêle à bois et granulés, chaudières gaz et fioul. Audit caméra HD. Certificat RSD 13 immédiat. Martigues, Côte Bleue, Bouches-du-Rhône.',
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  serviceType: 'Ramonage particuliers',
  areaServed: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
  offers: [
    { '@type': 'Offer', name: 'Ramonage cheminée foyer ouvert', price: '75', priceCurrency: 'EUR' },
    { '@type': 'Offer', name: 'Ramonage insert / poêle à bois', price: '90', priceCurrency: 'EUR' },
    { '@type': 'Offer', name: 'Entretien poêle à granulés', price: '120', priceCurrency: 'EUR' },
  ],
};

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Particuliers', url: '/particuliers' },
];
---

<Layout
  title="Ramonage Particuliers Martigues — Cheminée, Poêle, Chaudière | Sud Ramonage"
  description="Ramonage certifié pour particuliers à Martigues. Cheminée, insert, poêle à bois et granulés, chaudières gaz & fioul. Certificat RSD 13 immédiat. Tarifs à partir de 75 €."
  canonical={`${siteUrl}/particuliers`}
  breadcrumbs={breadcrumbs}
  pageSchema={pageSchema}
>

  <!-- HERO -->
  <section class="pt-28 pb-14 px-6 md:px-10 bg-[#FFFFFF]">
    <div class="max-w-4xl mx-auto">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-[#1A1A1A]/35 mb-6">
        <a href="/" class="hover:text-[#EA580C] transition-colors">Accueil</a>
        <span>/</span>
        <span class="text-[#1A1A1A]/60">Particuliers</span>
      </nav>
      <div class="inline-flex items-center gap-2 bg-[#FFF3E0] border border-[#EA580C]/20 text-[#EA580C] text-[11px] font-bold px-4 py-2 rounded-full mb-6 uppercase tracking-widest">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        Particuliers — Certifié COSTIC · Qualibat 6521
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-[#1A1A1A] leading-tight mb-5">
        Ramonage & Entretien<br /><span class="text-[#EA580C]">pour Particuliers</span>
      </h1>
      <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed mb-6 max-w-2xl">
        Cheminée à foyer ouvert, insert, poêle à bois ou à granulés, chaudière gaz ou fioul — chaque appareil à combustion requiert un entretien annuel. Le <strong class="text-[#1A1A1A]/80">RSD 13</strong> l'impose en Bouches-du-Rhône. Certificat officiel remis sur place après chaque intervention.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#EA580C] hover:bg-[#C2410C] text-white text-sm font-bold px-6 py-3 rounded-xl transition-colors shadow-sm">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          06 64 72 96 00 — Prendre RDV
        </a>
        <a href="#tarifs" class="inline-flex items-center gap-2 bg-white border border-[#E2E8F0] hover:border-[#EA580C]/40 text-[#1A1A1A] text-sm font-medium px-6 py-3 rounded-xl transition-colors">
          Voir les tarifs ↓
        </a>
      </div>
    </div>
  </section>

  <!-- NAVIGATION ANCRES -->
  <nav class="sticky top-16 z-30 bg-white border-b border-[#EEEEEE] shadow-sm">
    <div class="max-w-4xl mx-auto px-6 md:px-10">
      <ul class="flex gap-1 py-2 overflow-x-auto">
        {[
          { href: '#ramonage',   label: 'Ramonage' },
          { href: '#entretien',  label: 'Entretien' },
          { href: '#chaudieres', label: 'Chaudières' },
          { href: '#audit',      label: 'Diagnostic' },
          { href: '#tarifs',     label: 'Tarifs' },
        ].map(({ href, label }) => (
          <li>
            <a href={href} class="whitespace-nowrap px-4 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#EA580C] hover:bg-[#FFF3E0] transition-colors duration-150">{label}</a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <!-- SECTION RAMONAGE -->
  <section id="ramonage" class="py-16 px-6 md:px-10 bg-[#FFFFFF]">
    <div class="max-w-4xl mx-auto">
      <div class="mb-10">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[#EA580C] mb-3">Ramonage & Entretien</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-4">
          Cheminées, Foyers Ouverts & Inserts
        </h2>
        <p class="text-sm text-[#1A1A1A]/60 leading-relaxed max-w-2xl">
          Le ramonage mécanique est la seule méthode reconnue pour garantir la conformité RSD 13. Un hérisson adapté à votre conduit (maçonnerie, tubage inox, conduit flexible) nettoie intégralement les parois. Le test de vacuité confirme l'absence d'obstruction.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white border border-[#EEEEEE] rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 rounded-xl bg-[#FFF3E0] flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-[#EA580C]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            </div>
            <h3 class="text-base font-bold text-[#1A1A1A]">Foyer ouvert — NF DTU 24.2</h3>
          </div>
          <p class="text-sm text-[#1A1A1A]/60 leading-relaxed mb-4">
            Cheminée traditionnelle à âtre ouvert. Le conduit en maçonnerie accumule des dépôts variables selon les essences brûlées et la fréquence d'utilisation. La norme NF DTU 24.2 définit les règles de mise en œuvre et les distances de sécurité.
          </p>
          <ul class="space-y-2 text-xs text-[#1A1A1A]/60">
            <li class="flex gap-2"><span class="text-[#EA580C] shrink-0 font-bold">→</span>Ramonage mécanique hérisson en acier ou nylon</li>
            <li class="flex gap-2"><span class="text-[#EA580C] shrink-0 font-bold">→</span>Test de vacuité et contrôle du tirage thermique</li>
            <li class="flex gap-2"><span class="text-[#EA580C] shrink-0 font-bold">→</span>Nettoyage du foyer et de la plaque de fond</li>
            <li class="flex gap-2"><span class="text-[#EA580C] shrink-0 font-bold">→</span>Certificat officiel RSD 13 remis sur place</li>
          </ul>
        </div>

        <div class="bg-white border border-[#EEEEEE] rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 rounded-xl bg-[#FFF3E0] flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-[#EA580C]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/></svg>
            </div>
            <h3 class="text-base font-bold text-[#1A1A1A]">Insert & Poêle à bois — NF DTU 24.1</h3>
          </div>
          <p class="text-sm text-[#1A1A1A]/60 leading-relaxed mb-4">
            Les appareils raccordés fermés (inserts, poêles à bois) sont soumis à la norme NF DTU 24.1. Le conduit, souvent tubé inox, accumule moins de dépôts qu'un conduit de foyer ouvert — mais le ramonage reste obligatoire et les joints de raccordement doivent être vérifiés.
          </p>
          <ul class="space-y-2 text-xs text-[#1A1A1A]/60">
            <li class="flex gap-2"><span class="text-[#EA580C] shrink-0 font-bold">→</span>Ramonage conduit inox et conduit de liaison</li>
            <li class="flex gap-2"><span class="text-[#EA580C] shrink-0 font-bold">→</span>Vérification joints de porte et raccordement</li>
            <li class="flex gap-2"><span class="text-[#EA580C] shrink-0 font-bold">→</span>Nettoyage chambre de combustion</li>
            <li class="flex gap-2"><span class="text-[#EA580C] shrink-0 font-bold">→</span>Certificat officiel RSD 13 remis sur place</li>
          </ul>
        </div>
      </div>

      <div class="mt-6 bg-amber-50 border border-amber-200 rounded-2xl p-5">
        <div class="flex items-start gap-3">
          <svg class="w-4 h-4 text-amber-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <div>
            <p class="text-xs font-bold text-amber-800 mb-1">Bistre — Risque incendie</p>
            <p class="text-xs text-amber-700 leading-relaxed">
              Le bistre est un dépôt de goudron hautement inflammable qui se forme lors de combustion de bois humide ou à basse température. Présent dès l'inspection, il nécessite un <strong>débistrage</strong> chimique et mécanique avant tout ramonage standard. La non-élimination du bistre est la première cause d'incendie de conduit en France.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION ENTRETIEN -->
  <section id="entretien" class="py-16 px-6 md:px-10 bg-white border-t border-[#EEEEEE]">
    <div class="max-w-4xl mx-auto">
      <div class="mb-10">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[#EA580C] mb-3">Entretien</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-4">
          Entretien Poêle à Bois & à Granulés (Pellets)
        </h2>
        <p class="text-sm text-[#1A1A1A]/60 leading-relaxed max-w-2xl">
          Le poêle à granulés est un appareil électronique et mécanique qui nécessite un entretien spécifique, bien au-delà du simple ramonage. Les granulés créent des cendres fines et des mâchefers qui obstruent le brûleur et les capteurs.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-[#FFFFFF] border border-[#EEEEEE] rounded-2xl p-6">
          <h3 class="text-base font-bold text-[#1A1A1A] mb-4">Ce que comprend l'entretien annuel</h3>
          <ul class="space-y-3 text-sm text-[#1A1A1A]/65">
            {[
              'Ramonage du conduit d\'évacuation (hérisson adapté)',
              'Nettoyage complet du brûleur et enlèvement des mâchefers',
              'Nettoyage de la chambre de combustion et du cendrier',
              'Contrôle du ventilateur de combustion et d\'extraction',
              'Vérification et nettoyage des capteurs de température',
              'Contrôle de la vis sans fin et du système d\'alimentation',
              'Test de fonctionnement électronique — cycle allumage',
              'Certificat officiel RSD 13 remis sur place',
            ].map(item => (
              <li class="flex items-start gap-2.5">
                <svg class="w-4 h-4 text-[#16A34A] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="space-y-4">
          <div class="bg-[#FFFFFF] border border-[#EEEEEE] rounded-2xl p-5">
            <h4 class="text-sm font-bold text-[#1A1A1A] mb-2">Spécificités techniques du pellet</h4>
            <p class="text-xs text-[#1A1A1A]/60 leading-relaxed">
              Les granulés de bois brûlent à haute température (800–900 °C dans le brûleur). Cette combustion produit des cendres très fines et des mâchefers vitreux qui adhèrent aux parois. Un nettoyage insuffisant entraîne une baisse de rendement significative et peut bloquer la détection de flamme.
            </p>
          </div>
          <div class="bg-[#FFFFFF] border border-[#EEEEEE] rounded-2xl p-5">
            <h4 class="text-sm font-bold text-[#1A1A1A] mb-2">Fréquence recommandée</h4>
            <p class="text-xs text-[#1A1A1A]/60 leading-relaxed">
              Annuelle obligatoire (RSD 13). Pour une utilisation intensive (plus de 8h/jour en hiver), un nettoyage saisonnier intermédiaire du brûleur est recommandé. Le conduit d'évacuation doit être ramoné même en cas d'entretien par le fabricant.
            </p>
          </div>
          <div class="bg-[#FFF3E0] border border-[#EA580C]/20 rounded-2xl p-5">
            <h4 class="text-sm font-bold text-[#EA580C] mb-2">Signes d'alerte</h4>
            <ul class="text-xs text-[#EA580C]/80 space-y-1">
              <li>• Extinction répétée sans raison apparente</li>
              <li>• Fumée visible dans la pièce (retour de fumées)</li>
              <li>• Odeur de brûlé lors du fonctionnement</li>
              <li>• Bruit anormal du ventilateur ou de la vis sans fin</li>
              <li>• Baisse de chaleur malgré puissance maximale</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION CHAUDIERES -->
  <section id="chaudieres" class="py-16 px-6 md:px-10 bg-[#FFFFFF] border-t border-[#EEEEEE]">
    <div class="max-w-4xl mx-auto">
      <div class="mb-10">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[#EA580C] mb-3">Chaudières</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-4">
          Ramonage Conduit Chaudière Gaz & Fioul
        </h2>
        <p class="text-sm text-[#1A1A1A]/60 leading-relaxed max-w-2xl">
          Le conduit de fumée de votre chaudière est soumis à la même obligation de ramonage annuel que celui d'une cheminée. L'arrêté du 15 septembre 2009 et le RSD 13 l'imposent pour toute chaudière de 4 à 400 kW.
        </p>
        <div class="mt-4 bg-[#F8FAFC] border border-[#E2E8F0] rounded-xl px-4 py-3">
          <p class="text-xs text-[#475569] leading-relaxed">
            <strong class="text-[#1A1A1A]">Périmètre d'intervention :</strong> ramonage du conduit d'évacuation uniquement. L'entretien du corps de chauffe (brûleur, échangeur, vase d'expansion) doit être réalisé par un technicien habilité gaz ou fioul, distinct du ramonage.
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white border border-[#EEEEEE] rounded-2xl p-6">
          <h3 class="text-base font-bold text-[#1A1A1A] mb-3">Chaudière gaz à tirage naturel</h3>
          <ul class="space-y-2 text-sm text-[#1A1A1A]/65">
            <li class="flex gap-2"><span class="text-[#EA580C] shrink-0">→</span>Conduit individuel ou collectif (shunt)</li>
            <li class="flex gap-2"><span class="text-[#EA580C] shrink-0">→</span>Vérification du tirage — minimum 4 Pa</li>
            <li class="flex gap-2"><span class="text-[#EA580C] shrink-0">→</span>Contrôle joint de raccordement</li>
            <li class="flex gap-2"><span class="text-[#EA580C] shrink-0">→</span>Rapport de ramonage pour assurance</li>
          </ul>
        </div>
        <div class="bg-white border border-[#EEEEEE] rounded-2xl p-6">
          <h3 class="text-base font-bold text-[#1A1A1A] mb-3">Chaudière fioul</h3>
          <ul class="space-y-2 text-sm text-[#1A1A1A]/65">
            <li class="flex gap-2"><span class="text-[#EA580C] shrink-0">→</span>Conduit avec dépôts sulfureux (suie acide)</li>
            <li class="flex gap-2"><span class="text-[#EA580C] shrink-0">→</span>Ramonage spécifique — hérisson adapté</li>
            <li class="flex gap-2"><span class="text-[#EA580C] shrink-0">→</span>Contrôle état de la chemise intérieure</li>
            <li class="flex gap-2"><span class="text-[#EA580C] shrink-0">→</span>Inspection caméra recommandée (corrosion)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION AUDIT -->
  <section id="audit" class="py-16 px-6 md:px-10 bg-white border-t border-[#EEEEEE]">
    <div class="max-w-4xl mx-auto">
      <div class="mb-10">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[#EA580C] mb-3">Audit & Diagnostic</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-4">
          Inspection Caméra HD, Test Fumigène & Vacuité
        </h2>
        <p class="text-sm text-[#1A1A1A]/60 leading-relaxed max-w-2xl">
          Trois techniques complémentaires permettent un diagnostic complet de l'état de votre conduit — indispensable avant achat immobilier, après un incendie de conduit, ou en cas d'anomalie de tirage.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-5 mb-8">
        {[
          {
            titre: 'Inspection Caméra HD',
            desc: 'Diagnostic vidéo endoscopique en temps réel. Détecte fissures, joints déjointés, état du tubage, nids d\'oiseaux profonds, écrasement du conduit. Rapport illustré avec photos et vidéos accepté par les assureurs et notaires.',
            prix: 'À partir de 120 €',
            icon: 'M15 10l4.553-2.069A1 1 0 0121 8.868V15.13a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z',
          },
          {
            titre: 'Test Fumigène',
            desc: 'Injection de fumée colorée pour vérifier l\'étanchéité du conduit et la direction des flux. Détecte les fissures et les défauts d\'étanchéité non visibles à la caméra. Incontournable avant l\'installation d\'un nouveau poêle.',
            prix: 'Sur devis',
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
          },
          {
            titre: 'Test de Vacuité',
            desc: 'Vérification mécanique de l\'absence d\'obstruction dans le conduit. Réalisé systématiquement lors de chaque ramonage. Confirme que le tirage est possible et que les fumées s\'évacuent correctement.',
            prix: 'Inclus dans le ramonage',
            icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10',
          },
        ].map(({ titre, desc, prix, icon }) => (
          <div class="bg-[#FFFFFF] border border-[#EEEEEE] rounded-2xl p-6">
            <div class="w-10 h-10 rounded-xl bg-[#FFF3E0] flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-[#EA580C]" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d={icon}/></svg>
            </div>
            <h3 class="text-sm font-bold text-[#1A1A1A] mb-2">{titre}</h3>
            <p class="text-xs text-[#1A1A1A]/60 leading-relaxed mb-4">{desc}</p>
            <p class="text-xs font-bold text-[#EA580C]">{prix}</p>
          </div>
        ))}
      </div>

      <div class="bg-[#FFF3E0] border border-[#EA580C]/20 rounded-2xl p-6">
        <h4 class="text-sm font-bold text-[#EA580C] mb-3">Quand réaliser un audit ?</h4>
        <ul class="grid md:grid-cols-2 gap-2 text-xs text-[#EA580C]/80">
          {[
            'Achat d\'un bien immobilier avec cheminée ou poêle',
            'Après un incendie de conduit, même partiel',
            'Tirage insuffisant malgré un ramonage récent',
            'Suintements ou taches d\'humidité sur le conduit',
            'Conduit maçonné ancien avant installation d\'un nouvel appareil',
            'Vente immobilière — annexe au dossier notarié',
          ].map(item => (
            <li class="flex items-start gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-[#EA580C] shrink-0 mt-1.5"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- TARIFS -->
  <section id="tarifs" class="py-16 px-6 md:px-10 bg-[#FFFFFF] border-t border-[#EEEEEE]">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-10">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[#EA580C] mb-3">Tarifs</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-3">Tarifs — certificat inclus</h2>
        <p class="text-sm text-[#1A1A1A]/50 font-light max-w-lg mx-auto">
          Chaque intervention comprend le ramonage mécanique, le test de vacuité et la remise du certificat officiel RSD 13.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
