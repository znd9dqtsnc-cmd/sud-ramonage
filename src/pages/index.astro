---
import Layout from '../layouts/Layout.astro';
import ContactButton from '../components/ContactButton.astro';
import EmailButton from '../components/EmailButton.astro';
import TrustBadge from '../components/TrustBadge.astro';
import FAQ from '../components/FAQ.astro';
import { Image, getImage } from 'astro:assets';

// ─── Images locales ───────────────────────────────────────────────────────────
import heroImg      from '../assets/images/hero-poele.jpg';
import ramonageImg  from '../assets/images/service-ramonage.jpg';
import bistrageImg  from '../assets/images/service-bistrage.jpg';
import controleImg  from '../assets/images/service-controle.jpg';
import artisanImg   from '../assets/images/artisan-intervention.jpg';

// Preload LCP : récupère l'URL optimisée de l'image hero pour <link rel="preload">
const optimizedHero = await getImage({ src: heroImg, width: 1920, height: 1080, format: 'webp' });
---

<Layout
  title="Sud Ramonage — Artisan Ramoneur Certifié à Martigues & Côte Bleue"
  description="Artisan ramoneur certifié à Martigues. Ramonage cheminée, poêle à bois et granulés, débistrage, contrôle technique. Certificat immédiat. Assurance pro. Conforme RSD 13."
  canonical="https://sud-ramonage.vercel.app/"
  preloadImageHref={optimizedHero.src}
>

  <!-- ═══════════════════════════════════════════════
       HERO — Image de fond avec overlay
  ═══════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex flex-col items-center justify-center text-center pt-16 pb-24 px-6 md:px-10 overflow-hidden">

    <!-- Image de fond optimisée en WebP par Astro -->
    <div class="absolute inset-0 z-0">
      <Image
        src={heroImg}
        alt="Poêle à bois moderne dans un intérieur chaleureux"
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <!-- Overlay sombre progressif -->
      <div class="absolute inset-0 bg-gradient-to-b from-[#1A1A1A]/75 via-[#1A1A1A]/60 to-[#1A1A1A]/80"></div>
    </div>

    <!-- Contenu texte -->
    <div class="relative z-10 max-w-3xl mx-auto">

      <!-- Badge localisation -->
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 text-white text-[11px] font-semibold px-4 py-2 rounded-full mb-8">
        <svg class="w-3.5 h-3.5 shrink-0 text-[#E65100]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        VOTRE ARTISAN RAMONEUR À MARTIGUES & CÔTE BLEUE
      </div>

      <h1 class="text-[clamp(2.4rem,6.5vw,5rem)] font-extrabold tracking-tight text-white leading-[1.08] mb-6 drop-shadow-lg">
        SUD RAMONAGE :<br />L'Art de la Sécurité.
      </h1>

      <p class="text-base md:text-lg text-white/75 font-light max-w-lg mx-auto leading-relaxed mb-10">
        Ramoneur certifié basé à Martigues. Certificat officiel remis après chaque intervention — conforme aux exigences de votre assurance et au RSD 13.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-6">
        <ContactButton variant="phone" class="w-full sm:w-auto px-8 py-3.5 text-sm" />
        <a
          href="#services"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 border border-white/30 text-white text-xs font-semibold px-8 py-3.5 rounded-lg hover:bg-white/10 transition-all duration-200 backdrop-blur-sm"
        >
          Voir nos services
        </a>
      </div>

      <!-- Badge de confiance hero -->
      <TrustBadge variant="hero" class="mt-2" />

    </div>

    <!-- Flèche scroll -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
      <svg class="w-5 h-5 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>

  </section>

  <!-- ═══ TRUST STRIP ═══ -->
  <TrustBadge variant="strip" />

  <!-- ═══════════════════════════════════════════════
       CHIFFRES CLÉS
  ═══════════════════════════════════════════════ -->
  <section class="border-b border-[#EEEEEE] bg-[#FAFAFA]">
    <div class="max-w-6xl mx-auto px-6 md:px-10">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-[#EEEEEE]">
        {[
          { val: '100%', label: 'Certifié & Assuré' },
          { val: '24h',  label: 'Délai de réponse'  },
          { val: 'RSD 13', label: 'Conformité légale' },
          { val: 'Lu–Sa',  label: 'Disponibilité'    },
        ].map(({ val, label }) => (
          <div class="py-10 px-6 text-center">
            <p class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-1">{val}</p>
            <p class="text-[10px] font-medium tracking-wide uppercase text-[#1A1A1A]/35">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       GALERIE SERVICES — 3 cartes avec photo
  ═══════════════════════════════════════════════ -->
  <section id="services" class="py-24 px-6 md:px-10">
    <div class="max-w-6xl mx-auto">

      <div class="mb-14 text-center">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-4">Ce que nous faisons</p>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-[#1A1A1A]">Nos Prestations</h2>
        <p class="text-sm text-[#1A1A1A]/45 font-light mt-3 max-w-md mx-auto">
          Chaque intervention est réalisée avec soin et se conclut par la remise d'un certificat officiel.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Carte 1 — Ramonage certifié -->
        <div class="group bg-white border border-[#EEEEEE] rounded-xl overflow-hidden hover:shadow-lg hover:border-[#E65100]/20 transition-all duration-300">
          <!-- Photo service (remplaçable : src/assets/images/service-ramonage.jpg) -->
          <div class="aspect-[4/3] overflow-hidden bg-[#F5F5F5]">
            <Image
              src={ramonageImg}
              alt="Conduit de cheminée en brique — ramonage certifié Martigues"
              width={600}
              height={450}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-7">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-9 h-9 rounded-lg bg-[#FFF3E0] flex items-center justify-center shrink-0">
                <!-- Icône flamme -->
                <svg class="w-5 h-5 text-[#E65100]" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/>
                </svg>
              </div>
              <p class="text-[10px] font-semibold tracking-widest uppercase text-[#E65100]">01 — Ramonage</p>
            </div>
            <h3 class="text-lg font-bold tracking-tight text-[#1A1A1A] mb-3">Ramonage Certifié</h3>
            <p class="text-sm text-[#1A1A1A]/55 leading-relaxed font-light mb-5">
              Ramonage mécanique complet de votre conduit, cheminée, insert ou poêle. <strong class="font-medium text-[#1A1A1A]/75">Certificat officiel</strong> remis à l'issue — exigé par les assurances et le RSD 13.
            </p>
            <a href="#contact" class="inline-flex items-center gap-1.5 text-xs font-semibold text-[#E65100] hover:gap-3 transition-all duration-200">
              Prendre RDV
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Carte 2 — Débistrage -->
        <div class="group bg-white border border-[#EEEEEE] rounded-xl overflow-hidden hover:shadow-lg hover:border-[#E65100]/20 transition-all duration-300">
          <!-- Photo service (remplaçable : src/assets/images/service-bistrage.jpg) -->
          <figure class="aspect-[4/3] overflow-hidden bg-[#F5F5F5]">
            <Image
              src={bistrageImg}
              alt="Dépôts de bistre dans un conduit de cheminée — débistrage professionnel Martigues"
              width={600}
              height={450}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <figcaption class="sr-only">Débistrage professionnel à Martigues — élimination des dépôts de goudron et de bistre dans les conduits de cheminée. Traitement chimique et mécanique conforme RSD 13.</figcaption>
          </figure>
          <div class="p-7">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-9 h-9 rounded-lg bg-[#FFF3E0] flex items-center justify-center shrink-0">
                <!-- Icône maison -->
                <svg class="w-5 h-5 text-[#E65100]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
              </div>
              <p class="text-[10px] font-semibold tracking-widest uppercase text-[#E65100]">02 — Débistrage</p>
            </div>
            <h3 class="text-lg font-bold tracking-tight text-[#1A1A1A] mb-3">Débistrage</h3>
            <p class="text-sm text-[#1A1A1A]/55 leading-relaxed font-light mb-5">
              Élimination des dépôts de goudron hautement inflammables. Traitement <strong class="font-medium text-[#1A1A1A]/75">chimique et mécanique</strong> pour rétablir la sécurité totale de votre installation.
            </p>
            <a href="#contact" class="inline-flex items-center gap-1.5 text-xs font-semibold text-[#E65100] hover:gap-3 transition-all duration-200">
              Prendre RDV
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Carte 3 — Contrôle Technique -->
        <div class="group bg-white border border-[#EEEEEE] rounded-xl overflow-hidden hover:shadow-lg hover:border-[#E65100]/20 transition-all duration-300">
          <!-- Photo service (remplaçable : src/assets/images/service-controle.jpg) -->
          <figure class="aspect-[4/3] overflow-hidden bg-[#F5F5F5]">
            <Image
              src={controleImg}
              alt="Contrôle technique et test de vacuité d'un conduit de cheminée à Martigues"
              width={600}
              height={450}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <figcaption class="sr-only">Contrôle technique conduit cheminée Martigues — test de vacuité, vérification étanchéité tubage inox, tirage thermique. Artisan certifié RSD 13 Bouches-du-Rhône.</figcaption>
          </figure>
          <div class="p-7">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-9 h-9 rounded-lg bg-[#FFF3E0] flex items-center justify-center shrink-0">
                <!-- Icône bouclier -->
                <svg class="w-5 h-5 text-[#E65100]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <p class="text-[10px] font-semibold tracking-widest uppercase text-[#E65100]">03 — Diagnostic</p>
            </div>
            <h3 class="text-lg font-bold tracking-tight text-[#1A1A1A] mb-3">Contrôle Technique</h3>
            <p class="text-sm text-[#1A1A1A]/55 leading-relaxed font-light mb-5">
              Inspection complète : <strong class="font-medium text-[#1A1A1A]/75">vacuité</strong> (absence d'obstruction) et <strong class="font-medium text-[#1A1A1A]/75">étanchéité</strong> du conduit. Indispensable avant mise en service ou achat immobilier.
            </p>
            <a href="#contact" class="inline-flex items-center gap-1.5 text-xs font-semibold text-[#E65100] hover:gap-3 transition-all duration-200">
              Prendre RDV
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION ENGAGEMENT — Image latérale + puces
  ═══════════════════════════════════════════════ -->
  <section id="engagement" class="py-24 px-6 md:px-10 bg-[#1A1A1A]">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Image latérale artisan (remplaçable : src/assets/images/artisan-intervention.jpg) -->
        <div class="relative order-2 lg:order-1">
          <figure>
          <Image
            src={artisanImg}
            alt="Artisan ramoneur certifié en intervention à Martigues — ramonage mécanique conduit cheminée"
            width={800}
            height={600}
            class="w-full rounded-xl object-cover aspect-[4/3] shadow-2xl shadow-black/40"
            loading="lazy"
          />
          <figcaption class="sr-only">Artisan ramoneur certifié Sud Ramonage à Martigues — intervention ramonage mécanique, tirage thermique, tubage inox, test de vacuité, certificat RSD 13 Bouches-du-Rhône.</figcaption>
          </figure>
          <!-- Badge overlay sérieux technique -->
          <div class="absolute -bottom-4 -right-4 bg-[#E65100] text-white px-5 py-4 rounded-xl shadow-lg shadow-[#E65100]/30">
            <p class="text-2xl font-extrabold leading-none">RSD 13</p>
            <p class="text-[10px] font-medium tracking-widest uppercase text-white/70 mt-1">Conformité garantie</p>
          </div>
        </div>

        <!-- Engagements -->
        <div class="order-1 lg:order-2">
          <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-5">Ce qui nous distingue</p>
          <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white leading-tight mb-4">
            L'Engagement<br />Sud Ramonage.
          </h2>
          <p class="text-base text-white/45 font-light leading-relaxed mb-8">
            Artisan local basé à Martigues, j'interviens chez vous avec soin, ponctualité et le respect de votre foyer.
          </p>
          <ul class="space-y-5">
            {[
              { path: 'M5 13l4 4L19 7',    title: 'Travail propre garanti',    desc: 'Protection du sol et nettoyage complet après chaque intervention.' },
              { path: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Certificat immédiat', desc: 'Document officiel remis sur place, valable pour votre assurance habitation.' },
              { path: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: 'Assurance professionnelle', desc: 'Couvert en responsabilité civile pro pour toutes mes interventions.' },
              { path: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Artisan de proximité', desc: 'Basé à Martigues, je connais le secteur et interviens rapidement.' },
            ].map(({ path, title, desc }) => (
              <li class="flex gap-4 items-start">
                <div class="w-9 h-9 rounded-lg bg-[#E65100]/15 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-4.5 h-4.5 text-[#E65100]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={path} />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-white mb-0.5">{title}</p>
                  <p class="text-sm text-white/40 font-light leading-relaxed">{desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       ZONE LOCALE
  ═══════════════════════════════════════════════ -->
  <section class="py-24 px-6 md:px-10">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-5">Zone d'intervention</p>
          <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-[#1A1A1A] leading-tight mb-6">
            Martigues, Côte Bleue<br />& Étang de Berre.
          </h2>
          <p class="text-sm text-[#1A1A1A]/55 font-light leading-relaxed mb-8">
            Le <strong class="font-semibold text-[#1A1A1A]">RSD 13</strong> impose le ramonage annuel pour tout appareil à combustion. Intervention conforme, certificat reconnu par votre assureur.
          </p>
          <div class="flex flex-wrap gap-2">
            {['Martigues', 'Istres', 'Fos-sur-Mer', 'Port-de-Bouc', 'Miramas', 'Sausset-les-Pins', 'Carry-le-Rouet', 'Ensuès'].map((ville) => (
              <span class="text-[11px] font-medium border border-[#EEEEEE] text-[#1A1A1A]/45 px-3 py-1.5 rounded-md hover:border-[#E65100]/40 hover:text-[#E65100] transition-colors duration-200 cursor-default">
                {ville}
              </span>
            ))}
          </div>
        </div>
        <div class="space-y-5 text-[#1A1A1A]/65 text-base font-light leading-relaxed">
          <p>
            Sud Ramonage couvre <strong class="font-semibold text-[#1A1A1A]">Martigues</strong>, <strong class="font-semibold text-[#1A1A1A]">Port-de-Bouc</strong>, <strong class="font-semibold text-[#1A1A1A]">Fos-sur-Mer</strong>, <strong class="font-semibold text-[#1A1A1A]">Istres</strong>, <strong class="font-semibold text-[#1A1A1A]">Miramas</strong>, le pourtour de l'<strong class="font-semibold text-[#1A1A1A]">Étang de Berre</strong> et la <strong class="font-semibold text-[#1A1A1A]">Côte Bleue</strong> (Sausset-les-Pins, Carry-le-Rouet, Ensuès-la-Redonne).
          </p>
          <p>
            Chaque intervention comprend le ramonage mécanique, un <strong class="font-semibold text-[#1A1A1A]">test de vacuité</strong> (vérification de l'absence d'obstruction), le contrôle du <strong class="font-semibold text-[#1A1A1A]">tirage thermique</strong> et la remise du certificat conforme au <strong class="font-semibold text-[#1A1A1A]">Règlement Sanitaire Départemental (RSD 13)</strong>.
          </p>
          <p>
            Artisan local, nous connaissons le terrain et garantissons une réactivité maximale. Devis gratuit sous 24h, intervention possible en urgence.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FAQ
  ═══════════════════════════════════════════════ -->
  <FAQ
    title="Vos Questions sur le Ramonage à Martigues."
    items={[
      {
        q: "Le ramonage est-il vraiment obligatoire à Martigues ?",
        a: "Oui. Le Règlement Sanitaire Départemental des Bouches-du-Rhône (RSD 13) impose un ramonage au minimum une fois par an pour tout conduit de fumée en service — cheminée à foyer ouvert, insert, poêle à bois ou poêle à granulés. Cette obligation s'applique aux résidences principales comme secondaires. En cas de sinistre (incendie de conduit, intoxication au monoxyde de carbone) sans certificat de ramonage valide, votre assureur peut légalement refuser la prise en charge.",
      },
      {
        q: "Quel est le tarif d'un ramonage à Martigues ?",
        a: "Le tarif varie selon le type d'appareil (cheminée à foyer ouvert, insert, poêle à bois ou à granulés), la longueur du conduit et son matériau (maçonnerie, tubage inox, conduit flexible). Contactez-nous pour un devis personnalisé gratuit sous 24h. Le certificat officiel est toujours inclus dans la prestation.",
      },
      {
        q: "Délivrez-vous un certificat officiel de ramonage ?",
        a: "Oui, un certificat de ramonage officiel est remis sur place immédiatement après chaque intervention. Ce document est conforme aux exigences du RSD 13 et reconnu par l'ensemble des assurances habitation. Il atteste du ramonage mécanique, du test de vacuité et du contrôle du tirage thermique.",
      },
      {
        q: "Qu'est-ce que le bistre et pourquoi est-ce dangereux ?",
        a: "Le bistre est un dépôt de goudron et de résines qui se forme dans les conduits lors d'une combustion incomplète (bois humide, température trop basse, tirage insuffisant). Contrairement à la suie sèche, le bistre est collant, adhère aux parois et est hautement inflammable — c'est la première cause d'incendie de cheminée en France. Un débistrage professionnel chimique et mécanique est nécessaire dès son apparition.",
      },
      {
        q: "Intervenez-vous sur les poêles à granulés ?",
        a: "Oui, nous intervenons sur tous types d'appareils : cheminées à foyer ouvert, inserts, poêles à bois et poêles à granulés. Les poêles à granulés nécessitent une maintenance spécifique incluant le ramonage du conduit, le nettoyage du brûleur, le contrôle du ventilateur et la vérification du système électronique, en plus du test de vacuité standard.",
      },
      {
        q: "Qu'est-ce que le tubage inox et en avez-vous besoin ?",
        a: "Le tubage inox est un conduit en acier inoxydable installé à l'intérieur d'un conduit de cheminée existant, pour le mettre aux normes ou l'adapter à un nouvel appareil. Nous intervenons sur tous les conduits tubés en inox pour le ramonage et le contrôle. Si un tubage est nécessaire suite à notre diagnostic, nous vous orientons vers un professionnel agréé.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════
