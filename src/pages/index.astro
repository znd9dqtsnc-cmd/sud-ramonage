---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';
import LatestArticles from '../components/LatestArticles.astro';
import { Image, getImage } from 'astro:assets';

import heroImg       from '../assets/images/hero-poele.jpg';
import artisanImg    from '../assets/images/artisan-toiture.jpg';
import bistrageImg   from '../assets/images/service-bistrage.jpg';
import controleImg   from '../assets/images/service-controle.jpg';
import interiorImg   from '../assets/images/hero-poele.jpg';
import finChantierImg from '../assets/images/cheminee-interieur.jpg';

const optimizedHero = await getImage({ src: heroImg, width: 1920, height: 1080, format: 'webp' });
---

<Layout
  title="Sud Ramonage — Artisan Ramoneur Certifié à Martigues & Côte Bleue"
  description="Artisan ramoneur certifié COSTIC à Martigues. Ramonage, débistrage, contrôle technique. Certificat RSD 13 remis après chaque intervention. Bouches-du-Rhône."
  canonical="https://www.sud-ramonage.fr/"
  preloadImageHref={optimizedHero.src}
>

  <!-- ═══════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════ -->
  <section class="relative h-screen min-h-[640px] flex flex-col items-center justify-center text-center overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={heroImg}
        alt="Poêle à bois design avec bûches — Sud Ramonage Martigues"
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/75 via-black/55 to-black/70"></div>
    </div>

    <div class="relative z-10 px-6 max-w-2xl mx-auto flex flex-col items-center text-center gap-5 -mt-16">

      <!-- Surtitre -->
      <p class="text-[11px] font-light uppercase tracking-[0.3em] text-white">
        Votre foyer en toute sécurité
      </p>

      <!-- H1 -->
      <h1 class="text-[clamp(3rem,8vw,5rem)] font-extrabold tracking-tight text-white leading-[1.05] [text-shadow:0_2px_16px_rgba(0,0,0,0.6)]">
        Ramonage Artisanal<br class="hidden sm:block"/> &amp; Expertise Conduit
      </h1>

      <!-- Sous-titre -->
      <p class="text-sm text-white font-light tracking-wide max-w-md">
        Un travail propre, certifié et sans poussière pour votre confort cet hiver.
      </p>

      <!-- Bloc localisation -->
      <div class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 text-sm text-white font-light mt-2">
        <svg class="w-3.5 h-3.5 shrink-0 text-[#F39C12]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        50 km autour de Martigues
      </div>

    </div>

    <a href="#services" class="absolute bottom-24 lg:bottom-10 left-1/2 -translate-x-1/2 animate-bounce text-white/70 hover:text-white transition-colors duration-200" aria-label="Voir nos tarifs">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
      </svg>
    </a>
  </section>

  <!-- ═══════════════════════════════════════════════
       PRESTATIONS + TARIFS
  ═══════════════════════════════════════════════ -->
  <section id="services" class="py-10 md:py-16 px-6 md:px-10 bg-[#F2EFE9] scroll-mt-16">
    <div class="max-w-6xl mx-auto">

      <div class="mb-8">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-[#2C3E50]">Prestations & Tarifs.</h2>
        <div class="w-10 h-0.5 bg-[#F39C12] mt-4 mb-0"></div>
        <p class="text-base text-[#4B4B4B] font-light mt-4">
          Certificat RSD 13 inclus dans chaque prestation. Devis gratuit sous 24h.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Ramonage & Entretien -->
          <a href="/ramonage" class="group flex flex-col bg-[#FFFFFF] rounded-2xl shadow-md overflow-hidden hover:shadow-xl hover:-translate-y-1 hover:scale-[1.01] transition-all duration-300">
            <div class="relative bg-[#2C3E50] px-7 pt-7 pb-5">
              <span class="absolute right-4 top-0 text-[7rem] font-black text-white/8 leading-none select-none pointer-events-none">01</span>
              <p class="text-[10px] font-bold uppercase tracking-widest text-white/60 mb-3 relative z-10">Ramonage & Entretien</p>
              <p class="text-3xl font-extrabold text-white relative z-10">75 <span class="text-lg font-semibold">€</span></p>
              <p class="text-[11px] text-white/50 font-light relative z-10">Tarif foyer ouvert</p>
            </div>
            <div class="p-7 flex flex-col flex-1">
              <h3 class="text-lg font-extrabold text-[#2C3E50] mb-2">Ramonage, Débistrage & Entretien Poêle</h3>
              <p class="text-base text-[#4B4B4B] font-light leading-[1.6]">Nettoyage mécanique du conduit, traitement du bistre et maintenance complète de votre appareil. Certificat RSD 13 inclus.</p>
              <div class="mt-5 pt-5 border-t border-[#E2E8F0] space-y-2.5">
                {[['Ramonage foyer ouvert', '75 €'], ['Insert / Poêle à bois', '90 €'], ['Débistrage conduit', 'dès 150 €'], ['Entretien poêle granulés', '120 €']].map(([l, p]) => (
                  <div class="flex items-center justify-between">
                    <span class="text-xs text-[#4B4B4B] font-light">{l}</span>
                    <span class="text-xs font-semibold text-[#1A1A1A]">{p}</span>
                  </div>
                ))}
              </div>
              <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-[#2C3E50] group-hover:gap-3 transition-all duration-200">
                Voir le détail <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>

        <!-- Inspection & Diagnostic -->
          <a href="/inspection-camera" class="group flex flex-col bg-[#FFFFFF] rounded-2xl shadow-md overflow-hidden hover:shadow-xl hover:-translate-y-1 hover:scale-[1.01] transition-all duration-300">
            <div class="relative bg-[#2C3E50] px-7 pt-7 pb-5">
              <span class="absolute right-4 top-0 text-[7rem] font-black text-white/8 leading-none select-none pointer-events-none">02</span>
              <p class="text-[10px] font-bold uppercase tracking-widest text-white/60 mb-3 relative z-10">Inspection & Diagnostic</p>
              <p class="text-3xl font-extrabold text-white relative z-10">60 <span class="text-lg font-semibold">€</span></p>
              <p class="text-[11px] text-white/50 font-light relative z-10">Diagnostic conduit</p>
            </div>
            <div class="p-7 flex flex-col flex-1">
              <h3 class="text-lg font-extrabold text-[#2C3E50] mb-2">Caméra, Vacuité & Audit de Sécurité</h3>
              <p class="text-base text-[#4B4B4B] font-light leading-[1.6]">Inspection vidéo HD du conduit, contrôle de vacuité et rapport certifié — pour votre assurance, un notaire ou une vente.</p>
              <div class="mt-5 pt-5 border-t border-[#E2E8F0] space-y-2.5">
                {[['Inspection caméra HD', 'dès 60 €'], ['Contrôle de vacuité', 'dès 60 €'], ['Diagnostic de sécurité', 'sur devis'], ['Rapport illustré inclus', '✓']].map(([l, p]) => (
                  <div class="flex items-center justify-between">
                    <span class="text-xs text-[#4B4B4B] font-light">{l}</span>
                    {p === '✓' ? (
                      <span class="w-5 h-5 rounded-full bg-[#D1FAE5] flex items-center justify-center shrink-0">
                        <svg class="w-3 h-3 text-[#2D6A4F]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                      </span>
                    ) : (
                      <span class="text-xs font-semibold text-[#1A1A1A]">{p}</span>
                    )}
                  </div>
                ))}
              </div>
              <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-[#2C3E50] group-hover:gap-3 transition-all duration-200">
                Voir le détail <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>

        <!-- Réhabilitation -->
          <a href="/tubage" class="group flex flex-col bg-[#FFFFFF] rounded-2xl shadow-md overflow-hidden hover:shadow-xl hover:-translate-y-1 hover:scale-[1.01] transition-all duration-300">
            <div class="relative bg-[#2C3E50] px-7 pt-7 pb-5">
              <span class="absolute right-4 top-0 text-[7rem] font-black text-white/8 leading-none select-none pointer-events-none">03</span>
              <p class="text-[10px] font-bold uppercase tracking-widest text-white/60 mb-3 relative z-10">Réhabilitation</p>
              <p class="text-3xl font-extrabold text-white">Sur devis</p>
              <p class="text-[11px] text-white/50 font-light">Étude gratuite</p>
            </div>
            <div class="p-7 flex flex-col flex-1">
              <h3 class="text-lg font-extrabold text-[#2C3E50] mb-2">Tubage, Pose de Conduit & Accessoires</h3>
              <p class="text-base text-[#4B4B4B] font-light leading-[1.6]">Mise aux normes DTU 24.1, installation neuve et équipements toiture — pour sécuriser et pérenniser votre installation.</p>
              <div class="mt-5 pt-5 border-t border-[#E2E8F0] space-y-2.5">
                {[['Tubage rigide & flexible', 'sur devis'], ['Pose conduit métallique', 'sur devis'], ['Chapeaux anti-refoulement', 'sur devis'], ['Étude technique gratuite', '✓']].map(([l, p]) => (
                  <div class="flex items-center justify-between">
                    <span class="text-xs text-[#4B4B4B] font-light">{l}</span>
                    {p === '✓' ? (
                      <span class="w-5 h-5 rounded-full bg-[#D1FAE5] flex items-center justify-center shrink-0">
                        <svg class="w-3 h-3 text-[#2D6A4F]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                      </span>
                    ) : (
                      <span class="text-xs font-semibold text-[#1A1A1A]">{p}</span>
                    )}
                  </div>
                ))}
              </div>
              <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-[#2C3E50] group-hover:gap-3 transition-all duration-200">
                Voir le détail <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>

      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       ENGAGEMENT — Image + 4 mini-cards
  ═══════════════════════════════════════════════ -->
  <div class="w-4/5 mx-auto h-px bg-[#E5E0D5]" aria-hidden="true"></div>
  <section class="py-10 md:py-16 px-6 md:px-10 bg-[#F2EFE9]">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <div class="relative order-2 lg:order-1">
        <Image
          src={interiorImg}
          alt="Poêle à bois design — Sud Ramonage Martigues"
          width={800}
          height={600}
          class="w-full rounded-2xl object-cover aspect-[4/3]"
          loading="lazy"
        />
      </div>

      <div class="order-1 lg:order-2">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-[#2C3E50] leading-tight mb-4">
          Un seul artisan.<br />Un travail fait bien.
        </h2>
        <div class="w-10 h-0.5 bg-[#F39C12] mb-6"></div>
        <p class="text-base text-[#4B4B4B] font-light leading-relaxed mb-8">
          Basé à Martigues, j'interviens seul chez vous — avec soin, ponctualité et respect de votre foyer.
        </p>
        <div class="space-y-3">
          {[
            { t: 'Chantier propre garanti',     d: 'Protection du sol et nettoyage complet après chaque intervention, sans trace.' },
            { t: 'Certificat RSD 13 immédiat',  d: 'Document officiel remis sur place, valide auprès de votre assurance.' },
            { t: 'Assuré RC Pro',               d: 'Couverture complète pour toutes mes interventions.' },
            { t: 'Artisan local, sous 48h',     d: 'Basé à Martigues, je connais votre secteur et interviens rapidement.' },
          ].map(({ t, d }, i) => (
            <div class="relative bg-[#FFFFFF] border border-[#E2E8F0] rounded-xl px-6 py-5 overflow-hidden">
              <div class="absolute top-0 left-0 w-[3px] h-full bg-[#F39C12] rounded-l-xl"></div>
              <div class="flex items-center gap-4">
                <span class="text-3xl font-black text-[#2C3E50]/30 leading-none shrink-0 w-8 text-right">{String(i + 1)}</span>
                <div>
                  <p class="text-sm font-bold text-[#1A1A1A]">{t}</p>
                  <p class="text-sm text-[#4B4B4B] font-light mt-1 leading-[1.6]">{d}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       TÉMOIGNAGES
  ═══════════════════════════════════════════════ -->
  <style>
    @keyframes starPop {
      from { opacity: 0; transform: scale(0.3) rotate(-15deg); }
      to   { opacity: 1; transform: scale(1) rotate(0deg); }
    }
    .star-item { opacity: 0; }
    .testimonial-card.in-view .star-item {
      animation: starPop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    @media (hover: none) {
      .testimonial-card:active { transform: scale(1.02) translateY(-2px); }
    }
  </style>

  <div class="w-4/5 mx-auto h-px bg-[#E5E0D5]" aria-hidden="true"></div>
  <section class="py-10 md:py-16 px-6 md:px-10 bg-[#F2EFE9]">
    <div class="max-w-6xl mx-auto">
      <div class="mb-8">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-[#2C3E50]">Témoignages Clients.</h2>
        <div class="w-10 h-0.5 bg-[#F39C12] mt-4 mb-4"></div>
        <p class="text-base text-[#4B4B4B] font-light">Ils nous ont fait confiance sur Martigues et la Côte Bleue.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { q: 'Intervention rapide et soignée sur ma cheminée à Sausset-les-Pins. Le certificat m\'a été remis dans la foulée. Enfin un artisan qui respecte son engagement.', n: 'Jean-Luc M.', l: 'Sausset-les-Pins · Foyer ouvert' },
          { q: 'Mon poêle à granulés n\'avait pas été entretenu depuis 3 ans — tout démonté, nettoyé et vérifié. Je le recommande sans hésiter à mes voisins d\'Istres.', n: 'Marie A.', l: 'Istres · Poêle à granulés' },
          { q: '14 appartements gérés, tous les certificats remis en une seule tournée avec un rapport consolidé. Un vrai partenaire professionnel.', n: 'Cabinet Immo Provence', l: 'Aix-en-Provence · 14 lots gérés' },
        ].map(({ q, n, l }) => (
          <div class="testimonial-card group bg-[#FFFFFF] border border-[#E2E8F0] rounded-2xl p-8 flex flex-col hover:shadow-xl hover:-translate-y-1 transition-all duration-300 touch-manipulation">

            <!-- Guillemet décoratif -->
            <span class="text-[4.5rem] leading-none text-[#F39C12] font-serif select-none -mb-4">&ldquo;</span>

            <!-- Étoiles -->
            <div class="flex gap-1 mb-5">
              {[0,1,2,3,4].map((i) => (
                <svg class="star-item w-5 h-5 text-[#F39C12]" style={`animation-delay:${i * 0.1}s`} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.033a1 1 0 00-1.175 0l-2.8 2.033c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>

            <!-- Citation -->
            <blockquote class="text-base text-[#4B4B4B] font-light leading-relaxed italic flex-1 mb-8">
              {q}
            </blockquote>

            <!-- Auteur -->
            <div class="flex items-center gap-3 pt-5 border-t border-[#E2E8F0]">
              <div class="w-8 h-8 rounded-full bg-[#2C3E50] flex items-center justify-center shrink-0">
                <span class="text-xs font-bold text-white">{n[0]}</span>
              </div>
              <div>
                <p class="text-sm font-bold text-[#1A1A1A]">{n}</p>
                <p class="text-[11px] text-[#1A1A1A]/85 font-light">{l}</p>
              </div>
            </div>

          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    const cards = document.querySelectorAll('.testimonial-card');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.25 });
    cards.forEach(card => observer.observe(card));
  </script>

  <!-- ═══════════════════════════════════════════════
       ZONE + CONTACT
  ═══════════════════════════════════════════════ -->
  <div class="w-4/5 mx-auto h-px bg-[#E5E0D5]" aria-hidden="true"></div>
  <section class="py-10 md:py-16 px-6 md:px-10 bg-[#F2EFE9]">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Zone gauche -->
      <div>
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-[#2C3E50] leading-tight mb-4">
          Martigues, Côte Bleue<br />& Étang de Berre.
        </h2>
        <div class="w-10 h-0.5 bg-[#F39C12] mb-6"></div>
        <p class="text-base text-[#4B4B4B] font-light leading-[1.6] mb-8">
          Basé à Martigues, j'interviens dans un rayon de 50 km — Côte Bleue, Étang de Berre, Pays d'Aix. Certificat conforme RSD 13 remis à l'issue de chaque visite.
        </p>

        <!-- Pastilles villes -->
        <div class="flex flex-wrap gap-2 mb-8">
          {[
            { label: 'Martigues',       slug: 'martigues' },
            { label: 'Istres',          slug: 'istres' },
            { label: 'Fos-sur-Mer',    slug: 'fos-sur-mer' },
            { label: 'Port-de-Bouc',   slug: 'port-de-bouc' },
            { label: 'Miramas',        slug: 'miramas' },
            { label: 'Sausset',        slug: 'sausset-les-pins' },
            { label: 'Carry-le-Rouet', slug: 'carry-le-rouet' },
            { label: 'Ensuès',         slug: 'ensues-la-redonne' },
          ].map(({ label, slug }) => (
            <a
              href={`/villes/${slug}`}
              class="inline-flex items-center gap-1.5 bg-[#FFFFFF] border border-[#E2E8F0] text-[#1A1A1A]/85 text-xs font-semibold px-4 py-2 rounded-lg hover:border-[#F39C12]/30 hover:text-[#F39C12] hover:shadow-sm transition-all duration-200"
            >
              {label}
            </a>
          ))}
        </div>

        <a href="/zones" class="inline-flex items-center gap-1.5 text-xs font-bold text-[#2C3E50] hover:gap-2.5 transition-all duration-200">
          Voir toutes les zones d'intervention
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Devis gratuit -->
      <div class="relative overflow-hidden rounded-2xl bg-[#FFFFFF] border border-[#E2E8F0] shadow-sm">
        <!-- Header coloré -->
        <div class="relative bg-[#2C3E50] px-8 pt-8 pb-6 overflow-hidden">
          <span class="absolute right-4 top-0 text-[7rem] font-black text-white/8 leading-none select-none">24h</span>
          <p class="text-[10px] font-bold uppercase tracking-widest text-white/60 mb-3 relative z-10">Prendre rendez-vous</p>
          <p class="text-3xl font-extrabold tracking-tight text-white leading-tight relative z-10">Devis Gratuit.</p>
          <p class="text-base text-white/50 font-light mt-1 relative z-10">Réponse assurée sous 24h</p>
        </div>

        <div class="px-8 py-7">
          <p class="text-base text-[#4B4B4B] font-light mb-7 leading-[1.6]">Lundi au samedi, 8h–19h. Intervention disponible sous 48h sur Martigues et la Côte Bleue.</p>
          <a
            href="mailto:contact@sud-ramonage.fr?subject=Demande%20de%20devis%20ramonage"
            class="inline-flex items-center gap-1.5 text-xs font-bold text-[#2C3E50] hover:gap-2.5 transition-all duration-200"
          >
            Écrire un message <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>

          <div class="mt-7 pt-6 border-t border-[#E5E0D5]">
            <ul class="flex flex-col sm:flex-row flex-wrap gap-x-6 gap-y-2.5">
              {[
                'Devis gratuit sous 24h',
                'Intervention propre & soignée',
                'Certificat RSD 13 inclus',
                'Un doute ? Appelez sans engagement',
              ].map(arg => (
                <li class="flex items-center gap-2 text-sm text-[#4B4B4B] font-light">
                  <span class="w-4 h-4 rounded-full bg-[#C8DFC9] flex items-center justify-center shrink-0">
                    <svg class="w-2.5 h-2.5 text-[#2D6A4F]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                    </svg>
                  </span>
                  {arg}
