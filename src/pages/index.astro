---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';
import LatestArticles from '../components/LatestArticles.astro';
import { Image, getImage } from 'astro:assets';

import heroImg     from '../assets/images/ramonage-toiture.jpg';
import artisanImg  from '../assets/images/artisan-toiture.jpg';
import bistrageImg from '../assets/images/service-bistrage.jpg';
import controleImg from '../assets/images/service-controle.jpg';
import interiorImg from '../assets/images/cheminee-interieur.jpg';

const optimizedHero = await getImage({ src: heroImg, width: 1920, height: 1080, format: 'webp' });
---

<Layout
  title="Sud Ramonage — Artisan Ramoneur Certifié à Martigues & Côte Bleue"
  description="Artisan ramoneur certifié COSTIC à Martigues. Ramonage, débistrage, contrôle technique. Certificat RSD 13 remis après chaque intervention. Bouches-du-Rhône."
  canonical="https://www.sud-ramonage.fr/"
  preloadImageHref={optimizedHero.src}
>

  <!-- ═══════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════ -->
  <section class="relative h-screen min-h-[640px] flex flex-col items-center justify-center text-center overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={heroImg}
        alt="Artisans ramoneurs en intervention sur un toit — Sud Ramonage Martigues"
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/75 via-black/55 to-black/70"></div>
    </div>

    <div class="relative z-10 px-6 max-w-3xl mx-auto">
      <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-white/40 mb-6">Martigues · Bouches-du-Rhône</p>
      <h1 class="text-[clamp(2.5rem,6vw,5rem)] font-extrabold tracking-tight text-white leading-[1.05] mb-6">
        L'expertise du conduit.<br />La sécurité de votre foyer.
      </h1>
      <p class="text-base md:text-lg text-white/60 font-light max-w-xl mx-auto mb-10">
        Artisan certifié COSTIC — certificat RSD 13 remis à l'issue de chaque intervention.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="tel:+33664729600"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-[#E65100] hover:bg-[#BF360C] text-white text-sm font-bold px-8 py-4 rounded-xl transition-colors duration-200"
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          06 64 72 96 00
        </a>
        <a
          href="#tarifs"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-white/10 border border-white/20 backdrop-blur-sm text-white text-sm font-semibold px-8 py-4 rounded-xl hover:bg-white/20 transition-colors duration-200"
        >
          Voir les tarifs
        </a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-5 h-5 text-white/25" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       BARRE GARANTIES
  ═══════════════════════════════════════════════ -->
  <section class="bg-[#111111] py-12 px-6">
    <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-10 text-center">
      {[
        { val: 'COSTIC', label: 'Certifié fumisterie' },
        { val: '6j / 7', label: 'Intervention rapide' },
        { val: 'RSD 13', label: 'Certificat officiel' },
        { val: 'RC Pro', label: 'Couverture assurance' },
      ].map(({ val, label }) => (
        <div>
          <p class="text-xl md:text-2xl font-extrabold text-white tracking-tight">{val}</p>
          <p class="text-[10px] text-white/30 uppercase tracking-widest mt-1.5">{label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PRESTATIONS
  ═══════════════════════════════════════════════ -->
  <section id="services" class="py-28 px-6 md:px-10">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-[#1A1A1A]">Nos Prestations.</h2>
        <p class="text-base text-[#1A1A1A]/40 font-light mt-3">
          Chaque intervention se conclut par un certificat officiel remis sur place.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <a href="/ramonage" class="group block overflow-hidden rounded-2xl border border-[#EEEEEE] hover:border-[#E65100]/30 hover:-translate-y-1 hover:shadow-xl transition-all duration-300">
          <div class="aspect-[3/2] overflow-hidden">
            <Image src={artisanImg} alt="Artisan ramoneur sur un toit — ramonage certifié Martigues" width={600} height={400} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-7 bg-white">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#E65100] mb-3">01 — Ramonage</p>
            <h3 class="text-lg font-bold text-[#1A1A1A] mb-2">Ramonage Certifié</h3>
            <p class="text-sm text-[#1A1A1A]/50 leading-relaxed font-light">Ramonage mécanique complet — cheminée, insert, poêle. Certificat RSD 13 remis immédiatement.</p>
            <p class="mt-5 text-sm font-bold text-[#E65100]">À partir de 75 € →</p>
          </div>
        </a>

        <a href="/debistrage" class="group block overflow-hidden rounded-2xl border border-[#EEEEEE] hover:border-[#E65100]/30 hover:-translate-y-1 hover:shadow-xl transition-all duration-300">
          <div class="aspect-[3/2] overflow-hidden">
            <Image src={bistrageImg} alt="Dépôts de bistre dans un conduit — débistrage professionnel" width={600} height={400} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-7 bg-white">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#E65100] mb-3">02 — Débistrage</p>
            <h3 class="text-lg font-bold text-[#1A1A1A] mb-2">Traitement Bistre & Goudron</h3>
            <p class="text-sm text-[#1A1A1A]/50 leading-relaxed font-light">Élimination des dépôts hautement inflammables par traitement chimique et mécanique.</p>
            <p class="mt-5 text-sm font-bold text-[#E65100]">À partir de 150 € →</p>
          </div>
        </a>

        <a href="/entretien-poele" class="group block overflow-hidden rounded-2xl border border-[#EEEEEE] hover:border-[#E65100]/30 hover:-translate-y-1 hover:shadow-xl transition-all duration-300">
          <div class="aspect-[3/2] overflow-hidden">
            <Image src={controleImg} alt="Contrôle technique d'un conduit de cheminée" width={600} height={400} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-7 bg-white">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#E65100] mb-3">03 — Diagnostic</p>
            <h3 class="text-lg font-bold text-[#1A1A1A] mb-2">Contrôle Technique</h3>
            <p class="text-sm text-[#1A1A1A]/50 leading-relaxed font-light">Inspection vacuité et étanchéité du conduit. Rapport illustré pour assurance et notaire.</p>
            <p class="mt-5 text-sm font-bold text-[#E65100]">À partir de 60 € →</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       TARIFS — fond sombre, très visibles
  ═══════════════════════════════════════════════ -->
  <section id="tarifs" class="py-28 px-6 md:px-10 bg-[#111111]">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16 text-center">
        <p class="text-[10px] font-bold uppercase tracking-widest text-[#E65100] mb-4">Transparence tarifaire</p>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white">Nos Tarifs.</h2>
        <p class="text-sm text-white/30 font-light mt-3">Certificat RSD 13 inclus dans chaque prestation.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

        <!-- Ramonage -->
        <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden hover:border-[#E65100]/40 transition-all duration-300">
          <div class="p-8 border-b border-white/10">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#E65100] mb-4">Ramonage certifié</p>
            <p class="text-5xl font-extrabold text-white leading-none">75 <span class="text-2xl font-semibold text-white/35">€</span></p>
            <p class="text-xs text-white/30 mt-2">à partir de · certificat inclus</p>
          </div>
          <div class="p-8 space-y-4">
            {[
              ['Foyer ouvert', '75 €'],
              ['Insert bois', '90 €'],
              ['Poêle à bois', '90 €'],
              ['Poêle à granulés', '110 €'],
            ].map(([l, p]) => (
              <div class="flex items-center justify-between">
                <span class="text-sm text-white/45 font-light">{l}</span>
                <span class="text-sm font-bold text-white">{p}</span>
              </div>
            ))}
            <a href="/ramonage" class="mt-6 flex items-center justify-center w-full bg-[#E65100] text-white text-sm font-bold px-4 py-3 rounded-xl hover:bg-[#BF360C] transition-colors">
              Réserver
            </a>
          </div>
        </div>

        <!-- Débistrage (mise en avant) -->
        <div class="bg-[#E65100] rounded-2xl overflow-hidden">
          <div class="p-8 border-b border-white/20">
            <div class="flex items-center justify-between mb-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-white/70">Débistrage</p>
              <span class="text-[10px] font-bold bg-white text-[#E65100] px-2.5 py-1 rounded-full uppercase tracking-wide">Urgent</span>
            </div>
            <p class="text-5xl font-extrabold text-white leading-none">150 <span class="text-2xl font-semibold text-white/50">€</span></p>
            <p class="text-xs text-white/55 mt-2">à partir de · traitement complet</p>
          </div>
          <div class="p-8 space-y-4">
            {[
              ['Traitement chimique + mécanique', 'dès 150 €'],
              ['Conduit très encrassé (2 passes)', 'dès 195 €'],
              ['Diagnostic inclus', '✓'],
              ['Certificat RSD 13 inclus', '✓'],
            ].map(([l, p]) => (
              <div class="flex items-center justify-between">
                <span class="text-sm text-white/65 font-light">{l}</span>
                <span class="text-sm font-bold text-white">{p}</span>
              </div>
            ))}
            <a href="/debistrage" class="mt-6 flex items-center justify-center w-full bg-white text-[#E65100] text-sm font-bold px-4 py-3 rounded-xl hover:bg-white/92 transition-colors">
              Réserver
            </a>
          </div>
        </div>

        <!-- Entretien poêle -->
        <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden hover:border-[#E65100]/40 transition-all duration-300">
          <div class="p-8 border-b border-white/10">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#E65100] mb-4">Entretien poêle</p>
            <p class="text-5xl font-extrabold text-white leading-none">90 <span class="text-2xl font-semibold text-white/35">€</span></p>
            <p class="text-xs text-white/30 mt-2">à partir de · entretien complet</p>
          </div>
          <div class="p-8 space-y-4">
            {[
              ['Poêle à bois', '90 €'],
              ['Poêle à granulés', '120 €'],
              ['Ramonage conduit inclus', '✓'],
              ['Certificat RSD 13 inclus', '✓'],
            ].map(([l, p]) => (
              <div class="flex items-center justify-between">
                <span class="text-sm text-white/45 font-light">{l}</span>
                <span class="text-sm font-bold text-white">{p}</span>
              </div>
            ))}
            <a href="/entretien-poele" class="mt-6 flex items-center justify-center w-full bg-[#E65100] text-white text-sm font-bold px-4 py-3 rounded-xl hover:bg-[#BF360C] transition-colors">
              Réserver
            </a>
          </div>
        </div>

      </div>

      <p class="mt-10 text-center text-xs text-white/20 font-light">
        Tarifs indicatifs — zone Martigues et Côte Bleue. Devis gratuit sous 24h. Modification possible après diagnostic.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       ENGAGEMENT — Image + texte
  ═══════════════════════════════════════════════ -->
  <section class="py-28 px-6 md:px-10 bg-white border-t border-[#EEEEEE]">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <div class="relative order-2 lg:order-1">
        <Image
          src={interiorImg}
          alt="Cheminée en brique dans un intérieur chaleureux — entretien annuel certifié"
          width={800}
          height={600}
          class="w-full rounded-2xl object-cover aspect-[4/3]"
          loading="lazy"
        />
        <div class="absolute -bottom-4 -right-4 bg-[#1A1A1A] text-white px-5 py-4 rounded-xl shadow-xl">
          <p class="text-xl font-extrabold leading-none">RSD 13</p>
          <p class="text-[10px] uppercase tracking-widest text-white/40 mt-1">Conformité garantie</p>
        </div>
      </div>

      <div class="order-1 lg:order-2">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-[#1A1A1A] leading-tight mb-6">
          Un seul artisan.<br />Un travail fait bien.
        </h2>
        <p class="text-base text-[#1A1A1A]/50 font-light leading-relaxed mb-10">
          Basé à Martigues, j'interviens seul chez vous — avec soin, ponctualité et respect de votre foyer.
        </p>
        <ul class="space-y-6">
          {[
            ['Travail propre garanti', 'Protection du sol et nettoyage complet après chaque intervention.'],
            ['Certificat officiel immédiat', 'Document valide auprès de votre assurance habitation.'],
            ['Assuré RC Pro', 'Couverture complète pour toutes mes interventions.'],
            ['Artisan local', 'Basé à Martigues, je connais votre secteur.'],
          ].map(([t, d]) => (
            <li class="flex gap-4">
              <div class="w-1.5 h-1.5 rounded-full bg-[#E65100] mt-2 shrink-0"></div>
              <div>
                <p class="text-sm font-semibold text-[#1A1A1A]">{t}</p>
                <p class="text-sm text-[#1A1A1A]/40 font-light mt-0.5">{d}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       TÉMOIGNAGES
  ═══════════════════════════════════════════════ -->
  <section class="py-28 px-6 md:px-10 bg-[#FAFAFA] border-t border-[#EEEEEE]">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-[#1A1A1A]">Témoignages Clients.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            q: '"Intervention rapide et soignée sur ma cheminée à Sausset-les-Pins. Le certificat m\'a été remis dans la foulée. Enfin un artisan qui respecte son engagement."',
            n: 'Jean-Luc M.',
            l: 'Sausset-les-Pins · Foyer ouvert',
          },
          {
            q: '"Mon poêle à granulés n\'avait pas été entretenu depuis 3 ans — tout démonté, nettoyé et vérifié. Je le recommande sans hésiter à mes voisins d\'Istres."',
            n: 'Marie A.',
            l: 'Istres · Poêle à granulés',
          },
          {
            q: '"14 appartements gérés, tous les certificats remis en une seule tournée avec un rapport consolidé. Un vrai partenaire professionnel."',
            n: 'Cabinet Immo Provence',
            l: 'Aix-en-Provence · 14 lots gérés',
          },
        ].map(({ q, n, l }) => (
          <div class="bg-white border border-[#EEEEEE] rounded-2xl p-8">
            <div class="flex gap-0.5 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-[#E65100]" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.033a1 1 0 00-1.175 0l-2.8 2.033c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <blockquote class="text-sm text-[#1A1A1A]/65 font-light leading-relaxed mb-7 italic">{q}</blockquote>
            <p class="text-xs font-semibold text-[#1A1A1A]">{n}</p>
            <p class="text-[11px] text-[#1A1A1A]/30 mt-0.5">{l}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       ZONE + CONTACT
  ═══════════════════════════════════════════════ -->
  <section class="py-28 px-6 md:px-10 border-t border-[#EEEEEE]">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <div>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-[#1A1A1A] leading-tight mb-6">
          Martigues, Côte Bleue<br />& Étang de Berre.
        </h2>
        <p class="text-sm text-[#1A1A1A]/50 font-light leading-relaxed mb-8">
          Basé à Martigues, j'interviens dans un rayon de 50 km — Côte Bleue, Étang de Berre, Pays d'Aix. Certificat conforme RSD 13 remis à l'issue de chaque visite.
        </p>
        <div class="flex flex-wrap gap-2 mb-8">
          {[
            { label: 'Martigues', slug: 'martigues' },
            { label: 'Istres', slug: 'istres' },
            { label: 'Fos-sur-Mer', slug: 'fos-sur-mer' },
            { label: 'Port-de-Bouc', slug: 'port-de-bouc' },
            { label: 'Miramas', slug: 'miramas' },
            { label: 'Sausset-les-Pins', slug: 'sausset-les-pins' },
            { label: 'Carry-le-Rouet', slug: 'carry-le-rouet' },
            { label: 'Ensuès', slug: 'ensues-la-redonne' },
          ].map(({ label, slug }) => (
            <a href={`/villes/${slug}`} class="text-[11px] font-medium border border-[#EEEEEE] text-[#1A1A1A]/45 px-3 py-1.5 rounded-md hover:border-[#E65100]/40 hover:text-[#E65100] transition-colors">
              {label}
            </a>
          ))}
        </div>
        <a href="/zones" class="inline-flex items-center gap-2 text-sm font-semibold text-[#E65100] hover:gap-3 transition-all duration-200">
          Voir toutes les zones d'intervention
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="bg-[#111111] rounded-2xl p-10 text-white">
        <h3 class="text-xl font-extrabold mb-2">Devis Gratuit Sous 24H.</h3>
        <p class="text-sm text-white/35 font-light mb-8">Disponible du lundi au samedi, 8h–19h.</p>
        <a
          href="tel:+33664729600"
          class="flex items-center justify-center gap-2 w-full bg-[#E65100] hover:bg-[#BF360C] text-white text-sm font-bold px-6 py-4 rounded-xl mb-3 transition-colors"
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          06 64 72 96 00
        </a>
        <a
          href="mailto:contact@sud-ramonage.fr?subject=Demande%20de%20devis%20ramonage"
          class="flex items-center justify-center gap-2 w-full bg-white/8 border border-white/15 text-white text-sm font-semibold px-6 py-4 rounded-xl hover:bg-white/15 transition-colors"
        >
          Par email
        </a>
        <div class="mt-8 pt-7 border-t border-white/10 flex items-center gap-3">
          <svg class="w-4 h-4 text-white/25 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <p class="text-xs text-white/25">31 chemin des tamaris, 13500 Martigues</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FAQ
  ═══════════════════════════════════════════════ -->
  <FAQ
    title="Vos Questions."
    items={[
      {
        q: "Le ramonage est-il vraiment obligatoire à Martigues ?",
        a: "Oui. Le RSD 13 impose un ramonage annuel pour tout conduit de fumée actif — cheminée, insert, poêle à bois ou granulés. Sans certificat valide, votre assureur peut refuser toute indemnisation en cas de sinistre.",
      },
      {
        q: "Quel est le tarif d'un ramonage ?",
        a: "À partir de 75 € pour une cheminée à foyer ouvert, 90 € pour un insert ou poêle à bois, 110 € pour un poêle à granulés. Certificat RSD 13 toujours inclus. Devis gratuit sous 24h.",
      },
      {
        q: "Qu'est-ce que le bistre et pourquoi est-ce dangereux ?",
