---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';
import LatestArticles from '../components/LatestArticles.astro';
import { Image, getImage } from 'astro:assets';

import heroImg     from '../assets/images/hero-poele.jpg';
import ramonageImg from '../assets/images/service-ramonage.jpg';
import bistrageImg from '../assets/images/service-bistrage.jpg';
import controleImg from '../assets/images/service-controle.jpg';
import artisanImg  from '../assets/images/artisan-intervention.jpg';

const optimizedHero = await getImage({ src: heroImg, width: 1920, height: 1080, format: 'webp' });
---

<Layout
  title="Sud Ramonage — Artisan Ramoneur Certifié à Martigues"
  description="Artisan ramoneur certifié COSTIC à Martigues. Ramonage cheminée, insert, poêle, chaudière. Certificat RSD 13 immédiat. Assurance pro. Bouches-du-Rhône."
  canonical="https://www.sud-ramonage.fr/"
  preloadImageHref={optimizedHero.src}
>

  <!-- ═══ HERO — PLEIN ÉCRAN SOMBRE ═══ -->
  <section class="relative min-h-screen flex items-end pb-16 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={heroImg}
        alt="Cheminée et poêle à bois — artisan ramoneur certifié Martigues"
        width={1920} height={1080}
        class="w-full h-full object-cover"
        loading="eager" fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[#111111] via-[#111111]/60 to-[#111111]/20"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-10 w-full">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 border border-[#D4763A]/40 text-[#D4763A] text-[11px] font-bold px-4 py-2 rounded-full mb-8 uppercase tracking-widest">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          Certifié COSTIC · Qualibat 6521 · RSD 13
        </div>
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-white leading-[1.0] mb-6">
          L'Art de la<br /><span class="text-[#D4763A]">Sécurité.</span>
        </h1>
        <p class="text-lg md:text-xl text-white/65 font-light leading-relaxed mb-10 max-w-2xl">
          Artisan ramoneur certifié à Martigues. Ramonage, diagnostic, entretien — certificat officiel remis sur place. Conforme RSD 13 et assurance habitation.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="tel:+33664729600" class="inline-flex items-center gap-2.5 bg-[#D4763A] hover:bg-[#BE6530] text-white text-sm font-bold px-7 py-4 rounded-xl transition-colors shadow-lg shadow-[#D4763A]/30">
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            06 64 72 96 00 — Prendre RDV
          </a>
          <a href="#prestations" class="inline-flex items-center gap-2 border border-white/25 text-white text-sm font-medium px-7 py-4 rounded-xl hover:bg-white/10 hover:border-white/40 transition-all">
            Nos prestations
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </a>
        </div>
      </div>
    </div>
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 right-8 z-10 flex flex-col items-center gap-2 opacity-40">
      <div class="w-px h-12 bg-white animate-pulse"></div>
    </div>
  </section>

  <!-- ═══ BANDE DE CONFIANCE ═══ -->
  <section class="bg-white border-t border-[#F3F4F6]">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="flex items-center gap-3 bg-[#F0FDF4] border border-[#BBF7D0] rounded-xl px-4 py-4">
          <svg class="w-5 h-5 text-[#16A34A] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <div>
            <p class="text-sm font-extrabold text-[#166534]">Certifié COSTIC</p>
            <p class="text-[10px] text-[#166534]/60 leading-tight">Fumisterie nationale</p>
          </div>
        </div>
        <div class="flex items-center gap-3 bg-[#EFF6FF] border border-[#BFDBFE] rounded-xl px-4 py-4">
          <svg class="w-5 h-5 text-[#2563EB] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>
          <div>
            <p class="text-sm font-extrabold text-[#1E40AF]">RSD 13</p>
            <p class="text-[10px] text-[#1E40AF]/60 leading-tight">Conformité Bouches-du-Rhône</p>
          </div>
        </div>
        <div class="flex items-center gap-3 bg-[#FFFBEB] border border-[#FDE68A] rounded-xl px-4 py-4">
          <svg class="w-5 h-5 text-[#D97706] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <div>
            <p class="text-sm font-extrabold text-[#92400E]">Certificat</p>
            <p class="text-[10px] text-[#92400E]/60 leading-tight">Remis sur place · immédiat</p>
          </div>
        </div>
        <div class="flex items-center gap-3 bg-[#F0FDF4] border border-[#BBF7D0] rounded-xl px-4 py-4">
          <svg class="w-5 h-5 text-[#16A34A] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <div>
            <p class="text-sm font-extrabold text-[#166534]">RC Pro</p>
            <p class="text-[10px] text-[#166534]/60 leading-tight">Assuré · attestation sur demande</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PRESTATIONS — 3 CARTES PHOTO ═══ -->
  <section id="prestations" class="py-24 px-6 md:px-10 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-[#D4763A] mb-3">Ce que nous faisons</p>
          <h2 class="text-4xl font-extrabold tracking-tight text-[#111111]">Nos Prestations</h2>
        </div>
        <a href="/particuliers" class="hidden md:inline-flex items-center gap-1.5 text-sm font-semibold text-[#6B7280] hover:text-[#D4763A] transition-colors">
          Voir tout
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <a href="/particuliers#ramonage" class="group block overflow-hidden rounded-2xl border border-[#F3F4F6] hover:shadow-xl hover:shadow-black/8 hover:-translate-y-1 transition-all duration-300">
          <div class="aspect-[16/10] overflow-hidden bg-[#F9F9F9]">
            <Image src={ramonageImg} alt="Ramonage cheminée certifié Martigues" width={600} height={375} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-7 bg-white">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#D4763A] mb-2">Particuliers · Ramonage</p>
            <h3 class="text-xl font-bold text-[#111111] mb-3">Ramonage Certifié</h3>
            <p class="text-sm text-[#6B7280] leading-relaxed mb-5">Ramonage mécanique cheminée, insert, poêle à bois. Certificat officiel RSD 13 remis sur place — valable pour votre assurance habitation.</p>
            <span class="inline-flex items-center gap-1.5 text-xs font-bold text-[#D4763A] group-hover:gap-3 transition-all">
              Découvrir <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>

        <a href="/particuliers#audit" class="group block overflow-hidden rounded-2xl border border-[#F3F4F6] hover:shadow-xl hover:shadow-black/8 hover:-translate-y-1 transition-all duration-300">
          <div class="aspect-[16/10] overflow-hidden bg-[#F9F9F9]">
            <Image src={controleImg} alt="Inspection caméra HD conduit cheminée Martigues" width={600} height={375} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-7 bg-white">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#D4763A] mb-2">Audit · Diagnostic</p>
            <h3 class="text-xl font-bold text-[#111111] mb-3">Inspection Caméra HD</h3>
            <p class="text-sm text-[#6B7280] leading-relaxed mb-5">Diagnostic vidéo endoscopique du conduit. Détection de fissures, obstructions, faiblesses invisibles. Rapport photo fourni. Indispensable avant achat immobilier.</p>
            <span class="inline-flex items-center gap-1.5 text-xs font-bold text-[#D4763A] group-hover:gap-3 transition-all">
              Découvrir <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>

        <a href="/particuliers#poeles" class="group block overflow-hidden rounded-2xl border border-[#F3F4F6] hover:shadow-xl hover:shadow-black/8 hover:-translate-y-1 transition-all duration-300">
          <div class="aspect-[16/10] overflow-hidden bg-[#F9F9F9]">
            <Image src={bistrageImg} alt="Entretien poêle à granulés et débistrage Martigues" width={600} height={375} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-7 bg-white">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#D4763A] mb-2">Poêles · Granulés</p>
            <h3 class="text-xl font-bold text-[#111111] mb-3">Entretien & Débistrage</h3>
            <p class="text-sm text-[#6B7280] leading-relaxed mb-5">Entretien complet poêle à granulés : brûleur, ventilateur, capteurs, vis sans fin. Débistrage chimique et mécanique. Performances et sécurité optimales.</p>
            <span class="inline-flex items-center gap-1.5 text-xs font-bold text-[#D4763A] group-hover:gap-3 transition-all">
              Découvrir <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ═══ TARIFS ═══ -->
  <section id="tarifs" class="py-24 px-6 md:px-10 bg-[#F9F9F9]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#D4763A] mb-3">Tarifs</p>
        <h2 class="text-4xl font-extrabold tracking-tight text-[#111111] mb-3">Prestations & Prix</h2>
        <p class="text-sm text-[#6B7280] font-light max-w-lg mx-auto">Certificat officiel inclus dans chaque prestation. TVA non applicable — Art. 293 B du CGI.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">

        <div class="bg-white border border-[#F3F4F6] rounded-2xl overflow-hidden shadow-sm">
          <div class="px-7 pt-8 pb-6 border-b border-[#F9F9F9]">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#6B7280] mb-4">Cheminée / Foyer ouvert</p>
            <div class="flex items-baseline gap-1"><span class="text-6xl font-extrabold text-[#111111] tracking-tight">75</span><span class="text-2xl font-light text-[#6B7280]">€</span></div>
            <p class="text-xs text-[#6B7280] mt-2">tarif unique · certificat inclus</p>
          </div>
          <ul class="px-7 py-7 space-y-3.5">
            {['Ramonage mécanique du conduit', 'Test de vacuité', 'Contrôle du tirage thermique', 'Nettoyage foyer et plaque', 'Certificat officiel RSD 13'].map(i => (
              <li class="flex items-start gap-3 text-sm text-[#374151]">
                <svg class="w-4 h-4 text-[#D4763A] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                {i}
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white border-2 border-[#D4763A] rounded-2xl overflow-hidden shadow-lg shadow-[#D4763A]/10 relative">
          <div class="absolute top-5 right-5">
            <span class="text-[10px] font-bold bg-[#D4763A] text-white px-3 py-1.5 rounded-full uppercase tracking-wider">Le plus demandé</span>
          </div>
          <div class="px-7 pt-8 pb-6 border-b border-[#FEF6EE]">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#6B7280] mb-4">Insert / Poêle à bois</p>
            <div class="flex items-baseline gap-1"><span class="text-6xl font-extrabold text-[#111111] tracking-tight">90</span><span class="text-2xl font-light text-[#6B7280]">€</span></div>
            <p class="text-xs text-[#6B7280] mt-2">tarif unique · certificat inclus</p>
          </div>
          <ul class="px-7 py-7 space-y-3.5">
            {['Ramonage mécanique du conduit', 'Test de vacuité et tirage', 'Vérification joints et raccordement', 'Nettoyage chambre de combustion', 'Certificat officiel RSD 13'].map(i => (
              <li class="flex items-start gap-3 text-sm text-[#374151]">
                <svg class="w-4 h-4 text-[#D4763A] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                {i}
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white border border-[#F3F4F6] rounded-2xl overflow-hidden shadow-sm">
          <div class="px-7 pt-8 pb-6 border-b border-[#F9F9F9]">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#6B7280] mb-4">Poêle à Granulés</p>
            <div class="flex items-baseline gap-1"><span class="text-6xl font-extrabold text-[#111111] tracking-tight">120</span><span class="text-2xl font-light text-[#6B7280]">€</span></div>
            <p class="text-xs text-[#6B7280] mt-2">entretien complet · certificat inclus</p>
          </div>
          <ul class="px-7 py-7 space-y-3.5">
            {["Ramonage du conduit d'évacuation", 'Nettoyage brûleur et chambre', 'Contrôle ventilateur et capteurs', 'Vérification vis sans fin', 'Certificat officiel RSD 13'].map(i => (
              <li class="flex items-start gap-3 text-sm text-[#374151]">
                <svg class="w-4 h-4 text-[#D4763A] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                {i}
              </li>
            ))}
          </ul>
        </div>

      </div>
      <div class="text-center">
        <a href="tel:+33664729600" class="inline-flex items-center gap-2.5 bg-[#D4763A] hover:bg-[#BE6530] text-white text-sm font-bold px-8 py-4 rounded-xl transition-colors shadow-sm shadow-[#D4763A]/20">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Prendre rendez-vous — 06 64 72 96 00
        </a>
        <p class="text-xs text-[#6B7280] mt-4">Déplacement inclus sur 30 km · Devis gratuit sous 24h · TVA non applicable Art. 293 B CGI</p>
      </div>
    </div>
  </section>

  <!-- ═══ ARTISAN PHOTO + ENGAGEMENT ═══ -->
  <section class="py-24 px-6 md:px-10 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="relative">
          <Image
            src={artisanImg}
            alt="Artisan ramoneur certifié en intervention à Martigues"
            width={800} height={600}
            class="w-full rounded-2xl object-cover aspect-[4/3] shadow-xl shadow-black/10"
            loading="lazy"
          />
          <div class="absolute -bottom-6 -right-6 bg-[#D4763A] text-white px-6 py-5 rounded-2xl shadow-xl shadow-[#D4763A]/30">
            <p class="text-3xl font-extrabold leading-none">RSD 13</p>
            <p class="text-[10px] font-medium tracking-widest uppercase text-white/70 mt-1.5">Conformité garantie</p>
          </div>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-[#D4763A] mb-5">Votre artisan</p>
          <h2 class="text-4xl font-extrabold tracking-tight text-[#111111] leading-tight mb-6">
            Formé. Certifié.<br />Local.
          </h2>
          <p class="text-base text-[#6B7280] font-light leading-relaxed mb-8">
            Artisan ramoneur certifié COSTIC basé à Martigues, j'interviens sur les Bouches-du-Rhône avec rigueur et respect de votre foyer. La certification COSTIC atteste d'une formation rigoureuse aux normes NF DTU 24.1, à la réglementation RSD 13 et aux techniques de diagnostic avancé.
          </p>
          <ul class="space-y-5 mb-8">
            {[
              { icon: 'M5 13l4 4L19 7', title: 'Travail propre garanti', desc: 'Protection complète du sol et des meubles. Nettoyage après chaque intervention.' },
              { icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Certificat officiel immédiat', desc: 'Document remis sur place, valable pour votre assureur habitation.' },
              { icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z', title: 'Prévention CO', desc: 'Détection des risques monoxyde de carbone et conseils de prévention après chaque visite.' },
            ].map(({ icon, title, desc }) => (
              <li class="flex gap-4">
                <div class="w-10 h-10 rounded-xl bg-[#FEF6EE] flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-[#D4763A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-bold text-[#111111] mb-1">{title}</p>
                  <p class="text-sm text-[#6B7280] font-light leading-relaxed">{desc}</p>
                </div>
              </li>
            ))}
          </ul>
          <blockquote class="border-l-4 border-[#D4763A] pl-5 italic text-[#6B7280] text-sm leading-relaxed">
            "Je travaille dans ce métier parce qu'un conduit propre, c'est une famille à l'abri. Chaque intervention, je prends le temps d'expliquer ce que j'ai trouvé."
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ZONE INTERVENTION + PRO ═══ -->
  <section class="py-24 px-6 md:px-10 bg-[#FAFAF8]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-[#D4763A] mb-5">Zone d'intervention</p>
          <h2 class="text-4xl font-extrabold tracking-tight text-[#1A1A1A] leading-tight mb-6">
            Martigues,<br />Côte Bleue<br />&amp; Étang de Berre.
          </h2>
          <p class="text-base text-[#6B7280] font-light leading-relaxed mb-8">
            Intervention dans un rayon de 30 km autour de Martigues. Déplacement inclus dans le tarif. Le RSD 13 impose le ramonage annuel pour tout appareil à combustion — certificat reconnu par toutes les assurances.
          </p>
          <div class="flex flex-wrap gap-2 mb-10">
            {['Martigues', 'Istres', 'Fos-sur-Mer', 'Port-de-Bouc', 'Miramas', 'Sausset-les-Pins', 'Carry-le-Rouet', 'Ensuès'].map(v => (
              <span class="text-xs font-medium border border-[#E5E7EB] bg-white text-[#6B7280] px-3 py-1.5 rounded-lg hover:border-[#D4763A]/40 hover:text-[#D4763A] transition-colors cursor-default">{v}</span>
            ))}
          </div>
