---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';
import LatestArticles from '../components/LatestArticles.astro';
import { Image, getImage } from 'astro:assets';

import heroImg     from '../assets/images/ramonage-toiture.jpg';
import artisanImg  from '../assets/images/artisan-toiture.jpg';
import bistrageImg from '../assets/images/service-bistrage.jpg';
import controleImg from '../assets/images/service-controle.jpg';
import interiorImg from '../assets/images/cheminee-interieur.jpg';

const optimizedHero = await getImage({ src: heroImg, width: 1920, height: 1080, format: 'webp' });
---

<Layout
  title="Sud Ramonage — Artisan Ramoneur Certifié à Martigues & Côte Bleue"
  description="Artisan ramoneur certifié COSTIC à Martigues. Ramonage, débistrage, contrôle technique. Certificat RSD 13 remis après chaque intervention. Bouches-du-Rhône."
  canonical="https://www.sud-ramonage.fr/"
  preloadImageHref={optimizedHero.src}
>

  <!-- ═══════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════ -->
  <section class="relative h-screen min-h-[640px] flex flex-col items-center justify-center text-center overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={heroImg}
        alt="Artisans ramoneurs en intervention sur un toit — Sud Ramonage Martigues"
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/75 via-black/55 to-black/70"></div>
    </div>

    <div class="relative z-10 px-6 max-w-3xl mx-auto">
      <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-white/40 mb-6">Martigues · Bouches-du-Rhône</p>
      <h1 class="text-[clamp(2.5rem,6vw,5rem)] font-extrabold tracking-tight text-white leading-[1.05] mb-6">
        L'expertise du conduit.<br />La sécurité de votre foyer.
      </h1>
      <p class="text-base md:text-lg text-white/60 font-light max-w-xl mx-auto mb-10">
        Artisan certifié COSTIC — certificat RSD 13 remis à l'issue de chaque intervention.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="tel:+33664729600"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-[#C4B5AC] hover:bg-[#A09080] text-white text-sm font-bold px-8 py-4 rounded-xl transition-colors duration-200"
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          06 64 72 96 00
        </a>
        <a
          href="#services"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-[#F9F6F3]/10 border border-white/20 backdrop-blur-sm text-white text-sm font-semibold px-8 py-4 rounded-xl hover:bg-[#F9F6F3]/20 transition-colors duration-200"
        >
          Voir les tarifs
        </a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-5 h-5 text-white/25" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PRESTATIONS + TARIFS
  ═══════════════════════════════════════════════ -->
  <section id="services" class="py-28 px-6 md:px-10 bg-[#F9F6F3]">
    <div class="max-w-6xl mx-auto">

      <div class="mb-16">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#C4B5AC] mb-5"><span class="inline-block w-1.5 h-1.5 rounded-full bg-[#C4B5AC] mr-2 mb-0.5"></span>Certifié COSTIC · RSD 13</p>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-[#1A1A1A]">Prestations & Tarifs.</h2>
        <div class="w-10 h-0.5 bg-[#C4B5AC]/25 mt-4 mb-0"></div>
        <p class="text-base text-[#1A1A1A]/80 font-light mt-4">
          Certificat RSD 13 inclus dans chaque prestation. Devis gratuit sous 24h.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Ramonage & Entretien — vedette orange -->
        <a href="/ramonage" class="group flex flex-col bg-[#F9F6F3] rounded-2xl border border-[#C4B5AC] overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <div class="relative bg-[#E8DDD4] px-7 pt-7 pb-5 overflow-hidden">
            <span class="absolute right-4 top-2 text-[5rem] font-black text-[#1C1917]/10 leading-none select-none">01</span>
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#1C1917]/75 mb-3 relative z-10">Ramonage & Entretien</p>
            <p class="text-3xl font-extrabold text-[#1C1917] relative z-10">75 <span class="text-lg font-semibold">€</span></p>
            <p class="text-[11px] text-[#1C1917]/70 font-light relative z-10">Tarif foyer ouvert</p>
          </div>
          <div class="p-7 flex flex-col flex-1">
            <h3 class="text-lg font-bold text-[#1A1A1A] mb-2">Ramonage, Débistrage & Entretien Poêle</h3>
            <p class="text-sm text-[#1A1A1A]/85 font-light leading-relaxed">Nettoyage mécanique du conduit, traitement du bistre et maintenance complète de votre appareil. Certificat RSD 13 inclus.</p>
            <div class="mt-5 pt-5 border-t border-[#F0F0F0] space-y-2.5">
              {[['Ramonage foyer ouvert', '75 €'], ['Insert / Poêle à bois', '90 €'], ['Débistrage conduit', 'dès 150 €'], ['Entretien poêle granulés', '120 €']].map(([l, p]) => (
                <div class="flex items-center justify-between">
                  <span class="text-xs text-[#1A1A1A]/80 font-light">{l}</span>
                  <span class="text-xs font-semibold text-[#1A1A1A]">{p}</span>
                </div>
              ))}
            </div>
            <span class="mt-6 inline-flex items-center gap-1.5 text-xs font-semibold text-[#C4B5AC] group-hover:gap-2.5 transition-all duration-200">
              Voir les prestations <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>

        <!-- Inspection & Diagnostic — gris moyen -->
        <a href="/inspection-camera" class="group flex flex-col bg-[#F9F6F3] rounded-2xl border border-[#D0C8C0] overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <div class="relative bg-[#D5E0D8] px-7 pt-7 pb-5 overflow-hidden">
            <span class="absolute right-4 top-2 text-[5rem] font-black text-[#1C1917]/10 leading-none select-none">02</span>
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#1C1917]/75 mb-3 relative z-10">Inspection & Diagnostic</p>
            <p class="text-3xl font-extrabold text-[#1C1917] relative z-10">60 <span class="text-lg font-semibold">€</span></p>
            <p class="text-[11px] text-[#1C1917]/70 font-light relative z-10">Diagnostic conduit</p>
          </div>
          <div class="p-7 flex flex-col flex-1">
            <h3 class="text-lg font-bold text-[#1A1A1A] mb-2">Caméra, Vacuité & Audit de Sécurité</h3>
            <p class="text-sm text-[#1A1A1A]/85 font-light leading-relaxed">Inspection vidéo HD du conduit, contrôle de vacuité et rapport certifié — pour votre assurance, un notaire ou une vente.</p>
            <div class="mt-5 pt-5 border-t border-[#F0F0F0] space-y-2.5">
              {[['Inspection caméra HD', 'dès 60 €'], ['Contrôle de vacuité', 'dès 60 €'], ['Diagnostic de sécurité', 'sur devis'], ['Rapport illustré inclus', '✓']].map(([l, p]) => (
                <div class="flex items-center justify-between">
                  <span class="text-xs text-[#1A1A1A]/80 font-light">{l}</span>
                  <span class="text-xs font-semibold text-[#1A1A1A]">{p}</span>
                </div>
              ))}
            </div>
            <span class="mt-6 inline-flex items-center gap-1.5 text-xs font-semibold text-[#C4B5AC] group-hover:gap-2.5 transition-all duration-200">
              Voir les prestations <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>

        <!-- Réhabilitation — gris foncé -->
        <a href="/tubage" class="group flex flex-col bg-[#F9F6F3] rounded-2xl border border-[#D0C8C0] overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <div class="relative bg-[#CDD5E0] px-7 pt-7 pb-5 overflow-hidden">
            <span class="absolute right-4 top-2 text-[5rem] font-black text-[#1C1917]/10 leading-none select-none">03</span>
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#1C1917]/75 mb-3 relative z-10">Réhabilitation</p>
            <p class="text-3xl font-extrabold text-[#1C1917] relative z-10">Sur devis</p>
            <p class="text-[11px] text-[#1C1917]/70 font-light relative z-10">Étude gratuite</p>
          </div>
          <div class="p-7 flex flex-col flex-1">
            <h3 class="text-lg font-bold text-[#1A1A1A] mb-2">Tubage, Pose de Conduit & Accessoires</h3>
            <p class="text-sm text-[#1A1A1A]/85 font-light leading-relaxed">Mise aux normes DTU 24.1, installation neuve et équipements toiture — pour sécuriser et pérenniser votre installation.</p>
            <div class="mt-5 pt-5 border-t border-[#F0F0F0] space-y-2.5">
              {[['Tubage rigide & flexible', 'sur devis'], ['Pose conduit métallique', 'sur devis'], ['Chapeaux anti-refoulement', 'sur devis'], ['Étude technique gratuite', '✓']].map(([l, p]) => (
                <div class="flex items-center justify-between">
                  <span class="text-xs text-[#1A1A1A]/80 font-light">{l}</span>
                  <span class="text-xs font-semibold text-[#1A1A1A]">{p}</span>
                </div>
              ))}
            </div>
            <span class="mt-6 inline-flex items-center gap-1.5 text-xs font-semibold text-[#C4B5AC] group-hover:gap-2.5 transition-all duration-200">
              Voir les prestations <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>

      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       ENGAGEMENT — Image + 4 mini-cards
  ═══════════════════════════════════════════════ -->
  <section class="py-28 px-6 md:px-10 bg-[#F2EDE8] border-t border-[#EEEEEE]">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <div class="relative order-2 lg:order-1">
        <Image
          src={interiorImg}
          alt="Cheminée en brique dans un intérieur chaleureux — entretien annuel certifié"
          width={800}
          height={600}
          class="w-full rounded-2xl object-cover aspect-[4/3]"
          loading="lazy"
        />
      </div>

      <div class="order-1 lg:order-2">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#C4B5AC] mb-5"><span class="inline-block w-1.5 h-1.5 rounded-full bg-[#C4B5AC] mr-2 mb-0.5"></span>Notre engagement</p>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-[#1A1A1A] leading-tight mb-4">
          Un seul artisan.<br />Un travail fait bien.
        </h2>
        <div class="w-10 h-0.5 bg-[#C4B5AC]/25 mb-6"></div>
        <p class="text-base text-[#1A1A1A]/85 font-light leading-relaxed mb-8">
          Basé à Martigues, j'interviens seul chez vous — avec soin, ponctualité et respect de votre foyer.
        </p>
        <div class="space-y-3">
          {[
            { t: 'Chantier propre garanti',     d: 'Protection du sol et nettoyage complet après chaque intervention, sans trace.' },
            { t: 'Certificat RSD 13 immédiat',  d: 'Document officiel remis sur place, valide auprès de votre assurance.' },
            { t: 'Assuré RC Pro',               d: 'Couverture complète pour toutes mes interventions.' },
            { t: 'Artisan local, sous 48h',     d: 'Basé à Martigues, je connais votre secteur et interviens rapidement.' },
          ].map(({ t, d }, i) => (
            <div class="relative bg-[#F9F6F3] border border-[#EEEEEE] rounded-xl px-6 py-5 overflow-hidden">
              <div class="absolute top-0 left-0 w-[3px] h-full bg-[#E8DDD4] rounded-l-xl"></div>
              <div class="flex items-center gap-4">
                <span class="text-3xl font-black text-[#A8A29E] leading-none shrink-0 w-8 text-right">{String(i + 1)}</span>
                <div>
                  <p class="text-sm font-bold text-[#1A1A1A]">{t}</p>
                  <p class="text-xs text-[#1A1A1A]/80 font-light mt-1 leading-relaxed">{d}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       TÉMOIGNAGES
  ═══════════════════════════════════════════════ -->
  <section class="py-28 px-6 md:px-10 bg-[#F9F6F3] border-t border-[#EEEEEE]">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#C4B5AC] mb-5"><span class="inline-block w-1.5 h-1.5 rounded-full bg-[#C4B5AC] mr-2 mb-0.5"></span>Ils nous font confiance</p>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-[#1A1A1A]">Témoignages Clients.</h2>
        <div class="w-10 h-0.5 bg-[#C4B5AC]/25 mt-4 mb-4"></div>
        <p class="text-base text-[#1A1A1A]/80 font-light">Ils nous ont fait confiance sur Martigues et la Côte Bleue.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { q: 'Intervention rapide et soignée sur ma cheminée à Sausset-les-Pins. Le certificat m\'a été remis dans la foulée. Enfin un artisan qui respecte son engagement.', n: 'Jean-Luc M.', l: 'Sausset-les-Pins · Foyer ouvert' },
          { q: 'Mon poêle à granulés n\'avait pas été entretenu depuis 3 ans — tout démonté, nettoyé et vérifié. Je le recommande sans hésiter à mes voisins d\'Istres.', n: 'Marie A.', l: 'Istres · Poêle à granulés' },
          { q: '14 appartements gérés, tous les certificats remis en une seule tournée avec un rapport consolidé. Un vrai partenaire professionnel.', n: 'Cabinet Immo Provence', l: 'Aix-en-Provence · 14 lots gérés' },
        ].map(({ q, n, l }) => (
          <div class="group bg-[#F9F6F3] border border-[#EEEEEE] rounded-2xl p-8 flex flex-col hover:shadow-xl hover:-translate-y-1 transition-all duration-300">

            <!-- Guillemet décoratif -->
            <span class="text-[4.5rem] leading-none text-[#C4B5AC]/15 font-serif select-none -mb-4">&ldquo;</span>

            <!-- Étoiles -->
            <div class="flex gap-1 mb-5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-[#C4B5AC]" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.033a1 1 0 00-1.175 0l-2.8 2.033c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>

            <!-- Citation -->
            <blockquote class="text-base text-[#1A1A1A]/85 font-light leading-relaxed italic flex-1 mb-8">
              {q}
            </blockquote>

            <!-- Auteur -->
            <div class="flex items-center gap-3 pt-5 border-t border-[#F0F0F0]">
              <div class="w-8 h-8 rounded-full bg-[#FFF3E0] flex items-center justify-center shrink-0">
                <span class="text-xs font-bold text-[#C4B5AC]">{n[0]}</span>
              </div>
              <div>
                <p class="text-sm font-bold text-[#1A1A1A]">{n}</p>
                <p class="text-[11px] text-[#1A1A1A]/85 font-light">{l}</p>
              </div>
            </div>

          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       ZONE + CONTACT
  ═══════════════════════════════════════════════ -->
  <section class="py-28 px-6 md:px-10 border-t border-[#EEEEEE] bg-[#F2EDE8]">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Zone gauche -->
      <div>
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#C4B5AC] mb-5"><span class="inline-block w-1.5 h-1.5 rounded-full bg-[#C4B5AC] mr-2 mb-0.5"></span>Zone d'intervention</p>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-[#1A1A1A] leading-tight mb-4">
          Martigues, Côte Bleue<br />& Étang de Berre.
        </h2>
        <div class="w-10 h-0.5 bg-[#C4B5AC]/25 mb-6"></div>
        <p class="text-sm text-[#1A1A1A]/85 font-light leading-relaxed mb-8">
          Basé à Martigues, j'interviens dans un rayon de 50 km — Côte Bleue, Étang de Berre, Pays d'Aix. Certificat conforme RSD 13 remis à l'issue de chaque visite.
        </p>

        <!-- Pastilles villes -->
        <div class="flex flex-wrap gap-2 mb-8">
          {[
            { label: 'Martigues',       slug: 'martigues' },
            { label: 'Istres',          slug: 'istres' },
            { label: 'Fos-sur-Mer',    slug: 'fos-sur-mer' },
            { label: 'Port-de-Bouc',   slug: 'port-de-bouc' },
            { label: 'Miramas',        slug: 'miramas' },
            { label: 'Sausset',        slug: 'sausset-les-pins' },
            { label: 'Carry-le-Rouet', slug: 'carry-le-rouet' },
            { label: 'Ensuès',         slug: 'ensues-la-redonne' },
          ].map(({ label, slug }) => (
            <a
              href={`/villes/${slug}`}
              class="inline-flex items-center gap-1.5 bg-[#F9F6F3] border border-[#E0E0E0] text-[#1A1A1A]/85 text-xs font-semibold px-4 py-2 rounded-lg hover:border-[#E8DDD4]/40 hover:text-[#C4B5AC] hover:shadow-sm transition-all duration-200"
            >
              {label}
            </a>
          ))}
        </div>

        <a href="/zones" class="inline-flex items-center gap-1.5 text-xs font-semibold text-[#C4B5AC] hover:gap-2.5 transition-all duration-200">
          Voir toutes les zones d'intervention
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Devis gratuit -->
      <div class="relative overflow-hidden rounded-2xl bg-[#F9F6F3] border border-[#EEEEEE] shadow-sm">
        <!-- Header coloré -->
        <div class="relative bg-[#CDD5E0] px-8 pt-8 pb-6 overflow-hidden">
          <span class="absolute right-4 top-0 text-[7rem] font-black text-[#1C1917]/8 leading-none select-none">24h</span>
          <p class="text-[10px] font-bold uppercase tracking-widest text-[#1C1917]/75 mb-3 relative z-10">Prendre rendez-vous</p>
          <p class="text-3xl font-extrabold tracking-tight text-[#1C1917] leading-tight relative z-10">Devis Gratuit.</p>
          <p class="text-sm text-[#1C1917]/40 font-light mt-1 relative z-10">Réponse assurée sous 24h</p>
        </div>

        <div class="px-8 py-7">
          <p class="text-xs text-[#1A1A1A]/80 font-light mb-7 leading-relaxed">Lundi au samedi, 8h–19h. Intervention disponible sous 48h sur Martigues et la Côte Bleue.</p>
          <a
            href="mailto:contact@sud-ramonage.fr?subject=Demande%20de%20devis%20ramonage"
            class="inline-flex items-center gap-1.5 text-xs font-semibold text-[#C4B5AC] hover:gap-2.5 transition-all duration-200"
          >
            Écrire un message <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FAQ
  ═══════════════════════════════════════════════ -->
  <FAQ
    title="Vos Questions."
    items={[
      {
        q: "Le ramonage est-il vraiment obligatoire à Martigues ?",
        a: "Oui. Le RSD 13 impose un ramonage annuel pour tout conduit de fumée actif — cheminée, insert, poêle à bois ou granulés. Sans certificat valide, votre assureur peut refuser toute indemnisation en cas de sinistre.",
      },
      {
        q: "Quel est le tarif d'un ramonage ?",
        a: "À partir de 75 € pour une cheminée à foyer ouvert, 90 € pour un insert ou poêle à bois, 110 € pour un poêle à granulés. Certificat RSD 13 toujours inclus. Devis gratuit sous 24h.",
      },
      {
        q: "Qu'est-ce que le bistre et pourquoi est-ce dangereux ?",
        a: "Le bistre est un dépôt de goudron formé lors de combustion incomplète. Hautement inflammable, c'est la première cause d'incendie de conduit en France. Le ramonage classique ne l'élimine pas — un débistrage chimique et mécanique est nécessaire.",
      },
      {
        q: "Locataire ou propriétaire : qui doit payer le ramonage ?",
