---
import Layout from '../layouts/Layout.astro';
import ContactButton from '../components/ContactButton.astro';
import EmailButton from '../components/EmailButton.astro';
import TrustBadge from '../components/TrustBadge.astro';
import FAQ from '../components/FAQ.astro';
import COSTICBadge from '../components/COSTICBadge.astro';
import LatestArticles from '../components/LatestArticles.astro';
import { Image, getImage } from 'astro:assets';

// ─── Images locales ───────────────────────────────────────────────────────────
import heroImg      from '../assets/images/hero-poele.jpg';
import ramonageImg  from '../assets/images/service-ramonage.jpg';
import bistrageImg  from '../assets/images/service-bistrage.jpg';
import controleImg  from '../assets/images/service-controle.jpg';
import artisanImg   from '../assets/images/artisan-intervention.jpg';

// Preload LCP : récupère l'URL optimisée de l'image hero pour <link rel="preload">
const optimizedHero = await getImage({ src: heroImg, width: 1920, height: 1080, format: 'webp' });
---

<Layout
  title="Sud Ramonage — Artisan Ramoneur Certifié à Martigues & Côte Bleue"
  description="Artisan ramoneur certifié à Martigues. Ramonage cheminée, poêle à bois et granulés, débistrage, contrôle technique. Certificat immédiat. Assurance pro. Conforme RSD 13."
  canonical="https://www.sud-ramonage.fr/"
  preloadImageHref={optimizedHero.src}
>

  <!-- ═══════════════════════════════════════════════
       HERO — Image de fond avec overlay
  ═══════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex flex-col items-center justify-center text-center pt-16 pb-24 px-6 md:px-10 overflow-hidden">

    <!-- Image de fond optimisée en WebP par Astro -->
    <div class="absolute inset-0 z-0">
      <Image
        src={heroImg}
        alt="Poêle à bois moderne dans un intérieur chaleureux"
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <!-- Overlay sombre progressif — fond plus léger en bas pour le glassmorphisme -->
      <div class="absolute inset-0 bg-gradient-to-b from-[#1A1A1A]/82 via-[#1A1A1A]/65 to-[#1A1A1A]/40"></div>
    </div>

    <!-- Contenu texte -->
    <div class="relative z-10 max-w-3xl mx-auto">

      <!-- Badge localisation -->
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 text-white text-[11px] font-semibold px-4 py-2 rounded-full mb-8">
        <svg class="w-3.5 h-3.5 shrink-0 text-[#E65100]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        VOTRE ARTISAN RAMONEUR À MARTIGUES & CÔTE BLEUE
      </div>

      <h1 class="text-[clamp(2.4rem,6.5vw,5rem)] font-extrabold tracking-tight text-white leading-[1.08] mb-6 drop-shadow-lg">
        SUD RAMONAGE :<br />L'Art de la Sécurité.
      </h1>

      <p class="text-base md:text-lg text-white/75 font-light max-w-lg mx-auto leading-relaxed mb-10">
        <strong class="text-white font-semibold">Sud Ramonage</strong> — artisan certifié <strong class="text-white font-semibold">COSTIC</strong> basé à Martigues. Certificat officiel conforme <strong class="text-white font-semibold">NF DTU 24.1</strong> et <strong class="text-white font-semibold">RSD&nbsp;13</strong> remis à l'issue de chaque intervention — valable auprès de votre assureur.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-6">
        <!-- CTA principal : Appeler l'Expert (Orange) -->
        <a
          href="tel:+33664729600"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2.5 bg-[#E65100] hover:bg-[#BF360C] active:bg-[#8A2200] active:scale-[0.97] text-white text-sm font-extrabold px-8 py-4 rounded-xl shadow-lg shadow-[#E65100]/30 transition-all duration-150 touch-manipulation"
          aria-label="Appeler l'expert ramoneur — 06 64 72 96 00"
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Appeler l'Expert
          <span class="text-white/70 font-normal text-xs">06 64 72 96 00</span>
        </a>
        <!-- CTA secondaire : Audit Email (Anthracite) -->
        <a
          href="mailto:majeo@ik.me?subject=Demande%20d%27audit%20fumisterie&body=Bonjour%2C%20je%20souhaite%20un%20audit%20de%20mon%20installation.%20"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2.5 bg-[#2D2D2D]/90 hover:bg-[#1A1A1A] border border-white/15 backdrop-blur-sm text-white text-sm font-semibold px-8 py-4 rounded-xl transition-all duration-150"
          aria-label="Demander un audit fumisterie par email"
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Audit Email
        </a>
      </div>

      <!-- Badge de confiance hero -->
      <TrustBadge variant="hero" class="mt-2" />

    </div>

    <!-- Flèche scroll — remontée au-dessus de la trust bar -->
    <div class="absolute bottom-28 left-1/2 -translate-x-1/2 z-10 animate-bounce">
      <svg class="w-5 h-5 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>

  </section>

  <!-- ═══════════════════════════════════════════════
       TRUST-BAR PREMIUM — Overlap hero + glassmorphisme
  ═══════════════════════════════════════════════ -->
  <section class="relative z-10 -mt-16 sm:-mt-20 lg:-mt-24 px-4 sm:px-6 md:px-10 pb-2">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">

        <!-- Carte 1 — COSTIC Certifié -->
        <a href="/ramonage" class="group relative bg-[#0c0c0c]/90 backdrop-blur-2xl rounded-2xl p-5 md:p-6 border border-white/8 shadow-2xl shadow-black/70 hover:-translate-y-2 transition-all duration-300 overflow-hidden block" style="border-left: 3px solid #1A4B8F">
          <div class="absolute -top-10 -right-10 w-28 h-28 bg-[#1A4B8F]/12 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></div>
          <div class="w-11 h-11 rounded-xl bg-[#1A4B8F]/15 flex items-center justify-center mb-4 group-hover:bg-[#1A4B8F]/25 transition-colors duration-300">
            <svg class="w-5 h-5 text-[#4A90D9]" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="8" r="6"/>
              <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
            </svg>
          </div>
          <p class="text-xl md:text-2xl font-extrabold text-white tracking-tight leading-none mb-1">COSTIC</p>
          <p class="text-[10px] font-bold text-[#4A90D9] uppercase tracking-widest mb-2.5">Certifié Fumisterie</p>
          <p class="text-[11px] text-white/40 font-light leading-relaxed">Formation COSTIC + Qualibat 6521. Normes NF DTU 24.1 maîtrisées.</p>
        </a>

        <!-- Carte 2 — Caméra HD -->
        <a href="/inspection-camera" class="group relative bg-[#0c0c0c]/90 backdrop-blur-2xl rounded-2xl p-5 md:p-6 border border-white/8 shadow-2xl shadow-black/70 hover:-translate-y-2 transition-all duration-300 overflow-hidden block" style="border-left: 3px solid #E65100">
          <div class="absolute -top-10 -right-10 w-28 h-28 bg-[#E65100]/8 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></div>
          <div class="w-11 h-11 rounded-xl bg-[#E65100]/12 flex items-center justify-center mb-4 group-hover:bg-[#E65100]/20 transition-colors duration-300">
            <svg class="w-5 h-5 text-[#E65100]" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M15 10l4.553-2.069A1 1 0 0121 8.868V15.13a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/>
            </svg>
          </div>
          <p class="text-xl md:text-2xl font-extrabold text-white tracking-tight leading-none mb-1">Caméra HD</p>
          <p class="text-[10px] font-bold text-[#E65100] uppercase tracking-widest mb-2.5">Inspection vidéo</p>
          <p class="text-[11px] text-white/40 font-light leading-relaxed">Diagnostic endoscopique. Rapport photo. Fissures invisibles révélées.</p>
        </a>

        <!-- Carte 3 — Conformité RSD 13 -->
        <div class="group relative bg-[#0c0c0c]/90 backdrop-blur-2xl rounded-2xl p-5 md:p-6 border border-white/8 shadow-2xl shadow-black/70 hover:-translate-y-2 transition-all duration-300 overflow-hidden" style="border-left: 3px solid #E65100">
          <div class="absolute -top-10 -right-10 w-28 h-28 bg-[#E65100]/8 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></div>
          <div class="w-11 h-11 rounded-xl bg-[#E65100]/12 flex items-center justify-center mb-4 group-hover:bg-[#E65100]/20 transition-colors duration-300">
            <svg class="w-5 h-5 text-[#E65100]" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path d="m9 12 2 2 4-4"/>
            </svg>
          </div>
          <p class="text-xl md:text-2xl font-extrabold text-white tracking-tight leading-none mb-1">Assuré RC Pro</p>
          <p class="text-[10px] font-bold text-[#E65100] uppercase tracking-widest mb-2.5">Certificat RSD 13</p>
          <p class="text-[11px] text-white/40 font-light leading-relaxed">Certificat officiel délivré après chaque intervention. Assurance RC Pro incluse.</p>
        </div>

        <!-- Carte 4 — Disponibilité 6j/7 -->
        <div class="group relative bg-[#0c0c0c]/90 backdrop-blur-2xl rounded-2xl p-5 md:p-6 border border-white/8 shadow-2xl shadow-black/70 hover:-translate-y-2 transition-all duration-300 overflow-hidden" style="border-left: 3px solid #E65100">
          <div class="absolute -top-10 -right-10 w-28 h-28 bg-[#E65100]/8 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></div>
          <div class="w-11 h-11 rounded-xl bg-[#E65100]/12 flex items-center justify-center mb-4 group-hover:bg-[#E65100]/20 transition-colors duration-300">
            <svg class="w-5 h-5 text-[#E65100]" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2"/>
              <path d="M16 2v4M8 2v4M3 10h18"/>
              <path d="m9 16 2 2 4-4"/>
            </svg>
          </div>
          <p class="text-xl md:text-2xl font-extrabold text-white tracking-tight leading-none mb-1">6j / 7</p>
          <p class="text-[10px] font-bold text-[#E65100] uppercase tracking-widest mb-2.5">Intervention rapide</p>
          <p class="text-[11px] text-white/40 font-light leading-relaxed">Lundi au samedi, 8h-19h. Déplacement sur 50 km autour de Martigues.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION COSTIC — Certification & confiance
  ═══════════════════════════════════════════════ -->
  <section class="py-16 px-6 md:px-10 border-b border-[#EEEEEE]">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <div>
          <!-- Logo COSTIC officiel — section certification -->
          <COSTICBadge variant="hero" class="mb-6" />
          <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-4">
            Formé aux dernières normes<br />de sécurité fumisterie.
          </h2>
          <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed">
            La certification COSTIC atteste d'une formation rigoureuse aux techniques de fumisterie, à la réglementation en vigueur (NF DTU 24.1, RSD 13) et aux méthodes de diagnostic avancées. Ce n'est pas une simple attestation — c'est la garantie que votre artisan maîtrise les normes qui protègent votre famille.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-4">
          {[
            {
              icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
              titre: 'Maîtrise des normes NF DTU 24.1',
              desc: 'Distances de sécurité, obligations de tubage, conformité des installations — appliquées à chaque intervention.',
            },
            {
              icon: 'M15 10l4.553-2.069A1 1 0 0121 8.868V15.13a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z',
              titre: 'Diagnostic avancé par caméra HD',
              desc: 'Formation aux techniques d\'inspection vidéo endoscopique pour détecter fissures et anomalies invisibles à l\'œil nu.',
            },
            {
              icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
              titre: 'Prévention CO & risques incendie',
              desc: 'Bonnes pratiques de combustion, détection des situations à risque, conseils de prévention au client après chaque intervention.',
            },
          ].map(({ icon, titre, desc }) => (
            <div class="flex gap-4 bg-[#FAFAFA] rounded-xl p-4 border border-[#EEEEEE]">
              <div class="w-9 h-9 rounded-lg bg-[#1A4B8F]/8 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-4.5 h-4.5 text-[#1A4B8F]" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                  <path d={icon} />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-[#1A1A1A] mb-1">{titre}</p>
                <p class="text-xs text-[#1A1A1A]/55 font-light leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SIMULATEUR ÉCO-RENDEMENT
  ═══════════════════════════════════════════════ -->
  <section class="py-16 px-6 md:px-10 bg-gradient-to-br from-[#1A1A1A] to-[#2D1A00] text-white">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-[#E65100]/20 border border-[#E65100]/30 text-[#E65100] text-[11px] font-bold px-4 py-2 rounded-full mb-5 uppercase tracking-widest">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            Simulateur COSTIC — Calcul d'économies
          </div>
          <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-white mb-4">
            Combien pouvez-vous<br />économiser par an ?
          </h2>
          <p class="text-sm text-white/60 leading-relaxed mb-6">
            Un conduit certifié COSTIC améliore le rendement de votre appareil de <strong class="text-white">8 à 15 %</strong> en moyenne. Calculez votre économie estimée en quelques secondes.
          </p>
          <p class="text-[11px] text-white/35 leading-relaxed">
            Calcul basé sur un gain moyen de rendement de 12 % (source COSTIC — Fiche Technique FT 002). Résultat indicatif, non contractuel.
          </p>
        </div>

        <div class="bg-white/8 backdrop-blur-sm border border-white/12 rounded-2xl p-8">
          <label for="budget-bois" class="block text-sm font-semibold text-white mb-2">
            Votre budget bois / granulés annuel (€)
          </label>
          <div class="relative mb-3">
            <input
              type="range"
              id="budget-slider"
              min="200"
              max="3000"
              step="50"
              value="800"
              class="w-full h-2 bg-white/20 rounded-full appearance-none cursor-pointer accent-[#E65100] mb-4"
              aria-label="Budget bois annuel en euros"
            />
          </div>
          <div class="flex items-center gap-3 mb-6">
            <input
              type="number"
              id="budget-bois"
              min="100"
              max="5000"
              value="800"
              class="w-32 bg-white/10 border border-white/20 text-white font-bold text-lg text-center rounded-xl px-3 py-2.5 focus:outline-none focus:border-[#E65100] transition-colors"
              aria-label="Budget bois annuel"
            />
            <span class="text-white/60 text-sm font-medium">€ / an</span>
          </div>

          <div class="bg-[#E65100]/15 border border-[#E65100]/30 rounded-xl p-5 mb-5">
            <p class="text-[11px] font-bold uppercase tracking-widest text-[#E65100] mb-1">Économie estimée</p>
            <p class="text-4xl font-extrabold text-white mb-1"><span id="eco-value">96</span> €</p>
            <p class="text-xs text-white/50" id="eco-detail">par an · 12 % de gain sur 800 €</p>
          </div>

          <p class="text-xs text-white/50 text-center mb-4" id="eco-phrase">
            Économisez jusqu'à <strong class="text-white">96 €</strong> par an grâce à un conduit certifié COSTIC.
          </p>

          <a
            href="tel:+33664729600"
            class="flex items-center justify-center gap-2 bg-[#E65100] hover:bg-[#BF360C] text-white text-sm font-bold px-6 py-3.5 rounded-xl transition-colors shadow-lg shadow-[#E65100]/25 w-full"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Réaliser ces économies — 06 64 72 96 00
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       GALERIE SERVICES — 3 cartes avec photo
  ═══════════════════════════════════════════════ -->
  <section id="services" class="py-24 px-6 md:px-10">
    <div class="max-w-6xl mx-auto">

      <div class="mb-14 text-center">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-4">Ce que nous faisons</p>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-[#1A1A1A]">Nos Prestations</h2>
        <p class="text-sm text-[#1A1A1A]/45 font-light mt-3 max-w-md mx-auto">
          Chaque intervention est réalisée avec soin et se conclut par la remise d'un certificat officiel.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Carte 1 — Ramonage certifié -->
        <a href="/ramonage" class="group bg-white border border-[#EEEEEE] rounded-xl overflow-hidden hover:shadow-lg hover:border-[#E65100]/20 hover:-translate-y-1 transition-all duration-300 block">
          <!-- Photo service (remplaçable : src/assets/images/service-ramonage.jpg) -->
          <div class="aspect-[4/3] overflow-hidden bg-[#F5F5F5]">
            <Image
              src={ramonageImg}
              alt="Conduit de cheminée en brique — ramonage certifié Martigues"
              width={600}
              height={450}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-7">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-9 h-9 rounded-lg bg-[#FFF3E0] flex items-center justify-center shrink-0">
                <!-- Icône flamme -->
                <svg class="w-5 h-5 text-[#E65100]" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/>
                </svg>
              </div>
              <p class="text-[10px] font-semibold tracking-widest uppercase text-[#E65100]">01 — Ramonage</p>
            </div>
            <h3 class="text-lg font-bold tracking-tight text-[#1A1A1A] mb-3">Ramonage Certifié</h3>
            <p class="text-sm text-[#1A1A1A]/55 leading-relaxed font-light mb-5">
              Ramonage mécanique complet de votre conduit, cheminée, insert ou poêle. <strong class="font-medium text-[#1A1A1A]/75">Certificat officiel</strong> remis à l'issue — exigé par les assurances et le RSD 13.
            </p>
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-[#E65100] group-hover:gap-3 transition-all duration-200">
              Protocole de ramonage certifié RSD&nbsp;13
