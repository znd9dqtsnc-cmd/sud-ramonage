<script>
  const slider = document.getElementById('budget-slider') as HTMLInputElement | null;
  const input = document.getElementById('budget-bois') as HTMLInputElement | null;
  const ecoValue = document.getElementById('eco-value');
  const ecoDetail = document.getElementById('eco-detail');
  const ecoPhrase = document.getElementById('eco-phrase');

  function calcEco(budget: number): number {
    return Math.round(budget * 0.12);
  }

  function update(budget: number) {
    const eco = calcEco(budget);
    if (ecoValue) ecoValue.textContent = eco.toString();
    if (ecoDetail) ecoDetail.textContent = `par an · 12 % de gain sur ${budget} €`;
    if (ecoPhrase) ecoPhrase.innerHTML = `Économisez jusqu'à <strong class="text-white">${eco} €</strong> par an grâce à un conduit certifié COSTIC.`;
  }

  slider?.addEventListener('input', () => {
    const v = parseInt(slider.value);
    if (input) input.value = v.toString();
    update(v);
  });

  input?.addEventListener('input', () => {
    const v = Math.min(5000, Math.max(100, parseInt(input.value) || 0));
    if (slider) slider.value = Math.min(3000, Math.max(200, v)).toString();
    update(v);
  });
</script>
