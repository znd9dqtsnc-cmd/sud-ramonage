---
import Layout from '../layouts/Layout.astro';
import ContactButton from '../components/ContactButton.astro';
import EmailButton from '../components/EmailButton.astro';
import TrustBadge from '../components/TrustBadge.astro';
import FAQ from '../components/FAQ.astro';
import LatestArticles from '../components/LatestArticles.astro';
import { Image, getImage } from 'astro:assets';

import heroImg      from '../assets/images/hero-poele.jpg';
import ramonageImg  from '../assets/images/service-ramonage.jpg';
import bistrageImg  from '../assets/images/service-bistrage.jpg';
import controleImg  from '../assets/images/service-controle.jpg';
import artisanImg   from '../assets/images/artisan-intervention.jpg';

const optimizedHero = await getImage({ src: heroImg, width: 1920, height: 1080, format: 'webp' });
---

<Layout
  title="Sud Ramonage — Artisan Ramoneur Certifié à Martigues & Côte Bleue"
  description="Artisan ramoneur certifié à Martigues. Ramonage cheminée, poêle à bois et granulés, débistrage, contrôle technique. Certificat immédiat. Assurance pro. Conforme RSD 13."
  canonical="https://www.sud-ramonage.fr/"
  preloadImageHref={optimizedHero.src}
>

  <!-- ═══════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex flex-col items-center justify-center text-center pt-16 pb-24 px-6 md:px-10 overflow-hidden">

    <div class="absolute inset-0 z-0">
      <Image
        src={heroImg}
        alt="Poêle à bois moderne dans un intérieur chaleureux"
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#0F172A]/68 via-[#0F172A]/45 to-[#0F172A]/15"></div>
    </div>

    <div class="relative z-10 max-w-2xl mx-auto text-center">

      <h1 class="text-[clamp(3rem,7.5vw,5.5rem)] font-extrabold tracking-tight text-white leading-[1.05] mb-2 drop-shadow-md">
        SUD RAMONAGE
      </h1>

      <p class="text-xl md:text-2xl font-light italic text-white/85 mb-4 tracking-wide">
        L'Art de la Sécurité
      </p>

      <p class="text-sm text-white/60 font-light mb-10">
        Artisan ramoneur certifié à Martigues &amp; Côte Bleue.
      </p>

      <a
        href="#tarifs"
        class="inline-flex items-center gap-2 bg-[#1E293B]/75 hover:bg-[#1E293B] border border-white/20 backdrop-blur-sm text-white text-sm font-medium px-8 py-3.5 rounded-xl transition-all duration-200"
      >
        Découvrir nos prestations
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </a>

    </div>

  </section>

  <!-- ═══════════════════════════════════════════════
       TARIFS — 3 cartes par type d'appareil
  ═══════════════════════════════════════════════ -->
  <section id="tarifs" class="py-20 px-6 md:px-10 bg-[#F8FAFC]">
    <div class="max-w-5xl mx-auto">

      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-[#1E293B] mb-3">Tarifs — certificat inclus</h2>
        <p class="text-sm text-[#64748B] font-light max-w-lg mx-auto">
          Chaque intervention comprend le ramonage mécanique, le test de vacuité et la remise du certificat officiel conforme RSD 13.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">

        <!-- Cheminée / Foyer Ouvert -->
        <div class="bg-white border border-[#E2E8F0] rounded-2xl overflow-hidden shadow-sm">
          <div class="px-6 pt-7 pb-5 border-b border-[#F1F5F9]">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#64748B] mb-3">Cheminée / Foyer ouvert</p>
            <div class="flex items-baseline gap-1">
              <span class="text-5xl font-extrabold text-[#1E293B] tracking-tight">75</span>
              <span class="text-2xl font-light text-[#94A3B8]">€</span>
            </div>
            <p class="text-xs text-[#94A3B8] mt-1.5">tarif unique · certificat inclus</p>
          </div>
          <ul class="px-6 py-6 space-y-3">
            {[
              'Ramonage mécanique du conduit',
              'Test de vacuité (absence d\'obstruction)',
              'Contrôle du tirage thermique',
              'Nettoyage du foyer et de la plaque',
              'Certificat officiel RSD 13',
            ].map(item => (
              <li class="flex items-start gap-2.5 text-sm text-[#334155]">
                <svg class="w-4 h-4 text-[#16A34A] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Insert / Poêle à bois -->
        <div class="bg-white border border-[#1E293B]/20 rounded-2xl overflow-hidden shadow-md relative">
          <div class="absolute top-4 right-4">
            <span class="text-[10px] font-bold bg-[#1E293B] text-white px-2.5 py-1 rounded-full uppercase tracking-wider">Le plus demandé</span>
          </div>
          <div class="px-6 pt-7 pb-5 border-b border-[#F1F5F9]">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#64748B] mb-3">Insert / Poêle à bois</p>
            <div class="flex items-baseline gap-1">
              <span class="text-5xl font-extrabold text-[#1E293B] tracking-tight">90</span>
              <span class="text-2xl font-light text-[#94A3B8]">€</span>
            </div>
            <p class="text-xs text-[#94A3B8] mt-1.5">tarif unique · certificat inclus</p>
          </div>
          <ul class="px-6 py-6 space-y-3">
            {[
              'Ramonage mécanique du conduit',
              'Test de vacuité et contrôle du tirage',
              'Vérification joints de porte et raccordement',
              'Nettoyage chambre de combustion',
              'Certificat officiel RSD 13',
            ].map(item => (
              <li class="flex items-start gap-2.5 text-sm text-[#334155]">
                <svg class="w-4 h-4 text-[#16A34A] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Poêle à Granulés -->
        <div class="bg-white border border-[#E2E8F0] rounded-2xl overflow-hidden shadow-sm">
          <div class="px-6 pt-7 pb-5 border-b border-[#F1F5F9]">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#64748B] mb-3">Poêle à Granulés</p>
            <div class="flex items-baseline gap-1">
              <span class="text-5xl font-extrabold text-[#1E293B] tracking-tight">120</span>
              <span class="text-2xl font-light text-[#94A3B8]">€</span>
            </div>
            <p class="text-xs text-[#94A3B8] mt-1.5">entretien complet · certificat inclus</p>
          </div>
          <ul class="px-6 py-6 space-y-3">
            {[
              'Ramonage du conduit d\'évacuation',
              'Nettoyage brûleur et chambre de combustion',
              'Contrôle ventilateur et capteurs de température',
              'Vérification vis sans fin et alimentation',
              'Certificat officiel RSD 13',
            ].map(item => (
              <li class="flex items-start gap-2.5 text-sm text-[#334155]">
                <svg class="w-4 h-4 text-[#16A34A] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

      </div>

      <div class="text-center space-y-4">
        <a
          href="tel:+33664729600"
          class="inline-flex items-center gap-2.5 bg-[#1E293B] hover:bg-[#0F172A] text-white text-sm font-semibold px-8 py-3.5 rounded-xl transition-colors duration-200 shadow-sm"
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Prendre rendez-vous — 06 64 72 96 00
        </a>
        <p class="text-xs text-[#94A3B8]">TVA non applicable — Art. 293 B du CGI · Déplacement inclus sur 30 km · Devis gratuit sous 24h</p>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       RÉASSURANCE — 4 blocs horizontaux
  ═══════════════════════════════════════════════ -->
  <section class="py-10 px-6 md:px-10 bg-white border-b border-[#EEEEEE]">
    <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6">

      {[
        {
          icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
          titre: 'Certifié COSTIC',
          desc: 'Normes NF DTU 24.1 & Qualibat 6521',
        },
        {
          icon: 'M15 10l4.553-2.069A1 1 0 0121 8.868V15.13a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z',
          titre: 'Inspection caméra',
          desc: 'Diagnostic vidéo HD sur demande',
        },
        {
          icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10zm0 0v-9m0 4l-3-3m3 3l3-3',
          titre: 'Assuré RC Pro',
          desc: 'Certificat officiel remis sur place',
        },
        {
          icon: 'M5 13l4 4L19 7',
          titre: 'Intervention soignée',
          desc: 'Protection des sols, départ propre',
        },
      ].map(({ icon, titre, desc }) => (
        <div class="flex flex-col items-center text-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-[#F1F5F9] flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-[#475569]" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <path d={icon} />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-[#1E293B]">{titre}</p>
            <p class="text-xs text-[#94A3B8] mt-0.5 leading-relaxed">{desc}</p>
          </div>
        </div>
      ))}

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       GALERIE SERVICES — 3 cartes avec photo
  ═══════════════════════════════════════════════ -->
  <section id="services" class="py-24 px-6 md:px-10 bg-white">
    <div class="max-w-6xl mx-auto">

      <div class="mb-14 text-center">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-4">Ce que nous faisons</p>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-[#1E293B]">Nos Prestations</h2>
        <p class="text-sm text-[#1A1A1A]/45 font-light mt-3 max-w-md mx-auto">
          Chaque intervention est réalisée avec soin et se conclut par la remise d'un certificat officiel.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <a href="/ramonage" class="group bg-white border border-[#EEEEEE] rounded-xl overflow-hidden hover:shadow-lg hover:border-[#E65100]/20 hover:-translate-y-1 transition-all duration-300 block">
          <div class="aspect-[4/3] overflow-hidden bg-[#F5F5F5]">
            <Image src={ramonageImg} alt="Conduit de cheminée en brique — ramonage certifié Martigues" width={600} height={450} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-7">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-9 h-9 rounded-lg bg-[#FFF3E0] flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#E65100]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/></svg>
              </div>
              <p class="text-[10px] font-semibold tracking-widest uppercase text-[#E65100]">01 — Ramonage</p>
            </div>
            <h3 class="text-lg font-bold tracking-tight text-[#1E293B] mb-3">Ramonage Certifié</h3>
            <p class="text-sm text-[#1A1A1A]/55 leading-relaxed font-light mb-5">
              Ramonage mécanique complet de votre conduit, cheminée, insert ou poêle. <strong class="font-medium text-[#1A1A1A]/75">Certificat officiel</strong> remis à l'issue — exigé par les assurances et le RSD 13.
            </p>
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-[#E65100] group-hover:gap-3 transition-all duration-200">
              Protocole de ramonage certifié RSD&nbsp;13
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </a>

        <a href="/debistrage" class="group bg-white border border-[#EEEEEE] rounded-xl overflow-hidden hover:shadow-lg hover:border-[#E65100]/20 hover:-translate-y-1 transition-all duration-300 block">
          <figure class="aspect-[4/3] overflow-hidden bg-[#F5F5F5]">
            <Image src={bistrageImg} alt="Dépôts de bistre dans un conduit de cheminée — débistrage professionnel Martigues" width={600} height={450} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            <figcaption class="sr-only">Débistrage professionnel à Martigues — élimination des dépôts de goudron et de bistre dans les conduits de cheminée. Traitement chimique et mécanique conforme RSD 13.</figcaption>
          </figure>
          <div class="p-7">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-9 h-9 rounded-lg bg-[#FFF3E0] flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#E65100]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
              </div>
              <p class="text-[10px] font-semibold tracking-widest uppercase text-[#E65100]">02 — Débistrage</p>
            </div>
            <h3 class="text-lg font-bold tracking-tight text-[#1E293B] mb-3">Débistrage</h3>
            <p class="text-sm text-[#1A1A1A]/55 leading-relaxed font-light mb-5">
              Élimination des dépôts de goudron hautement inflammables. Traitement <strong class="font-medium text-[#1A1A1A]/75">chimique et mécanique</strong> pour rétablir la sécurité totale de votre installation.
            </p>
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-[#E65100] group-hover:gap-3 transition-all duration-200">
              Traitement anti-bistre — élimination du goudron
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </a>

        <a href="/entretien-poele" class="group bg-white border border-[#EEEEEE] rounded-xl overflow-hidden hover:shadow-lg hover:border-[#E65100]/20 hover:-translate-y-1 transition-all duration-300 block">
          <figure class="aspect-[4/3] overflow-hidden bg-[#F5F5F5]">
            <Image src={controleImg} alt="Contrôle technique et test de vacuité d'un conduit de cheminée à Martigues" width={600} height={450} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            <figcaption class="sr-only">Contrôle technique conduit cheminée Martigues — test de vacuité, vérification étanchéité tubage inox, tirage thermique. Artisan certifié RSD 13 Bouches-du-Rhône.</figcaption>
          </figure>
          <div class="p-7">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-9 h-9 rounded-lg bg-[#FFF3E0] flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#E65100]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
              </div>
              <p class="text-[10px] font-semibold tracking-widest uppercase text-[#E65100]">03 — Diagnostic</p>
            </div>
            <h3 class="text-lg font-bold tracking-tight text-[#1E293B] mb-3">Contrôle Technique</h3>
            <p class="text-sm text-[#1A1A1A]/55 leading-relaxed font-light mb-5">
              Inspection complète : <strong class="font-medium text-[#1A1A1A]/75">vacuité</strong> (absence d'obstruction) et <strong class="font-medium text-[#1A1A1A]/75">étanchéité</strong> du conduit. Indispensable avant mise en service ou achat immobilier.
            </p>
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-[#E65100] group-hover:gap-3 transition-all duration-200">
              Contrôle vacuité conduit &amp; entretien corps de chauffe
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </a>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════
       SECTION COSTIC — Certification & confiance
  ═══════════════════════════════════════════════ -->
  <section class="py-16 px-6 md:px-10 bg-white border-t border-b border-[#EEEEEE]">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <div>
          <p class="inline-flex items-center gap-2 bg-[#EFF4FF] border border-[#BFDBFE] text-[#1A4B8F] text-[11px] font-bold px-4 py-2 rounded-full mb-6 uppercase tracking-widest">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            Certifié COSTIC — Fumisterie & Qualibat 6521
          </p>
          <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1E293B] mb-4">
            Formé aux dernières normes<br />de sécurité fumisterie.
          </h2>
          <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed">
            La certification COSTIC atteste d'une formation rigoureuse aux techniques de fumisterie, à la réglementation en vigueur (NF DTU 24.1, RSD 13) et aux méthodes de diagnostic avancées. Ce n'est pas une simple attestation — c'est la garantie que votre artisan maîtrise les normes qui protègent votre famille.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-4">
          {[
            {
              icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
              titre: 'Maîtrise des normes NF DTU 24.1',
              desc: 'Distances de sécurité, obligations de tubage, conformité des installations — appliquées à chaque intervention.',
            },
            {
              icon: 'M15 10l4.553-2.069A1 1 0 0121 8.868V15.13a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z',
              titre: 'Diagnostic avancé par caméra HD',
              desc: 'Formation aux techniques d\'inspection vidéo endoscopique pour détecter fissures et anomalies invisibles à l\'œil nu.',
            },
            {
              icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
              titre: 'Prévention CO & risques incendie',
              desc: 'Bonnes pratiques de combustion, détection des situations à risque, conseils de prévention au client après chaque intervention.',
            },
          ].map(({ icon, titre, desc }) => (
            <div class="flex gap-4 bg-[#F8FAFC] rounded-xl p-4 border border-[#EEEEEE]">
              <div class="w-9 h-9 rounded-lg bg-[#EFF4FF] flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-4.5 h-4.5 text-[#1A4B8F]" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                  <path d={icon} />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-[#1E293B] mb-1">{titre}</p>
                <p class="text-xs text-[#1A1A1A]/55 font-light leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       AUDIT TECHNIQUE — Rendement & Performance thermique
  ═══════════════════════════════════════════════ -->
