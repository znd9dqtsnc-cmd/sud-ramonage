---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';
import LatestArticles from '../components/LatestArticles.astro';
import { Image, getImage } from 'astro:assets';

import heroImg     from '../assets/images/hero-poele.jpg';
import ramonageImg from '../assets/images/service-ramonage.jpg';
import bistrageImg from '../assets/images/service-bistrage.jpg';
import controleImg from '../assets/images/service-controle.jpg';
import artisanImg  from '../assets/images/artisan-intervention.jpg';

const optimizedHero = await getImage({ src: heroImg, width: 1920, height: 1080, format: 'webp' });
---

<Layout
  title="Sud Ramonage — Artisan Ramoneur Certifié à Martigues"
  description="Artisan ramoneur certifié COSTIC à Martigues. Ramonage cheminée, insert, poêle, chaudière. Certificat RSD 13 immédiat. Assurance pro. Bouches-du-Rhône."
  canonical="https://www.sud-ramonage.fr/"
  preloadImageHref={optimizedHero.src}
>

  <!-- ═══ HERO ═══ -->
  <section class="relative min-h-screen flex items-end pb-20 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={heroImg}
        alt="Cheminée et poêle à bois — artisan ramoneur certifié Martigues"
        width={1920} height={1080}
        class="w-full h-full object-cover"
        loading="eager" fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[#0D1F1E]/90 via-[#0D1F1E]/50 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-10 w-full">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 border border-[#2B7A78]/50 bg-[#2B7A78]/15 backdrop-blur-sm text-[#5EEAD4] text-[11px] font-bold px-4 py-2 rounded-full mb-8 uppercase tracking-widest">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          Certifié COSTIC · Qualibat 6521 · RSD 13
        </div>
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-white leading-[1.0] mb-6">
          L'Art de la<br /><span class="text-[#5EEAD4]">Sécurité.</span>
        </h1>
        <p class="text-lg text-white/75 font-light leading-relaxed mb-10 max-w-2xl">
          Artisan ramoneur certifié à Martigues. Ramonage, diagnostic, entretien — certificat officiel remis sur place. Conforme RSD 13 et assurance habitation.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="tel:+33664729600" class="inline-flex items-center gap-2.5 bg-[#2B7A78] hover:bg-[#1F5F5C] text-white text-sm font-bold px-7 py-4 rounded-xl transition-colors shadow-lg shadow-[#2B7A78]/30">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            06 64 72 96 00 — Prendre RDV
          </a>
          <a href="#prestations" class="inline-flex items-center gap-2 border border-white/30 text-white text-sm font-medium px-7 py-4 rounded-xl hover:bg-white/10 hover:border-white/50 transition-all backdrop-blur-sm">
            Nos prestations ↓
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BANDE DE CONFIANCE — 4 pastels ═══ -->
  <section class="bg-white border-b border-[#F3F4F6]">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">

        <div class="flex items-start gap-3 bg-[#F0FDF4] border border-[#BBF7D0] rounded-2xl px-5 py-5">
          <div class="w-9 h-9 bg-[#DCFCE7] rounded-xl flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4.5 h-4.5 text-[#16A34A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <div>
            <p class="text-sm font-bold text-[#166534] leading-tight">Certifié COSTIC</p>
            <p class="text-xs text-[#166534]/65 mt-0.5 leading-tight">Fumisterie nationale · Qualibat 6521</p>
          </div>
        </div>

        <div class="flex items-start gap-3 bg-[#EFF6FF] border border-[#BFDBFE] rounded-2xl px-5 py-5">
          <div class="w-9 h-9 bg-[#DBEAFE] rounded-xl flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4.5 h-4.5 text-[#2563EB]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>
          </div>
          <div>
            <p class="text-sm font-bold text-[#1E40AF] leading-tight">RSD 13</p>
            <p class="text-xs text-[#1E40AF]/65 mt-0.5 leading-tight">Conformité Bouches-du-Rhône</p>
          </div>
        </div>

        <div class="flex items-start gap-3 bg-[#FFFBEB] border border-[#FDE68A] rounded-2xl px-5 py-5">
          <div class="w-9 h-9 bg-[#FEF3C7] rounded-xl flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4.5 h-4.5 text-[#D97706]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <div>
            <p class="text-sm font-bold text-[#92400E] leading-tight">Certificat immédiat</p>
            <p class="text-xs text-[#92400E]/65 mt-0.5 leading-tight">Remis sur place après intervention</p>
          </div>
        </div>

        <div class="flex items-start gap-3 bg-[#F0FDFC] border border-[#99F6E4] rounded-2xl px-5 py-5">
          <div class="w-9 h-9 bg-[#CCFBF1] rounded-xl flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4.5 h-4.5 text-[#2B7A78]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <p class="text-sm font-bold text-[#134E4A] leading-tight">RC Pro</p>
            <p class="text-xs text-[#134E4A]/65 mt-0.5 leading-tight">Assuré · attestation sur demande</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ PRESTATIONS — 3 CARTES PHOTO ═══ -->
  <section id="prestations" class="py-24 px-6 md:px-10 bg-[#F9F8F6]">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-end justify-between mb-14">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-[#2B7A78] mb-3">Ce que nous faisons</p>
          <h2 class="text-4xl font-extrabold tracking-tight text-[#111827]">Nos Prestations</h2>
          <p class="text-base text-[#4B5563] font-light mt-3 max-w-lg">Chaque intervention se conclut par la remise d'un certificat officiel — reconnu par toutes les assurances habitation.</p>
        </div>
        <a href="/particuliers" class="hidden md:inline-flex items-center gap-1.5 text-sm font-semibold text-[#4B5563] hover:text-[#2B7A78] transition-colors">
          Voir tout <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <a href="/particuliers#ramonage" class="group block overflow-hidden rounded-2xl bg-white border border-[#E5E7EB] hover:shadow-xl hover:shadow-black/6 hover:-translate-y-1.5 transition-all duration-300">
          <div class="aspect-[16/10] overflow-hidden">
            <Image src={ramonageImg} alt="Ramonage cheminée certifié Martigues" width={600} height={375} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-7">
            <div class="inline-flex items-center gap-1.5 bg-[#F0FDF4] border border-[#BBF7D0] text-[#166534] text-[10px] font-bold px-2.5 py-1 rounded-lg mb-4 uppercase tracking-wide">
              <span class="w-1.5 h-1.5 rounded-full bg-[#16A34A]"></span>Ramonage
            </div>
            <h3 class="text-xl font-bold text-[#111827] mb-3">Ramonage Certifié</h3>
            <p class="text-sm text-[#4B5563] leading-relaxed mb-5">Ramonage mécanique cheminée, insert, poêle à bois. Certificat officiel RSD 13 remis sur place — valable pour votre assurance habitation.</p>
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-[#2B7A78] group-hover:gap-3 transition-all">
              Découvrir <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>

        <a href="/particuliers#audit" class="group block overflow-hidden rounded-2xl bg-white border border-[#E5E7EB] hover:shadow-xl hover:shadow-black/6 hover:-translate-y-1.5 transition-all duration-300">
          <div class="aspect-[16/10] overflow-hidden">
            <Image src={controleImg} alt="Inspection caméra HD conduit cheminée Martigues" width={600} height={375} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-7">
            <div class="inline-flex items-center gap-1.5 bg-[#EFF6FF] border border-[#BFDBFE] text-[#1E40AF] text-[10px] font-bold px-2.5 py-1 rounded-lg mb-4 uppercase tracking-wide">
              <span class="w-1.5 h-1.5 rounded-full bg-[#2563EB]"></span>Diagnostic
            </div>
            <h3 class="text-xl font-bold text-[#111827] mb-3">Inspection Caméra HD</h3>
            <p class="text-sm text-[#4B5563] leading-relaxed mb-5">Diagnostic vidéo endoscopique du conduit. Détection fissures et obstructions invisibles. Rapport photo fourni. Indispensable avant achat immobilier.</p>
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-[#2B7A78] group-hover:gap-3 transition-all">
              Découvrir <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>

        <a href="/particuliers#poeles" class="group block overflow-hidden rounded-2xl bg-white border border-[#E5E7EB] hover:shadow-xl hover:shadow-black/6 hover:-translate-y-1.5 transition-all duration-300">
          <div class="aspect-[16/10] overflow-hidden">
            <Image src={bistrageImg} alt="Entretien poêle à granulés et débistrage Martigues" width={600} height={375} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-7">
            <div class="inline-flex items-center gap-1.5 bg-[#FFFBEB] border border-[#FDE68A] text-[#92400E] text-[10px] font-bold px-2.5 py-1 rounded-lg mb-4 uppercase tracking-wide">
              <span class="w-1.5 h-1.5 rounded-full bg-[#D97706]"></span>Entretien
            </div>
            <h3 class="text-xl font-bold text-[#111827] mb-3">Entretien & Débistrage</h3>
            <p class="text-sm text-[#4B5563] leading-relaxed mb-5">Entretien complet poêle à granulés : brûleur, ventilateur, capteurs, vis sans fin. Débistrage chimique et mécanique. Sécurité et performances optimales.</p>
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-[#2B7A78] group-hover:gap-3 transition-all">
              Découvrir <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ═══ TARIFS ═══ -->
  <section id="tarifs" class="py-24 px-6 md:px-10 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#2B7A78] mb-3">Tarifs 2025</p>
        <h2 class="text-4xl font-extrabold tracking-tight text-[#111827] mb-4">Prestations & Prix</h2>
        <p class="text-base text-[#4B5563] font-light max-w-lg mx-auto">Certificat officiel inclus dans chaque prestation. TVA non applicable — Art. 293 B du CGI. Devis gratuit sous 24h.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">

        <div class="bg-[#F9F8F6] border border-[#E5E7EB] rounded-2xl overflow-hidden">
          <div class="px-7 pt-8 pb-6 border-b border-[#E5E7EB]">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#6B7280] mb-4">Cheminée / Foyer ouvert</p>
            <div class="flex items-baseline gap-1.5">
              <span class="text-6xl font-extrabold text-[#111827] tracking-tight">75</span>
              <span class="text-2xl font-light text-[#6B7280]">€</span>
            </div>
            <p class="text-sm text-[#6B7280] mt-2">tarif unique · certificat inclus</p>
          </div>
          <ul class="px-7 py-7 space-y-4">
            {['Ramonage mécanique du conduit', 'Test de vacuité', 'Contrôle du tirage thermique', 'Nettoyage foyer et plaque', 'Certificat officiel RSD 13'].map(i => (
              <li class="flex items-start gap-3 text-sm text-[#374151]">
                <div class="w-5 h-5 rounded-full bg-[#F0FDF4] border border-[#BBF7D0] flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-[#16A34A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
                {i}
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white border-2 border-[#2B7A78] rounded-2xl overflow-hidden shadow-lg shadow-[#2B7A78]/10 relative">
          <div class="absolute top-5 right-5">
            <span class="text-[10px] font-bold bg-[#2B7A78] text-white px-3 py-1.5 rounded-full uppercase tracking-wider">Le plus demandé</span>
          </div>
          <div class="px-7 pt-8 pb-6 border-b border-[#F0FDFC]">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#6B7280] mb-4">Insert / Poêle à bois</p>
            <div class="flex items-baseline gap-1.5">
              <span class="text-6xl font-extrabold text-[#111827] tracking-tight">90</span>
              <span class="text-2xl font-light text-[#6B7280]">€</span>
            </div>
            <p class="text-sm text-[#6B7280] mt-2">tarif unique · certificat inclus</p>
          </div>
          <ul class="px-7 py-7 space-y-4">
            {['Ramonage mécanique du conduit', 'Test de vacuité et tirage', 'Vérification joints et raccordement', 'Nettoyage chambre de combustion', 'Certificat officiel RSD 13'].map(i => (
              <li class="flex items-start gap-3 text-sm text-[#374151]">
                <div class="w-5 h-5 rounded-full bg-[#F0FDFC] border border-[#99F6E4] flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-[#2B7A78]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
                {i}
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-[#F9F8F6] border border-[#E5E7EB] rounded-2xl overflow-hidden">
          <div class="px-7 pt-8 pb-6 border-b border-[#E5E7EB]">
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#6B7280] mb-4">Poêle à Granulés</p>
            <div class="flex items-baseline gap-1.5">
              <span class="text-6xl font-extrabold text-[#111827] tracking-tight">120</span>
              <span class="text-2xl font-light text-[#6B7280]">€</span>
            </div>
            <p class="text-sm text-[#6B7280] mt-2">entretien complet · certificat inclus</p>
          </div>
          <ul class="px-7 py-7 space-y-4">
            {["Ramonage du conduit d'évacuation", 'Nettoyage brûleur et chambre', 'Contrôle ventilateur et capteurs', 'Vérification vis sans fin', 'Certificat officiel RSD 13'].map(i => (
              <li class="flex items-start gap-3 text-sm text-[#374151]">
                <div class="w-5 h-5 rounded-full bg-[#FFFBEB] border border-[#FDE68A] flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-[#D97706]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
                {i}
              </li>
            ))}
          </ul>
        </div>

      </div>
      <div class="text-center">
        <a href="tel:+33664729600" class="inline-flex items-center gap-2.5 bg-[#2B7A78] hover:bg-[#1F5F5C] text-white text-sm font-bold px-8 py-4 rounded-xl transition-colors shadow-md shadow-[#2B7A78]/20">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Prendre rendez-vous — 06 64 72 96 00
        </a>
        <p class="text-sm text-[#6B7280] mt-4">Déplacement inclus sur 30 km · Devis gratuit sous 24h · TVA non applicable Art. 293 B CGI</p>
      </div>
    </div>
  </section>

  <!-- ═══ ARTISAN + ENGAGEMENTS ═══ -->
  <section class="py-24 px-6 md:px-10 bg-[#F9F8F6]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="relative">
          <Image
            src={artisanImg}
            alt="Artisan ramoneur certifié en intervention à Martigues"
            width={800} height={600}
            class="w-full rounded-2xl object-cover aspect-[4/3] shadow-xl shadow-black/8"
            loading="lazy"
          />
          <div class="absolute -bottom-6 -right-6 bg-[#2B7A78] text-white px-6 py-5 rounded-2xl shadow-xl shadow-[#2B7A78]/25">
            <p class="text-3xl font-extrabold leading-none">RSD 13</p>
            <p class="text-[10px] font-medium tracking-widest uppercase text-white/70 mt-1.5">Conformité garantie</p>
          </div>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-[#2B7A78] mb-5">Votre artisan</p>
          <h2 class="text-4xl font-extrabold tracking-tight text-[#111827] leading-tight mb-6">
            Formé. Certifié.<br />Local.
          </h2>
          <p class="text-base text-[#374151] leading-relaxed mb-8">
            Artisan ramoneur certifié COSTIC basé à Martigues, j'interviens sur les Bouches-du-Rhône avec rigueur et respect de votre foyer. La certification COSTIC atteste d'une formation rigoureuse aux normes NF DTU 24.1, à la réglementation RSD 13 et aux techniques de diagnostic avancé.
          </p>
          <div class="space-y-4 mb-8">

            <div class="flex gap-4 bg-[#F0FDF4] border border-[#BBF7D0] rounded-2xl p-5">
              <div class="w-9 h-9 bg-[#DCFCE7] rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-4.5 h-4.5 text-[#16A34A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <p class="text-sm font-bold text-[#166534] mb-1">Travail propre garanti</p>
                <p class="text-sm text-[#166534]/70 leading-relaxed">Protection complète du sol et des meubles. Nettoyage après chaque intervention.</p>
              </div>
            </div>

            <div class="flex gap-4 bg-[#EFF6FF] border border-[#BFDBFE] rounded-2xl p-5">
              <div class="w-9 h-9 bg-[#DBEAFE] rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-4.5 h-4.5 text-[#2563EB]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              </div>
              <div>
                <p class="text-sm font-bold text-[#1E40AF] mb-1">Certificat officiel immédiat</p>
                <p class="text-sm text-[#1E40AF]/70 leading-relaxed">Document remis sur place, valable pour votre assureur habitation.</p>
              </div>
            </div>

