---
import Layout from '../layouts/Layout.astro';
const siteUrl = 'https://www.sud-ramonage.fr';
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/poeles-bois#service`,
  name: 'Ramonage et entretien poêle à bois',
  description: 'Entretien complet poêle à bois : ramonage conduit, joints, déflecteur, vitrocéramique. Certifié COSTIC. Bouches-du-Rhône.',
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  serviceType: 'Entretien poêle à bois',
  areaServed: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
  offers: { '@type': 'Offer', price: '90', priceCurrency: 'EUR', priceSpecification: { '@type': 'PriceSpecification', minPrice: '90', maxPrice: '120', priceCurrency: 'EUR' } },
};
const breadcrumbs = [{ name: 'Accueil', url: '/' }, { name: 'Poêles à Bois', url: '/poeles-bois' }];
---
<Layout
  title="Ramonage Poêle à Bois — Entretien Certifié COSTIC | Sud Ramonage"
  description="Entretien annuel poêle à bois : ramonage conduit, contrôle joints, déflecteur, vitrocéramique. Certifié COSTIC, certificat RSD 13. Bouches-du-Rhône. Dès 90 €."
  breadcrumbs={breadcrumbs}
  pageSchema={serviceSchema}
>

  <section class="bg-gradient-to-br from-[#1A1A1A] to-[#2D1A00] text-white pt-28 pb-16">
    <div class="max-w-4xl mx-auto px-6 md:px-10">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-white/40 mb-6">
        <a href="/" class="hover:text-white/70">Accueil</a><span>/</span><span class="text-white/60">Poêles à Bois</span>
      </nav>
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 rounded-full px-3 py-1.5 text-[11px] text-white/70 mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-[#E65100]"></span>
        Entretien annuel obligatoire — RSD 13
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-5">
        Entretien Poêle à Bois<br /><span class="text-[#E65100]">Ramonage & Contrôle Complet</span>
      </h1>
      <p class="text-base text-white/65 max-w-2xl leading-relaxed mb-8">
        Un poêle à bois mal entretenu consomme plus, chauffe moins, et peut provoquer un incendie de conduit ou une intoxication au CO. Je contrôle l'ensemble de l'installation : conduit, appareil, joints, déflecteur — une seule intervention, tout est vérifié.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#E65100] text-white text-sm font-bold px-5 py-3 rounded-xl hover:bg-[#BF360C] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          06 64 72 96 00
        </a>
        <span class="inline-flex items-center bg-white/8 border border-white/15 text-white/70 text-sm px-4 py-3 rounded-xl">Dès 90 € · Certificat immédiat</span>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-4xl mx-auto px-6 md:px-10 space-y-12">

      <div>
        <h2 class="text-2xl font-bold mb-5">Ce qui est contrôlé lors de l'entretien</h2>
        <div class="grid md:grid-cols-2 gap-4">
          {[
            { titre: 'Conduit de fumée', detail: 'Ramonage mécanique complet du conduit, vérification vacuité, état des joints de boisseau, dépassement en toiture.' },
            { titre: 'Corps du poêle', detail: 'Contrôle des soudures, des rivets, de l\'étanchéité de la chambre de combustion. Recherche de fissures et déformations.' },
            { titre: 'Joints et garnissages', detail: 'Vérification du joint de porte (tresse céramique), du joint de vitre et des joints de coude. Remplacement si usés.' },
            { titre: 'Déflecteur et chicanes', detail: 'Contrôle de l\'état du déflecteur (fonte ou vermiculite). Un déflecteur fissuré laisse passer les gaz chauds directement au conduit.' },
            { titre: 'Vitrocéramique', detail: 'Inspection des micro-fissures. Un vitrage fissuré = perte d\'étanchéité + risque de bris en fonctionnement.' },
            { titre: 'Tirage et réglage', detail: 'Vérification du tirage naturel et des réglages d\'air primaire/secondaire pour une combustion optimale.' },
          ].map(({ titre, detail }) => (
            <div class="bg-[#FAFAFA] border border-[#EEEEEE] rounded-xl p-5">
              <p class="text-sm font-semibold text-[#1A1A1A] mb-2 flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-[#E65100] shrink-0"></span>{titre}
              </p>
              <p class="text-xs text-[#1A1A1A]/55 leading-relaxed">{detail}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="bg-green-50 border border-green-200 rounded-2xl p-8">
        <h3 class="text-base font-bold text-green-900 mb-2">Économies réelles d'un poêle correctement entretenu</h3>
        <p class="text-sm text-green-800/75 leading-relaxed">
          Le COSTIC estime qu'un conduit encrassé de 3 mm réduit le tirage de 9 % et augmente la consommation de bois de 12 à 15 %. Sur 3 stères à 80 €/stère, c'est 29 à 36 € économisés par saison — sans compter le risque d'incendie de conduit. Le coût du ramonage est amorti dès la première saison.
        </p>
      </div>

      <div class="bg-[#1A1A1A] rounded-2xl p-8">
        <h2 class="text-lg font-bold text-white mb-6">Problèmes fréquents — poêles à bois</h2>
        <div class="space-y-4">
          {[
            { titre: 'Bois humide → bistre', detail: 'La combustion de bois à plus de 20 % d\'humidité génère des goudrons condensés. Bistre inflammable, tirage réduit, surconsommation.', dtu: 'RSD 13' },
            { titre: 'Conduit trop long ou coudes à 90°', detail: 'Chaque coude à 90° équivaut à 1,5 m de conduit supplémentaire. Tirage insuffisant → refoulement → CO.', dtu: 'NF DTU 24.1 P1-1 art. 5.3' },
            { titre: 'Raccordement non étanche', detail: 'Le raccord entre l\'appareil et le conduit doit être étanche. Une infiltration de gaz froid réduit le tirage et pollue l\'air ambiant.', dtu: 'NF DTU 24.1 P1-1 art. 4.2' },
          ].map(({ titre, detail, dtu }) => (
            <div class="flex gap-4 p-4 bg-white/5 rounded-xl border border-white/8">
              <div class="w-2 h-2 rounded-full bg-[#E65100] mt-1.5 shrink-0"></div>
              <div>
                <p class="text-sm font-semibold text-white mb-1">{titre}</p>
                <p class="text-xs text-white/55 leading-relaxed mb-2">{detail}</p>
                <span class="inline-block text-[10px] font-mono bg-[#E65100]/15 text-[#E65100] px-2 py-0.5 rounded">{dtu}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="bg-[#E65100] rounded-2xl p-8 text-white">
        <h2 class="text-xl font-bold mb-3">Entretien de votre poêle à bois ?</h2>
        <p class="text-sm text-white/75 mb-6">Je me déplace sur Martigues, Aix, Marseille, Salon et 60+ communes. RDV rapide, certificat le jour même.</p>
        <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-white text-[#E65100] text-sm font-bold px-6 py-3 rounded-xl hover:bg-white/90 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          06 64 72 96 00
        </a>
      </div>

      <nav aria-label="Services associés" class="pt-8 border-t border-[#EEEEEE]">
        <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-4">Voir aussi</p>
        <ul class="flex flex-wrap gap-3">
          {[
            { href: '/poeles-granules', label: 'Entretien poêle à granulés' },
            { href: '/entretien-poele', label: 'Entretien poêle complet' },
            { href: '/debistrage', label: 'Débistrage conduit' },
            { href: '/tubage', label: 'Tubage conduit inox' },
            { href: '/ramonage', label: 'Ramonage certifié' },
          ].map(({ href, label }) => (
            <li><a href={href} class="text-xs text-[#1A1A1A]/50 border border-[#EEEEEE] rounded-lg px-3 py-1.5 hover:text-[#E65100] hover:border-[#E65100]/30 transition-colors">{label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </section>
</Layout>
