---
import Layout from '../layouts/Layout.astro';
const siteUrl = 'https://www.sud-ramonage.fr';
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/accessoires-toiture#service`,
  name: 'Pose d\'accessoires de toiture — chapeaux, mitres, anti-refoulement',
  description: 'Pose de chapeaux anti-refoulement, mitres, anti-pluie sur conduits de fumée. Bouches-du-Rhône. Conforme NF DTU 24.1.',
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  serviceType: 'Pose accessoires toiture conduit fumée',
  areaServed: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
};
const breadcrumbs = [{ name: 'Accueil', url: '/' }, { name: 'Accessoires Toiture', url: '/accessoires-toiture' }];
---
<Layout
  title="Chapeaux Anti-Refoulement & Accessoires Toiture Conduit | Sud Ramonage"
  description="Pose de chapeaux anti-refoulement, mitres anti-pluie, grilles anti-nid pour conduits de fumée. Conforme NF DTU 24.1. Bouches-du-Rhône."
  breadcrumbs={breadcrumbs}
  pageSchema={serviceSchema}
>
  <section class="bg-[#F9F6F3] border-b border-[#EEEEEE] pt-28 pb-12">
    <div class="max-w-4xl mx-auto px-6 md:px-10">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-[#1A1A1A]/70 mb-6">
        <a href="/" class="hover:text-[#1A1A1A]/60">Accueil</a><span>/</span><span class="text-[#1A1A1A]/70">Accessoires Toiture</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-5">
        Accessoires de Toiture<br /><span class="text-[#C4B5AC]">Chapeaux, Mitres & Anti-Refoulement</span>
      </h1>
      <p class="text-base text-[#1A1A1A]/70 max-w-2xl leading-relaxed mb-8">
        En Méditerranée, le mistral et le vent marin créent des refoulements violents dans les conduits non protégés. La pose d'un accessoire adapté est souvent la solution la plus simple pour résoudre un problème de tirage ou de nid d'oiseaux.
      </p>
      <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#E8DDD4] text-white text-sm font-bold px-5 py-3 rounded-xl hover:bg-[#C4B5AC] transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        06 64 72 96 00 — Devis gratuit
      </a>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-4xl mx-auto px-6 md:px-10 space-y-12">
      <div>
        <h2 class="text-2xl font-bold mb-6">Les accessoires que je pose</h2>
        <div class="grid md:grid-cols-2 gap-5">
          {[
            { titre: 'Chapeau anti-refoulement', detail: 'Indispensable en zone mistralaise et côtière. Élimine les refoulements dus aux vents rasants. Conforme NF DTU 24.1. En inox, aluminium ou fonte selon le conduit.', recommande: true },
            { titre: 'Mitre anti-pluie', detail: 'Protège le conduit de la pluie et des infiltrations d\'eau. Évite la dégradation des joints et des parois intérieures par le gel-dégel.' },
            { titre: 'Grille anti-nid d\'oiseaux', detail: 'Maillage inox fin posé sur la sortie du conduit. Bloque l\'accès aux étourneaux et martinets sans réduire le tirage.' },
            { titre: 'Chapeau à turbine', detail: 'Pour les conduits à tirage difficile (conduit court, exposition au vent variable). La turbine amplifie le tirage par rotation passive.' },
            { titre: 'Manchette anti-refoulement', detail: 'Bague à orientation variable qui s\'adapte au vent dominant. Efficace sur les toitures exposées au mistral de secteur NW.' },
            { titre: 'Rehausse de souche', detail: 'Élévation du conduit lorsque le dépassement en toiture est insuffisant (NF DTU 24.1 (minimum 40 cm au-dessus du faîtage)).' },
          ].map(({ titre, detail, recommande }) => (
            <div class={`rounded-xl p-5 border ${recommande ? 'bg-[#FFF3E0] border-[#E8DDD4]/30' : 'bg-[#F2EDE8] border-[#EEEEEE]'}`}>
              <div class="flex items-center gap-2 mb-2">
                <p class="text-sm font-semibold text-[#1A1A1A]">{titre}</p>
                {recommande && <span class="text-[10px] bg-[#E8DDD4] text-white px-1.5 py-0.5 rounded font-medium">Recommandé Provence</span>}
              </div>
              <p class="text-xs text-[#1A1A1A]/70 leading-relaxed">{detail}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="border-l-4 border-[#1A4B8F] bg-[#EEF3FF] rounded-r-2xl p-8">
        <h3 class="text-base font-bold text-[#1A4B8F] mb-3">Note terrain — Côte Bleue et Martigues</h3>
        <p class="text-sm text-[#1A1A1A]/65 leading-relaxed">
          Sur le littoral de la Côte Bleue et à Martigues, je recommande systématiquement le chapeau anti-refoulement inox 316L. Le mistral de Nord-Ouest et la tramontane créent des dépressions brutales sur les toitures exposées. J'ai constaté des refoulements complets de fumée dans des cheminées sans défaut de ramonage — la seule cause étant l'absence de chapeau anti-refoulement adapté.
        </p>
      </div>

      <div class="border border-[#EEEEEE] rounded-2xl p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div>
          <h2 class="text-xl font-bold text-[#1A1A1A] mb-2">Pose d'accessoires de toiture — Bouches-du-Rhône</h2>
          <p class="text-sm text-[#1A1A1A]/70">Je détermine l'accessoire adapté à votre conduit et votre exposition au vent. Pose en même temps que le ramonage annuel.</p>
        </div>
        <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#E8DDD4] text-white text-sm font-bold px-6 py-3 rounded-xl hover:bg-[#C4B5AC] transition-colors shrink-0">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          06 64 72 96 00
        </a>
      </div>

      <nav aria-label="Services associés" class="pt-8 border-t border-[#EEEEEE]">
        <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-4">Voir aussi</p>
        <ul class="flex flex-wrap gap-3">
          {[
            { href: '/vacuite', label: 'Test de vacuité (nids)' },
            { href: '/foyers-ouverts', label: 'Ramonage foyer ouvert' },
            { href: '/tubage', label: 'Tubage conduit' },
            { href: '/ramonage', label: 'Ramonage certifié' },
          ].map(({ href, label }) => (
            <li><a href={href} class="text-xs text-[#1A1A1A]/70 border border-[#EEEEEE] rounded-lg px-3 py-1.5 hover:text-[#C4B5AC] hover:border-[#E8DDD4]/30 transition-colors">{label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </section>
</Layout>
