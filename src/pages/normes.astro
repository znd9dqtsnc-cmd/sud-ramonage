---
import Layout from '../layouts/Layout.astro';
import ContactButton from '../components/ContactButton.astro';
import FAQ from '../components/FAQ.astro';
import { Image } from 'astro:assets';

import conduitImg from '../assets/images/conduit-cheminee.jpg';

const siteUrl = 'https://www.sud-ramonage.fr';

const faqItems = [
  {
    q: "Qu'est-ce que la norme NF DTU 24.1 ?",
    a: "La norme NF DTU 24.1 (Document Technique Unifié) régit la construction, la rénovation et le tubage des conduits de fumée en France. Elle définit les distances de sécurité, les sections minimales de conduit, les matériaux autorisés et les conditions de raccordement des appareils à combustion. Tout travaux sur un conduit de fumée doit respecter cette norme pour être couvert par les assurances.",
  },
  {
    q: "Le tubage inox est-il obligatoire pour mon conduit ?",
    a: "Le tubage inox est obligatoire dans quatre cas : (1) adaptation d'un conduit maçonné ancien à un appareil à haut rendement (poêle à bois ou insert) ; (2) conduit présentant des fissures ou défauts d'étanchéité ; (3) section du conduit non adaptée à l'appareil raccordé ; (4) après un incendie de conduit. Un diagnostic par un artisan certifié permet de déterminer si votre installation nécessite un tubage.",
  },
  {
    q: "Quelle est la distance de sécurité autour d'un conduit de fumée ?",
    a: "La norme NF DTU 24.1 impose une distance minimale de 16 cm entre un conduit non isolé et tout matériau combustible (bois, isolation, etc.). Pour les conduits certifiés double paroi avec isolation intégrée, cette distance est réduite selon les spécifications du fabricant. En toiture, le conduit doit dépasser d'au moins 40 cm le point de la couverture le plus proche, ou de 50 cm si situé à moins de 1,5 m de l'arête du toit.",
  },
  {
    q: "Mon assurance peut-elle refuser d'indemniser en cas d'incendie de conduit ?",
    a: "Oui. En cas d'incendie de conduit, votre assurance vérifiera systématiquement : (1) que le conduit est conforme NF DTU 24.1 ; (2) que vous disposez d'un certificat de ramonage annuel valide (exigé par le RSD 13). L'absence de l'un ou l'autre constitue un motif légal de refus d'indemnisation ou de réduction de l'indemnité.",
  },
  {
    q: "Quelle est la différence entre le RSD 13 et la NF DTU 24.1 ?",
    a: "Le RSD 13 (Règlement Sanitaire Départemental des Bouches-du-Rhône) concerne l'usage et l'entretien : il impose le ramonage mécanique au moins une fois par an. La NF DTU 24.1 concerne la construction et la conformité de l'installation elle-même. Les deux sont complémentaires et exigés par les compagnies d'assurance : sans ramonage annuel (RSD 13) ET sans conduit conforme (NF DTU 24.1), tout sinistre peut être non couvert.",
  },
  {
    q: "Comment savoir si mon conduit est conforme NF DTU 24.1 ?",
    a: "Seul un professionnel certifié peut déterminer la conformité de votre installation. Notre diagnostic inclut : vérification de la section du conduit par rapport à l'appareil, contrôle de l'étanchéité (test de vacuité), mesure du tirage thermique, inspection visuelle de l'état des parois et des joints, et vérification des distances de sécurité. Un rapport de conformité peut être établi à l'issue.",
  },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'NF DTU 24.1 — Normes conduits de fumée, distances de sécurité et obligations de tubage',
  description: 'Guide complet sur la norme NF DTU 24.1 : distances de sécurité, obligations de tubage inox, lien avec le RSD 13 et les assurances. Artisan certifié à Martigues.',
  author: { '@type': 'Organization', name: 'Sud Ramonage', url: siteUrl },
  publisher: { '@type': 'Organization', name: 'Sud Ramonage', logo: `${siteUrl}/favicon.svg`, url: siteUrl },
  url: `${siteUrl}/normes`,
  mainEntity: {
    '@type': 'FAQPage',
    mainEntity: faqItems.map(item => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  },
};
---

<Layout
  title="Normes NF DTU 24.1 — Distances de Sécurité & Tubage Conduit | Sud Ramonage"
  description="Tout sur la norme NF DTU 24.1 : distances de sécurité, obligations de tubage inox, RSD 13 et assurances. Artisan ramoneur certifié à Martigues. Diagnostic gratuit."
  breadcrumbs={[
    { name: 'Accueil', url: '/' },
    { name: 'Normes & Sécurité', url: '/normes' },
  ]}
  pageSchema={pageSchema}
>

  <!-- ═══ HERO ═══ -->
  <section class="relative pt-32 pb-20 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={conduitImg}
        alt="Conduit de cheminée inox conforme NF DTU 24.1 — distances de sécurité et tubage certifié"
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-[#1A1A1A]/82"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto">
      <nav class="flex items-center gap-2 text-xs text-white/30 mb-8" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-white transition-colors duration-200">Accueil</a>
        <span>/</span>
        <span class="text-white/60">Normes & Sécurité</span>
      </nav>
      <p class="text-[11px] font-semibold tracking-widest uppercase text-[#2B7A78] mb-4">Légal & Confiance</p>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white leading-tight mb-6">
        Normes NF DTU 24.1<br />& Sécurité Conduit.
      </h1>
      <p class="text-base text-white/55 font-light max-w-xl leading-relaxed mb-8">
        La norme NF DTU 24.1 régit la construction et le tubage des conduits de fumée en France. La méconnaître, c'est risquer un refus d'indemnisation de votre assurance en cas de sinistre — ou pire, mettre votre famille en danger.
      </p>
      <ContactButton variant="phone" class="px-8 py-3.5" />
    </div>
  </section>

  <!-- ═══ TL;DR ═══ -->
  <section class="py-10 px-6 md:px-10 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="border-l-4 border-[#2B7A78] bg-[#F0FDFC] rounded-r-xl p-6" role="note" aria-label="Résumé de la page">
        <p class="text-[10px] font-bold tracking-widest uppercase text-[#2B7A78] mb-3">TL;DR — L'essentiel en 30 secondes</p>
        <ul class="space-y-2">
          {[
            'NF DTU 24.1 = norme obligatoire pour la construction et le tubage de tout conduit de fumée en France.',
            'Distance de sécurité minimale : 16 cm entre le conduit et tout matériau combustible.',
            'Tubage inox obligatoire dès qu\'un ancien conduit est raccordé à un appareil à haut rendement.',
            'RSD 13 (ramonage annuel) + NF DTU 24.1 (conformité installation) = deux obligations cumulatives pour votre assurance.',
            'Non-conformité : refus d\'indemnisation garanti en cas d\'incendie de conduit.',
          ].map(point => (
            <li class="flex items-start gap-2.5 text-sm text-[#1A1A1A]/75 font-light">
              <span class="w-1.5 h-1.5 rounded-full bg-[#2B7A78] mt-1.5 shrink-0"></span>
              {point}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ═══ CONTENU PRINCIPAL ═══ -->
  <section class="py-16 px-6 md:px-10">
    <div class="max-w-6xl mx-auto space-y-20">

      <!-- ── 1. Qu'est-ce que NF DTU 24.1 ── -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <p class="text-[11px] font-semibold tracking-widest uppercase text-[#2B7A78] mb-4">01 — La référence</p>
          <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-5">
            Qu'est-ce que la Norme NF DTU 24.1 ?
          </h2>
          <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed mb-5">
            La <strong class="font-medium text-[#1A1A1A]/80">NF DTU 24.1</strong> (Document Technique Unifié) est la norme française qui régit l'ensemble des travaux de fumisterie : construction de conduits de fumée neufs, réhabilitation de conduits existants, tubage inox, et raccordement des appareils à combustion (cheminées, inserts, poêles à bois et à granulés, chaudières).
          </p>
          <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed">
            Elle fixe les règles techniques impératives pour garantir la sécurité des utilisateurs. Tout artisan intervenant sur un conduit de fumée est tenu de la respecter. En cas de non-conformité constatée après un sinistre, l'assurance est fondée à refuser toute indemnisation.
          </p>
        </div>
        <div class="space-y-4">
          <div class="bg-[#FAFAFA] rounded-xl p-6">
            <p class="text-xs font-bold text-[#1A1A1A] uppercase tracking-wider mb-4">Ce que couvre la norme</p>
            {[
              { titre: 'Construction neuve', desc: 'Dimensionnement, matériaux, recoupements coupe-feu entre niveaux' },
              { titre: 'Tubage & réhabilitation', desc: 'Conditions d\'installation du tubage inox flexible ou rigide' },
              { titre: 'Distances de sécurité', desc: 'Espacement minimal aux matériaux combustibles et à la toiture' },
              { titre: 'Raccordement appareils', desc: 'Sections, tirage, adaptation conduit à l\'appareil neuf' },
              { titre: 'Débouchés en toiture', desc: 'Hauteur de sortie selon la pente et la distance aux arêtes' },
            ].map(({ titre, desc }) => (
              <div class="flex gap-3 py-3 border-b border-[#EEEEEE] last:border-0">
                <svg class="w-4 h-4 text-[#2B7A78] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <p class="text-xs font-semibold text-[#1A1A1A]">{titre}</p>
                  <p class="text-[11px] text-[#1A1A1A]/50 font-light">{desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- ── 2. Distances de sécurité ── -->
      <div>
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#2B7A78] mb-4">02 — Règles impératives</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-8">
          Distances de Sécurité à Respecter.
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {[
            {
              titre: 'Matériaux combustibles',
              valeur: '16 cm',
              desc: 'Distance minimale entre un conduit non isolé et tout matériau combustible (bois de charpente, isolation organique). Réduite pour les conduits certifiés double paroi.',
              couleur: 'text-[#2B7A78]',
            },
            {
              titre: 'Débouché en toiture',
              valeur: '40 cm',
              desc: 'Hauteur minimale de dépassement du conduit par rapport au point de couverture le plus proche. Portée à 50 cm si le conduit est à moins de 1,5 m d\'une arête.',
              couleur: 'text-[#2B7A78]',
            },
            {
              titre: 'Zone de proximité toit',
              valeur: '8 m',
              desc: 'Si le conduit se situe dans les 8 m du faîtage, il doit dépasser de 40 cm ce dernier. Au-delà, la règle des 40 cm depuis le point de pénétration s\'applique.',
              couleur: 'text-[#2B7A78]',
            },
          ].map(({ titre, valeur, desc, couleur }) => (
            <div class="bg-white border border-[#EEEEEE] rounded-xl p-6">
              <p class={`text-3xl font-extrabold tracking-tight ${couleur} mb-1`}>{valeur}</p>
              <p class="text-xs font-bold text-[#1A1A1A] uppercase tracking-wider mb-3">{titre}</p>
              <p class="text-sm text-[#1A1A1A]/55 font-light leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
        <div class="mt-6 bg-amber-50 border border-amber-200 rounded-xl p-5">
          <p class="text-sm font-semibold text-amber-900 mb-2">Cas des conduits certifiés</p>
          <p class="text-sm text-amber-800 font-light leading-relaxed">
            Les conduits double paroi avec isolation intégrée (type TEC ou conduits système) bénéficient de distances réduites selon leur certification CE. Un conduit certifié T400-N1-W-V2-L50050 peut, par exemple, être installé à 5 cm des matériaux combustibles. Consultez toujours la fiche technique du fabricant.
          </p>
        </div>
      </div>

      <!-- ── 3. Obligations de tubage ── -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <p class="text-[11px] font-semibold tracking-widest uppercase text-[#2B7A78] mb-4">03 — Mise en conformité</p>
          <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-5">
            Quand le Tubage Inox est Obligatoire.
          </h2>
          <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed mb-6">
            Le <strong class="font-medium text-[#1A1A1A]/80">tubage inox</strong> consiste à installer un conduit en acier inoxydable à l'intérieur d'un conduit existant. Cette opération est obligatoire — et non optionnelle — dans les situations suivantes :
          </p>
          <ol class="space-y-5">
            {[
              { n: '01', t: 'Raccordement d\'un appareil à haut rendement', d: 'Tout poêle à bois labellisé Flamme Verte ou insert moderne possède un tirage et des températures de fumée différents des cheminées traditionnelles. Un ancien conduit maçonné doit être tubé pour s\'adapter.' },
              { n: '02', t: 'Conduit fissuré ou non étanche', d: 'Fissures dans la maçonnerie, joints déjointés ou parois dégradées compromettent l\'évacuation des fumées et exposent au risque d\'intoxication au CO. Le tubage est la solution réglementaire.' },
              { n: '03', t: 'Section inadaptée', d: 'Un conduit de cheminée à foyer ouvert (section souvent 30×40 cm) branché sur un poêle (section 15 cm de diamètre) crée un sous-tirage. Un tubage approprié corrige la section.' },
              { n: '04', t: 'Après un incendie de conduit', d: 'Un incendie de conduit fragilise les parois maçonnées. Même sans dommage visible, un tubage est exigé par les normes avant toute remise en service.' },
            ].map(({ n, t, d }) => (
              <li class="flex gap-4">
                <span class="text-[11px] font-bold text-[#2B7A78] mt-0.5 shrink-0 w-7">{n}</span>
                <div>
                  <p class="text-sm font-semibold text-[#1A1A1A]">{t}</p>
                  <p class="text-sm text-[#1A1A1A]/50 font-light leading-relaxed">{d}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
        <div class="space-y-4">
          <div class="bg-[#F0FDFC] rounded-xl p-6">
            <p class="text-xs font-semibold text-[#9A3412]/60 uppercase tracking-widest mb-4">Types de tubage</p>
            {[
              { type: 'Flexible inox simple paroi', usage: 'Conduit existant en bon état, sans courbe trop prononcée', limite: 'Non adapté aux appareils très haute température' },
              { type: 'Flexible inox double paroi', usage: 'Appareils basse température ou condensation, longues longueurs', limite: 'Encombrement plus important' },
              { type: 'Rigide inox double paroi', usage: 'Performances thermiques maximales, longue durée de vie', limite: 'Conduit rectiligne quasi-obligatoire' },
            ].map(({ type, usage, limite }) => (
              <div class="py-4 border-b border-white/10 last:border-0">
                <p class="text-xs font-semibold text-white mb-1">{type}</p>
                <p class="text-[11px] text-white/50 font-light">✓ {usage}</p>
                <p class="text-[11px] text-white/30 font-light">— {limite}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- ── 4. RSD 13 + NF DTU 24.1 ── -->
      <div class="bg-[#FAFAFA] rounded-2xl p-8 md:p-12">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#2B7A78] mb-4">04 — Deux obligations cumulatives</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-6">
          RSD 13 & NF DTU 24.1 — Comprendre la Différence.
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-[#EEEEEE]">
            <p class="text-xs font-bold text-[#2B7A78] uppercase tracking-wider mb-3">RSD 13 — L'usage</p>
            <p class="text-sm text-[#1A1A1A]/65 font-light leading-relaxed mb-4">
              Le Règlement Sanitaire Départemental des Bouches-du-Rhône concerne l'<strong class="font-medium text-[#1A1A1A]/80">entretien régulier</strong> de votre installation. Il impose un ramonage mécanique au minimum une fois par an pour tout conduit de fumée en service.
            </p>
            <ul class="space-y-1.5">
              {['Ramonage mécanique annuel obligatoire', 'Certificat officiel remis après chaque ramonage', 'Exigé par toutes les compagnies d\'assurance', 'Amendes possibles en cas de contrôle'].map(p => (
                <li class="flex items-center gap-2 text-xs text-[#1A1A1A]/65 font-light">
                  <span class="w-1 h-1 rounded-full bg-[#2B7A78] shrink-0"></span>
                  {p}
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-white rounded-xl p-6 border border-[#EEEEEE]">
            <p class="text-xs font-bold text-[#2B7A78] uppercase tracking-wider mb-3">NF DTU 24.1 — L'installation</p>
            <p class="text-sm text-[#1A1A1A]/65 font-light leading-relaxed mb-4">
              La norme NF DTU 24.1 concerne la <strong class="font-medium text-[#1A1A1A]/80">conformité de l'installation</strong> elle-même. Elle s'applique lors de la construction d'un conduit neuf, de la rénovation d'un conduit existant, ou du remplacement d'un appareil.
            </p>
            <ul class="space-y-1.5">
              {['Distances de sécurité réglementaires', 'Tubage obligatoire si conduit inadapté', 'Matériaux certifiés CE exigés', 'Responsabilité civile de l\'artisan engagée'].map(p => (
                <li class="flex items-center gap-2 text-xs text-[#1A1A1A]/65 font-light">
                  <span class="w-1 h-1 rounded-full bg-[#2B7A78] shrink-0"></span>
                  {p}
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div class="mt-6 bg-[#F0FDFC] rounded-xl p-5">
          <p class="text-sm font-semibold text-white mb-1">Assurances : les deux sont exigés simultanément</p>
          <p class="text-sm text-[#334155] font-light leading-relaxed">
            Un ramonage annuel valide (RSD 13) ne suffit pas si votre conduit n'est pas conforme NF DTU 24.1 — et inversement. En cas d'incendie de conduit, l'expert mandaté par votre assureur vérifiera les deux points. L'absence de l'un d'eux constitue un motif de réduction ou de refus d'indemnisation.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <FAQ
    title="Questions sur les Normes & la Sécurité."
    items={faqItems}
  />

  <!-- ═══ MAILLAGE SILO ═══ -->
  <section class="py-12 px-6 md:px-10 bg-[#FAFAFA]">
    <div class="max-w-6xl mx-auto">
      <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/35 mb-4">Services associés</p>
      <div class="flex flex-wrap gap-3">
        {[
          { href: '/ramonage',        label: 'Ramonage Certifié RSD 13' },
          { href: '/debistrage',      label: 'Débistrage Conduit' },
          { href: '/entretien-poele', label: 'Entretien Poêle' },
          { href: '/villes/martigues', label: 'Artisan Certifié Martigues' },
          { href: '/villes/istres',    label: 'Artisan Certifié Istres' },
        ].map(({ href, label }) => (
          <a href={href} class="inline-flex items-center gap-2 bg-white border border-[#EEEEEE] rounded-lg px-4 py-2.5 text-xs font-medium text-[#1A1A1A]/65 hover:border-[#2B7A78]/30 hover:text-[#2B7A78] transition-all duration-200">
            <span class="w-1.5 h-1.5 rounded-full bg-[#2B7A78] shrink-0"></span>
            {label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="py-16 px-6 md:px-10 bg-[#F0FDFC] text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-4">Vérifiez la Conformité de Votre Installation</h2>
      <p class="text-sm text-[#1A1A1A]/55 font-light mb-8">
        Diagnostic gratuit par un artisan certifié. Nous vérifions la conformité NF DTU 24.1 de votre conduit et vous conseillons si un tubage est nécessaire.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <ContactButton variant="phone" class="px-8 py-4 text-sm" />
        <ContactButton variant="email" />
      </div>
    </div>
  </section>

</Layout>
