---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import conduitImg from '../assets/images/conduit-cheminee.jpg';

const siteUrl = 'https://www.sud-ramonage.fr';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/foyers-ouverts#service`,
  name: 'Ramonage foyer ouvert — cheminée traditionnelle',
  description: 'Ramonage certifié COSTIC de cheminée à foyer ouvert. Nettoyage conduit, certificat RSD 13, élimination bistre et suie. Bouches-du-Rhône.',
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  serviceType: 'Ramonage cheminée foyer ouvert',
  areaServed: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
  offers: {
    '@type': 'Offer',
    price: '75',
    priceCurrency: 'EUR',
    priceSpecification: { '@type': 'PriceSpecification', minPrice: '75', maxPrice: '95', priceCurrency: 'EUR' },
    eligibleRegion: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Services foyer ouvert',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Ramonage mécanique conduit grande section' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Certificat de ramonage RSD 13' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Contrôle tirage et vacuité' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Détection bistre et dépôts inflammables' } },
    ],
  },
  knowsAbout: 'NF DTU 24.1 P1-1 — Ramonage conduits de fumée foyer ouvert',
};

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Foyers Ouverts', url: '/foyers-ouverts' },
];
---

<Layout
  title="Ramonage Foyer Ouvert — Cheminée Traditionnelle | Sud Ramonage Martigues"
  description="Ramonage certifié COSTIC de votre cheminée à foyer ouvert. Grande section, bistre, tirage, certificat RSD 13 immédiat. Martigues & Bouches-du-Rhône. Dès 75 €."
  breadcrumbs={breadcrumbs}
  pageSchema={serviceSchema}
>

  <!-- Hero -->
  <section class="bg-[#FFFFFF] border-b border-[#EEEEEE] pt-28 pb-12">
    <div class="max-w-4xl mx-auto px-6 md:px-10">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-[#1A1A1A]/85 mb-6">
        <a href="/" class="hover:text-[#1A1A1A]/80 transition-colors">Accueil</a>
        <span>/</span>
        <span class="text-[#1A1A1A]/85">Foyers Ouverts</span>
      </nav>
      <div class="inline-flex items-center gap-2 bg-[#FFF3E0] border border-[#E8DDD4]/20 rounded-full px-3 py-1.5 text-[11px] font-medium text-[#F39C12] font-semibold mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-[#E8DDD4]"></span>
        NF DTU 24.1 P1-1 — Ramonage certifié COSTIC
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-5">
        Ramonage de Cheminée<br />
        <span class="text-[#F39C12]">à Foyer Ouvert</span>
      </h1>
      <p class="text-base md:text-lg text-[#1A1A1A]/85 max-w-2xl leading-relaxed mb-8">
        La cheminée traditionnelle à foyer ouvert est l'appareil le plus exigeant en matière de ramonage. Grande section de conduit, accumulation de suie et de bistre, risque de refoulement — chaque intervention demande une technique adaptée et un matériel professionnel.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#E8DDD4] text-white text-sm font-bold px-5 py-3 rounded-xl hover:bg-[#F39C12] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Prendre RDV — 06 64 72 96 00
        </a>
        <span class="inline-flex items-center gap-2 bg-[#F8F9FA] border border-[#EEEEEE] text-[#1A1A1A]/80 text-sm px-4 py-3 rounded-xl">
          Certificat RSD 13 immédiat · À partir de 75 €
        </span>
      </div>
    </div>
  </section>

  <!-- Points clés -->
  <section class="py-14 bg-[#F8F9FA] border-b border-[#EEEEEE]">
    <div class="max-w-4xl mx-auto px-6 md:px-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { val: '1×/an', label: 'Minimum RSD 13', sub: 'Bouches-du-Rhône' },
          { val: '75 €', label: 'Dès', sub: 'Conduit simple' },
          { val: '100 %', label: 'Mécanique', sub: 'Hérisson + aspirateur' },
          { val: '24h', label: 'Certificat', sub: 'Envoyé par mail' },
        ].map(({ val, label, sub }) => (
          <div class="bg-[#FFFFFF] rounded-xl border border-[#EEEEEE] p-5 text-center">
            <p class="text-2xl font-extrabold text-[#F39C12]">{val}</p>
            <p class="text-xs font-semibold text-[#1A1A1A] mt-1">{label}</p>
            <p class="text-[11px] text-[#1A1A1A]/80 mt-0.5">{sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- IMAGE IMMERSION -->
  <section class="max-w-4xl mx-auto px-6 md:px-10 py-10">
    <figure class="rounded-2xl overflow-hidden aspect-[21/9] relative">
      <Image
        src={conduitImg}
        alt="Conduit de cheminée à foyer ouvert — ramonage mécanique et contrôle de vacuité"
        width={1200}
        height={514}
        class="w-full h-full object-cover object-center"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[#1A1A1A]/60 to-transparent flex items-end p-8">
        <p class="text-white text-sm font-medium leading-snug">Conduit maçonné grande section — hérisson rotatif, aspiration, vacuité.</p>
      </div>
    </figure>
  </section>

  <!-- Contenu expert -->
  <section class="py-8">
    <div class="max-w-4xl mx-auto px-6 md:px-10 space-y-12">

      <div>
        <h2 class="text-2xl font-bold text-[#1A1A1A] mb-5">Pourquoi le foyer ouvert est-il le cas le plus complexe ?</h2>
        <p class="text-sm text-[#1A1A1A]/80 leading-relaxed mb-4">
          Une cheminée à foyer ouvert fonctionne avec un rendement thermique faible (15 à 30 %). Cela signifie que la majorité des gaz de combustion partent dans le conduit à une température peu élevée, favorisant la condensation des goudrons et la formation de bistre. Dans les Bouches-du-Rhône, le mistral aggrave le phénomène en créant des variations de pression brutales dans le conduit — refoulement intermittent, dépôts asymétriques.
        </p>
        <p class="text-sm text-[#1A1A1A]/80 leading-relaxed">
          Les conduits de foyer ouvert ont généralement une section large (250×250 mm à 400×300 mm). Cette grande surface de paroi multiplie la surface de dépôt et exige un hérisson de diamètre adapté pour un nettoyage efficace. La NF DTU 24.1 impose que la section du conduit soit cohérente avec l'ouverture du foyer — une exigence que j'applique systématiquement lors de mon diagnostic.
        </p>
      </div>

      <!-- Non-conformités fréquentes -->
      <div class="bg-[#F8F9FA] border border-[#EEEEEE] rounded-2xl p-8">
        <h2 class="text-lg font-bold text-[#1A1A1A] mb-6">Ce que je trouve le plus souvent sur les foyers ouverts</h2>
        <div class="space-y-4">
          {[
            { titre: 'Dépôt de bistre inflammable', detail: 'Bois humide ou foyer mal exploité → dépôt goudroneux noir sur les parois. Risque d\'incendie de conduit. Traitement spécifique débistrage requis.', dtu: 'RSD 13' },
            { titre: 'Conduit sans chapeau ou chapeau inadapté', detail: 'Nids d\'oiseaux, pluie, refoulement au vent du nord. Un chapeau anti-refoulement est indispensable en zone côtière Méditerranée.', dtu: 'NF DTU 24.1' },
            { titre: 'Dépassement insuffisant en toiture', detail: 'Le conduit doit dépasser d\'au moins 40 cm le faîtage le plus proche. En cas de vent rasant, ce non-respect crée un refoulement systématique.', dtu: 'NF DTU 24.1' },
            { titre: 'Fissure de la souche ou des joints de boisseau', detail: 'Infiltrations d\'eau, perte de tirage, monoxyde de carbone dans les combles. Visible à l\'inspection camera — invisible à l\'œil nu depuis le sol.', dtu: 'NF DTU 24.1' },
          ].map(({ titre, detail, dtu }) => (
            <div class="flex gap-4 p-4 bg-[#FFFFFF] rounded-xl border border-[#EEEEEE]">
              <div class="w-2 h-2 rounded-full bg-[#E8DDD4] mt-1.5 shrink-0"></div>
              <div>
                <p class="text-sm font-semibold text-[#1A1A1A] mb-1">{titre}</p>
                <p class="text-xs text-[#1A1A1A]/85 leading-relaxed mb-2">{detail}</p>
                <span class="inline-block text-[10px] font-mono bg-[#FFF3E0] text-[#F39C12] px-2 py-0.5 rounded">{dtu}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Déroulement intervention -->
      <div>
        <h2 class="text-2xl font-bold text-[#1A1A1A] mb-6">Déroulement d'une intervention</h2>
        <div class="space-y-4">
          {[
            { n: '1', t: 'Inspection visuelle', d: 'État du foyer, des parois, de la tablette de cheminée. Identification des dépôts, fissures, corps étrangers.' },
            { n: '2', t: 'Bâchage et protection', d: 'Pose de housse étanche sur le foyer. Protection totale de la pièce — zéro poussière dans votre intérieur.' },
            { n: '3', t: 'Ramonage mécanique', d: 'Passage du hérisson calibré de la base au sommet. Aspiration industrielle simultanée. Élimination de suie, bistre léger, résidus.' },
            { n: '4', t: 'Contrôle vacuité', d: 'Vérification de l\'absence d\'obstruction résiduelle par test de tirage.' },
            { n: '5', t: 'Compte-rendu et certificat', d: 'Certificat de ramonage RSD 13 remis sur place. Rapport technique envoyé par mail (rapport assurance sur demande).' },
          ].map(({ n, t, d }) => (
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded-full bg-[#E8DDD4] text-white text-sm font-bold flex items-center justify-center shrink-0">{n}</div>
              <div class="pt-1">
                <p class="text-sm font-semibold text-[#1A1A1A] mb-1">{t}</p>
                <p class="text-sm text-[#1A1A1A]/85 leading-relaxed">{d}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Section calculateur économies -->
      <div class="bg-green-50 border border-green-200 rounded-2xl p-8">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <h3 class="text-base font-bold text-green-900 mb-2">Ramonage certifié COSTIC = jusqu'à 15 % d'économie de combustible</h3>
            <p class="text-sm text-green-800/75 leading-relaxed mb-3">
              Selon les données COSTIC, un conduit encrassé réduit le tirage et force l'appareil à consommer plus de bois pour la même chaleur. Un ramonage annuel maintient la section libre, optimise le tirage et améliore le rendement de combustion. Sur une saison de chauffe à 3 stères, cela représente une économie réelle de 40 à 60 €.
            </p>
            <p class="text-xs text-green-700/60">Source : COSTIC — Centre d'études et de formation génie climatique / énergies</p>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="border border-[#EEEEEE] rounded-2xl p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div>
          <h2 class="text-xl font-extrabold tracking-tight text-[#2C3E50] mb-2">Foyer ouvert dans les Bouches-du-Rhône ?</h2>
          <p class="text-sm text-[#1A1A1A]/85 font-light">Martigues, Istres, Fos, Aix-en-Provence, Marseille et 60+ communes. Certificat RSD 13 le jour même.</p>
        </div>
        <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#E8DDD4] text-white text-sm font-bold px-6 py-3 rounded-xl hover:bg-[#F39C12] transition-colors shrink-0">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          06 64 72 96 00
        </a>
      </div>

      <!-- Maillage -->
      <nav aria-label="Services associés" class="pt-8 border-t border-[#EEEEEE]">
        <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-4">Services associés & complémentaires</p>
        <ul class="flex flex-wrap gap-3">
          {[
            { href: '/debistrage', label: 'Débistrage conduit — traitement bistre sévère' },
            { href: '/inspection-camera', label: 'Inspection caméra — fissures et anomalies' },
            { href: '/test-fumigene', label: 'Test fumigène — étanchéité conduit' },
            { href: '/tubage', label: 'Tubage — mise aux normes conduit' },
            { href: '/accessoires-toiture', label: 'Chapeau anti-refoulement' },
            { href: '/inserts', label: 'Fermeture par insert — gains thermiques' },
            { href: '/ramonage', label: 'Ramonage certifié RSD 13' },
            { href: '/normes', label: 'Normes NF DTU 24.1' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="text-xs text-[#1A1A1A]/85 border border-[#EEEEEE] rounded-lg px-3 py-1.5 hover:text-[#F39C12] hover:border-[#E8DDD4]/30 transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </nav>

    </div>
  </section>

</Layout>
