---
import Layout from '../layouts/Layout.astro';
import ContactButton from '../components/ContactButton.astro';

const siteUrl = 'https://www.sud-ramonage.fr';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'DataCatalog',
  name: 'Statistiques Sécurité Incendie & Obligations Ramonage — Bouches-du-Rhône',
  description: 'Données chiffrées sur les incendies domestiques de conduit, les intoxications au monoxyde de carbone et les obligations légales de ramonage dans les Bouches-du-Rhône (RSD 13).',
  url: `${siteUrl}/statistiques-securite`,
  publisher: {
    '@type': 'HomeAndConstructionBusiness',
    '@id': `${siteUrl}/#business`,
  },
  about: [
    { '@type': 'Thing', name: 'Incendies de conduit de fumée — statistiques France' },
    { '@type': 'Thing', name: 'Intoxication au monoxyde de carbone — prévention' },
    { '@type': 'Thing', name: 'Règlement Sanitaire Départemental 13 — obligations ramonage' },
  ],
  dataset: [
    {
      '@type': 'Dataset',
      name: 'Fréquences de ramonage obligatoires par type d\'appareil — RSD 13',
      description: 'Tableau des fréquences de ramonage imposées par le Règlement Sanitaire Départemental des Bouches-du-Rhône selon le type d\'appareil à combustion.',
      license: 'https://www.service-public.fr/particuliers/vosdroits/F20028',
      creator: { '@type': 'GovernmentOrganization', name: 'Préfecture des Bouches-du-Rhône' },
    },
    {
      '@type': 'Dataset',
      name: 'Statistiques incendies domestiques liés aux conduits de fumée — France',
      description: 'Données annuelles sur les feux de cheminée et incendies de conduit en France, issues des rapports SDIS et CNPP.',
      creator: { '@type': 'Organization', name: 'CNPP / SDIS' },
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Combien de fois par an faut-il ramoner sa cheminée dans les Bouches-du-Rhône ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Le RSD 13 (Règlement Sanitaire Départemental des Bouches-du-Rhône) impose un ramonage mécanique au minimum une fois par an pour tout conduit de fumée en service. Certains assureurs exigent deux ramonages annuels pour les appareils utilisés quotidiennement. Sans certificat de ramonage valide, l\'assureur peut refuser toute indemnisation en cas de sinistre.',
      },
    },
    {
      '@type': 'Question',
      name: 'Quels sont les risques d\'une cheminée non ramonée ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Une cheminée non ramonée expose à trois risques majeurs : (1) incendie de conduit par inflammation du bistre ou du calcin accumulé — ces dépôts s\'enflamment à 200 °C et atteignent 1 000 °C en quelques secondes ; (2) intoxication au monoxyde de carbone (CO) par refoulement des fumées dû à un conduit obstrué ou dégradé ; (3) refus d\'indemnisation assurantielle en cas de sinistre sans certificat de ramonage valide conforme RSD 13.',
      },
    },
    {
      '@type': 'Question',
      name: 'Combien d\'incendies de cheminée se produisent en France chaque année ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'En France, les feux de cheminée et de conduit représentent environ 70 000 interventions des sapeurs-pompiers chaque année selon les statistiques SDIS. Ils constituent l\'une des premières causes d\'incendie domestique, avec un coût moyen des sinistres évalué entre 8 000 € et 30 000 € selon l\'étendue des dégâts. La grande majorité de ces incendies aurait pu être évitée par un ramonage annuel.',
      },
    },
    {
      '@type': 'Question',
      name: 'Le bistre est-il vraiment dangereux dans un conduit de cheminée ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Oui. Le bistre est un dépôt de goudron (résine pyrolysée) qui s\'accumule sur les parois internes du conduit lors d\'une combustion à basse température ou avec du bois humide. Il s\'enflamme à partir de 200 °C, une température couramment atteinte lors d\'une flambée normale. Une fois enflammé, le bistre génère des températures de 800 à 1 000 °C à l\'intérieur du conduit — bien au-delà de la résistance thermique des maçonneries et tubages standard.',
      },
    },
    {
      '@type': 'Question',
      name: 'Quelle est l\'amende en cas de non-ramonage dans les Bouches-du-Rhône ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Le non-respect du RSD 13 peut entraîner une mise en demeure préfectorale. En cas de sinistre sans certificat de ramonage valide, c\'est surtout l\'assureur qui peut refuser la prise en charge — une pénalité économique pouvant dépasser 10 000 € pour un sinistre moyen. Le ramonage annuel (à partir de 75 €) est donc un investissement de prévention à coût très faible comparé au risque.',
      },
    },
    {
      '@type': 'Question',
      name: 'Comment le monoxyde de carbone (CO) est-il lié à l\'entretien des conduits ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Le monoxyde de carbone (CO) est un gaz inodore et incolore produit par toute combustion incomplète. Un conduit obstrué (nid, calcin, effondrement partiel), mal tirant ou en dépression provoque le refoulement des fumées chargées en CO dans la pièce de vie. En France, les intoxications au CO causent environ 3 000 accidents et 300 décès par an selon Santé Publique France. Un ramonage annuel avec test de vacuité est la mesure de prévention principale.',
      },
    },
  ],
};
---

<Layout
  title="Statistiques Sécurité Incendie & Obligations Ramonage — Bouches-du-Rhône"
  description="Données chiffrées sur les incendies de cheminée, les intoxications au CO et les obligations légales de ramonage dans les Bouches-du-Rhône (RSD 13). Source : SDIS, CNPP, Santé Publique France."
  breadcrumbs={[
    { name: 'Accueil', url: '/' },
    { name: 'Statistiques Sécurité', url: '/statistiques-securite' },
  ]}
  pageSchema={pageSchema}
>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- ═══ HERO ═══ -->
  <section class="pt-32 pb-16 px-6 md:px-10 bg-[#1A1A1A]">
    <div class="max-w-5xl mx-auto">
      <p class="text-[11px] font-semibold tracking-widest uppercase text-[#C0622F] mb-4">Données & Obligations</p>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight text-white leading-tight mb-6">
        Sécurité Incendie & Ramonage<br />
        <span class="text-white/45">Statistiques et Obligations Légales</span>
      </h1>
      <p class="text-base text-white/55 font-light leading-relaxed max-w-2xl">
        Données chiffrées sur les incendies de conduit, les intoxications au monoxyde de carbone et les fréquences de ramonage obligatoires dans les Bouches-du-Rhône — conformément au <strong class="text-white/80">RSD&nbsp;13</strong> et aux normes <strong class="text-white/80">NF DTU 24.1</strong>.
      </p>
    </div>
  </section>

  <!-- ═══ TABLE 1 — Fréquences de ramonage ═══ -->
  <section id="frequences-ramonage" class="py-16 px-6 md:px-10">
    <div class="max-w-5xl mx-auto">
      <div class="mb-10">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#C0622F] mb-3">RSD 13 — Bouches-du-Rhône</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-3">
          Fréquences de Ramonage Obligatoires par Type d'Appareil.
        </h2>
        <p class="text-sm text-[#1A1A1A]/55 font-light leading-relaxed max-w-2xl">
          Le Règlement Sanitaire Départemental des Bouches-du-Rhône (RSD 13) fixe les fréquences minimales d'entretien selon le type d'appareil à combustion. Ces obligations s'appliquent à tous les logements du département 13.
        </p>
      </div>

      <div class="overflow-x-auto rounded-xl border border-[#EEEEEE]">
        <table class="w-full text-sm border-collapse bg-white">
          <thead>
            <tr class="bg-[#1E293B] text-white">
              <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Type d'appareil</th>
              <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Fréquence RSD 13</th>
              <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Norme applicable</th>
              <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Risque principal</th>
              <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Tarif indicatif</th>
            </tr>
          </thead>
          <tbody>
            {[
              {
                appareil: 'Cheminée foyer ouvert',
                frequence: '1× / an minimum',
                norme: 'NF DTU 24.1 P1-1',
                risque: 'Bistre, calcin, tirage insuffisant',
                tarif: 'dès 75 €',
              },
              {
                appareil: 'Insert à bois',
                frequence: '1× / an minimum',
                norme: 'NF EN 13229 + NF DTU 24.1',
                risque: 'Bistre (combustion basse température), CO',
                tarif: 'dès 90 €',
              },
              {
                appareil: 'Poêle à bois',
                frequence: '1× / an minimum',
                norme: 'NF EN 13240 + NF DTU 24.1',
                risque: 'Condensation, point de rosée, corrosion tubage',
                tarif: 'dès 90 €',
              },
              {
                appareil: 'Poêle à granulés (pellets)',
                frequence: '1× / an minimum',
                norme: 'NF EN 14785 + NF DTU 24.1',
                risque: 'Cendres, obstruction brûleur, dépôt conduit',
                tarif: 'dès 110 €',
              },
              {
                appareil: 'Chaudière à bois / biomasse',
                frequence: '2× / an (saison + bilan)',
                norme: 'NF EN 303-5 + NF DTU 24.1',
                risque: 'Bistre intense, condensats acides, corrosion',
                tarif: 'Devis',
              },
              {
                appareil: 'Chaudière au fioul',
                frequence: '1× / an (entretien obligatoire)',
                norme: 'Décret n°2009-649',
                risque: 'Suies grasses, obstruction, CO',
                tarif: 'Devis',
              },
            ].map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#FAFAFA]'}>
                <td class="px-5 py-4 font-medium text-[#1A1A1A]">{row.appareil}</td>
                <td class="px-5 py-4">
                  <span class="inline-flex items-center gap-1.5 text-[#C0622F] font-semibold text-xs">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#C0622F] shrink-0"></span>
                    {row.frequence}
                  </span>
                </td>
                <td class="px-5 py-4 text-[#1A1A1A]/55 text-xs font-mono">{row.norme}</td>
                <td class="px-5 py-4 text-[#1A1A1A]/65 text-xs">{row.risque}</td>
                <td class="px-5 py-4 font-bold text-[#1A1A1A] text-xs">{row.tarif}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-[11px] text-[#1A1A1A]/35 font-light mt-3">Source : Règlement Sanitaire Départemental des Bouches-du-Rhône (RSD 13) — Arrêté préfectoral, Article 31. Tarifs indicatifs Sud Ramonage.</p>
    </div>
  </section>

  <!-- ═══ TABLE 2 — Statistiques incendies ═══ -->
  <section id="statistiques-incendies-conduit" class="py-16 px-6 md:px-10 bg-[#FAFAFA]">
    <div class="max-w-5xl mx-auto">
      <div class="mb-10">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#C0622F] mb-3">SDIS / CNPP — France</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-3">
          Incendies de Conduit & Feux de Cheminée en France.
        </h2>
        <p class="text-sm text-[#1A1A1A]/55 font-light leading-relaxed max-w-2xl">
          Les feux de cheminée et d'incendie de conduit représentent l'une des premières causes d'incendie domestique en France. La majorité de ces sinistres résulte d'un défaut d'entretien annuel du conduit.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        {[
          {
            chiffre: '~&nbsp;70 000',
            unite: 'interventions / an',
            label: 'Feux de cheminée pris en charge par les sapeurs-pompiers français chaque année',
            source: 'Source : SDIS — Direction générale de la Sécurité civile',
          },
          {
            chiffre: '~&nbsp;8 000 €',
            unite: 'coût moyen',
            label: 'Montant moyen d\'un sinistre lié à un feu de conduit (dégâts structure, fumée, eau d\'extinction)',
            source: 'Source : CNPP — Centre National de Prévention et de Protection',
          },
          {
            chiffre: '~&nbsp;80 %',
            unite: 'évitables',
            label: 'Des feux de cheminée auraient pu être évités par un ramonage annuel conforme, selon les enquêtes SDIS',
            source: 'Source : rapports d\'intervention SDIS 13 / CNPP',
          },
        ].map((stat) => (
          <div class="bg-white border border-[#EEEEEE] rounded-xl p-7">
            <p class="text-3xl md:text-4xl font-extrabold text-[#C0622F] leading-none mb-1" set:html={stat.chiffre}></p>
            <p class="text-xs text-[#1A1A1A]/45 font-medium uppercase tracking-wider mb-3">{stat.unite}</p>
            <p class="text-sm text-[#1A1A1A]/65 font-light leading-relaxed mb-4">{stat.label}</p>
            <p class="text-[10px] text-[#1A1A1A]/30 font-light italic">{stat.source}</p>
          </div>
        ))}
      </div>

      <div class="overflow-x-auto rounded-xl border border-[#EEEEEE]">
        <table class="w-full text-sm border-collapse bg-white">
          <thead>
            <tr class="bg-[#1E293B] text-white">
              <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Cause de l'incendie de conduit</th>
              <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Fréquence estimée</th>
              <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Mécanisme</th>
              <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Prévention</th>
            </tr>
          </thead>
          <tbody>
            {[
              {
                cause: 'Dépôt de bistre enflammé',
                freq: 'Cause principale (~60 %)',
                mecanisme: 'Goudron de combustion incomplète s\'enflamme à 200 °C, atteint 800–1 000 °C',
                prevention: 'Ramonage annuel + débistrage si encrassement',
              },
              {
                cause: 'Accumulation de calcin',
                freq: 'Cause secondaire (~20 %)',
                mecanisme: 'Dépôt minéral dur réduisant la section du conduit et augmentant la pression des fumées',
                prevention: 'Ramonage mécanique — hérisson adapté au type de conduit',
              },
              {
                cause: 'Obstruction (nid, corps étranger)',
                freq: '~10 % des interventions',
                mecanisme: 'Blocage des fumées → refoulement CO dans la pièce ou surpression thermique',
                prevention: 'Test de vacuité annuel lors du ramonage',
              },
              {
                cause: 'Fissure ou joint dégradé',
                freq: '~8 % des cas',
                mecanisme: 'Fuite de monoxyde de carbone dans les parois ou combles — indétectable sans caméra',
                prevention: 'Inspection caméra HD — diagnostic conduit complet',
              },
              {
                cause: 'Dépassement insuffisant en toiture',
                freq: '~2 % des sinistres',
                mecanisme: 'Tirage inversé par vent dominant — refoulement de fumées en pièce de vie',
                prevention: 'Contrôle réglementaire hauteur conduit — NF DTU 24.1 art. 6.4.1',
              },
            ].map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#FAFAFA]'}>
                <td class="px-5 py-4 font-medium text-[#1A1A1A]">{row.cause}</td>
                <td class="px-5 py-4">
                  <span class="inline-flex items-center gap-1.5 text-[#C0622F] font-semibold text-xs">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#C0622F] shrink-0"></span>
                    {row.freq}
                  </span>
                </td>
                <td class="px-5 py-4 text-[#1A1A1A]/65 text-xs leading-relaxed">{row.mecanisme}</td>
                <td class="px-5 py-4 text-[#1A1A1A]/65 text-xs leading-relaxed">{row.prevention}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-[11px] text-[#1A1A1A]/35 font-light mt-3">Sources : CNPP (Centre National de Prévention et de Protection), rapports d'intervention SDIS France, Observatoire national du risque incendie.</p>
    </div>
  </section>

  <!-- ═══ TABLE 3 — Monoxyde de carbone ═══ -->
  <section id="danger-monoxyde-carbone" class="py-16 px-6 md:px-10">
    <div class="max-w-5xl mx-auto">
      <div class="mb-10">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#C0622F] mb-3">Santé Publique France</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-3">
          Intoxications au Monoxyde de Carbone (CO) en France.
        </h2>
        <p class="text-sm text-[#1A1A1A]/55 font-light leading-relaxed max-w-2xl">
          Le monoxyde de carbone (CO) est la première cause de décès par intoxication en France. Les conduits de fumée mal entretenus ou obstrués sont l'une des sources principales d'exposition domestique.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
        {[
          {
            chiffre: '~&nbsp;3 000',
            unite: 'accidents / an',
            label: 'Intoxications accidentelles au monoxyde de carbone en France (toutes sources confondues)',
            source: 'Source : Santé Publique France — bilan annuel intoxications CO',
          },
          {
            chiffre: '~&nbsp;300',
            unite: 'décès / an',
            label: 'Décès par intoxication au CO en France — première cause de mortalité par intoxication',
            source: 'Source : Santé Publique France / InVS',
          },
        ].map((stat) => (
          <div class="bg-[#1A1A1A] border border-[#333] rounded-xl p-7">
            <p class="text-4xl font-extrabold text-[#C0622F] leading-none mb-1" set:html={stat.chiffre}></p>
            <p class="text-xs text-white/45 font-medium uppercase tracking-wider mb-3">{stat.unite}</p>
            <p class="text-sm text-white/65 font-light leading-relaxed mb-4">{stat.label}</p>
            <p class="text-[10px] text-white/30 font-light italic">{stat.source}</p>
          </div>
        ))}
      </div>

      <div class="overflow-x-auto rounded-xl border border-[#EEEEEE]">
        <table class="w-full text-sm border-collapse bg-white">
          <thead>
            <tr class="bg-[#1E293B] text-white">
              <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Concentration CO (ppm)</th>
              <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Effet sur la santé</th>
              <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Délai d'exposition</th>
              <th class="text-left px-5 py-4 text-xs font-semibold tracking-wider">Niveau de risque</th>
            </tr>
          </thead>
          <tbody>
            {[
              { ppm: '35 ppm', effet: 'Maux de tête après 6–8 h', delai: 'Exposition prolongée', risque: 'Faible', couleur: '#4CAF50' },
              { ppm: '100 ppm', effet: 'Maux de tête sévères, vertiges', delai: '2–3 heures', risque: 'Modéré', couleur: '#FF9800' },
              { ppm: '200 ppm', effet: 'Nausées, confusion, perte de connaissance', delai: '2–3 heures', risque: 'Élevé', couleur: '#F44336' },
              { ppm: '400 ppm', effet: 'Danger vital — mort possible', delai: '1–2 heures', risque: 'Critique', couleur: '#B71C1C' },
              { ppm: '1 600 ppm', effet: 'Mort rapide', delai: '< 20 minutes', risque: 'Mortel', couleur: '#4A0000' },
            ].map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#FAFAFA]'}>
                <td class="px-5 py-4 font-mono font-bold text-[#1A1A1A]">{row.ppm}</td>
                <td class="px-5 py-4 text-[#1A1A1A]/75">{row.effet}</td>
                <td class="px-5 py-4 text-[#1A1A1A]/55 text-xs">{row.delai}</td>
                <td class="px-5 py-4">
                  <span class="inline-block text-white text-[10px] font-bold px-3 py-1 rounded-full" style={`background-color: ${row.couleur}`}>
                    {row.risque}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-[11px] text-[#1A1A1A]/35 font-light mt-3">Source : Santé Publique France / InVS — Valeurs seuils CO d'après ANSES et OSHA. Le CO est inodore et incolore — seul un détecteur homologué EN 50291 et un conduit entretenu protègent efficacement.</p>
    </div>
  </section>

  <!-- ═══ FAQ structurée Q&A ═══ -->
  <section id="faq-securite-ramonage" class="py-16 px-6 md:px-10 bg-[#FAFAFA]">
    <div class="max-w-5xl mx-auto">
      <div class="mb-10">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#C0622F] mb-3">Questions fréquentes</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A]">
          Obligations, Risques & Statistiques — Réponses Directes.
        </h2>
      </div>

      <div class="space-y-0 divide-y divide-[#EEEEEE] border border-[#EEEEEE] rounded-xl overflow-hidden bg-white">
        {[
          {
            q: 'Combien de fois par an faut-il ramoner sa cheminée dans les Bouches-du-Rhône ?',
            a: 'Le RSD 13 impose un ramonage mécanique au minimum une fois par an pour tout conduit de fumée en service. Certains assureurs exigent deux ramonages annuels pour les appareils utilisés quotidiennement. Sans certificat de ramonage valide, l\'assureur peut refuser toute indemnisation en cas de sinistre.',
          },
          {
            q: 'Quels sont les risques d\'une cheminée non ramonée ?',
            a: 'Trois risques majeurs : (1) incendie de conduit par inflammation du bistre ou du calcin accumulé — ces dépôts s\'enflamment à 200 °C et atteignent 1 000 °C ; (2) intoxication au monoxyde de carbone par refoulement des fumées d\'un conduit obstrué ; (3) refus d\'indemnisation assurantielle sans certificat de ramonage conforme RSD 13.',
          },
          {
            q: 'Combien d\'incendies de cheminée se produisent en France chaque année ?',
            a: 'En France, les feux de cheminée et de conduit représentent environ 70 000 interventions des sapeurs-pompiers chaque année (SDIS). Ils constituent l\'une des premières causes d\'incendie domestique, avec un coût moyen de sinistre entre 8 000 € et 30 000 €. La grande majorité aurait pu être évitée par un ramonage annuel.',
          },
          {
