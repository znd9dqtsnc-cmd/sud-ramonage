---
import Layout from '../../layouts/Layout.astro';
import ContactButton from '../../components/ContactButton.astro';
import { realisations, realisationsMap, typeConfig } from '../../data/realisations';

export function getStaticPaths() {
  return realisations.map((r) => ({ params: { slug: r.slug }, props: { r } }));
}

const { r } = Astro.props;
const cfg = typeConfig[r.type];
const siteUrl = 'https://www.sud-ramonage.fr';

const dateFormatted = new Date(r.date).toLocaleDateString('fr-FR', {
  day: 'numeric', month: 'long', year: 'numeric'
});

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: r.titre,
  description: r.excerpt,
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  areaServed: {
    '@type': 'City',
    name: r.nomVille,
    postalCode: r.codePostal,
    containedInPlace: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
  },
  serviceType: cfg.label,
  url: `${siteUrl}/realisations/${r.slug}`,
  dateModified: r.date,
};
---

<Layout
  title={`${r.titre} — Rapport Technique | Sud Ramonage`}
  description={r.excerpt}
  canonical={`${siteUrl}/realisations/${r.slug}`}
  breadcrumbs={[
    { name: 'Accueil', url: '/' },
    { name: 'Réalisations', url: '/realisations' },
    { name: r.titre, url: `/realisations/${r.slug}` },
  ]}
  pageSchema={pageSchema}
>

  <!-- ═══ HERO RAPPORT ═══ -->
  <section class="pt-32 pb-12 px-6 md:px-10 bg-[#FAFAFA] border-b border-[#EEEEEE]">
    <div class="max-w-6xl mx-auto">
      <nav class="flex items-center gap-2 text-xs text-[#1A1A1A]/35 mb-6" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-[#2B7A78] transition-colors duration-200">Accueil</a>
        <span>/</span>
        <a href="/realisations" class="hover:text-[#2B7A78] transition-colors duration-200">Réalisations</a>
        <span>/</span>
        <span class="text-[#1A1A1A]/55 line-clamp-1">{r.titre}</span>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class={`inline-flex items-center px-2.5 py-1 rounded-md text-[10px] font-semibold ${cfg.color} ${cfg.bg} border ${cfg.border}`}>
            {cfg.label}
          </span>
          <span class="text-xs text-[#1A1A1A]/35">Rapport Technique</span>
          <span class="text-xs text-[#1A1A1A]/35">·</span>
          <span class="text-xs text-[#1A1A1A]/35 font-mono">{r.ref}</span>
          <span class="text-xs text-[#1A1A1A]/35">·</span>
          <time datetime={r.date} class="text-xs text-[#1A1A1A]/35">{dateFormatted}</time>
        </div>
        <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-[#1A1A1A] leading-tight mb-4">
          {r.titre}
        </h1>
        <p class="text-base text-[#1A1A1A]/55 font-light leading-relaxed">
          {r.excerpt}
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ CONTENU + SIDEBAR ═══ -->
  <div class="max-w-6xl mx-auto px-6 md:px-10 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

      <!-- Rapport principal -->
      <article class="lg:col-span-8 space-y-8">

        <!-- Fiche Intervention -->
        <div class="bg-[#9A3412] rounded-2xl p-7">
          <p class="text-[10px] font-semibold tracking-widest uppercase text-[#2B7A78] mb-5">Fiche d'Intervention</p>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-5">
            {[
              { label: 'Ville', val: `${r.nomVille} (${r.codePostal})` },
              { label: 'Zone', val: r.zone },
              { label: 'Durée', val: r.duree },
              { label: 'Référence', val: r.ref },
              { label: 'Date', val: dateFormatted },
              { label: 'Certificat', val: r.certificat ? 'Remis sur place' : 'Non applicable' },
            ].map(({ label, val }) => (
              <div>
                <p class="text-[10px] font-semibold tracking-widest uppercase text-white/25 mb-1">{label}</p>
                <p class="text-sm font-medium text-white/80">{val}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Matériel & Équipement -->
        <div class="bg-white border border-[#EEEEEE] rounded-2xl p-7">
          <p class="text-[10px] font-semibold tracking-widest uppercase text-[#2B7A78] mb-5">Appareil & Conduit</p>
          <div class="space-y-4">
            <div>
              <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-1">Appareil concerné</p>
              <p class="text-sm text-[#1A1A1A]/75 font-light">{r.appareil}</p>
            </div>
            <div>
              <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-1">Conduit d'évacuation</p>
              <p class="text-sm text-[#1A1A1A]/75 font-light">{r.conduit}</p>
            </div>
            <div>
              <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-2">Matériel utilisé</p>
              <ul class="flex flex-wrap gap-2">
                {r.materiel.map(m => (
                  <li class="inline-flex items-center px-3 py-1.5 bg-[#FAFAFA] border border-[#EEEEEE] rounded-lg text-xs text-[#1A1A1A]/60 font-light">
                    {m}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <!-- Constat Initial -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg bg-amber-100 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zm-3-9a9 9 0 100 18A9 9 0 009 3z" />
              </svg>
            </div>
            <h2 class="text-base font-extrabold text-[#1A1A1A] tracking-tight">Constat Initial</h2>
          </div>
          <div class="bg-amber-50 border border-amber-200 rounded-xl p-6">
            <p class="text-sm text-[#1A1A1A]/70 font-light leading-relaxed">{r.constatInitial}</p>
          </div>
        </div>

        <!-- Intervention Réalisée -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg bg-[#F0FDFC] flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-[#2B7A78]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h2 class="text-base font-extrabold text-[#1A1A1A] tracking-tight">Intervention Réalisée</h2>
          </div>
          <div class="bg-white border border-[#EEEEEE] rounded-xl p-6">
            <p class="text-sm text-[#1A1A1A]/70 font-light leading-relaxed whitespace-pre-line">{r.interventionRealisee}</p>
          </div>
        </div>

        <!-- Résultat -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h2 class="text-base font-extrabold text-[#1A1A1A] tracking-tight">Résultat & Conclusions</h2>
          </div>
          <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-6">
            <p class="text-sm text-[#1A1A1A]/70 font-light leading-relaxed">{r.resultat}</p>
            {r.certificat && (
              <div class="flex items-center gap-2 mt-4 pt-4 border-t border-emerald-200">
                <svg class="w-4 h-4 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <span class="text-xs font-semibold text-emerald-700">Certificat de ramonage conforme RSD 13 remis sur place</span>
              </div>
            )}
          </div>
        </div>

        <!-- Navigation -->
        <div class="pt-6 border-t border-[#EEEEEE] flex items-center justify-between">
          <a href="/realisations" class="inline-flex items-center gap-2 text-xs font-medium text-[#1A1A1A]/45 hover:text-[#2B7A78] transition-colors duration-200">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Toutes les interventions
          </a>
          <a href={`/villes/${r.villeSlug}`} class="inline-flex items-center gap-2 text-xs font-medium text-[#1A1A1A]/45 hover:text-[#2B7A78] transition-colors duration-200">
            Ramonage à {r.nomVille}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

      </article>

      <!-- Sidebar -->
      <aside class="lg:col-span-4">
        <div class="sticky top-24 space-y-5">

          <!-- CTA -->
          <div class="bg-[#F0FDFC] rounded-xl p-7 text-center">
            <div class="w-10 h-10 rounded-full bg-[#2B7A78] flex items-center justify-center mx-auto mb-4">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <p class="text-sm font-bold text-white mb-1">Même intervention chez vous ?</p>
            <p class="text-xs text-white/45 font-light mb-5 leading-relaxed">Devis gratuit, intervention rapide sur {r.nomVille} et toute la zone.</p>
            <a
              href="tel:+33664729600"
              class="flex items-center justify-center gap-2 bg-[#2B7A78] text-white text-sm font-bold px-5 py-3.5 rounded-lg hover:bg-[#1F5F5C] transition-colors duration-200 w-full"
            >
              06 64 72 96 00
            </a>
          </div>

          <!-- Service associé -->
          <a
            href={r.serviceHref}
            class="flex items-center justify-between bg-[#F0FDFC] border border-[#2B7A78]/20 rounded-xl px-5 py-4 group hover:bg-[#CCFBF1] transition-colors duration-200"
          >
            <div>
              <p class="text-[10px] font-semibold tracking-widest uppercase text-[#2B7A78] mb-0.5">Service associé</p>
              <p class="text-sm font-bold text-[#1A1A1A] group-hover:text-[#2B7A78] transition-colors duration-200">{cfg.label}</p>
            </div>
            <svg class="w-4 h-4 text-[#2B7A78] group-hover:translate-x-0.5 transition-transform duration-200 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>

          <!-- Info ville -->
          <div class="bg-[#FAFAFA] border border-[#EEEEEE] rounded-xl p-6 space-y-3">
            <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/35 mb-3">Zone d'intervention</p>
            <a href={`/villes/${r.villeSlug}`} class="flex items-center gap-2 group">
              <svg class="w-4 h-4 text-[#2B7A78] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="text-sm font-semibold text-[#1A1A1A] group-hover:text-[#2B7A78] transition-colors duration-200">
                Ramonage à {r.nomVille}
              </span>
            </a>
            <p class="text-xs text-[#1A1A1A]/40 font-light">{r.nomVille} — {r.codePostal} — {r.zone}</p>
          </div>

        </div>
      </aside>

    </div>
  </div>

</Layout>
