---
import Layout from '../../layouts/Layout.astro';
import ContactButton from '../../components/ContactButton.astro';
import { Image } from 'astro:assets';
import { villes } from '../../data/villes';
import { getRealisationsByVille, typeConfig } from '../../data/realisations';

import heroBg      from '../../assets/images/hero-toits.jpg';
import galleryImg1 from '../../assets/images/service-ramonage.jpg';
import galleryImg2 from '../../assets/images/artisan-intervention.jpg';
import galleryImg3 from '../../assets/images/service-controle.jpg';

export function getStaticPaths() {
  return villes.map((v) => ({ params: { ville: v.slug }, props: { data: v } }));
}

const { data } = Astro.props;
const villeRealisations = getRealisationsByVille(data.slug);
const siteUrl = 'https://sud-ramonage.vercel.app';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Ramonage certifié à ${data.nom}`,
  description: data.metaDescription,
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  areaServed: {
    '@type': 'City',
    name: data.nom,
    postalCode: data.codePostal,
    containedInPlace: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
  },
  serviceType: 'Ramonage de cheminée',
  url: `${siteUrl}/villes/${data.slug}`,
};
---

<Layout
  title={data.metaTitle}
  description={data.metaDescription}
  breadcrumbs={[
    { name: 'Accueil', url: '/' },
    { name: 'Services', url: '/#services' },
    { name: data.nom, url: `/villes/${data.slug}` },
  ]}
  pageSchema={pageSchema}
>

  <!-- ═══ HERO avec image de fond provençale ═══ -->
  <section class="relative pt-32 pb-20 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={heroBg}
        alt={`Toits de tuiles provençaux à ${data.nom} — zone d'intervention de Sud Ramonage`}
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#1A1A1A]/80 via-[#1A1A1A]/70 to-[#1A1A1A]/85"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto">
      <nav class="flex items-center gap-2 text-xs text-white/30 mb-8" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-white transition-colors duration-200">Accueil</a>
        <span>/</span>
        <a href="/#services" class="hover:text-white transition-colors duration-200">Services</a>
        <span>/</span>
        <span class="text-white/60">{data.nom}</span>
      </nav>
      <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-4">
        Ramonage — {data.zone}
      </p>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white leading-tight mb-6">
        Ramonage et Entretien<br />de Cheminée à {data.nom}.
      </h1>
      <p class="text-base text-white/55 font-light max-w-xl leading-relaxed mb-8">
        {data.intro}
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <ContactButton variant="phone" class="w-full sm:w-auto px-8 py-3.5" />
        <span class="inline-flex items-center gap-2 text-xs text-white/35">
          <svg class="w-4 h-4 text-[#E65100] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Intervention en {data.tempsIntervention} ({data.distance})
        </span>
      </div>
    </div>
  </section>

  <!-- ═══ CONTEXTE LOCAL ═══ -->
  <section class="py-20 px-6 md:px-10">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">

        <div class="lg:col-span-7 space-y-6">
          <div>
            <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-4">Contexte local</p>
            <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-5">
              Entretien de Cheminée sur le Secteur de {data.nom}.
            </h2>
            <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed">
              {data.contexteLocal}
            </p>
          </div>
          <div>
            <h3 class="text-lg font-bold tracking-tight text-[#1A1A1A] mb-3">Spécificités des conduits à {data.nom}</h3>
            <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed">
              {data.specificiteConduits}
            </p>
          </div>
        </div>

        <!-- Réassurance latérale -->
        <aside class="lg:col-span-5">
          <div class="bg-[#FFF3E0] rounded-xl p-7 space-y-5">
            <p class="text-sm font-bold text-[#1A1A1A]">Intervention à {data.nom}</p>
            {[
              { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', txt: `Délai : ${data.tempsIntervention}` },
              { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', txt: 'Certificat remis sur place' },
              { icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', txt: 'Conforme RSD 13' },
              { icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z', txt: 'Devis gratuit sous 24h' },
            ].map(({ icon, txt }) => (
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-white flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-[#E65100]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
                  </svg>
                </div>
                <span class="text-sm text-[#1A1A1A]/70 font-light">{txt}</span>
              </div>
            ))}
            <div class="pt-2">
              <ContactButton variant="phone" class="w-full justify-center" />
            </div>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- ═══ GALERIE D'INTERVENTION ═══ -->
  <section class="py-16 px-6 md:px-10 bg-[#FAFAFA]">
    <div class="max-w-6xl mx-auto">
      <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-4">Galerie</p>
      <h2 class="text-xl md:text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-8">
        Nos Interventions à {data.nom} et Environs.
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

        <!-- Photo 1 : ramonage en action -->
        <figure class="relative rounded-xl overflow-hidden aspect-[4/3] group">
          <Image
            src={galleryImg1}
            alt={`Ramonage mécanique de cheminée en cours à ${data.nom} — hérisson rotatif, élimination suies et bistre`}
            width={600}
            height={450}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#1A1A1A]/60 to-transparent"></div>
          <p class="absolute bottom-4 left-4 text-xs font-semibold text-white">Ramonage en action</p>
          <figcaption class="sr-only">Ramonage mécanique conduit cheminée à {data.nom} ({data.codePostal}) — élimination suies, bistre, calcin. Artisan certifié Bouches-du-Rhône, tirage thermique contrôlé, conforme RSD 13.</figcaption>
        </figure>

        <!-- Photo 2 : artisan certifié -->
        <figure class="relative rounded-xl overflow-hidden aspect-[4/3] group">
          <Image
            src={galleryImg2}
            alt={`Artisan ramoneur certifié de Sud Ramonage lors d'une intervention à ${data.nom}, Bouches-du-Rhône`}
            width={600}
            height={450}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#1A1A1A]/60 to-transparent"></div>
          <p class="absolute bottom-4 left-4 text-xs font-semibold text-white">Artisan certifié</p>
          <figcaption class="sr-only">Artisan ramoneur certifié Sud Ramonage à {data.nom} — intervention ramonage, test de vacuité, tubage inox. Devis gratuit sous 24h. Conforme Règlement Sanitaire Départemental RSD 13.</figcaption>
        </figure>

        <!-- Photo 3 : contrôle technique -->
        <figure class="relative rounded-xl overflow-hidden aspect-[4/3] group">
          <Image
            src={galleryImg3}
            alt={`Contrôle technique et test de vacuité du conduit de cheminée après ramonage à ${data.nom}`}
            width={600}
            height={450}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#1A1A1A]/60 to-transparent"></div>
          <p class="absolute bottom-4 left-4 text-xs font-semibold text-white">Contrôle & certificat</p>
          <figcaption class="sr-only">Contrôle technique conduit cheminée à {data.nom} — test de vacuité, vérification tirage thermique, absence bistre et calcin. Certificat de ramonage RSD 13 remis immédiatement.</figcaption>
        </figure>

      </div>
      <p class="text-xs text-[#1A1A1A]/35 mt-4 text-center">Photos illustratives — vos photos d'intervention seront intégrées ici.</p>
    </div>
  </section>

  <!-- ═══ SERVICES ═══ -->
  <section class="py-20 px-6 md:px-10">
    <div class="max-w-6xl mx-auto">
      <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-4">Prestations</p>
      <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-10">
        Nos Services à {data.nom}.
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { href: '/ramonage',        num: '01', titre: 'Ramonage Certifié',  desc: 'Nettoyage mécanique complet + certificat officiel conforme RSD 13.' },
          { href: '/debistrage',      num: '02', titre: 'Débistrage',          desc: 'Élimination des dépôts de goudron. Traitement chimique et mécanique.' },
          { href: '/entretien-poele', num: '03', titre: 'Entretien Poêle',    desc: 'Maintenance complète de votre poêle à bois ou à granulés.' },
        ].map(({ href, num, titre, desc }) => (
          <a href={href} class="group bg-white border border-[#EEEEEE] rounded-xl p-6 hover:border-[#E65100]/30 hover:shadow-md transition-all duration-200">
            <p class="text-[10px] font-semibold tracking-widest uppercase text-[#E65100] mb-3">{num}</p>
            <h3 class="text-base font-bold text-[#1A1A1A] mb-2 group-hover:text-[#E65100] transition-colors duration-200">{titre}</h3>
            <p class="text-sm text-[#1A1A1A]/50 font-light">{desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ RÉGLEMENTATION ═══ -->
  <section class="py-20 px-6 md:px-10 bg-[#FAFAFA]">
    <div class="max-w-6xl mx-auto">
      <div class="max-w-3xl">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-4">Réglementation</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-5">
          Obligation de Ramonage à {data.nom} (RSD 13).
        </h2>
        <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed mb-6">
          {data.rsdContexte}
        </p>
        <div class="bg-[#FFF3E0] border-l-4 border-[#E65100] rounded-r-xl px-6 py-5">
          <p class="text-sm font-semibold text-[#1A1A1A] mb-1">Rappel légal</p>
          <p class="text-sm text-[#1A1A1A]/65 font-light leading-relaxed">
            En cas de sinistre (incendie de conduit, intoxication au CO), votre assureur peut refuser la prise en charge si vous ne présentez pas un certificat de ramonage en cours de validité. Sud Ramonage vous remet ce document immédiatement après chaque intervention.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TÉMOIGNAGE ═══ -->
  <section class="py-16 px-6 md:px-10 bg-[#1A1A1A]">
    <div class="max-w-6xl mx-auto">
      <div class="max-w-2xl mx-auto text-center">
        <svg class="w-8 h-8 text-[#E65100] mx-auto mb-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
        </svg>
        <blockquote class="text-lg text-white/80 font-light italic leading-relaxed mb-6">
          "{data.temoignage.texte}"
        </blockquote>
        <p class="text-sm font-semibold text-white">{data.temoignage.auteur}</p>
        <p class="text-xs text-white/35 mt-1">{data.nom}, Bouches-du-Rhône</p>
      </div>
    </div>
  </section>

  <!-- ═══ MAILLAGE SILO ═══ -->
  <section class="py-12 px-6 md:px-10 bg-[#FAFAFA]">
    <div class="max-w-6xl mx-auto">
      <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/35 mb-4">Service principal & zones voisines</p>
      <div class="flex flex-wrap gap-3">
        <a href="/ramonage" class="inline-flex items-center gap-2 bg-white border border-[#E65100]/20 rounded-lg px-4 py-2.5 text-xs font-semibold text-[#E65100] hover:bg-[#FFF3E0] transition-all duration-200">
          <span class="w-1.5 h-1.5 rounded-full bg-[#E65100] shrink-0"></span>
          Ramonage Certifié — Toute la Zone
        </a>
        {villes.filter(v => v.slug !== data.slug).slice(0, 4).map(v => (
          <a href={`/villes/${v.slug}`} class="inline-flex items-center gap-2 bg-white border border-[#EEEEEE] rounded-lg px-4 py-2.5 text-xs font-medium text-[#1A1A1A]/65 hover:border-[#E65100]/30 hover:text-[#E65100] transition-all duration-200">
            <span class="w-1.5 h-1.5 rounded-full bg-[#1A1A1A]/20 shrink-0"></span>
            Ramonage {v.nom}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ DERNIÈRES INTERVENTIONS ═══ -->
  {villeRealisations.length > 0 && (
    <section class="py-16 px-6 md:px-10">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-end justify-between mb-8">
          <div>
            <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-2">Interventions récentes</p>
            <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A]">
              Dernières Interventions à {data.nom}.
            </h2>
          </div>
          <a href="/realisations" class="hidden md:inline-flex items-center gap-1.5 text-xs font-semibold text-[#E65100] hover:underline">
            Voir toutes les réalisations
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {villeRealisations.map((r) => {
            const cfg = typeConfig[r.type];
            const dateFormatted = new Date(r.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
            return (
              <a
                href={`/realisations/${r.slug}`}
                class="group bg-white border border-[#EEEEEE] rounded-2xl p-6 hover:border-[#E65100]/30 hover:shadow-md transition-all duration-200 flex flex-col gap-4"
              >
                <div class="flex items-start justify-between gap-3">
                  <span class={`inline-flex items-center px-2.5 py-1 rounded-md text-[10px] font-semibold ${cfg.color} ${cfg.bg} border ${cfg.border}`}>
                    {cfg.label}
                  </span>
                  <span class="text-[10px] text-[#1A1A1A]/30 font-mono shrink-0">{r.ref}</span>
                </div>
                <div>
                  <h3 class="text-sm font-bold text-[#1A1A1A] leading-snug mb-2 group-hover:text-[#E65100] transition-colors duration-200">
                    {r.titre}
                  </h3>
                  <p class="text-xs text-[#1A1A1A]/50 font-light leading-relaxed">{r.excerpt}</p>
                </div>
                <div class="flex items-center justify-between pt-3 border-t border-[#EEEEEE]">
                  <span class="text-[10px] text-[#1A1A1A]/30">{r.duree} · {dateFormatted}</span>
                  <span class="text-[11px] font-semibold text-[#E65100] group-hover:underline">Voir le rapport →</span>
                </div>
              </a>
            );
          })}
        </div>
        <div class="mt-6 md:hidden">
          <a href="/realisations" class="inline-flex items-center gap-1.5 text-xs font-semibold text-[#E65100] hover:underline">
            Voir toutes les réalisations →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ═══ CTA FINAL ═══ -->
  <section class="py-20 px-6 md:px-10 bg-[#FFF3E0]">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-4">
        Besoin d'un Ramonage à {data.nom} ?
      </h2>
      <p class="text-base text-[#1A1A1A]/55 font-light mb-8">
        Intervention sous {data.tempsIntervention}. Devis gratuit, sans engagement.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <ContactButton variant="phone" class="px-10 py-4 text-sm" />
        <ContactButton variant="email" />
      </div>
    </div>
  </section>

</Layout>
