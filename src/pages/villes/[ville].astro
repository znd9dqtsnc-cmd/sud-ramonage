---
import Layout from '../../layouts/Layout.astro';
import ContactButton from '../../components/ContactButton.astro';
import COSTICBadge from '../../components/COSTICBadge.astro';
import { Image } from 'astro:assets';
import { villes } from '../../data/villes';
import { villesWiki } from '../../data/villesWiki';
import { getRealisationsByVille, typeConfig } from '../../data/realisations';

import heroBg      from '../../assets/images/hero-toits.jpg';
import galleryImg1 from '../../assets/images/service-ramonage.jpg';
import galleryImg2 from '../../assets/images/artisan-intervention.jpg';
import galleryImg3 from '../../assets/images/service-controle.jpg';

export function getStaticPaths() {
  return villes.map((v) => ({ params: { ville: v.slug }, props: { data: v } }));
}

const { data } = Astro.props;
const villeRealisations = getRealisationsByVille(data.slug);
const siteUrl = 'https://www.sud-ramonage.fr';

// Cas typiques par défaut si la ville n'en a pas de spécifiques
const defaultCas = [
  {
    titre: 'Dépassement insuffisant en toiture',
    detail: `Conduit trop court par rapport au faîtage — tirage insuffisant et refoulements fréquents par vent dominant. Non-conformité courante sur les toitures modifiées.`,
    dtu: 'NF DTU 24.1',
  },
  {
    titre: 'Joint de boisseau fissuré',
    detail: `Mortier de jointement entre boisseaux de terre cuite dégradé après 30-40 ans. Fuite de monoxyde de carbone dans les combles possible — détectable uniquement à la caméra.`,
    dtu: 'NF DTU 24.1',
  },
  {
    titre: 'Section conduit inadaptée à l\'appareil',
    detail: `Poêle ou insert installé dans un foyer ouvert sans adaptation de section — ratio foyer/gorge non respecté, fumée dans la pièce dès vent fort.`,
    dtu: 'NF DTU 24.1',
  },
];

const casAffichés = data.casTypiques && data.casTypiques.length > 0 ? data.casTypiques : defaultCas;

const wikiData = villesWiki[data.slug];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Ramonage certifié à ${data.nom}`,
  description: data.metaDescription,
  provider: {
    '@type': 'HomeAndConstructionBusiness',
    '@id': `${siteUrl}/#business`,
    name: 'Sud Ramonage',
    employee: {
      '@type': 'Person',
      '@id': `${siteUrl}/#gerant`,
    },
  },
  areaServed: {
    '@type': 'City',
    name: data.nom,
    postalCode: data.codePostal,
    containedInPlace: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
    ...(data.geo ? {
      geo: {
        '@type': 'GeoCoordinates',
        latitude: data.geo.latitude,
        longitude: data.geo.longitude,
      },
    } : {}),
    ...(data.landmark ? { landmark: data.landmark } : {}),
    ...(wikiData ? {
      subjectOf: [
        { '@type': 'WebPage', url: wikiData.cityUrl, name: `${data.nom} — Wikipedia` },
        ...(wikiData.landmarkUrl ? [{ '@type': 'WebPage', url: wikiData.landmarkUrl, name: `${data.landmark ?? data.nom} — Wikipedia` }] : []),
      ],
      sameAs: wikiData.cityUrl,
    } : {}),
  },
  serviceType: 'Ramonage de cheminée',
  url: `${siteUrl}/villes/${data.slug}`,
  ...(data.geo ? {
    spatialCoverage: {
      '@type': 'Place',
      name: data.nom,
      geo: {
        '@type': 'GeoCoordinates',
        latitude: data.geo.latitude,
        longitude: data.geo.longitude,
      },
    },
  } : {}),
  offers: {
    '@type': 'Offer',
    price: '75',
    priceCurrency: 'EUR',
    priceSpecification: {
      '@type': 'PriceSpecification',
      minPrice: '75',
      maxPrice: '195',
      priceCurrency: 'EUR',
    },
  },
};

const collectionPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Services de ramonage à ${data.nom} — Sud Ramonage`,
  description: `Annuaire complet des services de ramonage, débistrage, inspection caméra et entretien poêle disponibles à ${data.nom} (${data.codePostal}).`,
  url: `${siteUrl}/villes/${data.slug}`,
  inLanguage: 'fr-FR',
  publisher: {
    '@type': 'HomeAndConstructionBusiness',
    '@id': `${siteUrl}/#business`,
  },
  hasPart: [
    { '@type': 'WebPage', name: 'Ramonage certifié RSD 13', url: `${siteUrl}/ramonage` },
    { '@type': 'WebPage', name: 'Débistrage — traitement anti-bistre', url: `${siteUrl}/debistrage` },
    { '@type': 'WebPage', name: 'Inspection caméra endoscopique HD', url: `${siteUrl}/inspection-camera` },
    { '@type': 'WebPage', name: 'Entretien corps de chauffe — poêle bois et granulés', url: `${siteUrl}/entretien-poele` },
    { '@type': 'WebPage', name: 'Tubage inox conduit de fumée', url: `${siteUrl}/tubage` },
    { '@type': 'WebPage', name: 'Normes et obligations légales RSD 13', url: `${siteUrl}/normes` },
  ],
  about: {
    '@type': 'City',
    name: data.nom,
    postalCode: data.codePostal,
    containedInPlace: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
  },
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${siteUrl}/#gerant`,
  name: 'Le gérant — Sud Ramonage',
  jobTitle: 'Artisan ramoneur certifié COSTIC',
  worksFor: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  knowsAbout: [
    'Ramonage de cheminée NF DTU 24.1',
    'Fumisterie — NF EN 1443',
    'Diagnostic sécurité conduits de fumée',
    'Inspection caméra endoscopique',
    'Règlement Sanitaire Départemental 13',
    'Débistrage chimique et mécanique',
  ],
  hasCredential: [
    { '@type': 'EducationalOccupationalCredential', credentialCategory: 'Certification professionnelle', name: 'Certification COSTIC — Fumisterie' },
    { '@type': 'EducationalOccupationalCredential', credentialCategory: 'Qualification', name: 'Qualibat 6521 — Conduits de fumée' },
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Martigues',
    postalCode: '13500',
    addressCountry: 'FR',
  },
};
---

<Layout
  title={data.metaTitle}
  description={data.metaDescription}
  breadcrumbs={[
    { name: 'Accueil', url: '/' },
    { name: 'Services', url: '/#services' },
    { name: data.nom, url: `/villes/${data.slug}` },
  ]}
  pageSchema={pageSchema}
>

<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(collectionPageSchema)} />

  <!-- ═══ HERO ═══ -->
  <section class="relative pt-32 pb-20 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={heroBg}
        alt={`Toits de tuiles provençaux à ${data.nom} — zone d'intervention Sud Ramonage`}
        width={1920} height={1080}
        class="w-full h-full object-cover"
        loading="eager" fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[#1A1A1A]/85 via-[#1A1A1A]/65 to-[#1A1A1A]/30"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto">
      <nav class="flex items-center gap-2 text-xs text-white/30 mb-8" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-white transition-colors duration-200">Accueil</a>
        <span>/</span>
        <a href="/#services" class="hover:text-white transition-colors duration-200">Services</a>
        <span>/</span>
        <span class="text-white/60">{data.nom}</span>
      </nav>
      <p class="text-[11px] font-semibold tracking-widest uppercase text-[#C1440E] mb-4">
        Ramonage — {data.zone}
      </p>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white leading-tight mb-6">
        Ramonage et Entretien<br />de Cheminée à {data.nom}.
      </h1>
      <p class="text-base text-white/55 font-light max-w-xl leading-relaxed mb-8">
        {data.intro}
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <ContactButton variant="phone" class="w-full sm:w-auto px-8 py-3.5" />
        <span class="inline-flex items-center gap-2 text-xs text-white/35">
          <svg class="w-4 h-4 text-[#C1440E] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Intervention en {data.tempsIntervention} ({data.distance})
        </span>
      </div>
    </div>
  </section>

  <!-- ═══ CONTEXTE LOCAL ═══ -->
  <section class="py-20 px-6 md:px-10">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">

        <div class="lg:col-span-7 space-y-6">
          <div>
            <p class="text-[11px] font-semibold tracking-widest uppercase text-[#C1440E] mb-4">Contexte local</p>
            <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-5">
              Conduits & Cheminées sur le Secteur de {data.nom}.
            </h2>
            <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed">
              {data.contexteLocal}
            </p>
            {data.landmark && (
              <p class="text-xs text-[#1A1A1A]/35 font-light mt-3 italic">
                Interventions régulières dans les quartiers de {data.nom} — du centre-ville jusqu'aux abords de {data.landmark}.
              </p>
            )}
          </div>
          <div>
            <h3 class="text-lg font-bold tracking-tight text-[#1A1A1A] mb-3">Spécificités des conduits à {data.nom}</h3>
            <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed">
              {data.specificiteConduits}
            </p>
          </div>

          <!-- Note de terrain — si disponible -->
          {data.expertiseTerrain && (
            <div class="bg-[#FAFAFA] border-l-4 border-[#E8DDD4] rounded-r-xl px-6 py-5 mt-2">
              <p class="text-[10px] font-semibold tracking-widest uppercase text-[#C1440E] mb-2">Ce que je vois sur le terrain ici</p>
              <p class="text-sm text-[#1A1A1A]/70 font-light leading-relaxed italic">
                {data.expertiseTerrain}
              </p>
            </div>
          )}
        </div>

        <!-- Réassurance latérale -->
        <aside class="lg:col-span-5">
          <div class="bg-[#FFF3E0] rounded-xl p-7 space-y-5">
            <p class="text-sm font-bold text-[#1A1A1A]">Intervention à {data.nom}</p>
            {[
              { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', txt: `Délai : ${data.tempsIntervention}` },
              { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', txt: 'Certificat remis sur place' },
              { icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', txt: 'Conforme RSD 13 & NF DTU 24.1' },
              { icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z', txt: 'Devis gratuit sous 24h' },
            ].map(({ icon, txt }) => (
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-white flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-[#C1440E]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
                  </svg>
                </div>
                <span class="text-sm text-[#1A1A1A]/70 font-light">{txt}</span>
              </div>
            ))}
            <div class="pt-2">
              <ContactButton variant="phone" class="w-full justify-center" />
            </div>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- ═══ CAS DE NON-CONFORMITÉ TERRAIN — DTU ═══ -->
  <section class="py-16 px-6 md:px-10 bg-[#FAFAFA] border-y border-[#EEEEEE]">
    <div class="max-w-6xl mx-auto">
      <div class="max-w-xl mb-10">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#C1440E] mb-3">Diagnostic expert</p>
        <h2 class="text-xl md:text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-3">
          Ce que je trouve le plus souvent à {data.nom}.
        </h2>
        <p class="text-sm text-[#1A1A1A]/55 font-light leading-relaxed">
          Chaque secteur a ses non-conformités récurrentes. Les ignorer, c'est risquer un incendie de conduit ou une intoxication au CO.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-{casAffichés.length === 2 ? '2' : '3'} gap-4">
        {casAffichés.map((cas, i) => (
          <div class="bg-white border border-[#EEEEEE] rounded-xl p-6 space-y-3">
            <div class="flex items-start justify-between gap-3">
              <span class="text-[10px] font-bold text-[#C1440E] font-mono">0{i + 1}</span>
              {cas.dtu && (
                <span class="text-[9px] font-mono text-[#C1440E] bg-[#FFF3E0] rounded px-2 py-1 shrink-0">{cas.dtu}</span>
              )}
            </div>
            <h3 class="text-sm font-bold text-[#1A1A1A] leading-snug">{cas.titre}</h3>
            <p class="text-xs text-[#1A1A1A]/55 font-light leading-relaxed">{cas.detail}</p>
          </div>
        ))}
      </div>
      <div class="mt-8 flex items-start gap-4 border-l-4 border-[#1A4B8F] bg-[#EEF3FF] rounded-r-xl p-5">
        <svg class="w-5 h-5 text-[#1A4B8F] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-xs text-[#1A4B8F]/80 font-light leading-relaxed">
          <strong class="text-[#1A4B8F]">Référence normative :</strong> La NF DTU 24.1 est la norme française applicable à tous les travaux de fumisterie. Son respect conditionne la validité de votre assurance habitation en cas de sinistre. Je travaille systématiquement dans ce cadre normatif.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ GALERIE D'INTERVENTION ═══ -->
  <section class="py-16 px-6 md:px-10 bg-[#FAFAFA]">
    <div class="max-w-6xl mx-auto">
      <p class="text-[11px] font-semibold tracking-widest uppercase text-[#C1440E] mb-4">Galerie</p>
      <h2 class="text-xl md:text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-8">
        Chantiers & Interventions — {data.nom} et ses Environs.
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

        <figure class="relative rounded-xl overflow-hidden aspect-[4/3] group">
          <Image
            src={galleryImg1}
            alt={`Ramonage mécanique de cheminée en cours à ${data.nom} — hérisson rotatif, élimination suies et bistre`}
            width={600} height={450}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#1A1A1A]/60 to-transparent"></div>
          <p class="absolute bottom-4 left-4 text-xs font-semibold text-white">Ramonage en action</p>
          <figcaption class="sr-only">Ramonage mécanique conduit cheminée à {data.nom} ({data.codePostal}) — élimination suies, bistre, calcin. Artisan certifié COSTIC, conforme NF DTU 24.1 et RSD 13.</figcaption>
        </figure>

        <figure class="relative rounded-xl overflow-hidden aspect-[4/3] group">
          <Image
            src={galleryImg2}
            alt={`Artisan ramoneur certifié COSTIC de Sud Ramonage lors d'une intervention à ${data.nom}`}
            width={600} height={450}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#1A1A1A]/60 to-transparent"></div>
          <p class="absolute bottom-4 left-4 text-xs font-semibold text-white">Artisan certifié COSTIC</p>
          <figcaption class="sr-only">Artisan ramoneur certifié COSTIC Sud Ramonage à {data.nom} — ramonage, test vacuité, inspection caméra. Devis gratuit. Conforme RSD 13 et NF DTU 24.1.</figcaption>
        </figure>

        <figure class="relative rounded-xl overflow-hidden aspect-[4/3] group">
          <Image
            src={galleryImg3}
            alt={`Contrôle technique et inspection caméra du conduit de cheminée après ramonage à ${data.nom}`}
            width={600} height={450}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#1A1A1A]/60 to-transparent"></div>
          <p class="absolute bottom-4 left-4 text-xs font-semibold text-white">Contrôle & certificat</p>
          <figcaption class="sr-only">Inspection caméra et test de vacuité conduit à {data.nom} — rapport technique joint au certificat RSD 13. Artisan COSTIC Bouches-du-Rhône.</figcaption>
        </figure>

      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ═══ -->
  <section class="py-20 px-6 md:px-10">
    <div class="max-w-6xl mx-auto">
      <p class="text-[11px] font-semibold tracking-widest uppercase text-[#C1440E] mb-4">Prestations</p>
      <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-10">
        Nos Services à {data.nom}.
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { href: '/ramonage',          num: '01', titre: 'Ramonage Certifié',     desc: 'Nettoyage mécanique complet, test de vacuité, certificat officiel conforme RSD 13 et NF DTU 24.1.' },
          { href: '/debistrage',        num: '02', titre: 'Débistrage',             desc: 'Traitement chimique et mécanique des dépôts de goudron et bistre tenaces.' },
          { href: '/entretien-poele',   num: '03', titre: 'Entretien Poêle',       desc: 'Maintenance complète de votre poêle à bois ou à granulés — vérification des joints, vitre, étanchéité.' },
          { href: '/inspection-camera', num: '04', titre: 'Inspection Caméra',     desc: 'Diagnostic HD du conduit. Rapport écrit joint au certificat — exigé pour les conduits de plus de 30 ans.' },
        ].map(({ href, num, titre, desc }) => (
          <a href={href} class="group bg-white border border-[#EEEEEE] rounded-xl p-6 hover:border-[#E8DDD4]/30 hover:shadow-md transition-all duration-200">
            <p class="text-[10px] font-semibold tracking-widest uppercase text-[#C1440E] mb-3">{num}</p>
            <h3 class="text-base font-bold text-[#1A1A1A] mb-2 group-hover:text-[#C1440E] transition-colors duration-200">{titre}</h3>
            <p class="text-sm text-[#1A1A1A]/50 font-light">{desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ RÉGLEMENTATION ═══ -->
  <section class="py-20 px-6 md:px-10 bg-[#FAFAFA]">
    <div class="max-w-6xl mx-auto">
      <div class="max-w-3xl">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#C1440E] mb-4">Réglementation</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-5">
          Obligation de Ramonage à {data.nom} (RSD 13).
        </h2>
        <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed mb-6">
          {data.rsdContexte}
        </p>
        <div class="bg-[#FFF3E0] border-l-4 border-[#E8DDD4] rounded-r-xl px-6 py-5">
          <p class="text-sm font-semibold text-[#1A1A1A] mb-1">Rappel légal</p>
          <p class="text-sm text-[#1A1A1A]/65 font-light leading-relaxed">
            En cas de sinistre — incendie de conduit ou intoxication au CO — votre assureur peut refuser la prise en charge sans certificat de ramonage valide. Sud Ramonage vous remet ce document immédiatement après chaque intervention, signé et conforme au Règlement Sanitaire Départemental des Bouches-du-Rhône.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TÉMOIGNAGE ═══ -->
  <section class="py-16 px-6 md:px-10 bg-white border-t border-[#EEEEEE]">
    <div class="max-w-6xl mx-auto">
      <div class="max-w-2xl mx-auto text-center">
        <svg class="w-8 h-8 text-[#C1440E] mx-auto mb-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
        </svg>
        <blockquote class="text-lg text-[#1A1A1A]/70 font-light italic leading-relaxed mb-6">
          "{data.temoignage.texte}"
        </blockquote>
        <p class="text-sm font-semibold text-[#1A1A1A]">{data.temoignage.auteur}</p>
        <p class="text-xs text-[#1A1A1A]/40 mt-1">{data.nom}, Bouches-du-Rhône</p>
      </div>
    </div>
  </section>

  <!-- ═══ CARTE ARTISAN ═══ -->
  <section class="py-16 px-6 md:px-10">
    <div class="max-w-6xl mx-auto">
      <div class="bg-[#FAFAFA] border border-[#EEEEEE] rounded-2xl p-8 flex flex-col md:flex-row items-start md:items-center gap-8">
        <div class="w-16 h-16 rounded-2xl bg-[#FFF3E0] border border-[#E8DDD4]/20 flex items-center justify-center shrink-0">
          <svg class="w-8 h-8 text-[#C1440E]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <div class="flex-1">
          <p class="text-[10px] font-semibold tracking-widest uppercase text-[#C1440E] mb-1">Votre artisan</p>
          <h3 class="text-lg font-extrabold text-[#1A1A1A] mb-1">Le gérant — Sud Ramonage, Martigues</h3>
          <p class="text-sm text-[#1A1A1A]/55 font-light leading-relaxed mb-4">
            Artisan ramoneur basé à Martigues, certifié <strong class="text-[#1A1A1A]">COSTIC</strong> et qualifié <strong class="text-[#1A1A1A]">Qualibat 6521</strong>. Je travaille seul, sans sous-traitance — c'est moi qui interviens chez vous, moi qui établis le diagnostic et moi qui signe le certificat. Je connais personnellement chaque secteur de ma zone d'intervention, des conduits du bord de mer aux cheminées des bastides du pays d'Aix.
          </p>
          <div class="flex flex-wrap items-center gap-3">
            <COSTICBadge variant="card" />
            {['NF DTU 24.1', 'Qualibat 6521', 'Inspection caméra HD', 'RSD Bouches-du-Rhône'].map(badge => (
              <span class="text-[10px] font-semibold text-[#1A1A1A]/50 bg-white border border-[#EEEEEE] rounded-md px-2.5 py-1">{badge}</span>
            ))}
          </div>
        </div>
        <div class="shrink-0">
          <ContactButton variant="phone" class="px-6 py-3 text-sm" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MAILLAGE SILO — liens uniquement vers services parents et accueil ═══ -->
  <section class="py-12 px-6 md:px-10 bg-[#FAFAFA]">
    <div class="max-w-6xl mx-auto">
      <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/35 mb-4">Nos prestations à {data.nom}</p>
      <div class="flex flex-wrap gap-3">
        <a href="/ramonage" class="inline-flex items-center gap-2 bg-white border border-[#E8DDD4]/20 rounded-lg px-4 py-2.5 text-xs font-semibold text-[#C1440E] hover:bg-[#FFF3E0] transition-all duration-200">
          <span class="w-1.5 h-1.5 rounded-full bg-[#E8DDD4] shrink-0"></span>
          Ramonage Certifié RSD 13
        </a>
        <a href="/debistrage" class="inline-flex items-center gap-2 bg-white border border-[#EEEEEE] rounded-lg px-4 py-2.5 text-xs font-medium text-[#1A1A1A]/65 hover:border-[#E8DDD4]/30 hover:text-[#C1440E] transition-all duration-200">
          <span class="w-1.5 h-1.5 rounded-full bg-[#1A1A1A]/20 shrink-0"></span>
          Débistrage Conduit
        </a>
        <a href="/inspection-camera" class="inline-flex items-center gap-2 bg-white border border-[#EEEEEE] rounded-lg px-4 py-2.5 text-xs font-medium text-[#1A1A1A]/65 hover:border-[#E8DDD4]/30 hover:text-[#C1440E] transition-all duration-200">
          <span class="w-1.5 h-1.5 rounded-full bg-[#1A1A1A]/20 shrink-0"></span>
          Inspection Caméra HD
        </a>
        <a href="/entretien-poele" class="inline-flex items-center gap-2 bg-white border border-[#EEEEEE] rounded-lg px-4 py-2.5 text-xs font-medium text-[#1A1A1A]/65 hover:border-[#E8DDD4]/30 hover:text-[#C1440E] transition-all duration-200">
          <span class="w-1.5 h-1.5 rounded-full bg-[#1A1A1A]/20 shrink-0"></span>
          Entretien Poêle
        </a>
        <a href="/tubage" class="inline-flex items-center gap-2 bg-white border border-[#EEEEEE] rounded-lg px-4 py-2.5 text-xs font-medium text-[#1A1A1A]/65 hover:border-[#E8DDD4]/30 hover:text-[#C1440E] transition-all duration-200">
          <span class="w-1.5 h-1.5 rounded-full bg-[#1A1A1A]/20 shrink-0"></span>
          Tubage Inox NF DTU 24.1
        </a>
        <a href="/normes" class="inline-flex items-center gap-2 bg-white border border-[#EEEEEE] rounded-lg px-4 py-2.5 text-xs font-medium text-[#1A1A1A]/65 hover:border-[#E8DDD4]/30 hover:text-[#C1440E] transition-all duration-200">
          <span class="w-1.5 h-1.5 rounded-full bg-[#1A1A1A]/20 shrink-0"></span>
          Normes & Sécurité
        </a>
        <a href="/" class="inline-flex items-center gap-2 bg-white border border-[#EEEEEE] rounded-lg px-4 py-2.5 text-xs font-medium text-[#1A1A1A]/65 hover:border-[#E8DDD4]/30 hover:text-[#C1440E] transition-all duration-200">
          <span class="w-1.5 h-1.5 rounded-full bg-[#1A1A1A]/20 shrink-0"></span>
          Accueil Sud Ramonage
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ DERNIÈRES INTERVENTIONS ═══ -->
  {villeRealisations.length > 0 && (
    <section class="py-16 px-6 md:px-10">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-end justify-between mb-8">
          <div>
            <p class="text-[11px] font-semibold tracking-widest uppercase text-[#C1440E] mb-2">Interventions récentes</p>
            <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A]">
              Dernières Interventions à {data.nom}.
            </h2>
          </div>
          <a href="/realisations" class="hidden md:inline-flex items-center gap-1.5 text-xs font-semibold text-[#C1440E] hover:underline">
            Voir toutes les réalisations
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {villeRealisations.map((r) => {
            const cfg = typeConfig[r.type];
            const dateFormatted = new Date(r.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
            return (
              <a href={`/realisations/${r.slug}`} class="group bg-white border border-[#EEEEEE] rounded-2xl p-6 hover:border-[#E8DDD4]/30 hover:shadow-md transition-all duration-200 flex flex-col gap-4">
                <div class="flex items-start justify-between gap-3">
                  <span class={`inline-flex items-center px-2.5 py-1 rounded-md text-[10px] font-semibold ${cfg.color} ${cfg.bg} border ${cfg.border}`}>{cfg.label}</span>
                  <span class="text-[10px] text-[#1A1A1A]/30 font-mono shrink-0">{r.ref}</span>
                </div>
                <div>
                  <h3 class="text-sm font-bold text-[#1A1A1A] leading-snug mb-2 group-hover:text-[#C1440E] transition-colors duration-200">{r.titre}</h3>
                  <p class="text-xs text-[#1A1A1A]/50 font-light leading-relaxed">{r.excerpt}</p>
                </div>
                <div class="flex items-center justify-between pt-3 border-t border-[#EEEEEE]">
                  <span class="text-[10px] text-[#1A1A1A]/30">{r.duree} · {dateFormatted}</span>
                  <span class="text-[11px] font-semibold text-[#C1440E] group-hover:underline">Voir le rapport →</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ CTA FINAL ═══ -->
  <section class="py-16 px-6 md:px-10">
    <div class="max-w-6xl mx-auto border border-[#EEEEEE] rounded-2xl p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <div>
        <h2 class="text-xl font-extrabold tracking-tight text-[#1A1A1A] mb-2">
          Besoin d'un Ramonage à {data.nom} ?
        </h2>
        <p class="text-sm text-[#1A1A1A]/55 font-light">
          Intervention sous {data.tempsIntervention}. Devis gratuit, sans engagement.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 shrink-0">
        <ContactButton variant="phone" class="px-6 py-3 text-sm" />
        <ContactButton variant="email" />
      </div>
    </div>
  </section>

</Layout>
