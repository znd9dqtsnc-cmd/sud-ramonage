---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import serviceControleImg from '../assets/images/service-controle.jpg';
const siteUrl = 'https://www.sud-ramonage.fr';
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/vacuite#service`,
  name: 'Test de vacuité conduit de fumée',
  description: 'Vérification de la vacuité du conduit de fumée : absence d\'obstruction, nids d\'oiseaux, corps étrangers. Rapport certifié. Bouches-du-Rhône.',
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  serviceType: 'Test vacuité conduit',
  areaServed: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
};
const breadcrumbs = [{ name: 'Accueil', url: '/' }, { name: 'Test de Vacuité', url: '/vacuite' }];
---
<Layout
  title="Test de Vacuité Conduit de Fumée | Sud Ramonage Martigues"
  description="Test de vacuité du conduit : détection nids d'oiseaux, obstructions, corps étrangers. Rapport certifié pour assurance et RSD 13. Bouches-du-Rhône."
  breadcrumbs={breadcrumbs}
  pageSchema={serviceSchema}
>
  <section class="bg-white border-b border-[#EEEEEE] pt-28 pb-12">
    <div class="max-w-4xl mx-auto px-6 md:px-10">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-[#1A1A1A]/35 mb-6">
        <a href="/" class="hover:text-[#1A1A1A]/60">Accueil</a><span>/</span><span class="text-[#1A1A1A]/50">Test de Vacuité</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-5 text-[#1A1A1A]">
        Test de Vacuité<br /><span class="text-[#B5694A]">Contrôle d'Obstruction Conduit</span>
      </h1>
      <div class="flex items-center gap-3 mb-5">
        <span class="bg-[#B5694A] text-white text-sm font-extrabold px-4 py-2 rounded-xl">à partir de 60 €</span>
        <span class="text-[#1A1A1A]/45 text-xs">inclus dans le ramonage certifié</span>
      </div>
      <p class="text-base text-[#1A1A1A]/55 max-w-2xl leading-relaxed mb-8">
        La vacuité d'un conduit est l'absence totale d'obstruction sur toute sa hauteur. Nids d'oiseaux, morceaux de boisseau effondré, corps étrangers — tout obstacle partiel ou total est une source de danger immédiat par refoulement de CO.
      </p>
      <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#B5694A] text-white text-sm font-bold px-5 py-3 rounded-xl hover:bg-[#9A4F36] transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        06 64 72 96 00
      </a>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 md:px-10 py-10">
    <figure class="rounded-2xl overflow-hidden aspect-[21/9] relative">
      <Image src={serviceControleImg} alt="Contrôle de vacuité d'un conduit de fumée — inspection et test d'obstruction certifié" width={1200} height={514} class="w-full h-full object-cover object-center" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#1A1A1A]/60 to-transparent flex items-end p-8">
        <p class="text-white text-sm font-medium leading-snug">Test de vacuité — détection nids d'oiseaux, corps étrangers, rapport certifié RSD 13.</p>
      </div>
    </figure>
  </section>

  <section class="py-8">
    <div class="max-w-4xl mx-auto px-6 md:px-10 space-y-12">
      <div>
        <h2 class="text-2xl font-bold mb-5">La vacuité : obligation réglementaire et technique</h2>
        <p class="text-sm text-[#1A1A1A]/65 leading-relaxed mb-4">
          Le RSD 13 des Bouches-du-Rhône stipule qu'un conduit de fumée doit être libre de tout obstacle avant toute mise en service. Le ramonage inclut systématiquement le test de vacuité — c'est l'une des raisons pour lesquelles le certificat de ramonage atteste non seulement du nettoyage mais aussi de la libre circulation des gaz.
        </p>
        <p class="text-sm text-[#1A1A1A]/65 leading-relaxed">
          En Provence, les étourneaux et martinets nichent abondamment dans les souches non protégées. Un nid construit en avril peut totalement boucher un conduit avant la saison de chauffe d'octobre. Je recommande systématiquement la pose d'un chapeau anti-nid après chaque test de vacuité révélant ce type d'obstruction.
        </p>
      </div>

      <div class="bg-[#FAFAFA] border border-[#EEEEEE] rounded-2xl p-8">
        <h2 class="text-lg font-bold text-[#1A1A1A] mb-5">Obstructions les plus fréquentes</h2>
        <div class="grid md:grid-cols-2 gap-4">
          {[
            { titre: 'Nids d\'oiseaux', detail: 'Étourneaux, martinets, pigeons. Le nid peut représenter jusqu\'à 80 % de la section du conduit. Fréquent sur conduits sans chapeau en Provence.', risque: 'élevé' },
            { titre: 'Maçonnerie effondrée', detail: 'Morceaux de boisseau tombés dans le conduit — fréquent sur les vieilles constructions. Souvent découvert à l\'inspection caméra.', risque: 'élevé' },
            { titre: 'Bistre et calcin consolidés', detail: 'Accumulation extrême qui réduit la section fonctionnelle. Requiert un débistrage avant toute utilisation.', risque: 'moyen' },
            { titre: 'Corps étrangers divers', detail: 'Outils oubliés lors de travaux, tuile tombée, briques... Surtout dans les vieilles maisons de village du Pays d\'Aix.', risque: 'variable' },
          ].map(({ titre, detail, risque }) => (
            <div class="p-4 bg-white rounded-xl border border-[#EEEEEE]">
              <div class="flex items-center gap-2 mb-2">
                <p class="text-sm font-semibold text-[#1A1A1A]">{titre}</p>
                <span class={`text-[10px] px-1.5 py-0.5 rounded font-mono ${risque === 'élevé' ? 'bg-red-100 text-red-600' : risque === 'moyen' ? 'bg-amber-100 text-amber-600' : 'bg-[#F5F5F5] text-[#1A1A1A]/45'}`}>{risque}</span>
              </div>
              <p class="text-xs text-[#1A1A1A]/55 leading-relaxed">{detail}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="border border-[#EEEEEE] rounded-2xl p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div>
          <h2 class="text-xl font-extrabold tracking-tight text-[#1A1A1A] mb-2">Vérification de la vacuité dans les Bouches-du-Rhône</h2>
          <p class="text-sm text-[#1A1A1A]/55 font-light">Inclus dans toute intervention de ramonage. Test seul possible sur devis (conduit inactif, remise en service, vente immobilière).</p>
        </div>
        <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#B5694A] text-white text-sm font-bold px-6 py-3 rounded-xl hover:bg-[#9A4F36] transition-colors shrink-0">06 64 72 96 00</a>
      </div>

      <nav aria-label="Services associés" class="pt-8 border-t border-[#EEEEEE]">
        <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-4">Voir aussi</p>
        <ul class="flex flex-wrap gap-3">
          {[
            { href: '/test-fumigene', label: 'Test fumigène étanchéité' },
            { href: '/inspection-camera', label: 'Inspection caméra HD' },
            { href: '/accessoires-toiture', label: 'Chapeau anti-nid d\'oiseaux' },
            { href: '/ramonage', label: 'Ramonage certifié RSD 13' },
          ].map(({ href, label }) => (
            <li><a href={href} class="text-xs text-[#1A1A1A]/50 border border-[#EEEEEE] rounded-lg px-3 py-1.5 hover:text-[#B5694A] hover:border-[#B5694A]/30 transition-colors">{label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </section>
</Layout>
