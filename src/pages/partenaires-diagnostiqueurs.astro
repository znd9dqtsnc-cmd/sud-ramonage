            </div>

            <!-- Urgence -->
            <div>
              <label for="urgence" class="block text-xs font-semibold text-[#1A1A1A]/70 mb-2">Délai souhaité</label>
              <select id="urgence" name="urgence"
                class="w-full border border-[#DDDDDD] rounded-xl px-4 py-3 text-sm text-[#1A1A1A] focus:outline-none focus:ring-2 focus:ring-[#1A4B8F]/30 focus:border-[#1A4B8F] bg-white">
                <option value="Standard (48–72h)">Standard — 48 à 72h</option>
                <option value="Urgent (24h)">Urgent — 24h</option>
                <option value="Très urgent (aujourd'hui)">Très urgent — aujourd'hui</option>
