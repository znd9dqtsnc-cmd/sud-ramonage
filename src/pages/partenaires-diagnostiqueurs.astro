---
import Layout from '../layouts/Layout.astro';
const siteUrl = 'https://www.sud-ramonage.fr';

// ── Schemas ────────────────────────────────────────────────────────────
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${siteUrl}/partenaires-diagnostiqueurs#service`,
  name: 'ACTS — Audit de Conformité Thermique & Sécurité conduit de fumée',
  alternateName: [
    'Expertise fumisterie après DPE',
    'Conformité cheminée vente maison',
    'Rapport caméra pour notaire Bouches-du-Rhône',
  ],
  description: 'Protocole post-DPE certifié COSTIC. Complément technique indispensable à tout DPE sur bien équipé d\'un appareil à combustion. Inspection caméra HD, test fumigène, calcul de dépression, rapport opposable 24h.',
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  areaServed: [
    { '@type': 'City', name: 'Marseille' },
    { '@type': 'City', name: 'Aix-en-Provence' },
    { '@type': 'City', name: 'Martigues' },
    { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Protocole ACTS — Niveaux d\'intervention',
    itemListElement: [
      {
        '@type': 'Offer',
        name: 'ACTS Essentiel',
        description: 'Inspection visuelle complète + certificat RSD 13 + rapport PDF 24h',
        price: '120', priceCurrency: 'EUR',
      },
      {
        '@type': 'Offer',
        name: 'ACTS Intégral',
        description: 'Inspection caméra HD + test fumigène + calcul de dépression + rapport notaire',
        price: '220', priceCurrency: 'EUR',
      },
    ],
  },
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  '@id': `${siteUrl}/partenaires-diagnostiqueurs#acts`,
  name: 'Protocole ACTS — Audit de Conformité Thermique & Sécurité',
  description: 'Comment fonctionne l\'Audit de Conformité Thermique & Sécurité (ACTS) de Sud Ramonage, complément post-DPE pour les professionnels de l\'immobilier.',
  totalTime: 'PT4H',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Réception du dossier DPE', text: 'Le diagnostiqueur ou l\'agent transmet le rapport DPE + adresse du bien. Prise en charge du dossier sous 4h.' },
    { '@type': 'HowToStep', position: 2, name: 'Inspection caméra HD du conduit', text: 'Endoscopie complète du conduit de fumée. Détection de fissures, dépôts, anomalies de section.' },
    { '@type': 'HowToStep', position: 3, name: 'Test fumigène NF DTU 24.1', text: 'Test d\'étanchéité à la fumée. Révèle les fuites invisibles vers les parois et pièces adjacentes.' },
    { '@type': 'HowToStep', position: 4, name: 'Calcul de dépression (tirage)', text: 'Mesure physique du tirage en Pascals. Détermine la performance réelle du conduit.' },
    { '@type': 'HowToStep', position: 5, name: 'Rapport ACTS transmis au notaire', text: 'Rapport PDF signé COSTIC : photos datées, mesures, état de conformité, préconisations. Disponible sous 24h.' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Qu\'est-ce que l\'expertise fumisterie après DPE ?',
      acceptedAnswer: { '@type': 'Answer', text: 'L\'expertise fumisterie après DPE est un audit technique réalisé par un artisan certifié COSTIC sur tout appareil à combustion et conduit de fumée d\'un bien immobilier. Elle complète le DPE — qui n\'examine pas les conduits — avec des mesures physiques réelles : inspection caméra, test fumigène, calcul de dépression. Le rapport est opposable et transmissible au notaire.' },
    },
    {
      '@type': 'Question',
      name: 'Conformité cheminée vente maison : que dit la loi ?',
      acceptedAnswer: { '@type': 'Answer', text: 'La loi n\'impose pas de diagnostic fumisterie obligatoire lors d\'une vente immobilière. Cependant, l\'article 1641 du Code civil engage la responsabilité du vendeur en cas de vice caché. Un conduit fissuré, obstrué ou non conforme non déclaré constitue un vice caché. Un rapport ACTS certifié COSTIC protège le vendeur en établissant l\'état de l\'installation à la date de la vente.' },
    },
    {
      '@type': 'Question',
      name: 'Comment obtenir un rapport caméra pour notaire dans les Bouches-du-Rhône ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Contactez Sud Ramonage au 06 64 72 96 00 ou transmettez le dossier via notre espace pro. L\'inspection caméra HD est réalisée sur site. Le rapport avec photos datées, mesures et état de conformité est disponible sous 24h, dans un format PDF transmissible directement au notaire.' },
    },
    {
      '@type': 'Question',
      name: 'Un diagnostiqueur DPE peut-il signaler un conduit non conforme sans équipement technique ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Non. Le diagnostiqueur DPE réalise une évaluation visuelle et théorique. Il n\'est pas équipé pour descendre une caméra dans un conduit, réaliser un test fumigène ou mesurer la dépression. Ces opérations nécessitent une formation spécifique (COSTIC, NF DTU 24.1) et un outillage dédié. C\'est précisément pourquoi le rapport ACTS de Sud Ramonage est le complément naturel de tout DPE.' },
    },
    {
      '@type': 'Question',
      name: 'L\'étanchéité d\'un conduit influence-t-elle la note DPE ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Oui. Un conduit étanche améliore le rendement de l\'appareil de chauffage (jusqu\'à +15 % selon COSTIC). Un insert ou poêle à bois à rendement amélioré peut faire progresser la note DPE d\'une classe. Par ailleurs, les pertes thermiques liées à un conduit fissuré ou mal raccordé sont prises en compte dans les calculs RT2012/RE2020 d\'étanchéité à l\'air des parois.' },
    },
    {
      '@type': 'Question',
      name: 'Quel est le délai d\'intervention pour lever une réserve conduit avant signature ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Sud Ramonage s\'engage à intervenir dans les 48h ouvrées sur tout dossier urgent lié à une transaction immobilière. Le rapport ACTS est transmis dans les 24h suivant l\'intervention. En cas d\'urgence notariale extrême, contactez directement le 06 64 72 96 00.' },
    },
  ],
};

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Partenaires Diagnostiqueurs', url: '/partenaires-diagnostiqueurs' },
];

// ── Données DPE vs COSTIC ───────────────────────────────────────────────
const comparatif = [
  {
    critere: 'Nature de l\'examen',
    dpe: { val: 'Visuel & théorique', ok: true },
    costic: { val: 'Physique & mesuré', ok: true },
  },
  {
    critere: 'Conduits de fumée internes',
    dpe: { val: '✗ Non accessibles au DPE', ok: false },
    costic: { val: '✓ Inspection caméra HD endoscopique', ok: true },
  },
  {
    critere: 'Test d\'étanchéité',
    dpe: { val: '✗ Non réalisé', ok: false },
    costic: { val: '✓ Test fumigène NF DTU 24.1 art. 9.2', ok: true },
  },
  {
    critere: 'Mesure du tirage (dépression)',
    dpe: { val: '✗ Calcul théorique uniquement', ok: false },
    costic: { val: '✓ Manomètre — mesure en Pascals', ok: true },
  },
  {
    critere: 'Détection bistre / goudron',
    dpe: { val: '✗ Invisible depuis l\'extérieur', ok: false },
    costic: { val: '✓ Caméra + lampe torche — quantification', ok: true },
  },
  {
    critere: 'Fissures et perforations internes',
    dpe: { val: '✗ Non détectables sans endoscope', ok: false },
    costic: { val: '✓ Révélées par caméra + fumigène', ok: true },
  },
  {
    critere: 'Adéquation appareil / conduit',
    dpe: { val: '✗ Pas de vérification technique croisée', ok: false },
    costic: { val: '✓ NF DTU 24.1 — diamètre, matériau, pression', ok: true },
  },
  {
    critere: 'Impact sur le rendement réel (DPE)',
    dpe: { val: 'Valeur théorique du fabricant', ok: true },
    costic: { val: '✓ Rendement mesuré après entretien (+8-15%)', ok: true },
  },
  {
    critere: 'Conformité RSD 13',
    dpe: { val: '✗ Non vérifiée', ok: false },
    costic: { val: '✓ Certificat officiel remis', ok: true },
  },
  {
    critere: 'Rapport opposable pour le notaire',
    dpe: { val: '✓ Obligatoire (DPE)', ok: true },
    costic: { val: '✓ Rapport PDF signé — photos datées', ok: true },
  },
  {
    critere: 'Protection vice caché art. 1641',
    dpe: { val: 'Partielle — ne couvre pas les conduits', ok: false },
    costic: { val: '✓ Couverture technique totale de l\'installation', ok: true },
  },
];

const actsNiveaux = [
  {
    code: 'ACTS Essentiel',
    prix: '120 €',
    badge: null,
    cible: 'Vente standard · conduit récent',
    prestations: [
      'Inspection visuelle conduit et appareil',
      'Contrôle raccordement & distances NF DTU 24.1',
      'Ramonage certifié si nécessaire',
      'Certificat de conformité RSD 13',
      'Rapport PDF 3-5 pages · 24h',
    ],
  },
  {
    code: 'ACTS Intégral',
    prix: '220 €',
    badge: 'Recommandé vente notariale',
    cible: 'Bien ancien · doute DPE · transaction > 300k€',
    prestations: [
      'Inspection caméra HD endoscopique complète',
      'Test fumigène NF DTU 24.1 art. 9.2',
      'Mesure de dépression (tirage réel en Pa)',
      'Calcul rendement effectif vs théorique',
      'Rapport ACTS 10-15 pages · photos datées · 24h',
      'Transmissible directement au notaire',
      'Communication téléphonique possible avec le notaire',
    ],
  },
];
---

<Layout
  title="Partenaires Diagnostiqueurs — Protocole ACTS & Expertise Fumisterie après DPE | Sud Ramonage"
  description="Sud Ramonage : le bras technique du DPE. Protocole ACTS post-DPE, inspection caméra HD, test fumigène, rapport notaire 24h. Conformité cheminée vente maison Marseille Aix — certifié COSTIC."
  breadcrumbs={breadcrumbs}
  pageSchema={serviceSchema}
>

  <!-- ══════════════════════════════════════════════════
       HERO — Positionnement B2B premium
  ══════════════════════════════════════════════════ -->
  <section class="relative bg-[#0D0D0D] text-white pt-28 pb-0 overflow-hidden">

    <!-- Grille fine -->
    <div class="absolute inset-0 opacity-[0.04]" style="background-image:repeating-linear-gradient(0deg,#fff,#fff 1px,transparent 1px,transparent 40px),repeating-linear-gradient(90deg,#fff,#fff 1px,transparent 1px,transparent 40px)"></div>

    <!-- Lueur bleue COSTIC -->
    <div class="absolute top-0 right-0 w-[600px] h-[400px] bg-[#1A4B8F] opacity-10 blur-[120px] pointer-events-none"></div>
    <!-- Lueur orange -->
    <div class="absolute bottom-0 left-0 w-[400px] h-[300px] bg-[#E65100] opacity-8 blur-[100px] pointer-events-none"></div>

    <div class="relative max-w-6xl mx-auto px-6 md:px-10 pb-20">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-white/30 mb-10">
        <a href="/" class="hover:text-white/55 transition-colors">Accueil</a>
        <span>/</span>
        <span class="text-white/50">Partenaires Diagnostiqueurs</span>
      </nav>

      <!-- Pro tags -->
      <div class="flex flex-wrap gap-2 mb-8">
        {['Diagnostiqueurs DPE', 'Agents immobiliers', 'Notaires', 'Géomètres-experts'].map(t => (
          <span class="text-[10px] font-bold uppercase tracking-widest border border-white/12 text-white/45 px-3 py-1.5 rounded-full bg-white/4">{t}</span>
        ))}
      </div>

      <div class="grid lg:grid-cols-[1fr_auto] gap-16 items-start">
        <div class="max-w-2xl">
          <!-- Eyebrow ACTS -->
          <div class="inline-flex items-center gap-2.5 bg-[#1A4B8F]/20 border border-[#1A4B8F]/30 rounded-xl px-5 py-3 mb-7">
            <svg class="w-4 h-4 text-[#4A90D9] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
            <span class="text-xs font-bold text-[#4A90D9] tracking-wide">ACTS — Audit de Conformité Thermique & Sécurité · Certifié COSTIC</span>
          </div>

          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.06] mb-6">
            Le bras technique<br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#E65100] to-[#FF7043]">de votre DPE.</span>
          </h1>

          <p class="text-lg text-white/55 font-light leading-relaxed mb-8 max-w-xl">
            Le DPE ne descend pas dans les conduits. L'ACTS si. Inspection caméra HD, test fumigène, calcul de dépression — le rapport technique que votre DPE ne peut pas produire, disponible sous 24h, opposable au notaire.
          </p>

          <div class="flex flex-col sm:flex-row gap-3">
            <!-- CTA Pro principal -->
            <a
              href="mailto:majeo@ik.me?subject=%5BACTS%5D%20Transmission%20dossier%20partenaire%20diagnostiqueur&body=Bonjour%2C%0A%0AJe%20suis%20%5Bdiagnostiqueur%20DPE%20%2F%20agent%20immobilier%20%2F%20notaire%5D%20et%20je%20souhaite%20vous%20transmettre%20un%20dossier%20pour%20un%20Audit%20de%20Conformit%C3%A9%20Thermique%20%26%20S%C3%A9curit%C3%A9%20(ACTS).%0A%0A%E2%80%94%20Adresse%20du%20bien%20%3A%0A%E2%80%94%20Type%20d%27appareil%20%3A%0A%E2%80%94%20Niveau%20ACTS%20souhait%C3%A9%20%3A%20Essentiel%20(120%E2%82%AC)%20%2F%20Int%C3%A9gral%20(220%E2%82%AC)%0A%E2%80%94%20Date%20de%20signature%20pr%C3%A9vue%20%3A%0A%E2%80%94%20Urgence%20%3A%20Oui%20%2F%20Non%0A%E2%80%94%20Rapport%20%C3%A0%20transmettre%20au%20notaire%20%3A%20Oui%20%2F%20Non%0A%0AMerci%20de%20me%20recontacter%20dans%20les%204h."
              class="inline-flex items-center justify-center gap-2.5 bg-[#E65100] hover:bg-[#BF360C] text-white font-bold text-sm px-8 py-4 rounded-xl shadow-xl shadow-[#E65100]/20 transition-all duration-150"
            >
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              Espace Pro — Transmettre un dossier
            </a>
            <a href="tel:+33664729600" class="inline-flex items-center justify-center gap-2 bg-white/8 hover:bg-white/12 border border-white/15 text-white font-semibold text-sm px-6 py-4 rounded-xl transition-all duration-150">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              06 64 72 96 00
            </a>
          </div>
        </div>

        <!-- Chiffres clés -->
        <div class="hidden lg:block space-y-3 w-56">
          {[
            { val: '24 h', label: 'Rapport disponible', sub: 'Compatible agenda notarial' },
            { val: '48 h', label: 'Intervention garantie', sub: 'Sur réserve DPE urgente' },
            { val: '100 %', label: 'Opposable', sub: 'Rapport signé COSTIC' },
            { val: '0 €', label: 'Pour le diagnostiqueur', sub: 'Facturation au client final' },
          ].map(({ val, label, sub }) => (
            <div class="bg-white/5 border border-white/8 rounded-2xl p-4 backdrop-blur-sm">
              <p class="text-2xl font-extrabold text-white leading-none mb-0.5">{val}</p>
              <p class="text-[11px] font-semibold text-[#E65100] mb-0.5">{label}</p>
              <p class="text-[10px] text-white/30">{sub}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Vague -->
    <div class="relative h-12 overflow-hidden">
      <svg viewBox="0 0 1440 48" class="absolute bottom-0 w-full" preserveAspectRatio="none">
        <path fill="white" d="M0,48 C480,0 960,0 1440,48 L1440,48 L0,48 Z"/>
      </svg>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════
       SECTION A — CTA PROPRIÉTAIRES (réserve DPE)
  ══════════════════════════════════════════════════ -->
  <section class="py-12 px-6 md:px-10 bg-[#FFF8F5] border-b border-[#FFE0CC]">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row gap-5 items-start md:items-center justify-between">

        <!-- Propriétaires -->
        <div class="flex gap-4 items-start flex-1">
          <div class="w-12 h-12 rounded-xl bg-[#E65100]/15 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-[#E65100]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
          </div>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#E65100] mb-1">Propriétaires vendeurs</p>
            <p class="text-sm font-bold text-[#1A1A1A] leading-snug mb-1">Votre diagnostiqueur a émis une réserve sur votre conduit ?</p>
            <p class="text-xs text-[#1A1A1A]/55 leading-relaxed">Nous levons le doute technique en 48h. Rapport ACTS transmis directement à votre notaire.</p>
          </div>
        </div>

        <div class="hidden md:block w-px h-16 bg-[#EEEEEE]"></div>

        <!-- Professionnels -->
        <div class="flex gap-4 items-start flex-1">
          <div class="w-12 h-12 rounded-xl bg-[#1A4B8F]/12 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-[#1A4B8F]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#1A4B8F] mb-1">Professionnels de l'immobilier</p>
            <p class="text-sm font-bold text-[#1A1A1A] leading-snug mb-1">Intégrez l'expertise ACTS à vos rapports.</p>
            <p class="text-xs text-[#1A1A1A]/55 leading-relaxed">Protection juridique totale. Votre responsabilité couverte sur le volet fumisterie.</p>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row md:flex-col gap-2 shrink-0">
          <a href="tel:+33664729600" class="inline-flex items-center justify-center gap-2 bg-[#E65100] text-white font-bold text-xs px-5 py-3 rounded-xl hover:bg-[#BF360C] transition-colors whitespace-nowrap">
            Lever une réserve — 48h
          </a>
          <a
            href="mailto:majeo@ik.me?subject=%5BACTS%5D%20Transmission%20dossier%20partenaire%20diagnostiqueur&body=Bonjour%2C%0A%0AJe%20suis%20%5Bdiagnostiqueur%20DPE%20%2F%20agent%20immobilier%20%2F%20notaire%5D%20et%20je%20souhaite%20vous%20transmettre%20un%20dossier%20pour%20un%20Audit%20de%20Conformit%C3%A9%20Thermique%20%26%20S%C3%A9curit%C3%A9%20(ACTS).%0A%0A%E2%80%94%20Adresse%20du%20bien%20%3A%0A%E2%80%94%20Type%20d%27appareil%20%3A%0A%E2%80%94%20Niveau%20ACTS%20souhait%C3%A9%20%3A%20Essentiel%20(120%E2%82%AC)%20%2F%20Int%C3%A9gral%20(220%E2%82%AC)%0A%E2%80%94%20Date%20de%20signature%20pr%C3%A9vue%20%3A%0A%E2%80%94%20Urgence%20%3A%20Oui%20%2F%20Non%0A%E2%80%94%20Rapport%20%C3%A0%20transmettre%20au%20notaire%20%3A%20Oui%20%2F%20Non%0A%0AMerci%20de%20me%20recontacter%20dans%20les%204h."
            class="inline-flex items-center justify-center gap-2 bg-[#1A4B8F]/10 text-[#1A4B8F] font-bold text-xs px-5 py-3 rounded-xl hover:bg-[#1A4B8F]/18 border border-[#1A4B8F]/20 transition-colors whitespace-nowrap"
          >
            Espace Pro — Dossier
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════
       SECTION B — PROTOCOLE ACTS
  ══════════════════════════════════════════════════ -->
  <section class="py-20 px-6 md:px-10 border-b border-[#EEEEEE]">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-16 items-start">
        <div>
          <p class="text-[11px] font-bold uppercase tracking-widest text-[#E65100] mb-3">Protocole exclusif</p>
          <h2 class="text-2xl md:text-3xl font-extrabold text-[#1A1A1A] mb-5 leading-tight">
            ACTS — Audit de Conformité<br />Thermique & Sécurité
          </h2>
          <p class="text-sm text-[#1A1A1A]/60 leading-relaxed mb-6">
            Le protocole ACTS est la réponse technique et documentaire à la zone d'ombre de tout DPE : le conduit de fumée. Conçu pour s'intégrer directement dans le dossier de vente, il fournit les données que le DPE ne peut légalement pas produire.
          </p>
          <p class="text-sm text-[#1A1A1A]/60 leading-relaxed mb-8">
