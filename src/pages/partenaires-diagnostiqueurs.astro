  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

</Layout>

<script>
const form = document.getElementById('acts-form') as HTMLFormElement | null;
const success = document.getElementById('form-success');

form?.addEventListener('submit', (e) => {
  e.preventDefault();

  const f = form.elements as any;
  const profil    = f.profil?.value    || '';
  const societe   = f.societe?.value   || '';
  const email     = f.email?.value     || '';
  const tel       = f.tel?.value       || 'Non fourni';
  const adresse   = f.adresse?.value   || '';
  const appareil  = f.appareil?.value  || 'Non précisé';
  const niveau    = f.niveau?.value    || 'Essentiel';
  const urgence   = f.urgence?.value   || 'Standard';
  const signature = f.signature?.value || 'Non précisée';
  const infos     = f.infos?.value     || 'Aucune';
  const notaire   = f.notaire?.checked ? 'Oui' : 'Non';

  if (!profil || !societe || !email || !adresse) {
    alert('Merci de remplir les champs obligatoires (*).');
    return;
  }

  const subject = encodeURIComponent(`[ACTS] Dossier partenaire — ${societe} — ${adresse}`);
  const body = encodeURIComponent(
`Nouveau dossier ACTS transmis via le formulaire partenaires.

— Profil        : ${profil}
— Société       : ${societe}
— Email         : ${email}
— Téléphone     : ${tel}
— Adresse bien  : ${adresse}
— Appareil      : ${appareil}
— Niveau ACTS   : ${niveau}
— Urgence       : ${urgence}
— Date signature: ${signature}
— Rapport notaire : ${notaire}

Informations complémentaires :
${infos}

---
Envoyé depuis /partenaires-diagnostiqueurs`
  );

  window.location.href = `mailto:contact@sud-ramonage.fr?subject=${subject}&body=${body}`;

  setTimeout(() => {
    form.reset();
    success?.classList.remove('hidden');
  }, 500);
});
</script>
