                class="w-full border border-[#DDDDDD] rounded-xl px-4 py-3 text-sm text-[#1A1A1A] focus:outline-none focus:ring-2 focus:ring-[#1A4B8F]/30 focus:border-[#1A4B8F] bg-white">
                <option value="">— Sélectionnez —</option>
                <option value="Diagnostiqueur DPE">Diagnostiqueur DPE</option>
                <option value="Agent immobilier">Agent immobilier</option>
                <option value="Notaire">Notaire</option>
                <option value="Syndic de copropriété">Syndic de copropriété</option>
                <option value="Architecte">Architecte</option>
                <option value="Autre professionnel">Autre professionnel</option>
