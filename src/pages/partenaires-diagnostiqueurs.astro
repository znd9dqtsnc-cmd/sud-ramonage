            <div>
              <label for="appareil" class="block text-xs font-semibold text-[#1A1A1A]/70 mb-2">Type d'appareil</label>
              <select id="appareil" name="appareil"
                class="w-full border border-[#DDDDDD] rounded-xl px-4 py-3 text-sm text-[#1A1A1A] focus:outline-none focus:ring-2 focus:ring-[#1A4B8F]/30 focus:border-[#1A4B8F] bg-white">
                <option value="Non précisé">Non précisé</option>
                <option value="Foyer ouvert">Foyer ouvert</option>
                <option value="Insert bois">Insert bois</option>
                <option value="Poêle bois">Poêle bois</option>
                <option value="Poêle granulés">Poêle granulés</option>
                <option value="Chaudière gaz/fioul">Chaudière gaz/fioul</option>
              </select>
            </div>

            <!-- Niveau ACTS -->
            <div>
              <label for="niveau-acts" class="block text-xs font-semibold text-[#1A1A1A]/70 mb-2">Niveau ACTS souhaité</label>
              <select id="niveau-acts" name="niveau"
                class="w-full border border-[#DDDDDD] rounded-xl px-4 py-3 text-sm text-[#1A1A1A] focus:outline-none focus:ring-2 focus:ring-[#1A4B8F]/30 focus:border-[#1A4B8F] bg-white">
                <option value="Essentiel (120 €)">Essentiel — 120 €</option>
                <option value="Intégral (220 €)">Intégral — 220 €</option>
                <option value="À définir">À définir ensemble</option>
