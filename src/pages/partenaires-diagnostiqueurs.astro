            <div>
              <label for="societe" class="block text-xs font-semibold text-[#1A1A1A]/70 mb-2">Société / Cabinet *</label>
              <input id="societe" name="societe" type="text" required placeholder="Cabinet Dupont DPE"
                class="w-full border border-[#DDDDDD] rounded-xl px-4 py-3 text-sm text-[#1A1A1A] placeholder-[#1A1A1A]/25 focus:outline-none focus:ring-2 focus:ring-[#1A4B8F]/30 focus:border-[#1A4B8F]" />
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <!-- Email -->
            <div>
              <label for="email-pro" class="block text-xs font-semibold text-[#1A1A1A]/70 mb-2">Email professionnel *</label>
              <input id="email-pro" name="email" type="email" required placeholder="contact@cabinet-dpe.fr"
                class="w-full border border-[#DDDDDD] rounded-xl px-4 py-3 text-sm text-[#1A1A1A] placeholder-[#1A1A1A]/25 focus:outline-none focus:ring-2 focus:ring-[#1A4B8F]/30 focus:border-[#1A4B8F]" />
            </div>

            <!-- Téléphone -->
            <div>
              <label for="tel-pro" class="block text-xs font-semibold text-[#1A1A1A]/70 mb-2">Téléphone direct</label>
              <input id="tel-pro" name="tel" type="tel" placeholder="06 xx xx xx xx"
                class="w-full border border-[#DDDDDD] rounded-xl px-4 py-3 text-sm text-[#1A1A1A] placeholder-[#1A1A1A]/25 focus:outline-none focus:ring-2 focus:ring-[#1A4B8F]/30 focus:border-[#1A4B8F]" />
            </div>
          </div>

          <!-- Adresse du bien -->
          <div>
            <label for="adresse-bien" class="block text-xs font-semibold text-[#1A1A1A]/70 mb-2">Adresse du bien à expertiser *</label>
            <input id="adresse-bien" name="adresse" type="text" required placeholder="12 avenue de la Mer, 13500 Martigues"
              class="w-full border border-[#DDDDDD] rounded-xl px-4 py-3 text-sm text-[#1A1A1A] placeholder-[#1A1A1A]/25 focus:outline-none focus:ring-2 focus:ring-[#1A4B8F]/30 focus:border-[#1A4B8F]" />
