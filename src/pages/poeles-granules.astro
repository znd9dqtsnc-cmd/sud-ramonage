---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroPoeleImg from '../assets/images/hero-poele.jpg';
const siteUrl = 'https://www.sud-ramonage.fr';
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/poeles-granules#service`,
  name: 'Ramonage et entretien poêle à granulés',
  description: 'Entretien complet poêle à granulés (pellets) : ramonage conduit, nettoyage brûleur, vis sans fin, ventilateur, électronique. Certifié COSTIC. Bouches-du-Rhône.',
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  serviceType: 'Entretien poêle à granulés pellets',
  areaServed: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
  offers: { '@type': 'Offer', price: '90', priceCurrency: 'EUR', priceSpecification: { '@type': 'PriceSpecification', minPrice: '90', maxPrice: '120', priceCurrency: 'EUR' } },
};
const breadcrumbs = [{ name: 'Accueil', url: '/' }, { name: 'Poêles à Granulés', url: '/poeles-granules' }];
---
<Layout
  title="Entretien Poêle à Granulés Pellets — COSTIC | Sud Ramonage Martigues"
  description="Entretien annuel poêle à granulés : ramonage conduit, brûleur, vis sans fin, ventilateur. Certifié COSTIC, certificat RSD 13. Bouches-du-Rhône. Dès 90 €."
  breadcrumbs={breadcrumbs}
  pageSchema={serviceSchema}
>
  <section class="bg-white border-b border-[#EEEEEE] pt-28 pb-12">
    <div class="max-w-4xl mx-auto px-6 md:px-10">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-[#1A1A1A]/35 mb-6">
        <a href="/" class="hover:text-[#1A1A1A]/60">Accueil</a><span>/</span><span class="text-[#1A1A1A]/50">Poêles à Granulés</span>
      </nav>
      <div class="inline-flex items-center gap-2 bg-[#FFF3E0] border border-[#EA580C]/20 rounded-full px-3 py-1.5 text-[11px] text-[#EA580C] font-semibold mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-[#EA580C]"></span>
        Entretien annuel + ramonage obligatoire — RSD 13
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-5">
        Entretien Poêle à Granulés<br /><span class="text-[#EA580C]">Pellets & Biomasse</span>
      </h1>
      <p class="text-base text-[#1A1A1A]/55 max-w-2xl leading-relaxed mb-8">
        Le poêle à granulés est l'appareil le plus technique à entretenir. Brûleur, vis sans fin, ventilateur, sonde lambda, électronique de pilotage — chaque composant doit être nettoyé et contrôlé. Sans entretien annuel, les pannes en pleine saison de chauffe sont inévitables.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#EA580C] text-white text-sm font-bold px-5 py-3 rounded-xl hover:bg-[#C2410C] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          06 64 72 96 00
        </a>
        <span class="inline-flex items-center bg-[#FAFAFA] border border-[#EEEEEE] text-[#1A1A1A]/60 text-sm px-4 py-3 rounded-xl">Dès 90 € · Certificat RSD 13</span>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 md:px-10 py-10">
    <figure class="rounded-2xl overflow-hidden aspect-[21/9] relative">
      <Image src={heroPoeleImg} alt="Poêle à granulés dans un intérieur moderne — entretien annuel certifié COSTIC" width={1200} height={514} class="w-full h-full object-cover object-center" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#1A1A1A]/60 to-transparent flex items-end p-8">
        <p class="text-white text-sm font-medium leading-snug">Poêle à granulés — nettoyage brûleur, vis sans fin, ventilateur, certificat RSD 13.</p>
      </div>
    </figure>
  </section>

  <section class="py-8">
    <div class="max-w-4xl mx-auto px-6 md:px-10 space-y-12">

      <div>
        <h2 class="text-2xl font-bold mb-5">L'entretien complet en 8 points</h2>
        <div class="grid md:grid-cols-2 gap-4">
          {[
            { n: '1', t: 'Ramonage du conduit', d: 'Nettoyage mécanique complet. Le granulé produit moins de suie que le bois mais accumule des cendres légères dans le conduit.' },
            { n: '2', t: 'Nettoyage du brûleur', d: 'Élimination des résidus de cendres et de clinker (scories). Un brûleur encrassé déclenche des erreurs d\'allumage.' },
            { n: '3', t: 'Vis sans fin et cellule photovoltaïque', d: 'Nettoyage de la vis d\'alimentation et de la cellule de flamme. Évite les pannes d\'allumage.' },
            { n: '4', t: 'Ventilateur de combustion', d: 'Dépoussiérage des pales. Un ventilateur freiné réduit l\'apport d\'air comburant → combustion incomplète → CO.' },
            { n: '5', t: 'Échangeur thermique', d: 'Nettoyage des plaques d\'échange. Un échangeur encrassé réduit le rendement de 15 à 20 %.' },
            { n: '6', t: 'Bac à cendres et foyer', d: 'Vidage et nettoyage complet. Contrôle des parois réfractaires.' },
            { n: '7', t: 'Joints et étanchéité', d: 'Contrôle du joint de porte, de vitre et du raccordement conduit.' },
            { n: '8', t: 'Test de fonctionnement', d: 'Cycle d\'allumage et vérification de tous les paramètres avant remise en service.' },
          ].map(({ n, t, d }) => (
            <div class="bg-[#FAFAFA] border border-[#EEEEEE] rounded-xl p-5 flex gap-3">
              <span class="w-6 h-6 rounded-full bg-[#EA580C]/10 text-[#EA580C] text-xs font-bold flex items-center justify-center shrink-0">{n}</span>
              <div>
                <p class="text-sm font-semibold text-[#1A1A1A] mb-1">{t}</p>
                <p class="text-xs text-[#1A1A1A]/55 leading-relaxed">{d}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6">
        <div class="flex gap-3">
          <svg class="w-5 h-5 text-amber-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <div>
            <p class="text-sm font-bold text-amber-900 mb-1">Risque CO — spécificité des granulés</p>
            <p class="text-sm text-amber-800/75 leading-relaxed">Les poêles à granulés fonctionnent avec un ventilateur forcé. En cas de panne de ventilateur ou de conduit obstrué, les gaz brûlés peuvent être refoulés dans la pièce. Le monoxyde de carbone (CO) est inodore et mortel. Un entretien annuel est la seule prévention efficace.</p>
          </div>
        </div>
      </div>

      <div class="bg-green-50 border border-green-200 rounded-2xl p-8">
        <h3 class="text-base font-bold text-green-900 mb-2">Entretien COSTIC = performances garanties</h3>
        <p class="text-sm text-green-800/75 leading-relaxed">Un poêle à granulés entretenu maintient un rendement de 88-92 %. Mal entretenu, il peut descendre à 70-75 % — soit une surconsommation de 15 à 20 % de pellets sur la saison. Sur 4 tonnes à 350 €/tonne, c'est 210 à 280 € de granulés gaspillés. Le coût de l'entretien est remboursé en 2-3 semaines de chauffe.</p>
      </div>

      <div class="border border-[#EEEEEE] rounded-2xl p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div>
          <h2 class="text-xl font-extrabold tracking-tight text-[#1A1A1A] mb-2">Entretien de votre poêle à granulés ?</h2>
          <p class="text-sm text-[#1A1A1A]/55 font-light">Intervention complète, toutes marques (MCZ, Edilkamin, Palazzetti, Wodtke...). Certificat RSD 13 remis le jour même.</p>
        </div>
        <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#EA580C] text-white text-sm font-bold px-6 py-3 rounded-xl hover:bg-[#C2410C] transition-colors shrink-0">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          06 64 72 96 00
        </a>
      </div>

      <nav aria-label="Services associés" class="pt-8 border-t border-[#EEEEEE]">
        <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-4">Voir aussi</p>
        <ul class="flex flex-wrap gap-3">
          {[
            { href: '/poeles-bois', label: 'Entretien poêle à bois' },
            { href: '/entretien-poele', label: 'Entretien poêle — offre complète' },
            { href: '/inspection-camera', label: 'Inspection caméra conduit' },
            { href: '/ramonage', label: 'Ramonage certifié RSD 13' },
          ].map(({ href, label }) => (
            <li><a href={href} class="text-xs text-[#1A1A1A]/50 border border-[#EEEEEE] rounded-lg px-3 py-1.5 hover:text-[#EA580C] hover:border-[#EA580C]/30 transition-colors">{label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </section>
</Layout>
