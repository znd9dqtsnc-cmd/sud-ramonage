  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

</Layout>

<script>
const slider = document.getElementById('nb-lots') as HTMLInputElement;
const numInput = document.getElementById('nb-lots-val') as HTMLInputElement;
const coutPonctuel = document.getElementById('cout-ponctuel')!;
const coutAbo = document.getElementById('cout-abonnement')!;
const economieEl = document.getElementById('economie')!;

function calcCouts(lots: number) {
  const ponctuel = lots * 120;
  const abo = Math.round(lots * 7.5 * 12);
  const eco = ponctuel - abo;
  coutPonctuel.textContent = ponctuel.toLocaleString('fr-FR') + ' €';
  coutAbo.textContent = abo.toLocaleString('fr-FR') + ' €';
  economieEl.textContent = (eco > 0 ? eco : 0).toLocaleString('fr-FR') + ' €';
}

function sync(val: string) {
  const n = Math.min(50, Math.max(3, parseInt(val) || 3));
  slider.value = String(n);
  numInput.value = String(n);
  calcCouts(n);
}

slider?.addEventListener('input', () => sync(slider.value));
numInput?.addEventListener('input', () => sync(numInput.value));
calcCouts(10);
</script>
