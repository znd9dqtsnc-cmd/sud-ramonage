          <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <summary itemprop="name">{item.name}</summary>
            <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text">{item.acceptedAnswer.text}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA FINAL ═══ -->
  <section class="py-16 px-6 md:px-10 bg-[#1A1A1A]">
    <div class="max-w-xl mx-auto text-center">
      <h2 class="text-2xl font-extrabold tracking-tight text-white mb-4">Gérez la conformité de tout votre parc en une conversation.</h2>
      <p class="text-sm text-white/45 font-light mb-8">
        Réponse sous 24h. Devis personnalisé par nombre de lots.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="mailto:contact@sud-ramonage.fr?subject=Devis%20Contrat%20S%C3%A9curit%C3%A9%20Mensualise%20%E2%80%94%20[NOM%20AGENCE]"
          class="inline-flex items-center gap-2 bg-[#E65100] text-white text-sm font-bold px-7 py-4 rounded-xl hover:bg-[#BF360C] transition-colors duration-200"
        >
