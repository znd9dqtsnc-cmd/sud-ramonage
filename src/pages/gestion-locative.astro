---
import Layout from '../layouts/Layout.astro';
import ContactButton from '../components/ContactButton.astro';

const siteUrl = 'https://www.sud-ramonage.fr';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Contrat de Sécurité Mensualisé — Sud Ramonage Bailleurs',
  description: 'Abonnement ramonage et entretien conduits pour bailleurs, agences de gestion locative et syndicats de copropriété. Zéro gestion, conformité garantie, certificats automatiques.',
  provider: {
    '@type': 'HomeAndConstructionBusiness',
    name: 'Sud Ramonage',
    url: siteUrl,
    areaServed: { '@type': 'State', name: 'Bouches-du-Rhône' },
  },
  serviceType: 'Gestion entretien conduits — Bailleurs',
  offers: [
    {
      '@type': 'Offer',
      name: 'Pack Essentiel Bailleur',
      description: 'Ramonage annuel + certificat RSD 13 par lot, facturation mensuelle mutualisée',
      priceSpecification: { '@type': 'UnitPriceSpecification', price: '7.50', priceCurrency: 'EUR', unitText: 'lot/mois' },
    },
    {
      '@type': 'Offer',
      name: 'Pack Intégral Bailleur',
      description: 'Ramonage + inspection caméra + rapport annuel + gestion sinistres assurance',
      priceSpecification: { '@type': 'UnitPriceSpecification', price: '14.90', priceCurrency: 'EUR', unitText: 'lot/mois' },
    },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Solutions bailleurs et agences',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Ramonage annuel multi-lots' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Certificats RSD 13 automatiques' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Rapport annuel copropriété' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Gestion urgences locataires' } },
    ],
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Le ramonage est-il à la charge du bailleur ou du locataire ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Selon le décret n°87-712 du 26 août 1987, le ramonage courant est une charge locative récupérable — c\'est donc le locataire qui la supporte in fine. Cependant, c\'est souvent au bailleur ou à l\'agence de gérer l\'organisation pratique pour garantir la conformité. Le Contrat de Sécurité Mensualisé gère tout : planification, intervention, certificat, récupération de charge.' },
    },
    {
      '@type': 'Question',
      name: 'Qu\'est-ce que le Contrat de Sécurité Mensualisé ?',
      acceptedAnswer: { '@type': 'Answer', text: 'C\'est un abonnement annuel facturé mensuellement qui couvre l\'ensemble des interventions d\'entretien des conduits pour un parc de logements. Le bailleur ou l\'agence reçoit une facture unique mensuelle et des certificats automatiques pour chaque lot. Zéro gestion administrative pour l\'agence, conformité garantie pour le bailleur.' },
    },
    {
      '@type': 'Question',
      name: 'Combien de lots minimum pour bénéficier du contrat ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Le Contrat de Sécurité Mensualisé est accessible dès 3 lots. Les tarifs dégressifs s\'appliquent à partir de 5 lots (Pack Essentiel) et 10 lots (tarif agence négocié). Contactez-nous pour un devis personnalisé basé sur votre parc.' },
    },
    {
      '@type': 'Question',
      name: 'Les charges sont-elles récupérables sur le locataire ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Oui. Le ramonage annuel figure explicitement dans la liste des charges récupérables du décret n°87-712. La facture mensuelle du Contrat de Sécurité Mensualisé est ventilable par lot et opposable à chaque locataire. Nous fournissons une attestation annuelle par lot pour votre comptabilité.' },
    },
  ],
};

const tarifs = [
  {
    nom: 'Pack Essentiel',
    lotMin: 3,
    mensuel: '7,50 €',
    annuel: '90 €',
    color: 'border-[#EEEEEE]',
    badge: null,
    inclus: [
      'Ramonage annuel par lot',
      'Certificat RSD 13 conforme',
      'Planification proactive',
      'Facturation mensuelle unique',
      'Attestation annuelle récupération de charge',
    ],
    exclus: [
      'Inspection caméra',
      'Rapport annuel complet',
      'Gestion sinistres',
    ],
  },
  {
    nom: 'Pack Intégral',
    lotMin: 5,
    mensuel: '14,90 €',
    annuel: '178,80 €',
    color: 'border-[#E65100]',
    badge: 'Recommandé agences',
    inclus: [
      'Ramonage annuel par lot',
      'Certificat RSD 13 conforme',
      'Inspection caméra tous les 3 ans',
      'Rapport annuel état du parc',
      'Gestion appels locataires (refoulement, urgence)',
      'Facturation mensuelle unique',
      'Attestation annuelle récupération de charge',
      'Accès espace agence en ligne',
    ],
    exclus: [],
  },
];
---

<Layout
  title="Gestion Locative & Ramonage — Contrat Sécurité Bailleurs — Sud Ramonage"
  description="Abonnement ramonage pour bailleurs et agences de gestion à Martigues. Contrat de Sécurité Mensualisé : zéro gestion, certificats automatiques, conformité garantie. À partir de 7,50 €/lot/mois."
  breadcrumbs={[
    { name: 'Accueil', url: '/' },
    { name: 'Gestion Locative', url: '/gestion-locative' },
  ]}
  pageSchema={pageSchema}
>

  <!-- ═══ HERO ═══ -->
  <section class="relative pt-32 pb-24 px-6 md:px-10 bg-[#0D1B2E] overflow-hidden">

    <!-- Grille décorative -->
    <div class="absolute inset-0 opacity-[0.04]" aria-hidden="true"
      style="background-image: repeating-linear-gradient(0deg, #fff 0px, #fff 1px, transparent 1px, transparent 60px), repeating-linear-gradient(90deg, #fff 0px, #fff 1px, transparent 1px, transparent 60px);">
    </div>

    <!-- Glows -->
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-[#1A4B8F] opacity-25 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-[#E65100] opacity-15 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-6xl mx-auto">
      <nav class="flex items-center gap-2 text-xs text-white/30 mb-10" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-white transition-colors duration-200">Accueil</a>
        <span>/</span>
        <span class="text-white/60">Gestion Locative</span>
      </nav>

      <div class="grid lg:grid-cols-2 gap-14 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-[#1A4B8F]/20 border border-[#1A4B8F]/30 rounded-full px-3 py-1.5 mb-6">
            <span class="w-1.5 h-1.5 rounded-full bg-[#1A4B8F] animate-pulse"></span>
            <span class="text-[10px] font-bold tracking-widest uppercase text-[#6B9FD4]">Bailleurs & Agences</span>
          </div>

          <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-white leading-tight mb-6">
            Zéro gestion.<br />
            <span class="text-[#E65100]">Conformité garantie.</span>
          </h1>

          <p class="text-base text-white/55 font-light leading-relaxed mb-8 max-w-lg">
            Le <strong class="text-white font-semibold">Contrat de Sécurité Mensualisé</strong> prend en charge l'ensemble des obligations d'entretien des conduits pour votre parc locatif — planification, intervention, certificats, récupération de charges.
          </p>

          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <a
              href="mailto:contact@sud-ramonage.fr?subject=Devis%20Contrat%20S%C3%A9curit%C3%A9%20Mensualise%20%E2%80%94%20[NOM%20AGENCE]&body=Bonjour%2C%0A%0AJe%20g%C3%A8re%20un%20parc%20de%20____%20lots%20%C3%A9quip%C3%A9s%20de%20ch%C3%A9min%C3%A9e%2Fpoele.%0AJe%20souhaite%20un%20devis%20pour%20le%20Contrat%20de%20S%C3%A9curit%C3%A9%20Mensualise.%0A%0APaolo%20%2F%20[Agence]"
              class="inline-flex items-center gap-2 bg-[#E65100] text-white text-sm font-bold px-6 py-3.5 rounded-xl hover:bg-[#BF360C] transition-colors duration-200"
            >
              Demander un devis agence
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <ContactButton variant="phone" class="text-white/70 hover:text-white text-sm" />
          </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: '3+', label: 'lots minimum', sub: 'pour souscrire' },
            { val: '7,50 €', label: 'par lot/mois', sub: 'Pack Essentiel' },
            { val: '100%', label: 'conformité RSD', sub: 'Certificat inclus' },
            { val: '0', label: 'gestion admin', sub: 'Pour votre agence' },
          ].map(s => (
            <div class="bg-white/5 border border-white/10 rounded-2xl p-5 text-center">
              <p class="text-3xl font-extrabold text-white mb-1">{s.val}</p>
              <p class="text-xs font-semibold text-white/70 mb-0.5">{s.label}</p>
              <p class="text-[10px] text-white/35">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ARGUMENTAIRE JURIDIQUE ═══ -->
  <section class="py-20 px-6 md:px-10 bg-white">
    <div class="max-w-6xl mx-auto">

      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <div>
          <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-4">Cadre légal</p>
          <h2 class="text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-6">
            Le bailleur porte la responsabilité — même si c'est le locataire qui paie.
          </h2>
          <p class="text-sm text-[#1A1A1A]/60 font-light leading-relaxed mb-6">
            Le décret n°87-712 classe le ramonage en charge récupérable — le locataire en supporte le coût in fine. Mais l'obligation de résultat pèse sur le bailleur : en cas de sinistre sans certificat conforme, c'est le bailleur qui engage sa responsabilité civile et pénale.
          </p>

          <div class="space-y-4">
            {[
              {
                titre: 'Décret n°87-712 (1987)',
                texte: 'Ramonage = charge locative récupérable. Le bailleur peut refacturer l\'intervention au locataire sur les charges annuelles.',
                icon: '⚖️',
              },
              {
                titre: 'Loi n°89-462 art. 6',
                texte: 'Le bailleur doit remettre et maintenir un logement décent. Un conduit non ramoné = logement non conforme = bailleur en défaut.',
                icon: '🏠',
              },
              {
                titre: 'Code des assurances',
                texte: 'En cas d\'incendie de conduit, l\'assureur du locataire cherche un responsable. Sans certificat de ramonage conforme, la responsabilité se retourne vers le bailleur.',
                icon: '🛡️',
              },
            ].map(item => (
              <div class="flex gap-4 p-4 bg-[#F9F9F9] rounded-xl border border-[#EEEEEE]">
                <span class="text-2xl shrink-0 mt-0.5">{item.icon}</span>
                <div>
                  <p class="text-sm font-bold text-[#1A1A1A] mb-1">{item.titre}</p>
                  <p class="text-xs text-[#1A1A1A]/55 font-light leading-relaxed">{item.texte}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Simulateur lots -->
        <div class="bg-[#1A1A1A] rounded-2xl p-8 text-white">
          <p class="text-[10px] font-bold tracking-widest uppercase text-[#E65100] mb-2">Simulateur</p>
          <h3 class="text-xl font-extrabold mb-1">Votre coût annuel</h3>
          <p class="text-xs text-white/40 mb-8">par abonnement vs interventions ponctuelles</p>

          <div class="mb-6">
            <label for="nb-lots" class="text-xs font-semibold text-white/70 block mb-2">Nombre de lots avec cheminée / poêle</label>
            <div class="flex items-center gap-4">
              <input
                id="nb-lots"
                type="range"
                min="3"
                max="50"
                value="10"
                class="flex-1 accent-[#E65100]"
              />
              <input
                id="nb-lots-val"
                type="number"
                min="3"
                max="50"
                value="10"
                class="w-16 bg-white/10 border border-white/20 rounded-lg px-2 py-1.5 text-sm text-white text-center font-bold"
              />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4 mb-8">
            <div class="bg-white/5 border border-white/10 rounded-xl p-4">
              <p class="text-[10px] text-white/40 mb-1">Sans abonnement</p>
              <p id="cout-ponctuel" class="text-2xl font-extrabold text-white">1 200 €</p>
              <p class="text-[10px] text-white/30 mt-1">≈ 120 €/lot/an</p>
            </div>
            <div class="bg-[#E65100]/15 border border-[#E65100]/30 rounded-xl p-4">
              <p class="text-[10px] text-[#E65100]/80 mb-1">Pack Essentiel</p>
              <p id="cout-abonnement" class="text-2xl font-extrabold text-[#E65100]">900 €</p>
              <p class="text-[10px] text-[#E65100]/50 mt-1">7,50 €/lot/mois</p>
            </div>
          </div>

          <div class="bg-green-500/15 border border-green-500/30 rounded-xl p-4 mb-6">
            <div class="flex items-center justify-between">
              <p class="text-xs font-semibold text-green-300">Économie annuelle estimée</p>
              <p id="economie" class="text-xl font-extrabold text-green-400">300 €</p>
            </div>
            <p class="text-[10px] text-green-400/50 mt-1">+ zéro gestion administrative</p>
          </div>

          <a
            href="mailto:contact@sud-ramonage.fr?subject=Devis%20Contrat%20S%C3%A9curit%C3%A9%20Mensualise&body=Nombre%20de%20lots%20:%20"
            class="block text-center bg-[#E65100] text-white text-sm font-bold px-6 py-3 rounded-xl hover:bg-[#BF360C] transition-colors duration-200"
          >
            Obtenir mon devis personnalisé
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══ TARIFS ═══ -->
  <section class="py-20 px-6 md:px-10 bg-[#F9F9F9]">
    <div class="max-w-5xl mx-auto">

      <div class="text-center mb-14">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-3">Contrat de Sécurité Mensualisé</p>
        <h2 class="text-3xl font-extrabold tracking-tight text-[#1A1A1A]">Deux formules, zéro contrainte.</h2>
        <p class="text-sm text-[#1A1A1A]/45 font-light mt-3">Tarifs par lot, facturés mensuellement. Engagement annuel.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-3xl mx-auto">
        {tarifs.map(pack => (
          <div class={`bg-white border-2 ${pack.color} rounded-2xl p-8 relative`}>
            {pack.badge && (
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                <span class="bg-[#E65100] text-white text-[10px] font-bold px-3 py-1 rounded-full">{pack.badge}</span>
              </div>
            )}

            <p class="text-xs font-bold tracking-widest uppercase text-[#1A1A1A]/40 mb-2">{pack.nom}</p>
            <div class="flex items-end gap-1 mb-1">
              <span class="text-4xl font-extrabold text-[#1A1A1A]">{pack.mensuel}</span>
              <span class="text-xs text-[#1A1A1A]/40 mb-1.5 font-medium">/ lot / mois</span>
            </div>
            <p class="text-xs text-[#1A1A1A]/35 mb-2">Soit {pack.annuel} par lot/an</p>
            <p class="text-[10px] text-[#1A1A1A]/30 mb-6">À partir de {pack.lotMin} lots</p>

            <ul class="space-y-2.5 mb-6">
              {pack.inclus.map(item => (
                <li class="flex items-start gap-2.5 text-xs text-[#1A1A1A]/70">
                  <svg class="w-3.5 h-3.5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  {item}
                </li>
              ))}
              {pack.exclus.map(item => (
                <li class="flex items-start gap-2.5 text-xs text-[#1A1A1A]/30">
                  <svg class="w-3.5 h-3.5 text-[#1A1A1A]/20 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                  <span class="line-through">{item}</span>
                </li>
              ))}
            </ul>

            <a
              href="mailto:contact@sud-ramonage.fr?subject=Devis%20Contrat%20S%C3%A9curit%C3%A9%20—%20{pack.nom}"
              class={`block text-center text-sm font-bold px-5 py-3 rounded-xl transition-colors duration-200 ${pack.badge ? 'bg-[#E65100] text-white hover:bg-[#BF360C]' : 'bg-[#1A1A1A]/5 text-[#1A1A1A] hover:bg-[#1A1A1A]/10'}`}
            >
              Demander ce devis
            </a>
          </div>
        ))}
      </div>

      <p class="text-center text-xs text-[#1A1A1A]/35 mt-6">Tarifs dégressifs pour les parcs de 20 lots et plus. Contactez-nous pour une offre sur mesure.</p>

    </div>
  </section>

  <!-- ═══ PROCESSUS ═══ -->
  <section class="py-20 px-6 md:px-10 bg-white">
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-14">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-3">Comment ça fonctionne</p>
        <h2 class="text-3xl font-extrabold tracking-tight text-[#1A1A1A]">Zéro appel de votre part. Tout est géré.</h2>
      </div>

      <div class="grid md:grid-cols-4 gap-6">
        {[
          {
            num: '01',
            titre: 'Inventaire du parc',
            texte: 'Vous nous transmettez la liste de vos lots avec cheminée/poêle. Nous établissons un calendrier d\'intervention sur 12 mois.',
          },
          {
            num: '02',
            titre: 'Prise de contact locataire',
            texte: 'Nous contactons directement le locataire pour fixer le rendez-vous. Vous n\'intervenez pas.',
          },
          {
            num: '03',
            titre: 'Intervention & certificat',
            texte: 'Le ramonage est réalisé, le certificat RSD 13 est émis dans les 24h et transmis à l\'agence par email.',
          },
          {
            num: '04',
            titre: 'Facturation mensuelle',
            texte: 'Une facture unique mensuelle pour l\'ensemble de votre parc. Attestation annuelle par lot pour les charges locatives.',
          },
        ].map(step => (
          <div class="relative">
            <div class="w-10 h-10 rounded-2xl bg-[#E65100]/10 flex items-center justify-center mb-4">
              <span class="text-xs font-extrabold text-[#E65100]">{step.num}</span>
            </div>
            <h3 class="text-sm font-bold text-[#1A1A1A] mb-2">{step.titre}</h3>
            <p class="text-xs text-[#1A1A1A]/50 font-light leading-relaxed">{step.texte}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══ PARTENAIRES CIBLES ═══ -->
  <section class="py-20 px-6 md:px-10 bg-[#F9F9F9]">
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-12">
        <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-3">Conçu pour votre métier</h2>
        <p class="text-sm text-[#1A1A1A]/45 font-light">Trois profils, une solution commune.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            titre: 'Agences de gestion locative',
            exemples: 'Foncia, Citya, Nexity, agences indépendantes',
            avantages: [
              'Délégation totale : zéro appel locataire',
              'Tableau de bord agence (certificats par lot)',
              'Facturation centralisée récupérable',
              'Interlocuteur unique pour tout le parc',
            ],
            cta: 'Espace agence →',
          },
          {
            titre: 'Propriétaires bailleurs multi-lots',
            exemples: 'SCI familiales, investisseurs LMNP, patrimoniaux',
            avantages: [
              'Planification automatique chaque saison',
              'Certificats conservés dans votre espace',
              'Argumentaire locataire clé en main',
              'Protection juridique renforcée',
            ],
            cta: 'Tarif bailleur →',
          },
          {
            titre: 'Syndicats de copropriété',
            exemples: 'Syndics professionnels, syndicats bénévoles',
            avantages: [
              'Gestion conduits communs (shunts VMC)',
              'Rapport annuel copropriété format AG',
              'Distinction parties communes / privatives',
              'Conformité NF DTU 24.1 documentée',
            ],
            cta: 'Contacter →',
          },
        ].map(profil => (
          <div class="bg-white border border-[#EEEEEE] rounded-2xl p-7 hover:shadow-lg hover:border-[#E65100]/20 transition-all duration-300">
            <h3 class="text-base font-extrabold text-[#1A1A1A] mb-1">{profil.titre}</h3>
            <p class="text-[10px] text-[#1A1A1A]/35 mb-5 font-light italic">{profil.exemples}</p>
            <ul class="space-y-2.5 mb-6">
              {profil.avantages.map(av => (
                <li class="flex items-start gap-2 text-xs text-[#1A1A1A]/65">
                  <svg class="w-3.5 h-3.5 text-[#E65100] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  {av}
                </li>
              ))}
            </ul>
            <a
              href="mailto:contact@sud-ramonage.fr?subject=Contrat%20S%C3%A9curit%C3%A9%20—%20{profil.titre}"
              class="text-xs font-bold text-[#E65100] hover:underline"
            >
              {profil.cta}
            </a>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="py-20 px-6 md:px-10 bg-white">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-10 text-center">Questions fréquentes</h2>
