---
import Layout from '../layouts/Layout.astro';
import ContactButton from '../components/ContactButton.astro';
import FAQ from '../components/FAQ.astro';
import { Image } from 'astro:assets';

import heroBg        from '../assets/images/service-ramonage.jpg';
import artisanImg    from '../assets/images/artisan-intervention.jpg';
import conduitImg    from '../assets/images/conduit-cheminee.jpg';

const siteUrl = 'https://www.sud-ramonage.fr';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Ramonage certifié cheminée et poêle',
  description: 'Ramonage mécanique complet avec certificat officiel conforme RSD 13. Cheminée foyer ouvert, insert, poêle à bois et granulés.',
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  areaServed: { '@type': 'City', name: 'Martigues' },
  serviceType: 'Ramonage de cheminée',
  url: `${siteUrl}/ramonage`,
};

const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Ramonage Certifié — Sud Ramonage Martigues',
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['h1', '.lead', '[data-speakable]'],
  },
  url: `${siteUrl}/ramonage`,
};
---

<Layout
  title="Ramonage Certifié Cheminée & Poêle — Sud Ramonage Martigues"
  description="Ramonage certifié de cheminées, inserts et poêles à Martigues et Côte Bleue. Certificat conforme RSD 13 remis immédiatement. Artisan assuré. Devis gratuit sous 24h."
  breadcrumbs={[
    { name: 'Accueil', url: '/' },
    { name: 'Ramonage Certifié', url: '/ramonage' },
  ]}
  pageSchema={pageSchema}
>

  <!-- ═══ HERO avec image de fond ═══ -->
  <section class="relative pt-32 pb-20 px-6 md:px-10 overflow-hidden">
    <!-- Image de fond -->
    <div class="absolute inset-0 z-0">
      <Image
        src={heroBg}
        alt="Artisan ramoneur au travail sur un conduit de cheminée à Martigues"
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[#1A1A1A]/85 via-[#1A1A1A]/65 to-[#1A1A1A]/30"></div>
    </div>
    <!-- Contenu -->
    <div class="relative z-10 max-w-6xl mx-auto">
      <nav class="flex items-center gap-2 text-xs text-white/30 mb-8" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-white transition-colors duration-200">Accueil</a>
        <span>/</span>
        <span class="text-white/60">Ramonage Certifié</span>
      </nav>
      <div class="flex items-center gap-3 mb-5">
        <span class="bg-[#E65100] text-white text-sm font-extrabold px-4 py-2 rounded-xl">à partir de 75 €</span>
        <span class="text-white/50 text-xs">certificat RSD 13 inclus</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white leading-tight mb-6">
        Ramonage Certifié<br />Cheminée & Poêle.
      </h1>
      <p class="text-base text-white/55 font-light max-w-xl leading-relaxed mb-8">
        Ramonage mécanique complet de votre conduit de fumée — cheminée à foyer ouvert, insert, poêle à bois ou à granulés. Certificat officiel remis sur place, conforme au RSD 13 et reconnu par votre assureur.
      </p>
      <ContactButton variant="phone" class="px-8 py-3.5" />
    </div>
  </section>

  <!-- ═══ CONTENU PRINCIPAL ═══ -->
  <section id="protocole-ramonage" class="py-20 px-6 md:px-10">
    <div class="max-w-6xl mx-auto">

      <!-- TL;DR — Résumé pour IA et lecteurs pressés -->
      <div class="border-l-4 border-[#E65100] bg-[#FFF3E0] rounded-r-xl p-6 mb-14" role="note" aria-label="Résumé de la page">
        <p class="text-[10px] font-bold tracking-widest uppercase text-[#E65100] mb-3">TL;DR — L'essentiel en 30 secondes</p>
        <ul class="space-y-2">
          {[
            'Ramonage mécanique obligatoire 1×/an (RSD 13) — hérisson rotatif + aspiration suies + test vacuité + certificat NF DTU 24.1.',
            'Bistre, calcin, condensation : détectés et éliminés avant que le point de rosée dégrade le tubage inox.',
            'Appareils traités : cheminée foyer ouvert, insert bois, poêle à bois, poêle à granulés, conduit maçonné ou tubage inox.',
            'Durée : 45 min à 1h30 selon l\'appareil — protection sol, aspiration intégrale, tirage contrôlé, chantier propre.',
            'Certificat RSD 13 conforme NF DTU 24.1 remis immédiatement — valable pour votre assureur.',
          ].map(point => (
            <li class="flex items-start gap-2.5 text-sm text-[#1A1A1A]/75 font-light">
              <span class="w-1.5 h-1.5 rounded-full bg-[#E65100] mt-1.5 shrink-0"></span>
              {point}
            </li>
          ))}
        </ul>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Colonne gauche : texte -->
        <div class="space-y-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1A1A1A] mb-5">
              Pourquoi le Ramonage est Obligatoire.
            </h2>
            <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed mb-4">
              Le <strong class="text-[#1A1A1A]/80">RSD 13</strong> (Règlement Sanitaire Départemental des Bouches-du-Rhône) impose un ramonage annuel de tout conduit de fumée actif. Cette obligation est renforcée au niveau national par le <strong class="text-[#1A1A1A]/80">décret n° 2023-641 du 20 juillet 2023</strong> encadrant l'entretien des appareils à combustion. Sans <strong class="text-[#1A1A1A]/80">certificat</strong> de ramonage conforme <strong class="text-[#1A1A1A]/80">NF DTU 24.1</strong>, votre assureur peut légalement refuser toute indemnisation en cas de sinistre.
            </p>
            <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed mb-4">
              Le principal danger est le <strong class="text-[#1A1A1A]/80">bistre</strong> : dépôt de goudron qui s'accumule sur les parois du conduit lors d'une combustion à basse température. Ce <strong class="text-[#1A1A1A]/80">bistre</strong> s'enflamme à 200 °C et provoque un incendie de conduit incontrôlable. Le test de <strong class="text-[#1A1A1A]/80">vacuité</strong>, réalisé à chaque ramonage selon la <strong class="text-[#1A1A1A]/80">NF DTU 24.1</strong>, vérifie l'absence d'obstruction et la conformité du tirage.
            </p>
            <p class="text-base text-[#1A1A1A]/60 font-light leading-relaxed">
              Un conduit mal entretenu atteint son <strong class="text-[#1A1A1A]/80">point de rosée</strong> en dessous de 100 °C — la <strong class="text-[#1A1A1A]/80">condensation</strong> acide corrode alors le <strong class="text-[#1A1A1A]/80">tubage</strong> inox et dégrade les joints de boisseau. Le <strong class="text-[#1A1A1A]/80">certificat RSD 13</strong> délivré après notre intervention atteste que conduit, <strong class="text-[#1A1A1A]/80">vacuité</strong> et <strong class="text-[#1A1A1A]/80">tirage</strong> répondent aux exigences de la <strong class="text-[#1A1A1A]/80">NF DTU 24.1 P1-1</strong>.
            </p>
          </div>

          <!-- Image illustration 1 : artisan en intervention -->
          <figure class="rounded-xl overflow-hidden aspect-[16/9]">
            <Image
              src={artisanImg}
              alt="Artisan ramoneur certifié lors d'une intervention de ramonage mécanique à Martigues"
              width={800}
              height={450}
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <figcaption class="sr-only">Artisan ramoneur certifié à Martigues effectuant un ramonage mécanique — hérisson rotatif, tirage thermique contrôlé, test de vacuité, tubage inox. Conforme RSD 13 Bouches-du-Rhône.</figcaption>
          </figure>

          <div>
            <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-4">
              Les 5 Étapes de Notre Ramonage.
            </h2>
            <ol class="space-y-4">
              {[
                { n: '01', t: 'Protection du chantier', d: 'Bâches de protection au sol et autour du foyer avant toute intervention.' },
                { n: '02', t: 'Ramonage mécanique', d: 'Hérissons rotatifs adaptés au type de conduit (maçonnerie, inox, tuile).' },
                { n: '03', t: 'Aspiration des suies', d: 'Aspiration professionnelle pour un chantier propre sans dépôt dans la pièce.' },
                { n: '04', t: 'Test de vacuité', d: 'Vérification de l\'absence d\'obstruction (nid, calcin, effondrement partiel) et contrôle du tirage thermique.' },
                { n: '05', t: 'Remise du certificat', d: 'Document officiel remis sur place, immédiatement après intervention.' },
              ].map(({ n, t, d }) => (
                <li class="flex gap-4">
                  <span class="text-[11px] font-bold text-[#E65100] mt-0.5 shrink-0">{n}</span>
                  <div>
                    <p class="text-sm font-semibold text-[#1A1A1A]">{t}</p>
                    <p class="text-sm text-[#1A1A1A]/50 font-light">{d}</p>
                  </div>
                </li>
              ))}
            </ol>
          </div>
        </div>

        <!-- Colonne droite : checklist + image -->
        <div class="space-y-6">
          <div class="bg-[#FFF3E0] rounded-xl p-7">
            <p class="text-sm font-bold text-[#1A1A1A] mb-5">Ce service comprend</p>
            {[
              'Ramonage mécanique complet',
              'Aspiration professionnelle des suies',
              'Contrôle visuel de l\'état du conduit',
              'Certificat officiel de ramonage (RSD 13)',
              'Conseils personnalisés sur l\'entretien',
            ].map((item) => (
              <div class="flex items-center gap-3 py-2.5 border-b border-[#E65100]/10 last:border-0">
                <svg class="w-4 h-4 text-[#E65100] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm text-[#1A1A1A]/70 font-light">{item}</span>
              </div>
            ))}
            <div class="pt-5">
              <ContactButton variant="phone" class="w-full justify-center" />
            </div>
          </div>

          <!-- Image illustration 2 : conduit/travaux -->
          <figure class="rounded-xl overflow-hidden aspect-[4/3]">
            <Image
              src={conduitImg}
              alt="Gros plan sur un conduit de cheminée inox lors d'une opération de ramonage à Martigues"
              width={700}
              height={525}
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <figcaption class="sr-only">Conduit de cheminée en inox à Martigues — ramonage mécanique, élimination suie et calcin, test de vacuité, vérification tirage thermique. Artisan certifié Bouches-du-Rhône.</figcaption>
          </figure>

          <div class="bg-[#FAFAFA] border border-[#EEEEEE] rounded-xl p-6">
            <p class="text-xs font-semibold text-[#1A1A1A]/40 uppercase tracking-widest mb-3">Appareils traités</p>
            <div class="flex flex-wrap gap-2">
              {['Cheminée foyer ouvert', 'Insert', 'Poêle à bois', 'Poêle à granulés', 'Conduit maçonné', 'Tubage inox'].map((tag) => (
                <span class="text-[11px] font-medium border border-[#EEEEEE] text-[#1A1A1A]/55 px-3 py-1.5 rounded-md">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TARIFS ═══ -->
  <section id="tarif-ramonage" class="py-16 px-6 md:px-10 bg-[#FAFAFA]">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">

        <div>
          <p class="text-[11px] font-semibold tracking-widest uppercase text-[#E65100] mb-4">Tarifs</p>
          <h2 class="text-2xl font-extrabold tracking-tight text-[#1A1A1A] mb-6">Ce que coûte un ramonage.</h2>
          <div class="bg-white border border-[#EEEEEE] rounded-xl overflow-hidden">
            {[
              { label: 'Cheminée foyer ouvert',    prix: '75 €' },
              { label: 'Insert bois',               prix: '90 €' },
              { label: 'Poêle à bois',              prix: '90 €' },
              { label: 'Poêle à granulés',          prix: '110 €' },
              { label: 'Conduit complexe / long',   prix: 'Devis' },
            ].map(({ label, prix }, i) => (
              <div class={`flex items-center justify-between px-6 py-3.5 ${i % 2 === 0 ? 'bg-white' : 'bg-[#FAFAFA]'}`}>
                <span class="text-sm text-[#1A1A1A]/65 font-light">{label}</span>
                <span class="text-sm font-bold text-[#1A1A1A]">{prix}</span>
              </div>
            ))}
          </div>
          <p class="text-[11px] text-[#1A1A1A]/40 font-light mt-4">
            Tarifs indicatifs — zone Martigues et Côte Bleue. Devis gratuit sous 24h.
          </p>
        </div>

        <div class="bg-[#FAFAFA] border border-[#EEEEEE] rounded-xl p-7">
          <p class="text-xs font-semibold text-[#1A1A1A]/40 uppercase tracking-widest mb-5">Inclus dans chaque ramonage</p>
          {[
            'Ramonage mécanique complet (hérisson rotatif)',
            'Aspiration professionnelle des suies',
            'Test de vacuité et contrôle tirage thermique',
            'Nettoyage du chantier après intervention',
            'Certificat officiel RSD 13 remis sur place',
            'Conseils personnalisés sur votre installation',
          ].map(item => (
            <div class="flex items-center gap-3 py-2.5 border-b border-[#EEEEEE] last:border-0">
              <svg class="w-4 h-4 text-[#E65100] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-[#1A1A1A]/60 font-light">{item}</span>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <FAQ
    title="Questions sur le Ramonage Certifié."
    items={[
      {
        q: "Quelle est la fréquence de ramonage obligatoire selon le RSD 13 ?",
        a: "Le Règlement Sanitaire Départemental des Bouches-du-Rhône (RSD 13) impose un ramonage mécanique au minimum une fois par an pour tout conduit de fumée en service. Certains assureurs exigent deux ramonages annuels pour les appareils à combustion utilisés quotidiennement en hiver. Nous vous conseillons un entretien avant la saison de chauffe (septembre–octobre).",
      },
      {
        q: "Qu'est-ce que le test de vacuité et est-il inclus dans le ramonage ?",
        a: "Le test de vacuité vérifie l'absence totale d'obstruction dans le conduit — nid d'oiseau, effondrement partiel de maçonnerie, accumulation de calcin ou dépôt de bistre. Ce contrôle est inclus dans notre prestation de ramonage standard et figure sur le certificat officiel remis à l'issue de l'intervention.",
      },
      {
        q: "Quelle différence entre un conduit maçonné et un tubage inox ?",
        a: "Un conduit maçonné est intégré dans la structure de la maison (briques, pierres, béton). Un tubage inox est un conduit en acier inoxydable installé à l'intérieur d'un conduit existant ou en façade. Nous intervenons sur les deux types. Le tubage inox est souvent recommandé pour adapter un conduit ancien à un poêle moderne à haut rendement.",
      },
      {
        q: "Combien de temps dure une intervention de ramonage ?",
        a: "Une intervention standard (ramonage mécanique + test de vacuité + contrôle du tirage thermique + remise du certificat) prend entre 45 minutes et 1h30 selon le type d'appareil et la longueur du conduit. Pour un débistrage, prévoir 2 à 3 heures.",
      },
      {
        q: "Le ramonage par caméra est-il obligatoire à Martigues ?",
        a: "Non, l'inspection caméra n'est pas imposée par le RSD 13. Seul le ramonage mécanique annuel est obligatoire dans les Bouches-du-Rhône. L'inspection caméra HD est en revanche fortement recommandée avant tout achat immobilier, après un incendie de conduit, ou si le tirage est anormalement faible. Le rapport d'inspection peut être joint à votre dossier d'assurance. En savoir plus : <a href='/inspection-camera'>inspection caméra HD</a>.",
      },
      {
        q: "Quel est le prix d'un ramonage à Martigues ?",
        a: "Le tarif d'un ramonage à Martigues varie selon l'appareil : 75 € pour une cheminée à foyer ouvert, 90 € pour un insert ou poêle à bois, 110 € pour un poêle à granulés. Le certificat officiel RSD 13 est inclus dans chaque prestation. Devis gratuit sous 24h — appelez le 06 64 72 96 00.",
      },
    ]}
  />

  <!-- ═══ MAILLAGE SILO ═══ -->
  <section class="py-12 px-6 md:px-10 bg-[#FAFAFA]">
    <div class="max-w-6xl mx-auto">
      <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/35 mb-4">Zone principale d'intervention</p>
      <div class="flex flex-wrap gap-3">
        {[
          { href: '/villes/martigues',                label: 'Ramonage Martigues' },
          { href: '/villes/istres',                   label: 'Ramonage Istres' },
          { href: '/villes/fos-sur-mer',              label: 'Ramonage Fos-sur-Mer' },
          { href: '/villes/sausset-les-pins',         label: 'Ramonage Sausset-les-Pins' },
          { href: '/villes/carry-le-rouet',           label: 'Ramonage Carry-le-Rouet' },
          { href: '/villes/chateauneuf-les-martigues',label: 'Ramonage Châteauneuf' },
          { href: '/villes/gignac-la-nerthe',         label: 'Ramonage Gignac-la-Nerthe' },
        ].map(({ href, label }) => (
          <a href={href} class="inline-flex items-center gap-2 bg-white border border-[#EEEEEE] rounded-lg px-4 py-2.5 text-xs font-medium text-[#1A1A1A]/65 hover:border-[#E65100]/30 hover:text-[#E65100] transition-all duration-200">
            <span class="w-1.5 h-1.5 rounded-full bg-[#E65100] shrink-0"></span>
            {label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="py-16 px-6 md:px-10">
    <div class="max-w-4xl mx-auto border border-[#EEEEEE] rounded-2xl p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <div>
        <h2 class="text-xl font-extrabold tracking-tight text-[#1A1A1A] mb-2">Prendre Rendez-Vous</h2>
        <p class="text-sm text-[#1A1A1A]/55 font-light">Disponible du lundi au samedi. Devis gratuit sous 24h.</p>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 shrink-0">
        <ContactButton variant="phone" class="px-6 py-3 text-sm" />
        <ContactButton variant="email" />
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(speakableSchema)} />

</Layout>
