---
import Layout from '../layouts/Layout.astro';
const siteUrl = 'https://www.sud-ramonage.fr';

const datasetSchema = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  '@id': `${siteUrl}/sante-qualite-air#dataset`,
  name: 'Données sanitaires — Impact fumisterie sur la qualité de l\'air intérieur',
  description: 'Données de référence sur les concentrations en monoxyde de carbone (CO), particules fines PM2.5 et risques associés aux conduits de fumée mal entretenus.',
  creator: {
    '@type': 'Organization',
    name: 'Compilation Sud Ramonage — sources : OMS, ANSES, Santé Publique France',
  },
  license: 'https://www.etalab.gouv.fr/licence-ouverte-open-licence',
  variableMeasured: [
    { '@type': 'PropertyValue', name: 'Concentration CO pièce (refoulement)', value: '50-500 ppm', unitCode: 'PPM' },
    { '@type': 'PropertyValue', name: 'Seuil d\'alerte CO OMS', value: '10 ppm', unitCode: 'PPM' },
    { '@type': 'PropertyValue', name: 'Seuil létal CO (exposition prolongée)', value: '> 200 ppm', unitCode: 'PPM' },
    { '@type': 'PropertyValue', name: 'Réduction PM2.5 après ramonage', value: '40-65 %', unitCode: 'P1' },
    { '@type': 'PropertyValue', name: 'Gain rendement après entretien COSTIC', value: '8-15 %', unitCode: 'P1' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Le monoxyde de carbone vient-il de ma cheminée ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Oui. Une cheminée, un insert, un poêle ou une chaudière mal entretenus ou dont le conduit est obstrué peut provoquer un refoulement de fumée contenant du CO. Le monoxyde de carbone (CO) est inodore, incolore et mortel en quelques heures à concentration élevée. En France, il cause environ 1 000 hospitalisations et 80 à 100 décès par an.',
      },
    },
    {
      '@type': 'Question',
      name: 'Comment les PM2.5 sont-elles liées au ramonage ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La combustion incomplète du bois (bois humide, conduit encrassé) produit des particules fines PM2.5 qui s\'accumulent dans le foyer, dans le conduit et dans l\'air intérieur. Un ramonage régulier et un conduit étanche réduisent les émissions de PM2.5 de 40 à 65 % selon les études ADEME.',
      },
    },
    {
      '@type': 'Question',
      name: 'Mon conduit doit-il être parfaitement étanche pour protéger la qualité de l\'air ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Oui. Un conduit fissuré ou mal raccordé laisse passer des gaz de combustion (CO, CO2, particules) vers les pièces de vie. La norme NF EN 1443 classe les conduits par résistance à la pression — un conduit de classe P1 (pression positive) doit être contrôlé régulièrement par un professionnel certifié.',
      },
    },
    {
      '@type': 'Question',
      name: 'Qu\'est-ce que l\'intoxication aiguë au CO et comment la reconnaître ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Les symptômes d\'une intoxication au CO sont proches d\'une grippe : maux de tête, nausées, vertiges, fatigue soudaine. Ils disparaissent à l\'air libre. Si plusieurs personnes dans le logement présentent ces symptômes simultanément, quittez immédiatement les lieux, appelez le 15 (SAMU) ou le 18 (pompiers) et ne ré-entrez pas avant aération complète et vérification par un professionnel.',
      },
    },
    {
      '@type': 'Question',
      name: 'Le RSD 13 protège-t-il vraiment la qualité de l\'air ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Oui. Le Règlement Sanitaire Départemental 13 impose le ramonage annuel précisément pour des raisons sanitaires et de sécurité publique. Un conduit ramoné chaque année par un artisan certifié émet moins de particules, ne présente pas de risque d\'incendie de conduit et garantit l\'évacuation correcte des gaz de combustion.',
      },
    },
  ],
};

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Santé & Qualité de l\'Air', url: '/sante-qualite-air' },
];

const stats = [
  { val: '≈ 80', unit: 'décès/an', label: 'Intoxications au CO mortelles en France', source: 'Santé Publique France' },
  { val: '3 000+', unit: 'hospitalisations', label: 'Intoxications au CO par an en France', source: 'ANSES 2022' },
  { val: '40–65 %', unit: 'réduction', label: 'De PM2.5 après ramonage certifié', source: 'ADEME' },
  { val: '10 ppm', unit: 'seuil OMS', label: 'De CO déjà dangereux sur 24h', source: 'OMS 2021' },
];
---

<Layout
  title="Santé & Qualité de l'Air — Monoxyde de Carbone CO, PM2.5 & Conduits | Sud Ramonage"
  description="Tout comprendre sur les risques sanitaires liés aux conduits de fumée : monoxyde de carbone (CO), particules fines PM2.5, importance de l'étanchéité. Données OMS, ANSES, ADEME. Artisan certifié COSTIC."
  breadcrumbs={breadcrumbs}
  pageSchema={datasetSchema}
>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-[#0D1A2D] via-[#1A1A1A] to-[#1A1A1A] text-white pt-28 pb-16">
    <div class="max-w-4xl mx-auto px-6 md:px-10">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-white/40 mb-6">
        <a href="/" class="hover:text-white/70">Accueil</a><span>/</span><span class="text-white/60">Santé & Qualité de l'Air</span>
      </nav>
      <div class="inline-flex items-center gap-2 bg-[#1A4B8F]/20 border border-[#1A4B8F]/30 text-[#4A90D9] text-[11px] font-bold px-4 py-2 rounded-full mb-6 uppercase tracking-widest">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        Guide scientifique · Sources OMS, ANSES, ADEME
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-5">
        Santé & Qualité de l'Air :<br />
        <span class="text-[#4A90D9]">Ce que votre conduit peut vous faire respirer</span>
      </h1>
      <p class="text-base text-white/65 max-w-2xl leading-relaxed">
        Monoxyde de carbone, particules PM2.5, étanchéité des conduits — voici ce que la science dit sur les risques sanitaires d'une installation mal entretenue, et comment les prévenir.
      </p>
    </div>
  </section>

  <!-- Stats choc -->
  <section class="py-10 px-6 md:px-10 bg-[#1A1A1A] border-b border-white/5">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {stats.map(({ val, unit, label, source }) => (
          <div class="text-center p-5 rounded-2xl bg-white/5 border border-white/8">
            <p class="text-3xl md:text-4xl font-extrabold text-white mb-0.5">{val}</p>
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#2563EB] mb-2">{unit}</p>
            <p class="text-[11px] text-white/50 leading-tight mb-2">{label}</p>
            <p class="text-[9px] text-white/25 font-medium">Source : {source}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CO section -->
  <section class="py-16 px-6 md:px-10 border-b border-[#EEEEEE]">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <div class="inline-flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 text-[11px] font-bold px-4 py-2 rounded-full mb-5 uppercase tracking-widest">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            Risque n°1 — Inodore & invisible
          </div>
          <h2 class="text-2xl md:text-3xl font-extrabold text-[#1A1A1A] mb-5">Monoxyde de Carbone (CO)</h2>
          <p class="text-sm text-[#1A1A1A]/65 leading-relaxed mb-6">
            Le monoxyde de carbone (CO) est produit lors de toute combustion incomplète. Un conduit obstrué, fissuré ou mal tirant empêche son évacuation. Le CO se répand alors dans les pièces de vie — sans odeur, sans couleur, sans goût.
          </p>
          <p class="text-sm text-[#1A1A1A]/65 leading-relaxed mb-6">
            Il se fixe sur l'hémoglobine à la place de l'oxygène (affinité 240 × supérieure), provoquant une asphyxie progressive. Les premiers symptômes ressemblent à une grippe — céphalées, nausées, vertiges — et disparaissent à l'air libre, d'où le retard fréquent de prise en charge.
          </p>

          <div class="bg-red-50 border border-red-200 rounded-2xl p-5">
            <p class="text-sm font-bold text-red-800 mb-3">Concentrations de référence (OMS / ANSES)</p>
            <div class="space-y-2">
              {[
                { ppm: '10 ppm', effet: 'Seuil d\'alerte OMS — dangereux sur 8h', color: 'text-orange-600' },
                { ppm: '50 ppm', effet: 'Maux de tête, nausées après 2-3h', color: 'text-orange-700' },
                { ppm: '200 ppm', effet: 'Céphalées intenses, malaise — 2h d\'exposition', color: 'text-red-600' },
                { ppm: '> 400 ppm', effet: 'Danger de mort — 3h d\'exposition', color: 'text-red-800' },
              ].map(({ ppm, effet, color }) => (
                <div class="flex items-center gap-3 text-xs">
                  <span class={`font-bold shrink-0 w-20 ${color}`}>{ppm}</span>
                  <span class="text-red-700">{effet}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="space-y-4">
          <div class="bg-[#1A4B8F] rounded-2xl p-6 text-white">
            <h3 class="font-bold text-white mb-3">Signes d'alerte en cas d'intoxication</h3>
            <ul class="space-y-2">
              {[
                'Maux de tête inhabituels à l\'intérieur',
                'Nausées et vertiges qui disparaissent à l\'air libre',
                'Plusieurs personnes du foyer malades simultanément',
                'Animaux domestiques somnolents ou malades',
                'Flamme jaune/orange au lieu de bleue (chaudière gaz)',
              ].map(s => (
                <li class="flex gap-2 text-sm text-white/65">
                  <span class="text-red-400 shrink-0">⚠</span>{s}
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-[#2563EB] rounded-2xl p-6 text-white">
            <h3 class="font-bold text-white mb-2">En cas de suspicion d'intoxication</h3>
            <p class="text-sm text-white/80 mb-4">Quittez immédiatement les lieux. N'allumez rien. Laissez la porte ouverte.</p>
            <div class="flex gap-3">
              <a href="tel:15" class="bg-white text-[#2563EB] font-bold text-sm px-4 py-2.5 rounded-xl">15 — SAMU</a>
              <a href="tel:18" class="bg-white/15 text-white font-bold text-sm px-4 py-2.5 rounded-xl border border-white/20">18 — Pompiers</a>
            </div>
          </div>
          <div class="bg-[#FAFAFA] border border-[#EEEEEE] rounded-2xl p-5">
            <h3 class="font-semibold text-[#1A1A1A] mb-2 text-sm">Prévention par le ramonage</h3>
            <p class="text-xs text-[#1A1A1A]/55 leading-relaxed">Un conduit propre évacue les gaz de combustion efficacement. Un ramonage annuel par un artisan certifié COSTIC élimine les dépôts qui réduisent la section du conduit et provoquent les refoulements de CO.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PM2.5 section -->
  <section class="py-16 px-6 md:px-10 bg-[#FAFAFA] border-b border-[#EEEEEE]">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <div class="inline-flex items-center gap-2 bg-amber-50 border border-amber-200 text-amber-700 text-[11px] font-bold px-4 py-2 rounded-full mb-5 uppercase tracking-widest">
            Particules fines — Risque chronique
          </div>
          <h2 class="text-2xl md:text-3xl font-extrabold text-[#1A1A1A] mb-5">Particules Fines PM2.5</h2>
          <p class="text-sm text-[#1A1A1A]/65 leading-relaxed mb-6">
            Les particules PM2.5 (diamètre inférieur à 2,5 micromètres) sont produites par la combustion du bois. Elles pénètrent profondément dans les alvéoles pulmonaires, traversent la barrière alvéolo-capillaire et peuvent atteindre la circulation sanguine.
          </p>
          <p class="text-sm text-[#1A1A1A]/65 leading-relaxed mb-6">
            Un foyer ouvert ou un poêle avec un conduit encrassé produit davantage de particules. La combustion incomplète — favorisée par un bois humide ou un manque de tirage — multiplie les émissions de PM2.5 par <strong>3 à 8</strong> par rapport à une installation bien entretenue.
          </p>

          <div class="bg-amber-50 border border-amber-200 rounded-2xl p-5">
            <p class="text-sm font-bold text-amber-800 mb-3">Impact sanitaire des PM2.5 (OMS)</p>
            <div class="space-y-3 text-xs text-amber-700">
              <div class="flex gap-2"><span>→</span><span>Irritation des voies respiratoires supérieures</span></div>
              <div class="flex gap-2"><span>→</span><span>Aggravation de l'asthme et des BPCO</span></div>
              <div class="flex gap-2"><span>→</span><span>Risque cardiovasculaire accru (inflammation vasculaire)</span></div>
              <div class="flex gap-2"><span>→</span><span>Seuil OMS : 5 µg/m³ sur 24h (valeur guide 2021)</span></div>
            </div>
          </div>
        </div>

        <div class="space-y-4">
          <div class="bg-white border border-[#EEEEEE] rounded-2xl p-6">
            <h3 class="font-bold text-[#1A1A1A] mb-4 text-sm">Facteurs aggravants PM2.5 en fumisterie</h3>
            <div class="space-y-3">
              {[
                { facteur: 'Bois humide (taux d\'humidité > 20 %)', impact: 'Émissions PM2.5 × 4', niveau: 'Élevé' },
                { facteur: 'Conduit encrassé (bistre)', impact: 'Tirage réduit → combustion incomplète', niveau: 'Élevé' },
                { facteur: 'Foyer ouvert sans plaque de propreté', impact: 'Diffusion directe dans la pièce', niveau: 'Moyen' },
                { facteur: 'Allumage par le bas', impact: 'Phase de démarrage polluante prolongée', niveau: 'Faible' },
              ].map(({ facteur, impact, niveau }) => (
                <div class="flex gap-3 text-xs">
                  <span class={`text-[10px] font-bold px-2 py-0.5 rounded-full shrink-0 self-start mt-0.5 ${niveau === 'Élevé' ? 'bg-red-100 text-red-700' : niveau === 'Moyen' ? 'bg-orange-100 text-orange-700' : 'bg-green-100 text-green-700'}`}>{niveau}</span>
                  <div>
                    <p class="font-medium text-[#1A1A1A]">{facteur}</p>
                    <p class="text-[#1A1A1A]/50 mt-0.5">{impact}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-[#1A4B8F]/8 border border-[#1A4B8F]/15 rounded-2xl p-5">
            <h3 class="font-semibold text-[#1A4B8F] mb-2 text-sm">Réduction par le ramonage</h3>
            <p class="text-xs text-[#1A1A1A]/60 leading-relaxed">Selon l'ADEME, un ramonage annuel par un artisan certifié réduit les émissions de PM2.5 d'un foyer de bois de 40 à 65 %. L'entretien complet (corps de chauffe + conduit) est la mesure la plus efficace pour améliorer la qualité de l'air intérieur.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Étanchéité conduit -->
  <section class="py-16 px-6 md:px-10 border-b border-[#EEEEEE]">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-10">
        <p class="text-[11px] font-semibold tracking-widest uppercase text-[#2563EB] mb-3">NF EN 1443 · NF DTU 24.1</p>
        <h2 class="text-2xl md:text-3xl font-extrabold text-[#1A1A1A]">L'étanchéité du conduit :<br />la barrière invisible qui vous protège</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            titre: 'Classe de pression NF EN 1443',
            desc: 'La norme classe les conduits en N1 (pression négative — tirage naturel) et P1 (pression positive — poêles à granulés, chaudières à condensation). Un conduit P1 fissuré injecte des gaz de combustion dans les parois.',
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
            color: '#1A4B8F',
          },
          {
            titre: 'Fissures et infiltrations',
            desc: 'Un conduit en brique ou en béton cellulaire peut se fissurer sous l\'effet des cycles thermiques. Ces microfissures laissent passer le CO et les goudrons vers les murs et les pièces adjacentes. Seule une inspection caméra HD les révèle.',
            icon: 'M15 10l4.553-2.069A1 1 0 0121 8.868V15.13a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z',
            color: '#E65100',
          },
          {
            titre: 'Test d\'étanchéité fumigène',
            desc: 'Le test au fumigène (NF DTU 24.1 article 9.2) injecte une fumée colorée sous pression dans le conduit. Toute fuite apparaît immédiatement. Obligatoire après travaux de tubage ou chemisage, recommandé lors de tout changement d\'appareil.',
            icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
            color: '#1A4B8F',
          },
        ].map(({ titre, desc, icon, color }) => (
          <div class="bg-white border border-[#EEEEEE] rounded-2xl p-6 hover:shadow-md transition-shadow">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-4" style={`background: ${color}12;`}>
              <svg class="w-5 h-5" style={`color: ${color};`} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
              </svg>
            </div>
            <h3 class="text-sm font-bold text-[#1A1A1A] mb-3">{titre}</h3>
            <p class="text-xs text-[#1A1A1A]/55 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Prévention & CTA -->
  <section class="py-16 px-6 md:px-10 bg-[#FAFAFA] border-b border-[#EEEEEE]">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <p class="text-[11px] font-semibold tracking-widest uppercase text-[#2563EB] mb-3">Ce que vous pouvez faire</p>
          <h2 class="text-2xl font-extrabold text-[#1A1A1A] mb-5">Prévention en 5 gestes essentiels</h2>
          <div class="space-y-3">
            {[
              { n: '1', geste: 'Ramonage annuel certifié', detail: 'Par un artisan qualifié COSTIC — certificat à conserver pour assurance et RSD 13.' },
              { n: '2', geste: 'Brûler du bois sec (< 20 % d\'humidité)', detail: 'Séchage minimum 2 ans. Label "Bois Énergie" recommandé. Bois humide = CO × 3.' },
              { n: '3', geste: 'Ventilation suffisante', detail: 'Un foyer nécessite 7 m³/h d\'air de combustion par kW. Veillez aux entrées d\'air.' },
              { n: '4', geste: 'Détecteur de CO normé EN 50291', detail: 'Obligatoire avec détecteur certifié. Placez-le à 1,5 m de hauteur, proche de la chambre.' },
              { n: '5', geste: 'Inspection caméra tous les 3-5 ans', detail: 'Pour détecter fissures et dépôts invisibles à l\'œil nu dans les conduits anciens.' },
            ].map(({ n, geste, detail }) => (
              <div class="flex gap-4 bg-white border border-[#EEEEEE] rounded-xl p-4">
                <div class="w-7 h-7 rounded-full bg-[#2563EB] text-white flex items-center justify-center text-xs font-bold shrink-0">{n}</div>
                <div>
                  <p class="text-sm font-semibold text-[#1A1A1A]">{geste}</p>
                  <p class="text-xs text-[#1A1A1A]/50 mt-0.5">{detail}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-[#1A4B8F] rounded-2xl p-8 text-white">
          <h2 class="text-xl font-bold mb-3">Contrôle qualité de l'air<br />de votre installation</h2>
          <p class="text-sm text-white/65 leading-relaxed mb-6">
            Je réalise un diagnostic complet : état du conduit, mesure de tirage, test d'étanchéité et inspection caméra si nécessaire. Rapport technique remis le jour même.
          </p>
          <div class="space-y-3">
            <a href="tel:+33664729600" class="flex items-center justify-center gap-2 bg-[#2563EB] text-white font-bold text-sm px-6 py-3.5 rounded-xl hover:bg-[#1D4ED8] transition-colors shadow-lg shadow-[#2563EB]/25">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              06 64 72 96 00
            </a>
            <a href="/diagnostic-securite" class="flex items-center justify-center gap-2 bg-white/8 text-white text-sm font-semibold px-6 py-3.5 rounded-xl hover:bg-white/12 border border-white/15 transition-colors">
              Faire le diagnostic sécurité gratuit →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-6 md:px-10">
    <div class="max-w-3xl mx-auto">
      <p class="text-[11px] font-semibold tracking-widest uppercase text-[#2563EB] mb-3 text-center">Questions fréquentes</p>
      <h2 class="text-2xl font-extrabold text-[#1A1A1A] mb-8 text-center">CO, PM2.5 & qualité de l'air — FAQ</h2>
      <div class="space-y-3" itemscope itemtype="https://schema.org/FAQPage">
        {faqSchema.mainEntity.map(item => (
          <details class="group bg-white border border-[#EEEEEE] rounded-xl overflow-hidden" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <summary class="flex items-center justify-between gap-4 p-5 cursor-pointer select-none list-none" itemprop="name">
              <span class="text-sm font-semibold text-[#1A1A1A]">{item.name}</span>
              <svg class="w-4 h-4 shrink-0 text-[#2563EB] transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p class="text-sm text-[#1A1A1A]/60 leading-relaxed" itemprop="text">{item.acceptedAnswer.text}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>
