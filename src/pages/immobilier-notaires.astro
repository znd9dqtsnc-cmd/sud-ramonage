---
import Layout from '../layouts/Layout.astro';
const siteUrl = 'https://www.sud-ramonage.fr';
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/immobilier-notaires#service`,
  name: 'Audit Fumisterie Pré-Vente — Immobilier & Notaires',
  description: 'Pack expertise technique fumisterie pré-vente pour transactions immobilières : diagnostic conduit, test fumigène, avis technique COSTIC. Bouches-du-Rhône.',
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  serviceType: 'Audit fumisterie diagnostic immobilier pré-vente',
  areaServed: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
  offers: {
    '@type': 'Offer',
    priceSpecification: { '@type': 'PriceSpecification', description: 'Pack diagnostic fumisterie — à partir de 150 € selon conduits', priceCurrency: 'EUR' },
  },
};
const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Immobilier & Notaires', url: '/immobilier-notaires' },
];
---
<Layout
  title="Audit Fumisterie Pré-Vente — Immobilier & Notaires | Sud Ramonage"
  description="Pack audit fumisterie pré-vente : diagnostic conduit certifié COSTIC, test fumigène, rapport pour notaire et assurance. Sécurisez votre transaction. Bouches-du-Rhône."
  breadcrumbs={breadcrumbs}
  pageSchema={serviceSchema}
>

  <section class="bg-gradient-to-br from-[#7A3520] to-[#0D2D5A] text-white pt-28 pb-16">
    <div class="max-w-4xl mx-auto px-6 md:px-10">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-white/40 mb-6">
        <a href="/" class="hover:text-white/70">Accueil</a><span>/</span><span class="text-white/60">Immobilier & Notaires</span>
      </nav>
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 rounded-full px-3 py-1.5 text-[11px] text-white/70 mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-[#C0622F]"></span>
        Espace Professionnel — Transactions Immobilières
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-5">
        Audit Fumisterie Pré-Vente<br /><span class="text-[#C0622F]">Pour Agents, Notaires & Acheteurs</span>
      </h1>
      <p class="text-base text-white/70 max-w-2xl leading-relaxed mb-8">
        Un bien avec une cheminée, un poêle ou une chaudière est soumis à des obligations réglementaires précises. Un conduit de fumée en mauvais état peut bloquer une vente, engager la responsabilité du vendeur, ou entraîner un refus d'assurance pour l'acquéreur. Mon rapport d'audit certifié COSTIC sécurise la transaction pour toutes les parties.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#C0622F] text-white text-sm font-bold px-5 py-3 rounded-xl hover:bg-[#A85228] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          RDV Audit — 06 64 72 96 00
        </a>
        <a href="mailto:majeo@ik.me" class="inline-flex items-center gap-2 bg-white/10 border border-white/20 text-white/80 text-sm px-5 py-3 rounded-xl hover:bg-white/15 transition-colors">
          Dossier par email
        </a>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-4xl mx-auto px-6 md:px-10 space-y-12">

      <div>
        <h2 class="text-2xl font-bold mb-5">Le Pack Audit Fumisterie Pré-Vente</h2>
        <div class="space-y-4">
          {[
            { n: '1', t: 'Inspection visuelle complète', d: 'Foyer, appareil, raccordement, sortie en toiture. Identification des non-conformités visibles.' },
            { n: '2', t: 'Inspection caméra endoscopique', d: 'Caméra HD introduite dans le conduit sur toute sa longueur. Détection des fissures, effondrements partiels, dépôts anormaux. Photos et vidéo transmises.' },
            { n: '3', t: 'Test fumigène d\'étanchéité', d: 'Révèle les fuites invisibles du conduit (joints dégradés, fissures de boisseau). Indispensable pour valider l\'absence de risque CO.' },
            { n: '4', t: 'Test de vacuité', d: 'Confirmation de l\'absence de toute obstruction. Obligatoire selon le RSD 13.' },
            { n: '5', t: 'Rapport technique certifié', d: 'Document complet avec photos, résultats des tests, conclusions et recommandations de travaux si nécessaire. Signé par un artisan certifié COSTIC.' },
          ].map(({ n, t, d }) => (
            <div class="flex gap-4 p-4 bg-[#FAFAFA] border border-[#EEEEEE] rounded-xl">
              <div class="w-8 h-8 rounded-full bg-[#7A3520] text-white text-sm font-bold flex items-center justify-center shrink-0">{n}</div>
              <div>
                <p class="text-sm font-semibold text-[#1A1A1A] mb-1">{t}</p>
                <p class="text-sm text-[#1A1A1A]/55 leading-relaxed">{d}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        {[
          { titre: 'Vendeur', detail: 'Anticipe les problèmes avant la mise en vente. Évite la décote ou l\'annulation de promesse de vente liée à un conduit non conforme. Démontre la bonne foi et le respect des obligations légales.' },
          { titre: 'Acquéreur', detail: 'Connaît exactement l\'état du conduit avant signature. Peut négocier en connaissance de cause ou exiger des travaux de mise aux normes dans le compromis.' },
          { titre: 'Agent & Notaire', detail: 'Document technique certifié COSTIC à intégrer au dossier de vente. Réduit le risque de vice caché lié à l\'installation de chauffage. Réponse rapide pour ne pas bloquer la transaction.' },
        ].map(({ titre, detail }) => (
          <div class="bg-[#FAFAFA] border border-[#EEEEEE] rounded-xl p-5">
            <p class="text-sm font-bold text-[#7A3520] mb-2">{titre}</p>
            <p class="text-xs text-[#1A1A1A]/55 leading-relaxed">{detail}</p>
          </div>
        ))}
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6">
        <div class="flex gap-3">
          <svg class="w-5 h-5 text-amber-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <div>
            <p class="text-sm font-bold text-amber-900 mb-1">Vice caché : la responsabilité du vendeur est engagée</p>
            <p class="text-sm text-amber-800/75 leading-relaxed">Un conduit de fumée dont le vendeur connaissait les défauts sans les déclarer constitue un vice caché au sens de l'article 1641 du Code civil. La jurisprudence reconnaît régulièrement la responsabilité du vendeur en cas d'intoxication au CO ou d'incendie de conduit survenu après la vente. Le rapport d'audit fumisterie pré-vente protège toutes les parties.</p>
          </div>
        </div>
      </div>

      <div class="bg-[#7A3520] rounded-2xl p-8 text-white">
        <h2 class="text-xl font-bold mb-3">Audit pré-vente sous 5 jours ouvrés</h2>
        <p class="text-sm text-white/75 mb-6">Je m'adapte au calendrier des transactions. Rapport transmis par email en format PDF signé, prêt à intégrer au dossier notarial.</p>
        <div class="flex flex-wrap gap-3">
          <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-white text-[#7A3520] text-sm font-bold px-5 py-3 rounded-xl hover:bg-white/90 transition-colors">06 64 72 96 00</a>
          <a href="mailto:majeo@ik.me" class="inline-flex items-center gap-2 bg-white/15 border border-white/25 text-white text-sm px-5 py-3 rounded-xl hover:bg-white/20 transition-colors">majeo@ik.me</a>
        </div>
      </div>

      <nav aria-label="Services associés" class="pt-8 border-t border-[#EEEEEE]">
        <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-4">Voir aussi</p>
        <ul class="flex flex-wrap gap-3">
          {[
            { href: '/inspection-camera', label: 'Inspection caméra HD' },
            { href: '/test-fumigene', label: 'Test fumigène étanchéité' },
            { href: '/vacuite', label: 'Test de vacuité' },
            { href: '/tubage', label: 'Tubage mise aux normes' },
            { href: '/reglementation', label: 'Obligations légales RSD 13' },
          ].map(({ href, label }) => (
            <li><a href={href} class="text-xs text-[#1A1A1A]/50 border border-[#EEEEEE] rounded-lg px-3 py-1.5 hover:text-[#C0622F] hover:border-[#C0622F]/30 transition-colors">{label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </section>
</Layout>
