---
import Layout from '../layouts/Layout.astro';
import COSTICBadge from '../components/COSTICBadge.astro';
const siteUrl = 'https://www.sud-ramonage.fr';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/aide-vente-immobilier#service`,
  name: 'Synergie Diagnostics Immobiliers — Audit Fumisterie Certifié COSTIC',
  alternateName: 'Complément DPE fumisterie — Vérification conduit vente maison',
  description: 'Audit technique de conduit et d\'appareil à combustion pour toute vente immobilière dans les Bouches-du-Rhône. Attestation COSTIC, rapport opposable, contre-audit disponible pour agents et diagnostiqueurs.',
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  serviceType: 'Audit fumisterie vente immobilière — Conformité cheminée notaire',
  areaServed: [
    { '@type': 'City', name: 'Marseille', postalCode: '13001' },
    { '@type': 'City', name: 'Aix-en-Provence', postalCode: '13100' },
    { '@type': 'City', name: 'Martigues', postalCode: '13500' },
    { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
  ],
  offers: {
    '@type': 'Offer',
    priceCurrency: 'EUR',
    priceSpecification: {
      '@type': 'PriceSpecification',
      minPrice: '120',
      maxPrice: '190',
      priceCurrency: 'EUR',
    },
  },
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  '@id': `${siteUrl}/aide-vente-immobilier#guide`,
  name: 'Vendre sa maison avec cheminée : les 5 points de contrôle obligatoires',
  description: 'Guide complet pour sécuriser la vente d\'un bien immobilier équipé d\'une cheminée, d\'un insert ou d\'un poêle. Établi par un expert certifié COSTIC.',
  estimatedCost: { '@type': 'MonetaryAmount', currency: 'EUR', value: '120' },
  totalTime: 'PT2H',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Vérification conduit vente maison — état général',
      text: 'Inspection visuelle et mécanique du conduit de fumée : propreté, absence de fissures, section libre, conformité avec le type d\'appareil raccordé. Nécessaire pour la vente maison avec cheminée à Marseille, Aix-en-Provence et tout le 13.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Conformité cheminée notaire — raccordement et distances de sécurité',
      text: 'Contrôle des distances de sécurité entre le conduit et les matériaux combustibles (NF DTU 24.1), du type de raccordement et de l\'adéquation entre l\'appareil et le conduit. Ce point est souvent négligé dans les diagnostics DPE.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Ramonage certifié et attestation officielle',
      text: 'Ramonage mécanique par un artisan certifié COSTIC, avec remise d\'un certificat officiel conforme au Règlement Sanitaire Départemental 13. Ce document est exigible par l\'assureur de l\'acquéreur.',
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Complément DPE fumisterie — rendement et étanchéité',
      text: 'Le DPE évalue le logement de façon théorique. L\'audit de fumisterie mesure le tirage réel, l\'étanchéité du conduit et le rendement effectif de l\'appareil. Ces données complètent le DPE avec des mesures physiques.',
    },
    {
      '@type': 'HowToStep',
      position: 5,
      name: 'Rapport technique opposable remis au notaire',
      text: 'Rapport PDF complet avec photos datées, mesures, état de conformité et recommandations. Transmissible directement au notaire pour inclusion dans le dossier de vente. Protège vendeur et acquéreur.',
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Vérification conduit vente maison Marseille : qu\'est-ce qui est obligatoire ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Pour la vente d\'une maison à Marseille ou dans les Bouches-du-Rhône, le RSD 13 impose un ramonage annuel. En cas de vice caché lié au conduit, le vendeur peut être condamné sur la base de l\'article 1641 du Code civil. Un audit de fumisterie certifié COSTIC protège le vendeur en établissant l\'état connu de l\'installation.',
      },
    },
    {
      '@type': 'Question',
      name: 'Conformité cheminée notaire Aix-en-Provence : que doit-on fournir ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Il n\'existe pas de diagnostic fumisterie légalement obligatoire comme le DPE, mais un rapport d\'audit COSTIC constitue une preuve opposable au notaire. Fournir ce document à la signature chez le notaire à Aix-en-Provence protège le vendeur et rassure l\'acheteur sur la conformité de l\'installation.',
      },
    },
    {
      '@type': 'Question',
      name: 'Quelle est la différence entre un DPE et un complément DPE fumisterie ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Le DPE (Diagnostic de Performance Énergétique) évalue la consommation d\'énergie de façon théorique et visuelle, sans démontage ni mesure des conduits. L\'audit de fumisterie Sud Ramonage est un contrôle technique et physique : mesure du tirage, inspection caméra, état réel du conduit, étanchéité. C\'est le complément DPE fumisterie que les acheteurs et notaires de plus en plus souhaitent.',
      },
    },
    {
      '@type': 'Question',
      name: 'Un agent immobilier peut-il commander un contre-audit de conduit avant la signature ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Oui. Sud Ramonage propose un service de contre-audit spécifiquement conçu pour les agents immobiliers et diagnostiqueurs qui ont un doute sur la conformité d\'un conduit avant la signature du compromis ou de l\'acte authentique. Le rapport est disponible sous 24h.',
      },
    },
    {
      '@type': 'Question',
      name: 'Un vice caché sur une cheminée peut-il annuler une vente immobilière ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Oui. L\'article 1641 du Code civil prévoit que le vendeur répond des vices cachés, même s\'il ne les connaissait pas. Un conduit fissuré, obstrué ou non conforme aux normes de sécurité peut constituer un vice caché. Une action en garantie des vices cachés peut mener à une réduction du prix voire à l\'annulation de la vente.',
      },
    },
  ],
};

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Aide à la Vente Immobilière', url: '/aide-vente-immobilier' },
];

const pointsControle = [
  {
    n: '01',
    titre: 'État général du conduit',
    keywords: 'Vérification conduit vente maison Marseille',
    desc: 'Inspection visuelle et mécanique complète : propreté, section libre, absence de fissures. Photos datées.',
    risque: 'Vice caché n°1 — conduit fissuré non déclaré.',
    color: '#E65100',
  },
  {
    n: '02',
    titre: 'Raccordement & distances de sécurité',
    keywords: 'Conformité cheminée notaire Aix-en-Provence',
    desc: 'Distances entre conduit et matériaux combustibles (NF DTU 24.1 §4.2). Adéquation appareil/conduit.',
    risque: 'Risque incendie. Non-conformité fréquente dans l\'habitat ancien.',
    color: '#E65100',
  },
  {
    n: '03',
    titre: 'Attestation de ramonage certifié',
    keywords: 'Attestation ramonage vente immobilière Bouches-du-Rhône',
    desc: 'Ramonage mécanique par artisan COSTIC. Certificat officiel conforme RSD 13. Exigé par les assureurs.',
    risque: 'Sans certificat récent : couverture assurance incendie à risque.',
    color: '#1A4B8F',
  },
  {
    n: '04',
    titre: 'Complément DPE fumisterie',
    keywords: 'Complément DPE fumisterie Bouches-du-Rhône',
    desc: 'Mesure réelle du tirage et de l\'étanchéité. Rendement effectif de l\'appareil. Données physiques vs théoriques du DPE.',
    risque: 'DPE seul ne détecte pas les fissures ni l\'encrassement du conduit.',
    color: '#1A4B8F',
  },
  {
    n: '05',
    titre: 'Rapport opposable pour le notaire',
    keywords: 'Rapport fumisterie notaire vente maison 13',
    desc: 'Rapport PDF signé, photos datées, état de conformité complet. Transmissible au notaire pour dossier de vente.',
    risque: 'Protège le vendeur contre l\'action en garantie des vices cachés.',
    color: '#1A4B8F',
  },
];
---

<Layout
  title="Aide à la Vente Immobilière — Conformité Cheminée Notaire Marseille Aix | Sud Ramonage"
  description="Vérification conduit vente maison Marseille, conformité cheminée notaire Aix, complément DPE fumisterie. Audit COSTIC certifié, rapport opposable 24h. Espace partenaires diagnostiqueurs & agents immobiliers."
  breadcrumbs={breadcrumbs}
  pageSchema={serviceSchema}
>

  <!-- ═══ HERO ═══ -->
  <section class="relative bg-[#1A1A1A] text-white pt-28 pb-0 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#1A1A1A] via-[#1A2A1A] to-[#1A1A1A] opacity-90"></div>
    <!-- Grille décorative -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative max-w-6xl mx-auto px-6 md:px-10 pb-16">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-white/35 mb-8">
        <a href="/" class="hover:text-white/60 transition-colors">Accueil</a>
        <span>/</span>
        <span class="text-white/55">Aide à la Vente Immobilière</span>
      </nav>

      <!-- Tags pro -->
      <div class="flex flex-wrap gap-2 mb-6">
        {['Agents immobiliers', 'Notaires', 'Diagnostiqueurs', 'Vendeurs'].map(tag => (
          <span class="text-[10px] font-bold uppercase tracking-widest bg-white/8 text-white/55 border border-white/12 px-3 py-1.5 rounded-full">{tag}</span>
        ))}
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-end">
        <div>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight leading-[1.08] mb-5">
            Vous vendez un bien<br />
            avec cheminée ?<br />
            <span class="text-[#2563EB]">Ne prenez aucun risque juridique.</span>
          </h1>
          <p class="text-base text-white/60 leading-relaxed mb-8 max-w-lg">
            Un conduit non conforme peut bloquer une vente, déclencher une action en garantie des vices cachés ou invalider la couverture incendie de l'acquéreur. L'audit de fumisterie certifié COSTIC est votre filet de sécurité.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="tel:+33664729600" class="inline-flex items-center justify-center gap-2.5 bg-[#2563EB] hover:bg-[#1D4ED8] text-white text-sm font-bold px-7 py-4 rounded-xl shadow-lg shadow-[#2563EB]/25 transition-all duration-150">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Demander un audit — 06 64 72 96 00
            </a>
            <a href="#partenaires" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/15 border border-white/20 text-white text-sm font-semibold px-6 py-4 rounded-xl transition-all duration-150">
              Espace partenaires →
            </a>
          </div>
        </div>

        <!-- Stat cards flottantes -->
        <div class="grid grid-cols-2 gap-3 pb-0">
          {[
            { val: 'Art. 1641', label: 'Code civil — vice caché', sub: 'Responsabilité vendeur engagée', icon: '⚖' },
            { val: '24 h', label: 'Délai rapport', sub: 'Compatible agenda notarial', icon: '📋' },
            { val: 'COSTIC', label: 'Certification officielle', sub: 'Rapport opposable', icon: '✓' },
            { val: '+15 %', label: 'Rendement retrouvé', sub: 'Argument DPE + valorisation', icon: '↑' },
          ].map(({ val, label, sub, icon }) => (
            <div class="bg-white/8 border border-white/10 rounded-2xl p-4 backdrop-blur-sm">
              <div class="text-2xl mb-2">{icon}</div>
              <p class="text-lg font-extrabold text-white leading-none mb-1">{val}</p>
              <p class="text-[11px] font-semibold text-[#2563EB] mb-1">{label}</p>
              <p class="text-[10px] text-white/35">{sub}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Vague de transition -->
    <div class="relative h-12 overflow-hidden">
      <svg viewBox="0 0 1440 48" class="absolute bottom-0 w-full" preserveAspectRatio="none">
        <path fill="white" d="M0,48 C360,0 1080,0 1440,48 L1440,48 L0,48 Z"/>
      </svg>
    </div>
  </section>

  <!-- ═══ SECTION 1 — AIDE À LA VENTE ═══ -->
  <section class="py-20 px-6 md:px-10 border-b border-[#EEEEEE]">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-14 items-start">
        <div>
          <p class="text-[11px] font-bold uppercase tracking-widest text-[#2563EB] mb-3">Valorisation & sécurité juridique</p>
          <h2 class="text-2xl md:text-3xl font-extrabold text-[#1A1A1A] mb-5 leading-tight">
            Comment l'attestation COSTIC<br />valorise votre bien à la vente
          </h2>
          <p class="text-sm text-[#1A1A1A]/60 leading-relaxed mb-6">
            Dans un marché immobilier exigeant, une installation de chauffage <strong class="text-[#1A1A1A]">documentée et conforme</strong> est un argument de vente. L'attestation COSTIC va au-delà du simple ramonage : elle certifie l'état technique complet du conduit et de l'appareil.
          </p>

          <div class="space-y-4">
            {[
              {
                titre: 'Argument de vente concret',
                desc: 'Un dossier complet (attestation + rapport caméra + certificat RSD 13) démontre à l\'acheteur que l\'installation est sûre, entretenue et conforme. Moins de négociation à la baisse sur les travaux à prévoir.',
                icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
                color: '#1A4B8F',
              },
              {
                titre: 'Impact positif sur le DPE',
                desc: 'Un insert ou poêle à bois avec conduit propre et étanche affiche un rendement réel de 75-85 %. Ce gain de performance améliore l\'étiquette énergétique et peut faire passer le bien d\'une classe F à E — valeur ajoutée de plusieurs milliers d\'euros.',
                icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
                color: '#E65100',
              },
              {
                titre: 'Protection juridique article 1641',
                desc: 'L\'attestation COSTIC établit formellement l\'état de l\'installation à la date de la vente. Si un problème survient après, le vendeur peut prouver qu\'il a fait vérifier et documenter l\'installation — ce qui exclut la mauvaise foi nécessaire à l\'action en vice caché.',
                icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3',
                color: '#1A4B8F',
              },
            ].map(({ titre, desc, icon, color }) => (
              <div class="flex gap-4 bg-[#FAFAFA] border border-[#EEEEEE] rounded-xl p-5 hover:border-[#2563EB]/20 transition-colors">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 mt-0.5" style={`background: ${color}12;`}>
                  <svg class="w-5 h-5" style={`color: ${color};`} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-bold text-[#1A1A1A] mb-1.5">{titre}</p>
                  <p class="text-xs text-[#1A1A1A]/55 leading-relaxed">{desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Témoignage / Cas type -->
        <div class="space-y-5">
          <div class="bg-[#1A4B8F] rounded-2xl p-8 text-white">
            <p class="text-[10px] font-bold uppercase tracking-widest text-white/35 mb-4">Cas typique — Vente Marseille 7e</p>
            <blockquote class="text-sm text-white/70 leading-relaxed mb-5 italic">
              "L'acheteur voulait retenir 8 000 € sur le prix pour les travaux de cheminée. Après l'audit COSTIC qui montrait que tout était conforme, la négociation a été close. Le rapport a été versé au dossier du notaire."
            </blockquote>
            <p class="text-xs text-white/40">Agent immobilier — Transaction 550 000 € · Marseille 7e</p>
          </div>

          <div class="bg-[#1A4B8F]/8 border border-[#1A4B8F]/15 rounded-2xl p-6">
            <p class="text-sm font-bold text-[#1A4B8F] mb-3">Ce que contient le dossier vendeur complet</p>
            <div class="space-y-2.5">
              {[
                'Certificat de ramonage conforme RSD 13',
                'Rapport technique d\'inspection du conduit',
                'Photos datées de l\'intérieur du conduit',
                'État de conformité NF DTU 24.1',
                'Mesures de tirage et d\'étanchéité',
                'Carnet de Santé du Conduit™ transmissible',
              ].map(item => (
                <div class="flex gap-2.5 text-xs text-[#1A1A1A]/65">
                  <span class="text-[#1A4B8F] font-bold shrink-0">✓</span>
                  <span>{item}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-[#2563EB] rounded-2xl p-6 text-white text-center">
            <p class="text-2xl font-extrabold mb-1">120 – 190 €</p>
            <p class="text-sm text-white/75 mb-4">Le coût d'un audit complet — négligeable dans une transaction immobilière</p>
            <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-white text-[#2563EB] font-bold text-sm px-6 py-3 rounded-xl hover:bg-white/90 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Commander l'audit
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SECTION 2 — LE DIAGNOSTIC MANQUANT ═══ -->
  <section class="py-20 px-6 md:px-10 bg-[#FAFAFA] border-b border-[#EEEEEE]">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[#2563EB] mb-3">Complément DPE fumisterie</p>
        <h2 class="text-2xl md:text-3xl font-extrabold text-[#1A1A1A] mb-4">
          Le Diagnostic Manquant
        </h2>
        <p class="text-sm text-[#1A1A1A]/55 max-w-2xl mx-auto leading-relaxed">
          Le DPE est obligatoire mais n'examine pas les conduits. L'audit de fumisterie est le complément technique qu'un DPE ne peut pas fournir.
        </p>
      </div>

      <!-- Tableau comparatif -->
      <div class="bg-white border border-[#EEEEEE] rounded-2xl overflow-hidden shadow-sm">
        <div class="grid grid-cols-3">
          <!-- En-têtes -->
          <div class="p-5 border-b border-[#EEEEEE] bg-[#FAFAFA]">
            <p class="text-xs font-bold uppercase tracking-widest text-[#1A1A1A]/40">Critère</p>
          </div>
          <div class="p-5 border-b border-l border-[#EEEEEE] bg-[#EFF6FF]">
            <p class="text-xs font-bold text-[#1A1A1A]/50 mb-1">DPE</p>
            <p class="text-[10px] text-[#1A1A1A]/35">Diagnostic de Performance Énergétique</p>
          </div>
          <div class="p-5 border-b border-l border-[#EEEEEE] bg-[#FFF8F6]">
            <div class="flex items-center gap-2">
              <img src="/images/costic-logo.png" alt="Logo officiel COSTIC - Certification ramonage et fumisterie Sud Ramonage" width="56" style="display:block; width:56px; height:auto; flex-shrink:0;" loading="lazy" />
              <div>
                <p class="text-xs font-bold text-[#1A1A1A]">Audit Fumisterie Sud Ramonage</p>
                <p class="text-[10px] text-[#1A1A1A]/35">Certifié COSTIC + Qualibat 6521</p>
              </div>
            </div>
          </div>

          {[
            { critere: 'Nature de l\'examen', dpe: 'Visuel et théorique', audit: 'Technique et physique (mesures réelles)' },
            { critere: 'Conduits de fumée', dpe: '❌ Non examinés', audit: '✓ Inspection complète + caméra HD' },
            { critere: 'Mesure du tirage', dpe: '❌ Non mesuré', audit: '✓ Mesure physique du tirage' },
            { critere: 'Étanchéité conduit', dpe: '❌ Non testée', audit: '✓ Test d\'étanchéité disponible' },
            { critere: 'État du bistre / encrassement', dpe: '❌ Non évalué', audit: '✓ Détection et quantification' },
            { critere: 'Conformité RSD 13', dpe: '❌ Non vérifiée', audit: '✓ Vérification complète + certificat' },
            { critere: 'Photos datées et géolocalisées', dpe: '❌', audit: '✓ Incluses dans le rapport' },
            { critere: 'Rapport opposable notaire', dpe: '✓ Obligatoire', audit: '✓ Rapport PDF signé COSTIC' },
            { critere: 'Protection vice caché art. 1641', dpe: 'Partielle', audit: '✓ Couverture technique complète' },
          ].map(({ critere, dpe, audit }) => (
            <div class="contents">
              <div class="p-4 border-b border-[#EEEEEE]">
                <p class="text-xs font-medium text-[#1A1A1A]/65">{critere}</p>
              </div>
              <div class={`p-4 border-b border-l border-[#EEEEEE] ${dpe.startsWith('❌') ? 'bg-red-50/40' : ''}`}>
                <p class={`text-xs ${dpe.startsWith('❌') ? 'text-red-600 font-medium' : 'text-[#1A1A1A]/55'}`}>{dpe}</p>
              </div>
