---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';

const siteUrl = 'https://www.sud-ramonage.fr';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/pro-syndics#service`,
  name: 'Ramonage professionnel — CHR, syndics, immobilier',
  description: "Ramonage et entretien conduits pour professionnels CHR, restauration, syndics de copropriété, immobilier. Contrats annuels, rapports consolidés. Bouches-du-Rhône.",
  provider: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
  serviceType: 'Ramonage professionnel CHR et syndics',
  areaServed: { '@type': 'AdministrativeArea', name: 'Bouches-du-Rhône' },
  offers: { '@type': 'Offer', priceSpecification: { '@type': 'PriceSpecification', description: 'Devis sur mesure selon installation et volume', priceCurrency: 'EUR' } },
};

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Pro & Syndics', url: '/pro-syndics' },
];
---

<Layout
  title="Ramonage Pro & Syndics — CHR, Restauration, Immobilier | Sud Ramonage Martigues"
  description="Ramonage professionnel pour CHR, restaurants, boulangeries, syndics de copropriété et immobilier. Contrats annuels multi-sites, rapports consolidés. Bouches-du-Rhône."
  canonical={`${siteUrl}/pro-syndics`}
  breadcrumbs={breadcrumbs}
  pageSchema={pageSchema}
>

  <!-- HERO -->
  <section class="pt-28 pb-14 px-6 md:px-10 bg-[#1E293B] text-white">
    <div class="max-w-4xl mx-auto">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-white/35 mb-6">
        <a href="/" class="hover:text-white/70 transition-colors">Accueil</a>
        <span>/</span>
        <span class="text-white/60">Pro & Syndics</span>
      </nav>
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 rounded-full px-3 py-1.5 text-[11px] text-white/70 mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-[#F97316]"></span>
        Espace Professionnel — CHR &amp; Immobilier
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-5">
        Ramonage <span class="text-[#F97316]">Pro & Syndics</span>
      </h1>
      <p class="text-base text-white/65 max-w-2xl leading-relaxed mb-8">
        Professionnels de la restauration, CHR, syndics de copropriété, gestionnaires immobiliers : Sud Ramonage propose des contrats annuels adaptés à vos contraintes — multi-sites, planification flexible, rapports consolidés et conformité réglementaire garantie.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#F97316] hover:bg-[#EA580C] text-white text-sm font-bold px-6 py-3 rounded-xl transition-colors">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Devis professionnel — 06 64 72 96 00
        </a>
        <a href="#syndics" class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/15 border border-white/20 text-white text-sm font-medium px-6 py-3 rounded-xl transition-colors">
          Syndics & Immobilier ↓
        </a>
      </div>
    </div>
  </section>

  <!-- NAV ANCRES -->
  <nav class="sticky top-16 z-30 bg-white border-b border-[#F3F4F6] shadow-sm">
    <div class="max-w-4xl mx-auto px-6 md:px-10">
      <ul class="flex gap-1 py-2">
        <li><a href="#pro" class="whitespace-nowrap px-4 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#F97316] hover:bg-[#FFF7ED] transition-colors">Professionnels & CHR</a></li>
        <li><a href="#syndics" class="whitespace-nowrap px-4 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#F97316] hover:bg-[#FFF7ED] transition-colors">Syndics & Immobilier</a></li>
      </ul>
    </div>
  </nav>

  <!-- SECTION PRO -->
  <section id="pro" class="py-16 px-6 md:px-10 bg-[#FFFFFF]">
    <div class="max-w-4xl mx-auto">
      <div class="mb-10">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[#F97316] mb-3">Professionnels & CHR</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1E293B] mb-4">
          Restauration, Boulangeries & Hôtellerie
        </h2>
        <p class="text-sm text-[#1A1A1A]/60 leading-relaxed max-w-2xl">
          Les établissements CHR (cafés, hôtels, restaurants) cumulent les contraintes les plus sévères en matière de conduits de fumée : fréquence d'utilisation extrême, températures élevées, accumulation rapide de bistre. La réglementation ERP impose des contrôles plus fréquents.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white border border-[#F3F4F6] rounded-2xl p-6 space-y-4">
          <h3 class="text-base font-bold text-[#1E293B]">Fours à pizza & boulangeries</h3>
          <p class="text-sm text-[#1A1A1A]/65 leading-relaxed">
            Un four à pizza à bois fonctionne 10 à 14h par jour. Le conduit accumule du bistre 4 à 6 fois plus vite qu'une cheminée domestique. La réglementation ERP impose un ramonage minimum trimestriel, et après chaque période de forte activité.
          </p>
          <ul class="space-y-2 text-xs text-[#1A1A1A]/60">
            <li class="flex gap-2"><span class="text-[#F97316] font-bold">→</span>Ramonage au hérisson + aspiration haute puissance</li>
            <li class="flex gap-2"><span class="text-[#F97316] font-bold">→</span>Traitement débistreur si accumulation sévère</li>
            <li class="flex gap-2"><span class="text-[#F97316] font-bold">→</span>Contrôle de la voûte et des parois réfractaires</li>
            <li class="flex gap-2"><span class="text-[#F97316] font-bold">→</span>Rapport d'intervention pour inspection DREAL/DDPP</li>
          </ul>
        </div>

        <div class="bg-white border border-[#F3F4F6] rounded-2xl p-6 space-y-4">
          <h3 class="text-base font-bold text-[#1E293B]">Hottes professionnelles & ventilation</h3>
          <p class="text-sm text-[#1A1A1A]/65 leading-relaxed">
            Les hottes de cuisine professionnelle accumulent des graisses hautement inflammables dans les conduits. L'arrêté du 25 juin 1980 (ERP) et le code du travail imposent leur entretien régulier. Un conduit de hotte encrassé est l'une des premières causes d'incendie en restauration.
          </p>
          <ul class="space-y-2 text-xs text-[#1A1A1A]/60">
            <li class="flex gap-2"><span class="text-[#F97316] font-bold">→</span>Dégraissage et nettoyage conduits de hotte</li>
            <li class="flex gap-2"><span class="text-[#F97316] font-bold">→</span>Vérification des filtres et du caisson d'aspiration</li>
            <li class="flex gap-2"><span class="text-[#F97316] font-bold">→</span>Rapport pour assurance professionnelle</li>
            <li class="flex gap-2"><span class="text-[#F97316] font-bold">→</span>Fréquence selon activité — devis annuel</li>
          </ul>
        </div>
      </div>

      <!-- Avantages contrats pro -->
      <div class="bg-[#1E293B] rounded-2xl p-8 text-white">
        <h3 class="text-lg font-bold mb-6">Contrats annuels multi-sites</h3>
        <div class="grid md:grid-cols-3 gap-6">
          {[
            { titre: 'Planification flexible', desc: 'Interventions programmées selon votre activité — avant ou après fermeture, jours de repos, hors saisons.' },
            { titre: 'Rapports consolidés', desc: 'Un rapport global pour tous vos établissements, directement transmis à votre assureur ou gérant de site.' },
            { titre: 'Tarifs dégressifs', desc: "Volume d'interventions récompensé — devis global sur mesure selon le nombre de sites et la fréquence." },
          ].map(({ titre, desc }) => (
            <div>
              <div class="w-2 h-2 rounded-full bg-[#F97316] mb-3"></div>
              <p class="text-sm font-bold mb-2">{titre}</p>
              <p class="text-xs text-white/55 leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
        <div class="mt-6 pt-6 border-t border-white/10">
          <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#F97316] hover:bg-[#EA580C] text-white text-sm font-bold px-6 py-3 rounded-xl transition-colors">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Demander un devis professionnel — 06 64 72 96 00
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION SYNDICS -->
  <section id="syndics" class="py-16 px-6 md:px-10 bg-white border-t border-[#F3F4F6]">
    <div class="max-w-4xl mx-auto">
      <div class="mb-10">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[#F97316] mb-3">Syndics & Immobilier</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1E293B] mb-4">
          Copropriétés, Vente Immobilière & Gestion Locative
        </h2>
        <p class="text-sm text-[#1A1A1A]/60 leading-relaxed max-w-2xl">
          Les conduits collectifs de copropriété (shunt, 3CE, alvéolaires) sont soumis aux normes NF EN 13384-2 et nécessitent une expertise spécifique. Pour la vente ou la location, la conformité des conduits est un enjeu juridique et assurantiel.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-[#FFFFFF] border border-[#F3F4F6] rounded-2xl p-6">
          <h3 class="text-base font-bold text-[#1E293B] mb-4">Conduits collectifs</h3>
          <p class="text-sm text-[#1A1A1A]/60 leading-relaxed mb-4">
            Les systèmes de conduits collectifs (shunt VMC gaz, 3CE, alvéolaires) obéissent à des règles strictes. La norme NF EN 13384-2 régit leur conception et entretien. Un conduit collectif défaillant peut mettre en danger l'ensemble des occupants de l'immeuble.
          </p>
          <ul class="space-y-2 text-xs text-[#1A1A1A]/60">
            <li class="flex gap-2"><span class="text-[#F97316] font-bold">→</span>Conduits shunt — ramonage et vérification VMC</li>
            <li class="flex gap-2"><span class="text-[#F97316] font-bold">→</span>Conduits 3CE — contrôle étanchéité chaque appartement</li>
            <li class="flex gap-2"><span class="text-[#F97316] font-bold">→</span>Conduits alvéolaires — inspection caméra recommandée</li>
            <li class="flex gap-2"><span class="text-[#F97316] font-bold">→</span>Carnet de santé conduit — suivi historique</li>
            <li class="flex gap-2"><span class="text-[#F97316] font-bold">→</span>Rapport global pour le conseil syndical</li>
          </ul>
        </div>

        <div class="space-y-4">
          <div class="bg-[#FFFFFF] border border-[#F3F4F6] rounded-2xl p-5">
            <h4 class="text-sm font-bold text-[#1E293B] mb-2">Aide à la vente immobilière</h4>
            <p class="text-xs text-[#1A1A1A]/60 leading-relaxed mb-3">
              Un rapport d'état du conduit certifié, annexé au dossier de vente, rassure l'acquéreur et protège le vendeur. Il peut prévenir des litiges post-vente sur des vices cachés liés à l'installation de chauffage.
            </p>
            <ul class="space-y-1 text-xs text-[#1A1A1A]/60">
              <li class="flex gap-2"><span class="text-[#F97316]">→</span>Rapport certifié accepté par les notaires</li>
              <li class="flex gap-2"><span class="text-[#F97316]">→</span>Inspection caméra HD avec photos</li>
              <li class="flex gap-2"><span class="text-[#F97316]">→</span>Remis sous 48h après intervention</li>
            </ul>
          </div>
          <div class="bg-[#FFFFFF] border border-[#F3F4F6] rounded-2xl p-5">
            <h4 class="text-sm font-bold text-[#1E293B] mb-2">Gestion locative</h4>
            <p class="text-xs text-[#1A1A1A]/60 leading-relaxed">
              Le ramonage est une charge récupérable sur le locataire (Décret 87-713, annexe II). Sa planification et sa facturation dans le cadre d'un contrat annuel multi-lots simplifie la gestion pour les administrateurs de biens.
            </p>
          </div>
        </div>
      </div>

      <!-- Carnet de santé -->
      <div class="bg-[#FFF7ED] border border-[#FED7AA] rounded-2xl p-6">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl bg-[#F97316] flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <div>
            <h4 class="text-sm font-bold text-[#9A3412] mb-2">Carnet de santé conduit</h4>
            <p class="text-xs text-[#9A3412]/80 leading-relaxed">
              Pour chaque immeuble, nous constituons un carnet de santé conduit : historique des interventions, état du conduit, recommandations, photos datées. Ce document est transmis au syndic après chaque passage et constitue une traçabilité irréprochable pour les assureurs et les futurs acquéreurs.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TARIFS PRO -->
  <section class="py-16 px-6 md:px-10 bg-[#FFFFFF] border-t border-[#F3F4F6]">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-2xl font-extrabold tracking-tight text-[#1E293B] mb-4">Tarifs Professionnels</h2>
      <p class="text-sm text-[#1A1A1A]/55 font-light max-w-lg mx-auto mb-8">
        Les tarifs professionnels sont établis sur devis selon le type d'installation, le volume d'interventions et la fréquence. Contactez-nous pour un devis personnalisé sous 24h.
      </p>
      <div class="grid md:grid-cols-3 gap-5 mb-8 text-left">
        {[
          { titre: 'CHR & Restauration', desc: 'Four à pizza, hotte professionnelle, boulangerie', tarif: 'Sur devis — à partir de 150 €' },
          { titre: 'Copropriété', desc: 'Conduits shunt, 3CE, alvéolaires — par lot ou par immeuble', tarif: 'Sur devis — tarif dégressif' },
          { titre: 'Immobilier', desc: 'Rapport vente, gestion locative, audit pré-achat', tarif: 'Sur devis — à partir de 120 €' },
        ].map(({ titre, desc, tarif }) => (
          <div class="bg-white border border-[#F3F4F6] rounded-2xl p-6">
            <h3 class="text-sm font-bold text-[#1E293B] mb-2">{titre}</h3>
            <p class="text-xs text-[#1A1A1A]/55 leading-relaxed mb-4">{desc}</p>
            <p class="text-xs font-bold text-[#F97316]">{tarif}</p>
          </div>
        ))}
      </div>
      <a href="tel:+33664729600" class="inline-flex items-center gap-2.5 bg-[#F97316] hover:bg-[#EA580C] text-white text-sm font-semibold px-8 py-3.5 rounded-xl transition-colors duration-200 shadow-sm">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        Demander un devis — 06 64 72 96 00
      </a>
    </div>
  </section>

</Layout>
