---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';

const siteUrl = 'https://www.sud-ramonage.fr';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${siteUrl}/expertise`,
  name: 'Expertise ramonage — Réglementation RSD 13, NF DTU 24.1, Conseils entretien',
  description: "Guide réglementaire complet : RSD 13 Bouches-du-Rhône, NF DTU 24.1 & 24.2, Décret 2022-780, dates clés et obligations légales. Conseils d'entretien et prévention CO.",
  url: `${siteUrl}/expertise`,
  inLanguage: 'fr',
  author: { '@type': 'HomeAndConstructionBusiness', '@id': `${siteUrl}/#business` },
};

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Expertise', url: '/expertise' },
];
---

<Layout
  title="Expertise Ramonage — Guide Réglementaire RSD 13, NF DTU 24.1, Conseils | Sud Ramonage"
  description="Guide réglementaire complet pour la fumisterie : RSD 13 Bouches-du-Rhône, NF DTU 24.1 & 24.2, chronologie des textes, sanctions et conseils pratiques d'entretien."
  canonical={`${siteUrl}/expertise`}
  breadcrumbs={breadcrumbs}
  pageSchema={pageSchema}
>

  <!-- HERO -->
  <section class="pt-28 pb-14 px-6 md:px-10 bg-[#FFFDF9]">
    <div class="max-w-4xl mx-auto">
      <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-[11px] text-[#1A1A1A]/35 mb-6">
        <a href="/" class="hover:text-[#C0622F] transition-colors">Accueil</a>
        <span>/</span>
        <span class="text-[#1A1A1A]/60">Expertise</span>
      </nav>
      <div class="inline-flex items-center gap-2 bg-[#FFF5EF] border border-[#FFC9A8] text-[#7A3520] text-[11px] font-bold px-4 py-2 rounded-full mb-6 uppercase tracking-widest">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
        Guide réglementaire & Conseils d'entretien
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-[#1E293B] leading-tight mb-5">
        Expertise <span class="text-[#C0622F]">Fumisterie & Réglementation</span>
      </h1>
      <p class="text-base text-[#1E293B]/60 font-light leading-relaxed mb-6 max-w-2xl">
        Maîtriser la réglementation, c'est comprendre vos droits et obligations. Ce guide synthétise les textes clés qui encadrent le ramonage en Bouches-du-Rhône — du premier arrêté de 1969 aux décrets de 2023.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="#reglementation" class="inline-flex items-center gap-2 bg-[#C0622F] hover:bg-[#A85228] text-white text-sm font-bold px-6 py-3 rounded-xl transition-colors shadow-sm">
          Guide réglementaire ↓
        </a>
        <a href="#conseils" class="inline-flex items-center gap-2 bg-white border border-[#E2E8F0] hover:border-[#C0622F]/40 text-[#1E293B] text-sm font-medium px-6 py-3 rounded-xl transition-colors">
          Conseils d'entretien ↓
        </a>
      </div>
    </div>
  </section>

  <!-- NAV ANCRES -->
  <nav class="sticky top-16 z-30 bg-white border-b border-[#F0EDE8] shadow-sm">
    <div class="max-w-4xl mx-auto px-6 md:px-10">
      <ul class="flex gap-1 py-2">
        <li><a href="#reglementation" class="whitespace-nowrap px-4 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#C0622F] hover:bg-[#FFF5EF] transition-colors">Guide réglementaire</a></li>
        <li><a href="#conseils" class="whitespace-nowrap px-4 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#C0622F] hover:bg-[#FFF5EF] transition-colors">Conseils d'entretien</a></li>
      </ul>
    </div>
  </nav>

  <!-- SECTION REGLEMENTATION -->
  <section id="reglementation" class="py-16 px-6 md:px-10 bg-[#FFFDF9]">
    <div class="max-w-4xl mx-auto">
      <div class="mb-12">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[#C0622F] mb-3">Réglementation</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1E293B] mb-4">
          Chronologie réglementaire
        </h2>
        <p class="text-sm text-[#1A1A1A]/60 leading-relaxed max-w-2xl">
          La réglementation du ramonage s'est construite sur plus de 50 ans, à travers des textes nationaux et des arrêtés préfectoraux locaux.
        </p>
      </div>

      <!-- Frise chronologique -->
      <div class="relative mb-12">
        <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-[#F0EDE8]"></div>
        <div class="space-y-8">
          {[
            {
              annee: '1969',
              titre: '1er arrêté national sur le ramonage',
              desc: 'Premier texte national imposant le ramonage des conduits de fumée pour les appareils à combustion. Pose les bases d\'une obligation générale d\'entretien préventif.',
            },
            {
              annee: '2009',
              titre: 'Arrêté du 15 septembre 2009 — Entretien chaudières',
              desc: "Obligation d'entretien annuel pour toutes les chaudières de 4 à 400 kW par un professionnel qualifié. Inclut le ramonage du conduit de fumée. Attestation d'entretien obligatoire.",
            },
            {
              annee: '2022',
              titre: 'Décret 2022-780',
              desc: "Renforcement des obligations d'entretien des appareils de chauffage. Précise les critères de qualification des professionnels habilités. Intégration des nouvelles technologies (granulés, pompes à chaleur).",
            },
            {
              annee: '2023',
              titre: 'Décret 2023-641 — Obligations renforcées',
              desc: 'Renforcement de la traçabilité des interventions. Obligation de délivrance d\'un certificat détaillé mentionnant le type d\'appareil, le conduit, la méthode et les conclusions du diagnostic.',
            },
          ].map(({ annee, titre, desc }) => (
            <div class="flex gap-6 pl-10 relative">
              <div class="absolute left-0 w-9 h-9 rounded-full bg-[#FFF5EF] border-2 border-[#C0622F] flex items-center justify-center shrink-0 -ml-[18px]">
                <span class="text-[9px] font-extrabold text-[#C0622F]">{annee.slice(-2)}</span>
              </div>
              <div class="bg-white border border-[#F0EDE8] rounded-2xl p-5 flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-xs font-bold text-[#C0622F]">{annee}</span>
                  <span class="text-xs font-bold text-[#1E293B]">{titre}</span>
                </div>
                <p class="text-xs text-[#1A1A1A]/60 leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- RSD 13 -->
      <div class="bg-[#1E293B] text-white rounded-2xl p-8 mb-8">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl bg-[#C0622F] flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-white/40">Bouches-du-Rhône</p>
            <h3 class="text-lg font-extrabold">RSD 13 — Règlement Sanitaire Départemental</h3>
          </div>
        </div>
        <p class="text-sm text-white/70 leading-relaxed mb-5">
          Le Règlement Sanitaire Départemental des Bouches-du-Rhône (RSD 13) est le texte de référence local pour le ramonage. Il impose des obligations plus strictes que la réglementation nationale dans certains cas.
        </p>
        <div class="grid md:grid-cols-2 gap-4">
          {[
            { titre: 'Fréquence minimum', detail: '1 ramonage par an pour tout conduit de fumée en service' },
            { titre: 'Appareils concernés', detail: 'Cheminées, inserts, poêles (bois et granulés), chaudières gaz et fioul' },
            { titre: 'Certificat obligatoire', detail: 'Document officiel remis par un professionnel qualifié après chaque intervention' },
            { titre: 'Sanction assurance', detail: 'Refus de prise en charge en cas de sinistre sans certificat valide de moins de 12 mois' },
          ].map(({ titre, detail }) => (
            <div class="bg-white/8 rounded-xl p-4">
              <p class="text-xs font-bold text-[#C0622F] mb-1">{titre}</p>
              <p class="text-xs text-white/60">{detail}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- NF DTU -->
      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white border border-[#F0EDE8] rounded-2xl p-6">
          <div class="w-8 h-8 rounded-lg bg-[#FFF5EF] flex items-center justify-center mb-3">
            <span class="text-[10px] font-extrabold text-[#C0622F]">DTU</span>
          </div>
          <h3 class="text-sm font-bold text-[#1E293B] mb-2">NF DTU 24.1 — Appareils raccordés fermés</h3>
          <p class="text-xs text-[#1A1A1A]/60 leading-relaxed mb-3">
            Norme qui régit la conception, la mise en œuvre et les règles d'entretien des conduits raccordés à des appareils fermés (inserts, poêles à bois, poêles à granulés, chaudières). Définit les distances de sécurité, l'étanchéité et les matériaux autorisés.
          </p>
          <p class="text-xs font-medium text-[#C0622F]">Concerne : inserts, poêles à bois, poêles à granulés, chaudières</p>
        </div>

        <div class="bg-white border border-[#F0EDE8] rounded-2xl p-6">
          <div class="w-8 h-8 rounded-lg bg-[#FFF5EF] flex items-center justify-center mb-3">
            <span class="text-[10px] font-extrabold text-[#C0622F]">DTU</span>
          </div>
          <h3 class="text-sm font-bold text-[#1E293B] mb-2">NF DTU 24.2 — Foyers ouverts et âtres</h3>
          <p class="text-xs text-[#1A1A1A]/60 leading-relaxed mb-3">
            Norme spécifique aux foyers ouverts (cheminées à âtre). Régit la section, la hauteur et l'état du conduit de fumée pour les foyers non fermés. Impose des contraintes particulières sur le rapport section foyer/section conduit.
          </p>
          <p class="text-xs font-medium text-[#C0622F]">Concerne : cheminées à foyer ouvert, âtres traditionnels</p>
        </div>
      </div>

      <!-- Sanctions -->
      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6">
        <h3 class="text-sm font-bold text-amber-900 mb-4 flex items-center gap-2">
          <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          Conséquences du non-respect
        </h3>
        <div class="grid md:grid-cols-3 gap-4 text-xs text-amber-800">
          <div>
            <p class="font-bold mb-1">Refus d'assurance</p>
            <p class="text-amber-700/80 leading-relaxed">En cas d'incendie de conduit ou d'intoxication au CO, l'assureur peut refuser la prise en charge totale si aucun certificat valide n'est présenté.</p>
          </div>
          <div>
            <p class="font-bold mb-1">Responsabilité civile</p>
            <p class="text-amber-700/80 leading-relaxed">Si un sinistre affecte des voisins (propagation d'incendie en copropriété), le propriétaire sans ramonage peut être tenu responsable des dommages causés à des tiers.</p>
          </div>
          <div>
            <p class="font-bold mb-1">Risque de santé</p>
            <p class="text-amber-700/80 leading-relaxed">Un conduit obstrué ou défaillant peut provoquer des retours de monoxyde de carbone (CO) dans le logement — gaz inodore et mortel. 3 000 intoxications au CO par an en France.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION CONSEILS -->
  <section id="conseils" class="py-16 px-6 md:px-10 bg-white border-t border-[#F0EDE8]">
    <div class="max-w-4xl mx-auto">
      <div class="mb-10">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[#C0622F] mb-3">Conseils d'entretien</p>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-[#1E293B] mb-4">
          Bien utiliser et entretenir votre installation
        </h2>
        <p class="text-sm text-[#1A1A1A]/60 leading-relaxed max-w-2xl">
          Un bon entretien commence par de bonnes pratiques au quotidien. Ces conseils réduisent l'encrassement, améliorent le rendement et prolongent la durée de vie de votre appareil.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-8">

        <!-- Bois de chauffage -->
        <div class="bg-[#FFFDF9] border border-[#F0EDE8] rounded-2xl p-6">
          <div class="w-10 h-10 rounded-xl bg-[#FFF5EF] flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-[#C0622F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/></svg>
          </div>
          <h3 class="text-sm font-bold text-[#1E293B] mb-3">Bois de chauffage — qualité et séchage</h3>
          <ul class="space-y-2 text-xs text-[#1A1A1A]/60">
            <li class="flex items-start gap-2"><span class="text-[#C0622F] shrink-0 mt-0.5">→</span><span><strong class="text-[#1A1A1A]/80">Taux d'humidité idéal : moins de 20 %.</strong> Un bois trop humide brûle mal, produit de la condensation et du bistre.</span></li>
            <li class="flex items-start gap-2"><span class="text-[#C0622F] shrink-0 mt-0.5">→</span><span><strong class="text-[#1A1A1A]/80">Séchage minimum :</strong> 2 ans pour des bûches de 25 cm de section, à l'abri sous un préau ventilé.</span></li>
            <li class="flex items-start gap-2"><span class="text-[#C0622F] shrink-0 mt-0.5">→</span><span><strong class="text-[#1A1A1A]/80">Essences recommandées :</strong> chêne, charme, hêtre — denses et à haut pouvoir calorifique.</span></li>
            <li class="flex items-start gap-2"><span class="text-[#C0622F] shrink-0 mt-0.5">→</span><span><strong class="text-[#1A1A1A]/80">À éviter :</strong> bois verts, bois traités, palettes de récupération, résidus industriels.</span></li>
            <li class="flex items-start gap-2"><span class="text-[#C0622F] shrink-0 mt-0.5">→</span><span><strong class="text-[#1A1A1A]/80">Label Bois de Chauffage :</strong> garantit un taux d'humidité inférieur à 20 % et un volume exact.</span></li>
          </ul>
        </div>

        <!-- Signes d'alerte -->
        <div class="bg-[#FFF5EF] border border-[#FFC9A8] rounded-2xl p-6">
          <div class="w-10 h-10 rounded-xl bg-[#C0622F]/15 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-[#C0622F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          </div>
          <h3 class="text-sm font-bold text-[#7A3520] mb-3">Signes d'alerte — Appelez-nous</h3>
          <ul class="space-y-2 text-xs text-[#7A3520]/80">
            <li class="flex items-start gap-2"><span class="font-bold text-[#C0622F] shrink-0">!</span><span><strong>Fumée noire ou âcre</strong> — signe de combustion incomplète ou de dépôts qui brûlent dans le conduit</span></li>
            <li class="flex items-start gap-2"><span class="font-bold text-[#C0622F] shrink-0">!</span><span><strong>Odeurs de goudron</strong> — bistre présent dans le conduit, risque incendie immédiat</span></li>
            <li class="flex items-start gap-2"><span class="font-bold text-[#C0622F] shrink-0">!</span><span><strong>Tirage insuffisant</strong> — fumée qui ne monte pas, condensation sur la vitre de l'insert</span></li>
            <li class="flex items-start gap-2"><span class="font-bold text-[#C0622F] shrink-0">!</span><span><strong>Bruits anormaux</strong> — crépitements ou vibrations dans le conduit en dehors du fonctionnement normal</span></li>
            <li class="flex items-start gap-2"><span class="font-bold text-[#C0622F] shrink-0">!</span><span><strong>Maux de tête répétés</strong> — symptôme possible d'une intoxication au CO, aérez et appelez les secours</span></li>
          </ul>
        </div>

        <!-- Prévention CO -->
        <div class="bg-white border border-[#F0EDE8] rounded-2xl p-6">
          <div class="w-10 h-10 rounded-xl bg-[#FFF5EF] flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-[#C0622F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="text-sm font-bold text-[#1E293B] mb-3">Prévention CO — Détecteurs obligatoires</h3>
          <p class="text-xs text-[#1A1A1A]/60 leading-relaxed mb-3">
            Depuis le 1er janvier 2023, le décret 2023-695 rend obligatoire l'installation d'un détecteur de monoxyde de carbone dans toute pièce contenant un appareil à combustion dans les logements neufs. Sa généralisation aux logements existants est recommandée par le Ministère de la Santé.
          </p>
          <ul class="space-y-1 text-xs text-[#1A1A1A]/60">
            <li class="flex gap-2"><span class="text-[#C0622F]">→</span>Installer un détecteur CO homologué (norme EN 50291) près de l'appareil</li>
            <li class="flex gap-2"><span class="text-[#C0622F]">→</span>Tester l'appareil mensuellement et remplacer les piles</li>
            <li class="flex gap-2"><span class="text-[#C0622F]">→</span>Ne jamais obstruer les aérations autour de l'appareil</li>
            <li class="flex gap-2"><span class="text-[#C0622F]">→</span>Ventiler la pièce avant la première mise en route saisonnière</li>
          </ul>
        </div>

        <!-- Fréquences entretien -->
        <div class="bg-white border border-[#F0EDE8] rounded-2xl p-6">
          <div class="w-10 h-10 rounded-xl bg-[#FFF5EF] flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-[#C0622F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-sm font-bold text-[#1E293B] mb-3">Fréquences d'entretien par type d'appareil</h3>
          <div class="space-y-3">
            {[
              { appareil: 'Cheminée à foyer ouvert', freq: '1 fois/an (obligatoire RSD 13)', note: 'En début ou fin de saison' },
              { appareil: 'Insert ou poêle à bois', freq: '1 fois/an (obligatoire RSD 13)', note: 'Après la saison de chauffe' },
              { appareil: 'Poêle à granulés', freq: '1 fois/an (obligatoire RSD 13)', note: 'Nettoyage brûleur intermédiaire recommandé' },
              { appareil: 'Chaudière gaz/fioul', freq: '1 fois/an (obligatoire)', note: 'Avant la mise en route hivernale' },
              { appareil: 'CHR / Restauration', freq: 'Trimestrielle minimum', note: 'Selon activité et réglementation ERP' },
            ].map(({ appareil, freq, note }) => (
              <div class="flex items-start gap-3 pb-3 border-b border-[#F0EDE8] last:border-0 last:pb-0">
                <div class="w-1.5 h-1.5 rounded-full bg-[#C0622F] mt-1.5 shrink-0"></div>
                <div>
                  <p class="text-xs font-medium text-[#1E293B]">{appareil}</p>
                  <p class="text-[11px] text-[#C0622F] font-bold">{freq}</p>
                  <p class="text-[10px] text-[#1A1A1A]/45 italic">{note}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-6 md:px-10 bg-[#FFFDF9] border-t border-[#F0EDE8]">
    <div class="max-w-4xl mx-auto">
      <div class="bg-[#1E293B] rounded-2xl p-8 text-white text-center">
        <h2 class="text-2xl font-extrabold mb-3">Des questions sur votre installation ?</h2>
        <p class="text-sm text-white/60 font-light mb-6 max-w-lg mx-auto">Artisan certifié COSTIC, je suis disponible pour répondre à vos questions techniques et réaliser un diagnostic sur site.</p>
        <a href="tel:+33664729600" class="inline-flex items-center gap-2.5 bg-[#C0622F] hover:bg-[#A85228] text-white text-sm font-bold px-8 py-4 rounded-xl transition-colors shadow-sm">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Appeler — 06 64 72 96 00
        </a>
      </div>
    </div>
  </section>

</Layout>
