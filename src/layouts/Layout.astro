---
import '../styles/global.css';
import ContactButton from '../components/ContactButton.astro';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'SUD RAMONAGE — Ramonage Professionnel',
  description = 'Expert en ramonage certifié. Intervention rapide, travail soigné. Prenez rendez-vous en ligne.',
} = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "SUD RAMONAGE",
  "description": description,
  "telephone": "+33664729600",
  "email": "majeo@ik.me",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "31 chemin des tamaris",
    "addressLocality": "Martigues",
    "postalCode": "13500",
    "addressCountry": "FR"
  },
  "areaServed": ["Martigues", "Istres", "Fos-sur-Mer", "Bouches-du-Rhône"],
  "url": "https://sud-ramonage.vercel.app",
  "openingHours": "Mo-Sa 08:00-18:00"
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="bg-white text-[#1A1A1A] font-sans antialiased">

    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-white shadow-[0_1px_0_0_#EEEEEE]">
      <div class="max-w-6xl mx-auto px-6 md:px-10 h-16 flex items-center justify-between">

        <a href="/" class="text-sm font-black tracking-[0.12em] uppercase text-[#000000] hover:text-[#D5001C] transition-colors duration-200">
          SUD RAMONAGE
        </a>

        <nav class="hidden md:flex items-center gap-8">
          <a href="/#services" class="text-xs font-medium tracking-[0.1em] uppercase text-[#1A1A1A]/50 hover:text-[#1A1A1A] transition-colors duration-200">Services</a>
          <a href="/#contact" class="text-xs font-medium tracking-[0.1em] uppercase text-[#1A1A1A]/50 hover:text-[#1A1A1A] transition-colors duration-200">Contact</a>
          <ContactButton variant="phone" />
        </nav>

        <!-- Mobile : bouton appel visible -->
        <a
          href="tel:+33664729600"
          class="md:hidden inline-flex items-center gap-2 bg-[#D5001C] text-white text-xs font-semibold tracking-[0.1em] uppercase px-4 py-2.5 rounded-sm hover:bg-[#AA0016] transition-colors duration-200"
        >
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Appeler
        </a>

      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-[#EEEEEE] mt-32">
      <div class="max-w-6xl mx-auto px-6 md:px-10 py-12">
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
          <div class="space-y-2">
            <p class="text-sm font-black tracking-[0.12em] uppercase text-[#000000]">SUD RAMONAGE</p>
            <p class="text-xs text-[#1A1A1A]/40">31 chemin des tamaris, 13500 Martigues</p>
            <ContactButton variant="email" />
          </div>
          <div class="flex flex-col md:flex-row items-start md:items-center gap-6 text-xs text-[#1A1A1A]/35">
            <a href="tel:+33664729600" class="hover:text-[#D5001C] transition-colors duration-200">06 64 72 96 00</a>
            <span class="hidden md:block">—</span>
            <span>&copy; {new Date().getFullYear()} Sud Ramonage</span>
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>
