---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  breadcrumbs?: { name: string; url: string }[];
  pageSchema?: object;
  preloadImageHref?: string;
}

const {
  title = 'SUD RAMONAGE — Ramonage Professionnel à Martigues',
  description = 'Artisan ramoneur certifié à Martigues. Ramonage cheminée, poêle à bois et granulés. Certificat immédiat. Assurance pro. Conforme RSD 13.',
  canonical,
  ogImage,
  breadcrumbs,
  pageSchema,
  preloadImageHref,
} = Astro.props;

const particuliersMenu = [
  { href: '/particuliers#ramonage',   label: 'Ramonage & Entretien',    desc: 'Cheminées, inserts, poêles à bois' },
  { href: '/particuliers#poeles',     label: 'Poêles à Granulés',        desc: 'Entretien complet corps de chauffe' },
  { href: '/particuliers#chaudieres', label: 'Chaudières Gaz & Fioul',   desc: 'Conduit d\'évacuation certifié' },
  { href: '/particuliers#audit',      label: 'Audit & Diagnostic',        desc: 'Caméra HD, fumigène, vacuité' },
];

const proMenu = [
  { href: '/pro-syndics#pro',     label: 'Restauration & CHR',    desc: 'Fours, hottes, contrats annuels' },
  { href: '/pro-syndics#syndics', label: 'Syndics & Immobilier',   desc: 'Conduits collectifs, audit vente' },
];

const expertiseMenu = [
  { href: '/expertise#reglementation', label: 'Réglementation RSD 13', desc: 'DTU, obligations, dates clés' },
  { href: '/expertise#conseils',       label: "Conseils d'Entretien",   desc: 'Bois, prévention CO, fréquences' },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Sud Ramonage" />
    {preloadImageHref && <link rel="preload" as="image" href={preloadImageHref} fetchpriority="high" />}
    <title>{title}</title>
    <ClientRouter />
    <SEO title={title} description={description} canonical={canonical} ogImage={ogImage} breadcrumbs={breadcrumbs} pageSchema={pageSchema} />
  </head>
  <body class="bg-white text-[#111827] font-sans antialiased">

    <!-- HEADER -->
    <header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-[#F3F4F6] transition-shadow duration-300">
      <div class="max-w-7xl mx-auto px-6 md:px-10 h-16 flex items-center justify-between gap-8">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 shrink-0 group" aria-label="Sud Ramonage">
          <div class="w-8 h-8 bg-[#2B7A78] rounded-lg flex items-center justify-center shrink-0">
            <svg class="w-4.5 h-4.5 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/>
            </svg>
          </div>
          <div>
            <span class="block text-sm font-extrabold tracking-tight text-[#111827] leading-none">SUD RAMONAGE</span>
            <span class="block text-[10px] text-[#4B5563] font-normal tracking-wide leading-none mt-0.5">Martigues · Bouches-du-Rhône</span>
          </div>
        </a>

        <!-- Nav Desktop -->
        <nav class="hidden lg:flex items-center gap-1 flex-1 ml-8" aria-label="Navigation principale">

          <a href="/" class="px-3.5 py-2 rounded-lg text-sm font-medium text-[#4B5563] hover:text-[#111827] hover:bg-[#F9F9F9] transition-all duration-150">
            Accueil
          </a>

          <!-- Particuliers -->
          <div class="relative group/part">
            <a href="/particuliers" class="flex items-center gap-1 px-3.5 py-2 rounded-lg text-sm font-medium text-[#4B5563] hover:text-[#111827] hover:bg-[#F9F9F9] transition-all duration-150">
              Particuliers
              <svg class="w-3.5 h-3.5 group-hover/part:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
            </a>
            <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover/part:opacity-100 group-hover/part:visible transition-all duration-200 z-50">
              <div class="bg-white border border-[#F3F4F6] rounded-2xl shadow-xl shadow-black/8 p-3 w-64">
                {particuliersMenu.map(({ href, label, desc }) => (
                  <a href={href} class="flex gap-3 px-3 py-2.5 rounded-xl hover:bg-[#F0FDFC] transition-colors duration-150 group/item">
                    <div class="w-1.5 h-1.5 rounded-full bg-[#2B7A78] shrink-0 mt-2"></div>
                    <div>
                      <p class="text-sm font-semibold text-[#111827] group-hover/item:text-[#2B7A78] transition-colors">{label}</p>
                      <p class="text-xs text-[#4B5563] leading-tight mt-0.5">{desc}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>

          <!-- Pro & Syndics -->
          <div class="relative group/pro">
            <a href="/pro-syndics" class="flex items-center gap-1 px-3.5 py-2 rounded-lg text-sm font-medium text-[#4B5563] hover:text-[#111827] hover:bg-[#F9F9F9] transition-all duration-150">
              Pro & Syndics
              <svg class="w-3.5 h-3.5 group-hover/pro:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
            </a>
            <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover/pro:opacity-100 group-hover/pro:visible transition-all duration-200 z-50">
              <div class="bg-white border border-[#F3F4F6] rounded-2xl shadow-xl shadow-black/8 p-3 w-64">
                {proMenu.map(({ href, label, desc }) => (
                  <a href={href} class="flex gap-3 px-3 py-2.5 rounded-xl hover:bg-[#F0FDFC] transition-colors duration-150 group/item">
                    <div class="w-1.5 h-1.5 rounded-full bg-[#2B7A78] shrink-0 mt-2"></div>
                    <div>
                      <p class="text-sm font-semibold text-[#111827] group-hover/item:text-[#2B7A78] transition-colors">{label}</p>
                      <p class="text-xs text-[#4B5563] leading-tight mt-0.5">{desc}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>

          <!-- Expertise -->
          <div class="relative group/exp">
            <a href="/expertise" class="flex items-center gap-1 px-3.5 py-2 rounded-lg text-sm font-medium text-[#4B5563] hover:text-[#111827] hover:bg-[#F9F9F9] transition-all duration-150">
              Expertise
              <svg class="w-3.5 h-3.5 group-hover/exp:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
            </a>
            <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover/exp:opacity-100 group-hover/exp:visible transition-all duration-200 z-50">
              <div class="bg-white border border-[#F3F4F6] rounded-2xl shadow-xl shadow-black/8 p-3 w-64">
                {expertiseMenu.map(({ href, label, desc }) => (
                  <a href={href} class="flex gap-3 px-3 py-2.5 rounded-xl hover:bg-[#F0FDFC] transition-colors duration-150 group/item">
                    <div class="w-1.5 h-1.5 rounded-full bg-[#2B7A78] shrink-0 mt-2"></div>
                    <div>
                      <p class="text-sm font-semibold text-[#111827] group-hover/item:text-[#2B7A78] transition-colors">{label}</p>
                      <p class="text-xs text-[#4B5563] leading-tight mt-0.5">{desc}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>

        </nav>

        <!-- CTA Desktop -->
        <div class="hidden lg:flex items-center gap-3 shrink-0">
          <a href="tel:+33664729600" class="inline-flex items-center gap-2 bg-[#2B7A78] hover:bg-[#1F5F5C] text-white text-sm font-bold px-5 py-2.5 rounded-xl transition-colors duration-150 shadow-sm shadow-[#2B7A78]/25">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            06 64 72 96 00
          </a>
        </div>

        <!-- Mobile burger -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-lg hover:bg-[#F9F9F9] transition-colors" aria-label="Menu" aria-expanded="false">
          <svg id="burger-icon" class="w-5 h-5 text-[#111827]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          <svg id="close-icon" class="w-5 h-5 text-[#111827] hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>

      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-[#F3F4F6]">
        <div class="max-w-7xl mx-auto px-6 py-6 space-y-1">
          <a href="/" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-[#F9F9F9] text-sm font-medium text-[#111827] transition-colors">Accueil</a>

          <div>
            <button id="mob-part-btn" class="flex items-center justify-between w-full px-4 py-3 rounded-xl hover:bg-[#F9F9F9] text-sm font-semibold text-[#111827] transition-colors">
              Particuliers <svg class="w-4 h-4 text-[#4B5563] transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div id="mob-part-panel" class="hidden pl-6 mt-1 space-y-1">
              {particuliersMenu.map(({ href, label }) => (
                <a href={href} class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm text-[#4B5563] hover:text-[#2B7A78] transition-colors">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#2B7A78] shrink-0"></span>{label}
                </a>
              ))}
            </div>
          </div>

          <div>
            <button id="mob-pro-btn" class="flex items-center justify-between w-full px-4 py-3 rounded-xl hover:bg-[#F9F9F9] text-sm font-semibold text-[#111827] transition-colors">
              Pro & Syndics <svg class="w-4 h-4 text-[#4B5563] transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div id="mob-pro-panel" class="hidden pl-6 mt-1 space-y-1">
              {proMenu.map(({ href, label }) => (
                <a href={href} class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm text-[#4B5563] hover:text-[#2B7A78] transition-colors">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#2B7A78] shrink-0"></span>{label}
                </a>
              ))}
            </div>
          </div>

          <div>
            <button id="mob-exp-btn" class="flex items-center justify-between w-full px-4 py-3 rounded-xl hover:bg-[#F9F9F9] text-sm font-semibold text-[#111827] transition-colors">
              Expertise <svg class="w-4 h-4 text-[#4B5563] transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div id="mob-exp-panel" class="hidden pl-6 mt-1 space-y-1">
              {expertiseMenu.map(({ href, label }) => (
                <a href={href} class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm text-[#4B5563] hover:text-[#2B7A78] transition-colors">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#2B7A78] shrink-0"></span>{label}
                </a>
              ))}
            </div>
          </div>

          <div class="pt-4 border-t border-[#F3F4F6]">
            <a href="tel:+33664729600" class="flex items-center justify-center gap-2 bg-[#2B7A78] hover:bg-[#1F5F5C] text-white text-sm font-bold px-6 py-3.5 rounded-xl transition-colors w-full">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              06 64 72 96 00 — Appeler
            </a>
          </div>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="bg-[#1C0F07] text-white">
      <div class="max-w-7xl mx-auto px-6 md:px-10 py-16">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">

          <!-- Marque -->
          <div class="md:col-span-1">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-8 h-8 bg-[#2B7A78] rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/>
                </svg>
              </div>
              <span class="text-sm font-extrabold tracking-tight">SUD RAMONAGE</span>
            </div>
            <p class="text-xs text-white/50 leading-relaxed mb-4">Artisan ramoneur certifié COSTIC à Martigues. Bouches-du-Rhône.</p>
            <p class="text-xs text-white/35">SIRET : [À COMPLÉTER]</p>
            <p class="text-xs text-white/35 mt-1">31 chemin des tamaris, 13500 Martigues</p>
            <a href="tel:+33664729600" class="inline-flex items-center gap-2 mt-4 text-[#2B7A78] text-sm font-bold hover:text-[#2B7A78] transition-colors">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              06 64 72 96 00
            </a>
          </div>

          <!-- Particuliers -->
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-white/40 mb-4">Particuliers</p>
            <ul class="space-y-2.5">
              {[
                { href: '/particuliers#ramonage',   label: 'Ramonage certifié' },
                { href: '/particuliers#poeles',     label: 'Poêles à granulés' },
                { href: '/particuliers#chaudieres', label: 'Chaudières gaz & fioul' },
                { href: '/particuliers#audit',      label: 'Audit & Diagnostic' },
              ].map(({ href, label }) => (
                <li><a href={href} class="text-xs text-white/55 hover:text-[#2B7A78] transition-colors">{label}</a></li>
              ))}
            </ul>
          </div>

          <!-- Pro & Syndics -->
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-white/40 mb-4">Pro & Syndics</p>
            <ul class="space-y-2.5">
              {[
                { href: '/pro-syndics#pro',     label: 'Restauration & CHR' },
                { href: '/pro-syndics#syndics', label: 'Syndics & Collectifs' },
                { href: '/pro-syndics#syndics', label: 'Immobilier & Notaires' },
                { href: '/pro-syndics#syndics', label: 'Gestion locative' },
              ].map(({ href, label }) => (
                <li><a href={href} class="text-xs text-white/55 hover:text-[#2B7A78] transition-colors">{label}</a></li>
              ))}
            </ul>
          </div>

          <!-- Expertise & Legal -->
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-white/40 mb-4">Expertise & Légal</p>
            <ul class="space-y-2.5">
              {[
                { href: '/expertise#reglementation', label: 'Réglementation RSD 13' },
                { href: '/expertise#conseils',       label: "Conseils d'entretien" },
                { href: '/cgv',                      label: 'Conditions Générales' },
                { href: '/mentions-legales',         label: 'Mentions légales' },
              ].map(({ href, label }) => (
                <li><a href={href} class="text-xs text-white/55 hover:text-[#2B7A78] transition-colors">{label}</a></li>
              ))}
            </ul>
          </div>

        </div>

        <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="text-xs text-white/30">© 2024 Sud Ramonage — Tous droits réservés · TVA non applicable Art. 293 B CGI</p>
          <div class="flex items-center gap-2">
            <span class="text-[10px] font-bold bg-[#2B7A78]/20 text-[#2B7A78] px-2.5 py-1 rounded-lg">Certifié COSTIC</span>
            <span class="text-[10px] font-bold bg-white/8 text-white/50 px-2.5 py-1 rounded-lg">Qualibat 6521</span>
            <span class="text-[10px] font-bold bg-white/8 text-white/50 px-2.5 py-1 rounded-lg">RC Pro</span>
          </div>
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const burgerIcon = document.getElementById('burger-icon');
      const closeIcon = document.getElementById('close-icon');

      btn?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', String(!isOpen));
        burgerIcon?.classList.toggle('hidden');
        closeIcon?.classList.toggle('hidden');
      });

      // Mobile accordions
      function setupAccordion(btnId: string, panelId: string) {
        const b = document.getElementById(btnId);
        const p = document.getElementById(panelId);
        const chevron = b?.querySelector('svg');
        b?.addEventListener('click', () => {
          p?.classList.toggle('hidden');
          chevron?.classList.toggle('rotate-180');
        });
      }
      setupAccordion('mob-part-btn', 'mob-part-panel');
      setupAccordion('mob-pro-btn', 'mob-pro-panel');
      setupAccordion('mob-exp-btn', 'mob-exp-panel');

      // Scroll shadow
      const header = document.getElementById('site-header');
      window.addEventListener('scroll', () => {
        header?.classList.toggle('shadow-md', window.scrollY > 20);
      }, { passive: true });
    </script>

  </body>
</html>
