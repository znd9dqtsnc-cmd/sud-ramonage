    ═══════════════════════════════════════════ -->
    <script>
      const burgerBtn   = document.getElementById('burger-btn');
      const mobileMenu  = document.getElementById('mobile-menu');
      const mobilePanel = document.getElementById('mobile-panel');
      const mobileOverlay = document.getElementById('mobile-overlay');
      const closeBtn    = document.getElementById('mobile-close');
      const iconOpen    = document.getElementById('burger-icon-open');
      const iconClose   = document.getElementById('burger-icon-close');

      function openMenu() {
        mobileMenu?.classList.remove('hidden');
        mobileMenu?.setAttribute('aria-hidden', 'false');
        burgerBtn?.setAttribute('aria-expanded', 'true');
        setTimeout(() => mobilePanel?.classList.remove('translate-x-full'), 10);
        iconOpen?.classList.add('hidden');
        iconClose?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }

      function closeMenu() {
        mobilePanel?.classList.add('translate-x-full');
        burgerBtn?.setAttribute('aria-expanded', 'false');
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
        document.body.style.overflow = '';
        setTimeout(() => {
          mobileMenu?.classList.add('hidden');
          mobileMenu?.setAttribute('aria-hidden', 'true');
        }, 300);
      }

      burgerBtn?.addEventListener('click', openMenu);
      closeBtn?.addEventListener('click', closeMenu);
      mobileOverlay?.addEventListener('click', closeMenu);

      // Fermer avec Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeMenu();
      });

      // Accordéons mobile
      function setupAccordion(btnId: string, panelId: string, arrowId: string) {
        const btn   = document.getElementById(btnId);
        const panel = document.getElementById(panelId);
        const arrow = document.getElementById(arrowId);
        btn?.addEventListener('click', () => {
          const isOpen = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', String(!isOpen));
          panel?.classList.toggle('hidden', isOpen);
          arrow?.classList.toggle('rotate-180', !isOpen);
        });
      }

      setupAccordion('mobile-services-btn', 'mobile-services', 'mobile-services-arrow');
      setupAccordion('mobile-pro-btn',      'mobile-pro',      'mobile-pro-arrow');
      setupAccordion('mobile-savoir-btn',   'mobile-savoir',   'mobile-savoir-arrow');
      setupAccordion('mobile-zones-btn',    'mobile-zones',    'mobile-zones-arrow');

      // Header : opacité pleine sur hero, glassmorphism + ombre sous hero
      const header = document.getElementById('site-header');
      const hero = document.querySelector('section');
      function updateHeader() {
        const heroBottom = hero ? hero.getBoundingClientRect().bottom : 0;
        if (heroBottom > 0) {
          header?.classList.remove('header-glass', 'header-scrolled');
        } else {
          header?.classList.add('header-glass');
          if (window.scrollY > 8) {
            header?.classList.add('header-scrolled');
          } else {
            header?.classList.remove('header-scrolled');
          }
        }
      }
      window.addEventListener('scroll', updateHeader, { passive: true });
      updateHeader();


    </script>

    <!-- ═══════════════════════════════════════════
         STICKY CALL BUTTON — Mobile uniquement
    ═══════════════════════════════════════════ -->
    <div id="sticky-call-btn" class="lg:hidden fixed bottom-0 left-0 right-0 z-[55] grid grid-cols-3 items-center bg-white border-t border-[#E2E8F0] px-4 py-3 shadow-lg transition-transform duration-700 ease-in-out">
      <!-- Gauche : bouton téléphone -->
      <div class="flex justify-start">
        <a
          href="tel:+33664729600"
          class="w-12 h-12 rounded-full bg-[#2C3E50] flex items-center justify-center shadow-sm active:scale-95 transition-transform touch-manipulation"
          aria-label="Appeler le 06 64 72 96 00"
        >
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </a>
      </div>
      <!-- Centre : bouton jaune -->
      <div class="flex justify-center">
        <a
          href="tel:+33664729600"
          class="inline-flex items-center justify-center gap-2 px-5 bg-[#F39C12] hover:bg-[#D68910] active:bg-[#D68910] active:scale-[0.99] text-white text-[15px] font-medium py-3 rounded-xl transition-colors duration-150 touch-manipulation"
          aria-label="Réserver un ramonage"
        >
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          Réserver en ligne
        </a>
      </div>
      <!-- Droite : croix -->
      <div class="flex justify-end">
        <button
          id="sticky-dismiss"
          aria-label="Fermer"
          class="w-10 h-10 flex items-center justify-center text-[#1A1A1A]/30 hover:text-[#1A1A1A]/60 transition-colors duration-150 touch-manipulation"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════
         SCROLL TO TOP
    ═══════════════════════════════════════════ -->
    <button
      id="scroll-top"
      aria-label="Remonter en haut"
      class="fixed bottom-[100px] lg:bottom-10 right-10 z-[54] w-10 h-10 rounded-full bg-[#F2EFE9]/80 border border-[#2C3E50]/15 text-[#2C3E50]/50 shadow-sm flex items-center justify-center opacity-0 pointer-events-none translate-y-4 transition-all duration-300 hover:bg-[#F2EFE9] hover:text-[#2C3E50]/80"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
      </svg>
    </button>
    <script>
      const scrollTopBtn = document.getElementById('scroll-top');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
          scrollTopBtn?.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
          scrollTopBtn?.classList.add('opacity-100', 'translate-y-0');
        } else {
          scrollTopBtn?.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
          scrollTopBtn?.classList.remove('opacity-100', 'translate-y-0');
        }
      }, { passive: true });
      scrollTopBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      // Sticky bar — masquage auto + dismiss (réinitialisé au refresh)
      const stickyBar = document.getElementById('sticky-call-btn');
      const stickyDismiss = document.getElementById('sticky-dismiss');
      let stickyTimer: ReturnType<typeof setTimeout> | null = null;
      let stickyDismissed = false;

      stickyDismiss?.addEventListener('click', () => {
        stickyDismissed = true;
        stickyBar?.classList.add('translate-y-full');
        if (stickyTimer) clearTimeout(stickyTimer);
      });

      function showStickyBar() {
        if (stickyDismissed) return;
        stickyBar?.classList.remove('translate-y-full');
        if (stickyTimer) clearTimeout(stickyTimer);
        stickyTimer = setTimeout(() => {
          stickyBar?.classList.add('translate-y-full');
        }, 2500);
      }

      // Opacité sticky bar — glassmorphism au scroll, solide en haut
      function updateStickyOpacity() {
        if (window.scrollY > 0) {
          stickyBar?.classList.add('sticky-glass');
          stickyBar?.classList.remove('bg-white');
        } else {
          stickyBar?.classList.remove('sticky-glass');
          stickyBar?.classList.add('bg-white');
        }
      }
      window.addEventListener('scroll', updateStickyOpacity, { passive: true });

      window.addEventListener('scroll', showStickyBar, { passive: true });
      window.addEventListener('touchstart', showStickyBar, { passive: true });

      // Premier masquage après 2.5s au chargement
      stickyTimer = setTimeout(() => {
        stickyBar?.classList.add('translate-y-full');
      }, 2500);
    </script>

  </body>
</html>
