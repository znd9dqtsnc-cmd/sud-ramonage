---
import '../styles/global.css';
import ContactButton from '../components/ContactButton.astro';
import EmailButton from '../components/EmailButton.astro';
import SEO from '../components/SEO.astro';
import COSTICBadge from '../components/COSTICBadge.astro';
import { ClientRouter } from 'astro:transitions';
import { villes } from '../data/villes';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  breadcrumbs?: { name: string; url: string }[];
  pageSchema?: object;
  /** URL de l'image hero à précharger (LCP) — passer getImage().src depuis la page */
  preloadImageHref?: string;
}

const {
  title = 'SUD RAMONAGE — Ramonage Professionnel à Martigues',
  description = 'Artisan ramoneur certifié à Martigues. Ramonage cheminée, poêle à bois et granulés. Certificat immédiat. Assurance pro. Conforme RSD 13.',
  canonical,
  ogImage,
  breadcrumbs,
  pageSchema,
  preloadImageHref,
} = Astro.props;

const megaMenu = {
  entretien: [
    { href: '/ramonage',          label: 'Ramonage',             desc: 'Nettoyage mécanique du conduit, test de vacuité et remise du certificat officiel RSD 13 le jour même.' },
    { href: '/entretien-poele',   label: 'Entretien Poêle',      desc: 'Maintenance complète poêle à bois et à granulés : brûleur, conduit, capteurs. Certificat RSD 13 inclus.' },
    { href: '/debistrage',        label: 'Débistrage',           desc: 'Traitement chimique et mécanique du bistre, dépôt goudronné hautement inflammable issu du bois humide.' },
  ],
  diagnostic: [
    { href: '/vacuite',          label: 'Contrôle de Vacuité',            desc: 'Vérification par caméra HD : obstruction, état des parois. Pour un doute ou un problème.' },
    { href: '/audit-conformite', label: 'Diagnostic de Sécurité',    desc: 'Contrôle complet vacuité + étanchéité avec rapport certifié. Pour l\'assurance, un notaire, ou une garantie totale.' },
  ],
  appareils: [
    { href: '/foyers-ouverts',   label: 'Foyers Ouverts' },
    { href: '/inserts',          label: 'Inserts' },
    { href: '/poeles-bois',      label: 'Poêles à Bois' },
    { href: '/poeles-granules',  label: 'Poêles à Granulés' },
    { href: '/chaudieres',       label: 'Chaudières Gaz & Fioul' },
  ],
  rehabilitation: [
    { href: '/tubage',               label: 'Tubage Rigide et Flexible',      desc: 'Mise aux normes DTU 24.1' },
    { href: '/pose-conduit',          label: 'Pose de Conduit Métallique',    desc: 'Installation neuve quand le tubage est impossible' },
    { href: '/accessoires-toiture',  label: 'Accessoires Toiture', desc: 'Chapeaux anti-refoulement' },
  ],
};

const proMenu = [
  { href: '/gestion-locative',            label: 'Gestion Locative',           desc: 'Contrat Sécurité Mensualisé bailleurs' },
  { href: '/partenaires-diagnostiqueurs', label: 'Diagnostiqueurs & Experts',  desc: 'Protocole ACTS post-DPE' },
  { href: '/syndics',                     label: 'Syndics & Collectifs',       desc: 'Gestion parcs immobiliers' },
  { href: '/aide-vente-immobilier',       label: 'Aide à la Vente',            desc: 'Synergie diagnostics immobiliers' },
  { href: '/audit-immobilier',            label: 'Carnet de Santé Conduit',    desc: 'Rapport certifié pour notaire' },
  { href: '/restauration',                label: 'Restauration',               desc: 'Fours à pizza, hottes pro' },
];

const savoirMenu = [
  { href: '/lexique',            label: 'Lexique de l\'Expert',    desc: '50 termes fumisterie expliqués' },
  { href: '/reglementation',     label: 'Aide & Réglementation',   desc: 'Guide complet RSD 13' },
  { href: '/normes',             label: 'Normes & Sécurité',       desc: 'NF DTU 24.1, distances sécurité' },
  { href: '/sante-qualite-air',  label: 'Santé & Qualité de l\'Air', desc: 'CO, PM2.5, risques conduit' },
  { href: '/valeur-verte',       label: 'Valeur Verte & DPE',      desc: 'Certificat performance conduit' },
  { href: '/statistiques-securite',   label: 'Statistiques Sécurité',    desc: 'Données incendies, CO, obligations RSD 13' },
  { href: '/guide-conformite-rsd13',  label: 'Guide Conformité RSD 13',  desc: 'Télécharger le guide PDF officiel 2026' },
  { href: '/conseils',                label: 'Conseils d\'Experts',       desc: 'Articles et guides pratiques' },
];

const services = [
  { href: '/ramonage',           label: 'Ramonage Certifié',    desc: 'Nettoyage mécanique, certificat RSD 13' },
  { href: '/debistrage',         label: 'Débistrage',            desc: 'Traitement chimique & mécanique du bistre' },
  { href: '/entretien-poele',    label: 'Entretien Poêle',      desc: 'Maintenance complète poêle à bois & granulés' },
  { href: '/inspection-camera',  label: 'Inspection Caméra',    desc: 'Diagnostic vidéo HD — fissures, rapport assurance' },
  { href: '/normes',             label: 'Normes & Sécurité',    desc: 'NF DTU 24.1, distances de sécurité, tubage' },
];

const zonesGroupes = [
  {
    label: 'Côte Bleue & Martigues',
    villes: villes.filter(v => ['martigues','sausset-les-pins','carry-le-rouet','chateauneuf-les-martigues'].includes(v.slug)),
  },
  {
    label: 'Étang de Berre',
    villes: villes.filter(v => ['istres','fos-sur-mer','gignac-la-nerthe'].includes(v.slug)),
  },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Sud Ramonage" />

    <!-- Preload image LCP si fournie par la page -->
    {preloadImageHref && (
      <link rel="preload" as="image" href={preloadImageHref} fetchpriority="high" />
    )}

    <!-- Inter Variable — hébergé localement via @fontsource-variable/inter (LCP optimisé, zéro DNS externe) -->

    <title>{title}</title>

    <!-- Transitions de page fluides (SPA-like avec prefetch) -->
    <ClientRouter />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      breadcrumbs={breadcrumbs}
      pageSchema={pageSchema}
    />
  </head>
  <body class="bg-white text-[#1A1A1A] font-sans antialiased">

    <!-- ═══════════════════════════════════════════
         HEADER
    ═══════════════════════════════════════════ -->
    <header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-[#EEEEEE] transition-shadow duration-300">
      <div class="max-w-6xl mx-auto px-6 md:px-10 h-16 flex items-center justify-between gap-6">

        <!-- ── Logo ── -->
        <a href="/" class="flex items-center gap-2.5 shrink-0 group" aria-label="Sud Ramonage - Ramonage à Martigues">
          <span class="w-7 h-7 rounded-md bg-[#E65100] flex items-center justify-center shrink-0" aria-hidden="true">
            <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/>
            </svg>
          </span>
          <span class="text-sm font-extrabold tracking-tight text-[#1A1A1A] group-hover:text-[#E65100] transition-colors duration-200">
            SUD RAMONAGE
          </span>
        </a>

        <!-- ── Nav Desktop ── -->
        <nav class="hidden lg:flex items-center gap-0.5 flex-1" aria-label="Navigation principale">
          <ul class="flex items-center gap-0.5">

            <!-- Accueil -->
            <li>
              <a href="/" class="px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150">
                Accueil
              </a>
            </li>

            <!-- Mega-menu Ramonage -->
            <li class="relative group/services">
              <button type="button" class="flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150" aria-haspopup="true">
                Ramonage
                <svg class="w-3 h-3 group-hover/services:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover/services:opacity-100 group-hover/services:visible transition-all duration-200 pointer-events-none group-hover/services:pointer-events-auto z-50">
                <div class="bg-white border border-[#EEEEEE] rounded-2xl shadow-2xl shadow-black/10 p-5 w-[660px] grid grid-cols-3 gap-6">
                  <!-- Col 1 : Ramonage & Entretien -->
                  <div>
                    <p class="text-[9px] font-bold tracking-widest uppercase text-[#1A1A1A]/30 mb-3">Ramonage & Entretien</p>
                    <ul class="space-y-0.5">
                      {megaMenu.entretien.map(({ href, label, desc }) => (
                        <li>
                          <a href={href} class="flex flex-col gap-0.5 px-3 py-2.5 rounded-lg hover:bg-[#FFF3E0] group/item transition-colors duration-150">
                            <span class="text-xs font-semibold text-[#1A1A1A] group-hover/item:text-[#E65100] transition-colors flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-[#E65100] shrink-0"></span>{label}</span>
                            <span class="text-[10px] text-[#1A1A1A]/40 pl-2.5">{desc}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                  <!-- Col 2 : Inspection & Diagnostic -->
                  <div>
                    <p class="text-[9px] font-bold tracking-widest uppercase text-[#1A1A1A]/30 mb-3">Inspection & Diagnostic</p>
                    <ul class="space-y-0.5">
                      {megaMenu.diagnostic.map(({ href, label, desc }) => (
                        <li>
                          <a href={href} class="flex flex-col gap-0.5 px-3 py-2.5 rounded-lg hover:bg-[#FFF3E0] group/item transition-colors duration-150">
                            <span class="text-xs font-semibold text-[#1A1A1A] group-hover/item:text-[#E65100] transition-colors flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-[#E65100] shrink-0"></span>{label}</span>
                            <span class="text-[10px] text-[#1A1A1A]/40 pl-2.5">{desc}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                  <!-- Col 3 : Type de Générateur -->
                  <div class="bg-gradient-to-br from-[#E65100] to-[#BF360C] rounded-xl p-4 text-white flex flex-col justify-between">
                    <div>
                      <p class="text-[9px] font-bold tracking-widest uppercase text-white/50 mb-2">Par générateur</p>
                      <p class="text-sm font-bold leading-snug mb-4">Type de Générateur</p>
                      <div class="flex flex-wrap gap-1.5">
                        <a href="/foyers-ouverts" class="bg-white/15 hover:bg-white/30 text-white text-[10px] font-medium px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">Cheminée</a>
                        <a href="/foyers-ouverts" class="bg-white/15 hover:bg-white/30 text-white text-[10px] font-medium px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">Foyer ouvert</a>
                        <a href="/inserts" class="bg-white/15 hover:bg-white/30 text-white text-[10px] font-medium px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">Insert</a>
                        <a href="/poeles-bois" class="bg-white/15 hover:bg-white/30 text-white text-[10px] font-medium px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">Poêle à bois</a>
                        <a href="/poeles-granules" class="bg-white/15 hover:bg-white/30 text-white text-[10px] font-medium px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">Poêle à granulés</a>
                        <a href="/chaudieres" class="bg-white/15 hover:bg-white/30 text-white text-[10px] font-medium px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">Chaudière gaz</a>
                        <a href="/chaudieres" class="bg-white/15 hover:bg-white/30 text-white text-[10px] font-medium px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">Chaudière fioul</a>
                        <a href="/chaudieres" class="bg-white/15 hover:bg-white/30 text-white text-[10px] font-medium px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">Chaudière bois</a>
                      </div>
                    </div>
                    <div class="mt-5">
                      <a href="/particuliers" class="inline-flex w-full items-center justify-center gap-2 bg-white text-[#E65100] text-xs font-bold px-3 py-2.5 rounded-lg hover:bg-white/90 transition-colors">
                        Toutes nos Prestations
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </li>

            <!-- Menu Réhabilitation -->
            <li class="relative group/rehab">
              <button type="button" class="flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150" aria-haspopup="true">
                Réhabilitation
                <svg class="w-3 h-3 group-hover/rehab:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover/rehab:opacity-100 group-hover/rehab:visible transition-all duration-200 pointer-events-none group-hover/rehab:pointer-events-auto z-50">
                <div class="bg-white border border-[#EEEEEE] rounded-xl shadow-xl shadow-black/8 p-2 w-72">
                  <p class="text-[9px] font-bold tracking-widest uppercase text-[#1A1A1A]/30 px-4 pt-2 pb-1">Pose & Réhabilitation</p>
                  <ul>
                    {megaMenu.rehabilitation.map(({ href, label, desc }) => (
                      <li>
                        <a href={href} class="flex flex-col gap-0.5 px-4 py-3 rounded-lg hover:bg-[#FFF3E0] group/item transition-colors duration-150">
                          <span class="text-xs font-semibold text-[#1A1A1A] group-hover/item:text-[#E65100] transition-colors flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#E65100] shrink-0"></span>{label}</span>
                          <span class="text-[11px] text-[#1A1A1A]/45 pl-3.5">{desc}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </li>

            <!-- Espace Pro -->
            <li class="relative group/pro">
              <button type="button" class="flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150" aria-haspopup="true">
                Espace Pro
                <svg class="w-3 h-3 group-hover/pro:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover/pro:opacity-100 group-hover/pro:visible transition-all duration-200 pointer-events-none group-hover/pro:pointer-events-auto z-50">
                <div class="bg-white border border-[#EEEEEE] rounded-xl shadow-xl shadow-black/8 p-2 w-64">
                  <ul>
                    {proMenu.map(({ href, label, desc }) => (
                      <li>
                        <a href={href} class="flex flex-col gap-0.5 px-4 py-3 rounded-lg hover:bg-[#EFF4FF] group/item transition-colors duration-150">
                          <span class="text-xs font-semibold text-[#1A1A1A] group-hover/item:text-[#1A4B8F] transition-colors flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#1A4B8F] shrink-0"></span>{label}</span>
                          <span class="text-[11px] text-[#1A1A1A]/45 pl-3.5">{desc}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </li>

            <!-- Guide Expert -->
            <li class="relative group/savoir">
              <button type="button" class="flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150" aria-haspopup="true">
                Guide Expert
                <svg class="w-3 h-3 group-hover/savoir:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover/savoir:opacity-100 group-hover/savoir:visible transition-all duration-200 pointer-events-none group-hover/savoir:pointer-events-auto z-50">
                <div class="bg-white border border-[#EEEEEE] rounded-xl shadow-xl shadow-black/8 p-2 w-64">
                  <ul>
                    {savoirMenu.map(({ href, label, desc }) => (
                      <li>
                        <a href={href} class="flex flex-col gap-0.5 px-4 py-3 rounded-lg hover:bg-[#F0F4FF] group/item transition-colors duration-150">
                          <span class="text-xs font-semibold text-[#1A1A1A] group-hover/item:text-[#1A4B8F] transition-colors flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#1A4B8F] shrink-0"></span>{label}</span>
                          <span class="text-[11px] text-[#1A1A1A]/45 pl-3.5">{desc}</span>
                        </a>
                      </li>
                    ))}
                    <li>
                      <a href="/realisations" class="flex flex-col gap-0.5 px-4 py-3 rounded-lg hover:bg-[#F0F4FF] group/item transition-colors duration-150">
                        <span class="text-xs font-semibold text-[#1A1A1A] group-hover/item:text-[#1A4B8F] transition-colors flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#1A4B8F] shrink-0"></span>Réalisations</span>
                        <span class="text-[11px] text-[#1A1A1A]/45 pl-3.5">Chantiers & photos d'interventions</span>
                      </a>
                    </li>
                  </ul>
                </div>
              </div>
            </li>

            <!-- Zones d'intervention dropdown -->
            <li class="relative group/zones">
              <button type="button" class="flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150" aria-haspopup="true">
                Zones
                <svg class="w-3 h-3 group-hover/zones:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover/zones:opacity-100 group-hover/zones:visible transition-all duration-200 pointer-events-none group-hover/zones:pointer-events-auto z-50">
                <div class="bg-white border border-[#EEEEEE] rounded-xl shadow-xl shadow-black/8 p-4 w-72">
                  <ul class="space-y-4">
                    {zonesGroupes.map(({ label, villes: vs }) => (
                      <li>
                        <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-2">{label}</p>
                        <ul class="space-y-0.5">
                          {vs.map(v => (
                            <li>
                              <a href={`/villes/${v.slug}`} class="flex items-center justify-between px-3 py-2 rounded-lg hover:bg-[#FFF3E0] group/vlink transition-colors duration-150">
                                <span class="text-xs font-medium text-[#1A1A1A]/70 group-hover/vlink:text-[#E65100] transition-colors">Ramonage {v.nom}</span>
                                <span class="text-[10px] text-[#1A1A1A]/30 font-mono">{v.codePostal}</span>
                              </a>
                            </li>
                          ))}
                        </ul>
                      </li>
                    ))}
                    <li>
                      <a href="/zones" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-[#FFF3E0] text-[#E65100] text-xs font-semibold hover:bg-[#FFE0B2] transition-colors">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                        Toutes les zones →
                      </a>
                    </li>
                  </ul>
                </div>
              </div>
            </li>

          </ul>
        </nav>

        <!-- ── CTA Desktop + Téléphone Mobile + Burger ── -->
        <div class="flex items-center gap-2 shrink-0">

          <!-- Bouton téléphone MOBILE (lg:hidden) — élément de contact principal -->
          <a
            href="tel:+33664729600"
            class="lg:hidden inline-flex items-center gap-2 bg-[#E65100] text-white text-xs font-bold px-4 py-2.5 rounded-lg hover:bg-[#BF360C] active:bg-[#8A2200] active:scale-[0.97] transition-all duration-150 touch-manipulation"
            aria-label="Appeler le 06 64 72 96 00"
          >
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Appeler
          </a>

          <!-- Bouton "Prendre RDV" DESKTOP uniquement -->
          <a
            href="tel:+33664729600"
            class="hidden lg:inline-flex items-center gap-2 bg-[#E65100] text-white text-xs font-bold px-4 py-2.5 rounded-lg hover:bg-[#BF360C] transition-colors duration-200 shadow-sm shadow-[#E65100]/25"
          >
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Prendre RDV
          </a>

          <!-- Bouton burger mobile -->
