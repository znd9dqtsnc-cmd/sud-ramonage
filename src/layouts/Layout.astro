---
import '../styles/global.css';
import ContactButton from '../components/ContactButton.astro';
import SEO from '../components/SEO.astro';
import { ClientRouter } from 'astro:transitions';
import { villes } from '../data/villes';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  breadcrumbs?: { name: string; url: string }[];
  pageSchema?: object;
  /** URL de l'image hero à précharger (LCP) — passer getImage().src depuis la page */
  preloadImageHref?: string;
}

const {
  title = 'SUD RAMONAGE — Ramonage Professionnel à Martigues',
  description = 'Artisan ramoneur certifié à Martigues. Ramonage cheminée, poêle à bois et granulés. Certificat immédiat. Assurance pro. Conforme RSD 13.',
  canonical,
  ogImage,
  breadcrumbs,
  pageSchema,
  preloadImageHref,
} = Astro.props;

const megaMenu = {
  entretien: [
    { href: '/ramonage',          label: 'Ramonage',             desc: 'Nettoyage mécanique du conduit, test de vacuité et remise du certificat officiel RSD 13 le jour même.' },
    { href: '/entretien-poele',   label: 'Entretien Poêle',      desc: 'Maintenance complète poêle à bois et à granulés : brûleur, conduit, capteurs. Certificat RSD 13 inclus.' },
    { href: '/debistrage',        label: 'Débistrage',           desc: 'Traitement chimique et mécanique du bistre, dépôt goudronné hautement inflammable issu du bois humide.' },
  ],
  diagnostic: [
    { href: '/inspection-camera', label: 'Inspection Caméra',         desc: 'Diagnostic vidéo HD intérieur du conduit — fissures, obstructions, état des parois.' },
    { href: '/vacuite',           label: 'Contrôle de Vacuité',       desc: 'Vérification d\'obstruction par caméra ou test fumigène. Pour un doute ou un problème de tirage.' },
    { href: '/audit-conformite',  label: 'Diagnostic de Sécurité',    desc: 'Contrôle complet + rapport certifié. Pour l\'assurance, un notaire, ou une garantie totale.' },
  ],
  appareils: [
    { href: '/foyers-ouverts',   label: 'Foyers Ouverts' },
    { href: '/inserts',          label: 'Inserts' },
    { href: '/poeles-bois',      label: 'Poêles à Bois' },
    { href: '/poeles-granules',  label: 'Poêles à Granulés' },
    { href: '/chaudieres',       label: 'Chaudières Gaz & Fioul' },
  ],
  rehabilitation: [
    { href: '/tubage',               label: 'Tubage Rigide et Flexible',      desc: 'Mise aux normes DTU 24.1' },
    { href: '/pose-conduit',          label: 'Pose de Conduit Métallique',    desc: 'Installation neuve quand le tubage est impossible' },
    { href: '/accessoires-toiture',  label: 'Accessoires Toiture', desc: 'Chapeaux anti-refoulement' },
  ],
};

const proMenu = [
  { href: '/bailleurs-syndics',         label: 'Bailleurs & Syndics',         desc: 'Contrats récurrents, parcs locatifs, colonnes copropriété. Certificats automatiques, tarif dégressif.' },
  { href: '/transaction-immobiliere',   label: 'Transaction Immobilière',     desc: 'Audit conduit pour la vente — protection vices cachés, rapport notaire, Carnet de Santé du Conduit.' },
  { href: '/restauration-pro',          label: 'Restauration & Pro',          desc: 'Fours à pizza, hottes professionnelles, conformité ERP. Intervention hors horaires d\'ouverture.' },
];

const savoirMenu = [
  { href: '/normes-reglementation', label: 'Normes & Réglementation', desc: 'RSD 13, NF DTU 24.1, fréquences légales. Tout ce que la loi impose.' },
  { href: '/securite-sante',        label: 'Sécurité & Santé',        desc: 'CO, incendies de conduit, PM2.5 — données chiffrées et prévention.' },
  { href: '/conseils',              label: 'Conseils & Articles',      desc: 'Guides pratiques, conseils d\'entretien et lexique fumisterie.' },
];

const services = [
  { href: '/ramonage',           label: 'Ramonage Certifié',    desc: 'Nettoyage mécanique, certificat RSD 13' },
  { href: '/debistrage',         label: 'Débistrage',            desc: 'Traitement chimique & mécanique du bistre' },
  { href: '/entretien-poele',    label: 'Entretien Poêle',      desc: 'Maintenance complète poêle à bois & granulés' },
  { href: '/inspection-camera',  label: 'Inspection Caméra',    desc: 'Diagnostic vidéo HD — fissures, rapport assurance' },
  { href: '/normes',             label: 'Normes & Sécurité',    desc: 'NF DTU 24.1, distances de sécurité, tubage' },
];

const zonesGroupes = [
  {
    label: 'Côte Bleue & Martigues',
    villes: villes.filter(v => ['martigues','sausset-les-pins','carry-le-rouet','chateauneuf-les-martigues'].includes(v.slug)),
  },
  {
    label: 'Étang de Berre',
    villes: villes.filter(v => ['istres','fos-sur-mer','gignac-la-nerthe'].includes(v.slug)),
  },
];

const pathname = Astro.url.pathname;
const isHome     = pathname === '/';
const isRamonage = ['/ramonage','/entretien-poele','/debistrage','/inspection-camera','/vacuite','/audit-conformite','/foyers-ouverts','/inserts','/poeles-bois','/poeles-granules','/chaudieres','/tubage','/pose-conduit','/accessoires-toiture','/particuliers'].some(p => pathname === p || pathname.startsWith(p + '/'));
const isPro      = ['/bailleurs-syndics','/transaction-immobiliere','/restauration-pro'].some(p => pathname === p || pathname.startsWith(p + '/'));
const isGuide    = ['/normes-reglementation','/securite-sante','/conseils','/lexique','/normes'].some(p => pathname === p || pathname.startsWith(p + '/'));
const isZones    = pathname === '/zones' || pathname.startsWith('/villes/');

const isRealisations = pathname === '/realisations' || pathname.startsWith('/realisations/');

const navLink = (active: boolean) => active
  ? 'px-3 py-2 rounded-lg text-xs font-semibold text-[#F39C12] bg-[#FFF3E0] transition-all duration-150'
  : 'px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/85 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150';

const navBtn = (active: boolean) => active
  ? 'flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-semibold text-[#F39C12] bg-[#FFF3E0] transition-all duration-150'
  : 'flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/85 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150';
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Sud Ramonage" />

    <!-- Preload image LCP si fournie par la page -->
    {preloadImageHref && (
      <link rel="preload" as="image" href={preloadImageHref} fetchpriority="high" />
    )}

    <!-- Inter Variable — hébergé localement via @fontsource-variable/inter (LCP optimisé, zéro DNS externe) -->

    <title>{title}</title>

    <!-- Transitions de page fluides (SPA-like avec prefetch) -->
    <ClientRouter />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      breadcrumbs={breadcrumbs}
      pageSchema={pageSchema}
    />
    <style>
      .header-scrolled {
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.03), 0 2px 4px -1px rgba(0,0,0,0.02);
      }
      .header-glass {
        background-color: rgba(255,255,255,0.92);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }
      .sticky-glass {
        background-color: rgba(255,255,255,0.92);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }
    </style>
  </head>
  <body class="bg-[#F2EFE9] text-[#4B4B4B] font-sans antialiased">

    <!-- ═══════════════════════════════════════════
         HEADER
    ═══════════════════════════════════════════ -->
    <header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-white transition-all duration-300">
      <div class="max-w-6xl mx-auto px-6 md:px-10 h-16 flex items-center justify-between gap-6">

        <!-- ── Logo ── -->
        <a href="/" class="flex items-center gap-1.5 shrink-0 group" aria-label="Sud Ramonage - Ramonage à Martigues">
          <svg class="w-9 h-9 text-[#F39C12] shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/>
          </svg>
          <span class="text-lg font-extrabold tracking-tight text-[#2C3E50] group-hover:text-[#F39C12] transition-colors duration-200">
            Sud Ramonage.
          </span>
        </a>

        <!-- ── Nav Desktop ── -->
        <nav class="hidden lg:flex items-center gap-0.5 flex-1" aria-label="Navigation principale">
          <ul class="flex items-center gap-0.5">

            <!-- Accueil -->
            <li>
              <a href="/" class={navLink(isHome)}>
                Accueil
              </a>
            </li>


            <!-- Mega-menu Ramonage -->
            <li class="relative group/services">
              <button type="button" class={navBtn(isRamonage)} aria-haspopup="true">
                Ramonage
                <svg class="w-3 h-3 group-hover/services:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover/services:opacity-100 group-hover/services:visible transition-all duration-200 pointer-events-none group-hover/services:pointer-events-auto z-50">
                <div class="bg-[#FFFFFF] border border-[#EEEEEE] rounded-2xl shadow-2xl shadow-black/10 p-5 w-[700px] grid grid-cols-3 gap-6">
                  <!-- Col 1 : Ramonage & Entretien + Réhabilitation -->
                  <div>
                    <p class="text-[9px] font-bold tracking-widest uppercase text-[#1A1A1A]/30 mb-3">Ramonage & Entretien</p>
                    <ul class="space-y-0.5">
                      {megaMenu.entretien.map(({ href, label, desc }) => (
                        <li>
                          <a href={href} class="flex flex-col gap-0.5 px-3 py-2.5 rounded-lg hover:bg-[#FFF3E0] group/item transition-colors duration-150">
                            <span class="text-xs font-semibold text-[#1A1A1A] group-hover/item:text-[#F39C12] transition-colors flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-[#F39C12] shrink-0"></span>{label}</span>
                            <span class="text-[10px] text-[#1A1A1A]/80 pl-2.5">{desc}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                    <div class="border-t border-[#EEEEEE] mt-3 pt-3">
                      <p class="text-[9px] font-bold tracking-widest uppercase text-[#1A1A1A]/30 mb-2">Réhabilitation</p>
                      <ul class="space-y-0.5">
                        {megaMenu.rehabilitation.map(({ href, label, desc }) => (
                          <li>
                            <a href={href} class="flex items-center gap-1.5 px-3 py-2 rounded-lg hover:bg-[#FFF3E0] group/item transition-colors duration-150">
                              <span class="w-1 h-1 rounded-full bg-[#F39C12]/50 shrink-0"></span>
                              <span class="text-xs font-medium text-[#1A1A1A]/85 group-hover/item:text-[#F39C12] transition-colors">{label}</span>
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                  <!-- Col 2 : Inspection & Diagnostic -->
                  <div>
                    <p class="text-[9px] font-bold tracking-widest uppercase text-[#1A1A1A]/30 mb-3">Inspection & Diagnostic</p>
                    <ul class="space-y-0.5">
                      {megaMenu.diagnostic.map(({ href, label, desc }) => (
                        <li>
                          <a href={href} class="flex flex-col gap-0.5 px-3 py-2.5 rounded-lg hover:bg-[#FFF3E0] group/item transition-colors duration-150">
                            <span class="text-xs font-semibold text-[#1A1A1A] group-hover/item:text-[#F39C12] transition-colors flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-[#F39C12] shrink-0"></span>{label}</span>
                            <span class="text-[10px] text-[#1A1A1A]/80 pl-2.5">{desc}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                  <!-- Col 3 : Type de Générateur -->
                  <div class="bg-gradient-to-br from-[#2C3E50] to-[#3498DB] rounded-xl p-4 text-white flex flex-col justify-between">
                    <div>
                      <p class="text-[9px] font-bold tracking-widest uppercase text-white/60 mb-2">Par générateur</p>
                      <p class="text-sm font-bold leading-snug mb-4">Type de Générateur</p>
                      <div class="flex flex-wrap gap-1.5">
                        <a href="/foyers-ouverts" class="bg-white/15 hover:bg-white/25 text-white text-[10px] font-medium px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">Cheminée</a>
                        <a href="/foyers-ouverts" class="bg-white/15 hover:bg-white/25 text-white text-[10px] font-medium px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">Foyer ouvert</a>
                        <a href="/inserts" class="bg-white/15 hover:bg-white/25 text-white text-[10px] font-medium px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">Insert</a>
                        <a href="/poeles-bois" class="bg-white/15 hover:bg-white/25 text-white text-[10px] font-medium px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">Poêle à bois</a>
                        <a href="/poeles-granules" class="bg-white/15 hover:bg-white/25 text-white text-[10px] font-medium px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">Poêle à granulés</a>
                        <a href="/chaudieres" class="bg-white/15 hover:bg-white/25 text-white text-[10px] font-medium px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">Chaudière gaz</a>
                        <a href="/chaudieres" class="bg-white/15 hover:bg-white/25 text-white text-[10px] font-medium px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">Chaudière fioul</a>
                        <a href="/chaudieres" class="bg-white/15 hover:bg-white/25 text-white text-[10px] font-medium px-2.5 py-1 rounded-full transition-colors whitespace-nowrap">Chaudière bois</a>
                      </div>
                    </div>
                    <div class="mt-5">
                      <a href="/particuliers" class="inline-flex w-full items-center justify-center gap-2 bg-[#FFFFFF] text-[#F39C12] text-xs font-bold px-3 py-2.5 rounded-lg hover:bg-[#FFFFFF]/90 transition-colors">
                        Toutes nos Prestations
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </li>

            <!-- Espace Pro -->
            <li class="relative group/pro">
              <button type="button" class={navBtn(isPro)} aria-haspopup="true">
                Espace Pro
                <svg class="w-3 h-3 group-hover/pro:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover/pro:opacity-100 group-hover/pro:visible transition-all duration-200 pointer-events-none group-hover/pro:pointer-events-auto z-50">
                <div class="bg-[#FFFFFF] border border-[#EEEEEE] rounded-xl shadow-xl shadow-black/8 p-2 w-64">
                  <ul>
                    {proMenu.map(({ href, label, desc }) => (
                      <li>
                        <a href={href} class="flex flex-col gap-0.5 px-4 py-3 rounded-lg hover:bg-[#EFF4FF] group/item transition-colors duration-150">
                          <span class="text-xs font-semibold text-[#1A1A1A] group-hover/item:text-[#1A4B8F] transition-colors flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#1A4B8F] shrink-0"></span>{label}</span>
                          <span class="text-[11px] text-[#1A1A1A]/80 pl-3.5">{desc}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </li>

            <!-- Guide Expert -->
            <li class="relative group/savoir">
              <button type="button" class={navBtn(isGuide)} aria-haspopup="true">
                Guide Expert
                <svg class="w-3 h-3 group-hover/savoir:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover/savoir:opacity-100 group-hover/savoir:visible transition-all duration-200 pointer-events-none group-hover/savoir:pointer-events-auto z-50">
                <div class="bg-[#FFFFFF] border border-[#EEEEEE] rounded-xl shadow-xl shadow-black/8 p-2 w-64">
                  <ul>
                    {savoirMenu.map(({ href, label, desc }) => (
                      <li>
                        <a href={href} class="flex flex-col gap-0.5 px-4 py-3 rounded-lg hover:bg-[#F0F4FF] group/item transition-colors duration-150">
                          <span class="text-xs font-semibold text-[#1A1A1A] group-hover/item:text-[#1A4B8F] transition-colors flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#1A4B8F] shrink-0"></span>{label}</span>
                          <span class="text-[11px] text-[#1A1A1A]/80 pl-3.5">{desc}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </li>

            <!-- Zones d'intervention dropdown -->
            <li class="relative group/zones">
              <button type="button" class={navBtn(isZones)} aria-haspopup="true">
                Zones
                <svg class="w-3 h-3 group-hover/zones:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover/zones:opacity-100 group-hover/zones:visible transition-all duration-200 pointer-events-none group-hover/zones:pointer-events-auto z-50">
                <div class="bg-[#FFFFFF] border border-[#EEEEEE] rounded-xl shadow-xl shadow-black/8 p-4 w-72">
                  <ul class="space-y-4">
                    {zonesGroupes.map(({ label, villes: vs }) => (
                      <li>
                        <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-2">{label}</p>
                        <ul class="space-y-0.5">
                          {vs.map(v => (
                            <li>
                              <a href={`/villes/${v.slug}`} class="flex items-center justify-between px-3 py-2 rounded-lg hover:bg-[#FFF3E0] group/vlink transition-colors duration-150">
                                <span class="text-xs font-medium text-[#1A1A1A]/85 group-hover/vlink:text-[#F39C12] transition-colors">Ramonage {v.nom}</span>
                                <span class="text-[10px] text-[#1A1A1A]/30 font-mono">{v.codePostal}</span>
                              </a>
                            </li>
                          ))}
                        </ul>
                      </li>
                    ))}
                    <li>
                      <a href="/zones" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-[#FFF3E0] text-[#F39C12] text-xs font-semibold hover:bg-[#FFE0B2] transition-colors">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                        Toutes les zones →
                      </a>
                    </li>
                  </ul>
                </div>
              </div>
            </li>

            <!-- Réalisations -->
            <li>
              <a href="/realisations" class={navLink(isRealisations)}>
                Réalisations
              </a>
            </li>

          </ul>
        </nav>

        <!-- ── CTA Desktop + Téléphone Mobile + Burger ── -->
        <div class="flex items-center gap-2 shrink-0">

          <!-- Bouton téléphone MOBILE (lg:hidden) — élément de contact principal -->
          <a
            href="tel:+33664729600"
            class="lg:hidden inline-flex items-center gap-2 bg-[#2C3E50] text-white text-xs font-bold px-4 py-2.5 rounded-lg hover:bg-[#1A2A3A] active:scale-[0.97] transition-all duration-150 touch-manipulation"
            aria-label="Appeler le 06 64 72 96 00"
          >
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Appeler
          </a>

          <!-- Contact DESKTOP -->
          <a href="/contact" class="hidden lg:inline-flex items-center gap-2 text-xs font-medium text-[#1A1A1A]/85 hover:text-[#1A1A1A] px-3 py-2.5 rounded-lg hover:bg-[#F5F5F5] transition-all duration-150">
            Contact
          </a>

          <!-- Bouton "Prendre RDV" DESKTOP uniquement -->
          <a
            href="tel:+33664729600"
            class="hidden lg:inline-flex items-center gap-2 bg-[#2C3E50] text-white text-xs font-bold px-4 py-2.5 rounded-lg hover:bg-[#1A2A3A] transition-colors duration-200 shadow-sm"
          >
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Prendre RDV
          </a>

          <!-- Bouton burger mobile -->
          <button
            id="burger-btn"
            type="button"
            class="lg:hidden flex items-center justify-center w-10 h-10 rounded-lg text-[#1A1A1A] hover:bg-[#F5F5F5] transition-colors duration-150"
            aria-label="Ouvrir le menu"
            aria-controls="mobile-menu"
            aria-expanded="false"
          >
            <!-- Icône hamburger -->
