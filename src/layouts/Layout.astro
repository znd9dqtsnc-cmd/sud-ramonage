---
import '../styles/global.css';
import ContactButton from '../components/ContactButton.astro';
import EmailButton from '../components/EmailButton.astro';
import SEO from '../components/SEO.astro';
import { ClientRouter } from 'astro:transitions';
import { villes } from '../data/villes';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  breadcrumbs?: { name: string; url: string }[];
  pageSchema?: object;
  /** URL de l'image hero à précharger (LCP) — passer getImage().src depuis la page */
  preloadImageHref?: string;
}

const {
  title = 'SUD RAMONAGE — Ramonage Professionnel à Martigues',
  description = 'Artisan ramoneur certifié à Martigues. Ramonage cheminée, poêle à bois et granulés. Certificat immédiat. Assurance pro. Conforme RSD 13.',
  canonical,
  ogImage,
  breadcrumbs,
  pageSchema,
  preloadImageHref,
} = Astro.props;

const services = [
  { href: '/ramonage',           label: 'Ramonage Certifié',    desc: 'Nettoyage mécanique, certificat RSD 13' },
  { href: '/debistrage',         label: 'Débistrage',            desc: 'Traitement chimique & mécanique du bistre' },
  { href: '/entretien-poele',    label: 'Entretien Poêle',      desc: 'Maintenance complète poêle à bois & granulés' },
  { href: '/inspection-camera',  label: 'Inspection Caméra',    desc: 'Diagnostic vidéo HD — fissures, rapport assurance' },
  { href: '/normes',             label: 'Normes & Sécurité',    desc: 'NF DTU 24.1, distances de sécurité, tubage' },
];

const zonesGroupes = [
  {
    label: 'Côte Bleue & Martigues',
    villes: villes.filter(v => ['martigues','sausset-les-pins','carry-le-rouet','chateauneuf-les-martigues'].includes(v.slug)),
  },
  {
    label: 'Étang de Berre',
    villes: villes.filter(v => ['istres','fos-sur-mer','gignac-la-nerthe'].includes(v.slug)),
  },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Sud Ramonage" />

    <!-- Preload image LCP si fournie par la page -->
    {preloadImageHref && (
      <link rel="preload" as="image" href={preloadImageHref} fetchpriority="high" />
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    </noscript>

    <title>{title}</title>

    <!-- Transitions de page fluides (SPA-like avec prefetch) -->
    <ClientRouter />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      breadcrumbs={breadcrumbs}
      pageSchema={pageSchema}
    />
  </head>
  <body class="bg-white text-[#1A1A1A] font-sans antialiased">

    <!-- ═══════════════════════════════════════════
         HEADER
    ═══════════════════════════════════════════ -->
    <header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-[#EEEEEE] transition-shadow duration-300">
      <div class="max-w-6xl mx-auto px-6 md:px-10 h-16 flex items-center justify-between gap-6">

        <!-- ── Logo ── -->
        <a href="/" class="flex items-center gap-2.5 shrink-0 group" aria-label="Sud Ramonage - Ramonage à Martigues">
          <span class="w-7 h-7 rounded-md bg-[#E65100] flex items-center justify-center shrink-0" aria-hidden="true">
            <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/>
            </svg>
          </span>
          <span class="text-sm font-extrabold tracking-tight text-[#1A1A1A] group-hover:text-[#E65100] transition-colors duration-200">
            SUD RAMONAGE
          </span>
        </a>

        <!-- ── Badge COSTIC — desktop uniquement ── -->
        <div class="hidden lg:flex items-center gap-1.5 bg-[#1A4B8F]/8 border border-[#1A4B8F]/20 rounded-lg px-2.5 py-1.5 shrink-0" title="Certification COSTIC — Formation fumisterie et sécurité">
          <svg class="w-3 h-3 text-[#1A4B8F] shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <span class="text-[9px] font-extrabold tracking-widest text-[#1A4B8F] uppercase">COSTIC</span>
        </div>

        <!-- ── Nav Desktop ── -->
        <nav class="hidden lg:flex items-center gap-1 flex-1" aria-label="Navigation principale">
          <ul class="flex items-center gap-1">

            <!-- Accueil -->
            <li>
              <a href="/" class="px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150">
                Accueil
              </a>
            </li>

            <!-- Services dropdown -->
            <li class="relative group/services">
              <button
                type="button"
                class="flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150"
                aria-haspopup="true"
                aria-expanded="false"
              >
                Services
                <svg class="w-3 h-3 group-hover/services:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <!-- Dropdown Services -->
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover/services:opacity-100 group-hover/services:visible transition-all duration-200 pointer-events-none group-hover/services:pointer-events-auto">
                <div class="bg-white border border-[#EEEEEE] rounded-xl shadow-xl shadow-black/8 p-2 w-64">
                  <ul>
                    {services.map(({ href, label, desc }) => (
                      <li>
                        <a
                          href={href}
                          class="flex flex-col gap-0.5 px-4 py-3 rounded-lg hover:bg-[#FFF3E0] group/item transition-colors duration-150"
                        >
                          <span class="text-xs font-semibold text-[#1A1A1A] group-hover/item:text-[#E65100] transition-colors duration-150 flex items-center gap-2">
                            <span class="w-1.5 h-1.5 rounded-full bg-[#E65100] shrink-0"></span>
                            {label}
                          </span>
                          <span class="text-[11px] text-[#1A1A1A]/45 font-light pl-3.5">{desc}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </li>

            <!-- Réalisations -->
            <li>
              <a href="/realisations" class="px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150">
                Réalisations
              </a>
            </li>

            <!-- Conseils -->
            <li>
              <a href="/conseils" class="px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150">
                Conseils
              </a>
            </li>

            <!-- Zones d'intervention dropdown -->
            <li class="relative group/zones">
              <button
                type="button"
                class="flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150"
                aria-haspopup="true"
                aria-expanded="false"
              >
                Zones d'intervention
                <svg class="w-3 h-3 group-hover/zones:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <!-- Dropdown Zones -->
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover/zones:opacity-100 group-hover/zones:visible transition-all duration-200 pointer-events-none group-hover/zones:pointer-events-auto">
                <div class="bg-white border border-[#EEEEEE] rounded-xl shadow-xl shadow-black/8 p-4 w-72">
                  <ul class="space-y-4">
                    {zonesGroupes.map(({ label, villes: vs }) => (
                      <li>
                        <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-2">{label}</p>
                        <ul class="space-y-0.5">
                          {vs.map(v => (
                            <li>
                              <a
                                href={`/villes/${v.slug}`}
                                class="flex items-center justify-between px-3 py-2 rounded-lg hover:bg-[#FFF3E0] group/vlink transition-colors duration-150"
                              >
                                <span class="text-xs font-medium text-[#1A1A1A]/70 group-hover/vlink:text-[#E65100] transition-colors duration-150">
                                  Ramonage {v.nom}
                                </span>
                                <span class="text-[10px] text-[#1A1A1A]/30 font-mono">{v.codePostal}</span>
                              </a>
                            </li>
                          ))}
                        </ul>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </li>

          </ul>
        </nav>

        <!-- ── CTA Desktop + Téléphone Mobile + Burger ── -->
        <div class="flex items-center gap-2 shrink-0">

          <!-- Bouton téléphone MOBILE (lg:hidden) — élément de contact principal -->
          <a
            href="tel:+33664729600"
            class="lg:hidden inline-flex items-center gap-2 bg-[#E65100] text-white text-xs font-bold px-4 py-2.5 rounded-lg hover:bg-[#BF360C] active:bg-[#8A2200] active:scale-[0.97] transition-all duration-150 touch-manipulation"
            aria-label="Appeler le 06 64 72 96 00"
          >
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Appeler
          </a>

          <!-- Bouton "Prendre RDV" DESKTOP uniquement -->
          <a
            href="tel:+33664729600"
            class="hidden lg:inline-flex items-center gap-2 bg-[#E65100] text-white text-xs font-bold px-4 py-2.5 rounded-lg hover:bg-[#BF360C] transition-colors duration-200 shadow-sm shadow-[#E65100]/25"
          >
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Prendre RDV
          </a>

          <!-- Bouton burger mobile -->
          <button
            id="burger-btn"
            type="button"
            class="lg:hidden flex items-center justify-center w-10 h-10 rounded-lg text-[#1A1A1A] hover:bg-[#F5F5F5] transition-colors duration-150"
            aria-label="Ouvrir le menu"
            aria-controls="mobile-menu"
            aria-expanded="false"
          >
            <!-- Icône hamburger -->
            <svg id="burger-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <!-- Icône close (masquée par défaut) -->
            <svg id="burger-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

      </div>
    </header>

    <!-- ═══════════════════════════════════════════
         MENU MOBILE (panneau overlay)
    ═══════════════════════════════════════════ -->
    <div
      id="mobile-menu"
      class="fixed inset-0 z-40 lg:hidden hidden"
      aria-hidden="true"
    >
      <!-- Overlay sombre -->
      <div id="mobile-overlay" class="absolute inset-0 bg-[#1A1A1A]/50 backdrop-blur-sm"></div>

      <!-- Panneau latéral -->
      <nav
        class="absolute top-0 right-0 h-full w-80 max-w-full bg-white shadow-2xl flex flex-col translate-x-full transition-transform duration-300 ease-in-out"
        id="mobile-panel"
        aria-label="Menu mobile"
      >
        <!-- En-tête panneau -->
        <div class="flex items-center justify-between px-6 h-16 border-b border-[#EEEEEE] shrink-0">
          <div class="flex items-center gap-2">
            <span class="w-6 h-6 rounded-md bg-[#E65100] flex items-center justify-center" aria-hidden="true">
              <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/>
              </svg>
            </span>
            <span class="text-sm font-extrabold tracking-tight text-[#1A1A1A]">SUD RAMONAGE</span>
          </div>
          <button
            id="mobile-close"
            type="button"
            class="flex items-center justify-center w-9 h-9 rounded-lg text-[#1A1A1A]/50 hover:bg-[#F5F5F5] transition-colors duration-150"
            aria-label="Fermer le menu"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Liens mobile -->
        <div class="flex-1 overflow-y-auto px-4 py-6 space-y-1">

          <ul class="space-y-1">
            <li>
              <a href="/" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-[#1A1A1A] hover:bg-[#FFF3E0] hover:text-[#E65100] transition-colors duration-150">
                <svg class="w-4 h-4 text-[#E65100] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                Accueil
              </a>
            </li>
          </ul>

          <!-- Services mobile (accordéon) -->
          <div>
            <button
              type="button"
              id="mobile-services-btn"
              class="w-full flex items-center justify-between px-4 py-3 rounded-xl text-sm font-medium text-[#1A1A1A] hover:bg-[#F5F5F5] transition-colors duration-150"
              aria-expanded="false"
              aria-controls="mobile-services"
            >
              <span class="flex items-center gap-3">
                <svg class="w-4 h-4 text-[#E65100] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                </svg>
                Services
              </span>
              <svg id="mobile-services-arrow" class="w-4 h-4 text-[#1A1A1A]/40 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <ul id="mobile-services" class="hidden mt-1 ml-4 space-y-0.5 border-l-2 border-[#E65100]/20 pl-3">
              {services.map(({ href, label, desc }) => (
                <li>
                  <a href={href} class="flex flex-col gap-0.5 px-3 py-2.5 rounded-lg hover:bg-[#FFF3E0] transition-colors duration-150">
                    <span class="text-xs font-semibold text-[#1A1A1A]">{label}</span>
                    <span class="text-[11px] text-[#1A1A1A]/45 font-light">{desc}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <ul class="space-y-1">
            <li>
              <a href="/realisations" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-[#1A1A1A] hover:bg-[#FFF3E0] hover:text-[#E65100] transition-colors duration-150">
                <svg class="w-4 h-4 text-[#E65100] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
                Réalisations
              </a>
            </li>
            <li>
              <a href="/conseils" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-[#1A1A1A] hover:bg-[#FFF3E0] hover:text-[#E65100] transition-colors duration-150">
                <svg class="w-4 h-4 text-[#E65100] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
                Conseils d'Experts
              </a>
            </li>
          </ul>

          <!-- Zones d'intervention mobile (accordéon) -->
          <div>
            <button
              type="button"
              id="mobile-zones-btn"
              class="w-full flex items-center justify-between px-4 py-3 rounded-xl text-sm font-medium text-[#1A1A1A] hover:bg-[#F5F5F5] transition-colors duration-150"
              aria-expanded="false"
              aria-controls="mobile-zones"
            >
              <span class="flex items-center gap-3">
                <svg class="w-4 h-4 text-[#E65100] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Zones d'intervention
              </span>
              <svg id="mobile-zones-arrow" class="w-4 h-4 text-[#1A1A1A]/40 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div id="mobile-zones" class="hidden mt-1 ml-4 border-l-2 border-[#E65100]/20 pl-3 space-y-3">
              {zonesGroupes.map(({ label, villes: vs }) => (
                <div>
                  <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 px-3 py-1.5">{label}</p>
                  <ul class="space-y-0.5">
                    {vs.map(v => (
                      <li>
                        <a href={`/villes/${v.slug}`} class="flex items-center justify-between px-3 py-2 rounded-lg hover:bg-[#FFF3E0] group transition-colors duration-150">
                          <span class="text-xs font-medium text-[#1A1A1A]/70 group-hover:text-[#E65100]">Ramonage {v.nom}</span>
                          <span class="text-[10px] text-[#1A1A1A]/30 font-mono">{v.codePostal}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>

        </div>

        <!-- CTA bas du panneau -->
        <div class="px-6 py-5 border-t border-[#EEEEEE] bg-[#FAFAFA] shrink-0 space-y-3">
          <a
            href="tel:+33664729600"
            class="flex items-center justify-center gap-2 w-full bg-[#E65100] text-white text-sm font-bold px-5 py-3.5 rounded-xl hover:bg-[#BF360C] transition-colors duration-200"
          >
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Prendre RDV — 06 64 72 96 00
          </a>
          <ContactButton variant="email" class="w-full justify-center" />
        </div>

      </nav>
    </div>

    <!-- ═══════════════════════════════════════════
         WIDGET URGENCE MONOXYDE DE CARBONE
    ═══════════════════════════════════════════ -->
    <div
