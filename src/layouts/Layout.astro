---
import '../styles/global.css';
import ContactButton from '../components/ContactButton.astro';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'SUD RAMONAGE — Ramonage Professionnel',
  description = 'Expert en ramonage certifié. Intervention rapide, travail soigné. Prenez rendez-vous en ligne.',
} = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "SUD RAMONAGE",
  "description": description,
  "telephone": "+33664729600",
  "email": "majeo@ik.me",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "31 chemin des tamaris",
    "addressLocality": "Martigues",
    "postalCode": "13500",
    "addressCountry": "FR"
  },
  "areaServed": ["Martigues", "Istres", "Fos-sur-Mer", "Bouches-du-Rhône"],
  "url": "https://sud-ramonage.vercel.app",
  "openingHours": "Mo-Sa 08:00-18:00"
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="bg-white text-[#000000] font-sans antialiased selection:bg-[#D5001C] selection:text-white">

    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-black/[0.06]">
      <div class="max-w-7xl mx-auto px-8 py-5 flex items-center justify-between">
        <a
          href="/"
          class="text-sm font-black tracking-[0.3em] uppercase text-[#000000] hover:text-[#D5001C] transition-colors duration-300"
        >
          SUD RAMONAGE
        </a>
        <nav class="hidden md:flex items-center gap-10">
          <a href="/#services" class="text-[11px] font-medium tracking-[0.18em] uppercase text-[#000000]/50 hover:text-[#000000] transition-colors duration-300">Services</a>
          <a href="/#contact" class="text-[11px] font-medium tracking-[0.18em] uppercase text-[#000000]/50 hover:text-[#000000] transition-colors duration-300">Contact</a>
          <ContactButton variant="phone" />
        </nav>
        <!-- Mobile -->
        <a href="tel:+33664729600" class="md:hidden inline-flex items-center justify-center w-10 h-10 bg-[#D5001C] rounded-[2px] text-white hover:bg-[#AA0016] transition-colors duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-black/[0.06] mt-40">
      <div class="max-w-7xl mx-auto px-8 py-14">
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-10">
          <div class="space-y-3">
            <span class="block text-sm font-black tracking-[0.3em] uppercase text-[#000000]">SUD RAMONAGE</span>
            <span class="block text-xs text-[#000000]/40 tracking-wide">31 chemin des tamaris, 13500 Martigues</span>
            <ContactButton variant="email" />
          </div>
          <div class="flex flex-col md:flex-row items-start md:items-center gap-6 md:gap-10">
            <a href="tel:+33664729600" class="text-xs font-medium tracking-[0.18em] uppercase text-[#000000]/40 hover:text-[#D5001C] transition-colors duration-300">
              06 64 72 96 00
            </a>
            <span class="hidden md:block w-px h-4 bg-black/10"></span>
            <span class="text-xs text-[#000000]/30">&copy; {new Date().getFullYear()} Sud Ramonage — Tous droits réservés</span>
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>
