---
import '../styles/global.css';
import ContactButton from '../components/ContactButton.astro';
import SEO from '../components/SEO.astro';
import { villes } from '../data/villes';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  breadcrumbs?: { name: string; url: string }[];
  pageSchema?: object;
}

const {
  title = 'SUD RAMONAGE — Ramonage Professionnel à Martigues',
  description = 'Artisan ramoneur certifié à Martigues. Ramonage cheminée, poêle à bois et granulés. Certificat immédiat. Assurance pro. Conforme RSD 13.',
  canonical,
  ogImage,
  breadcrumbs,
  pageSchema,
} = Astro.props;

const services = [
  { href: '/ramonage',        label: 'Ramonage Certifié' },
  { href: '/debistrage',      label: 'Débistrage'         },
  { href: '/entretien-poele', label: 'Entretien Poêle'   },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Sud Ramonage" />

    <!-- Preconnect Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- font-display:swap via &display=swap, chargement non-bloquant -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <title>{title}</title>

    <!-- SEO : canonical, OG, Twitter, JSON-LD -->
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      breadcrumbs={breadcrumbs}
      pageSchema={pageSchema}
    />
  </head>
  <body class="bg-white text-[#1A1A1A] font-sans antialiased">

    <!-- ═══ HEADER ═══ -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-white shadow-[0_1px_0_0_#EEEEEE]">
      <div class="max-w-6xl mx-auto px-6 md:px-10 h-16 flex items-center justify-between">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group shrink-0">
          <span class="w-7 h-7 rounded-md bg-[#E65100] flex items-center justify-center shrink-0">
            <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/>
            </svg>
          </span>
          <span class="text-sm font-extrabold tracking-tight text-[#1A1A1A] group-hover:text-[#E65100] transition-colors duration-200">
            SUD RAMONAGE
          </span>
        </a>

        <!-- Nav desktop -->
        <nav class="hidden md:flex items-center gap-7">

          <!-- Menu déroulant Services -->
          <div class="relative group/services">
            <button class="flex items-center gap-1 text-xs font-medium text-[#1A1A1A]/50 hover:text-[#1A1A1A] transition-colors duration-200 py-5">
              Services
              <svg class="w-3 h-3 group-hover/services:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <!-- Dropdown -->
            <div class="absolute top-full left-1/2 -translate-x-1/2 pt-1 opacity-0 invisible group-hover/services:opacity-100 group-hover/services:visible transition-all duration-200">
              <div class="bg-white border border-[#EEEEEE] rounded-xl shadow-lg shadow-black/5 p-2 min-w-[200px]">
                {services.map(({ href, label }) => (
                  <a
                    href={href}
                    class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-xs font-medium text-[#1A1A1A]/65 hover:bg-[#FFF3E0] hover:text-[#E65100] transition-colors duration-150"
                  >
                    <span class="w-1.5 h-1.5 rounded-full bg-[#E65100] shrink-0"></span>
                    {label}
                  </a>
                ))}
              </div>
            </div>
          </div>

          <a href="/#engagement" class="text-xs font-medium text-[#1A1A1A]/50 hover:text-[#1A1A1A] transition-colors duration-200">Engagements</a>
          <a href="/conseils" class="text-xs font-medium text-[#1A1A1A]/50 hover:text-[#1A1A1A] transition-colors duration-200">Conseils</a>
          <a href="/realisations" class="text-xs font-medium text-[#1A1A1A]/50 hover:text-[#1A1A1A] transition-colors duration-200">Réalisations</a>
          <a href="/#contact" class="text-xs font-medium text-[#1A1A1A]/50 hover:text-[#1A1A1A] transition-colors duration-200">Contact</a>
          <ContactButton variant="phone" />
        </nav>

        <!-- Mobile : bouton appel -->
        <a
          href="tel:+33664729600"
          class="md:hidden inline-flex items-center gap-2 bg-[#E65100] text-white text-xs font-semibold px-4 py-2.5 rounded-lg hover:bg-[#BF360C] transition-colors duration-200"
        >
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Appeler
        </a>

      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- ═══ FOOTER ═══ -->
    <footer class="border-t border-[#EEEEEE] mt-24 bg-[#FAFAFA]">
      <div class="max-w-6xl mx-auto px-6 md:px-10 py-14">

        <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-10">

          <!-- Colonne 1 : Marque -->
          <div class="md:col-span-1 space-y-3">
            <div class="flex items-center gap-2">
              <span class="w-6 h-6 rounded-md bg-[#E65100] flex items-center justify-center shrink-0">
                <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/>
                </svg>
              </span>
              <p class="text-sm font-extrabold tracking-tight text-[#1A1A1A]">SUD RAMONAGE</p>
            </div>
            <p class="text-xs text-[#1A1A1A]/40 leading-relaxed">
              Artisan ramoneur certifié. 31 chemin des tamaris, 13500 Martigues.
            </p>
            <ContactButton variant="email" />
            <a href="tel:+33664729600" class="block text-xs text-[#1A1A1A]/40 hover:text-[#E65100] transition-colors duration-200">
              06 64 72 96 00
            </a>
          </div>

          <!-- Colonne 2 : Services -->
          <div>
            <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/35 mb-4">Services</p>
            <ul class="space-y-2.5">
              {services.map(({ href, label }) => (
                <li>
                  <a href={href} class="text-xs text-[#1A1A1A]/55 hover:text-[#E65100] transition-colors duration-200">{label}</a>
                </li>
              ))}
              <li>
                <a href="/#services" class="text-xs text-[#1A1A1A]/55 hover:text-[#E65100] transition-colors duration-200">Tous les services</a>
              </li>
            </ul>
          </div>

          <!-- Colonne 3 : Villes Côte Bleue & Martigues -->
          <div>
            <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/35 mb-4">Côte Bleue & Martigues</p>
            <ul class="space-y-2.5">
              {villes.filter(v => ['martigues','sausset-les-pins','carry-le-rouet','chateauneuf-les-martigues'].includes(v.slug)).map(v => (
                <li>
                  <a href={`/villes/${v.slug}`} class="text-xs text-[#1A1A1A]/55 hover:text-[#E65100] transition-colors duration-200">
                    Ramonage {v.nom}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Colonne 4 : Étang de Berre -->
          <div>
            <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/35 mb-4">Étang de Berre</p>
            <ul class="space-y-2.5">
              {villes.filter(v => ['istres','fos-sur-mer','gignac-la-nerthe'].includes(v.slug)).map(v => (
                <li>
                  <a href={`/villes/${v.slug}`} class="text-xs text-[#1A1A1A]/55 hover:text-[#E65100] transition-colors duration-200">
                    Ramonage {v.nom}
                  </a>
                </li>
              ))}
            </ul>
          </div>

        </div>

        <!-- Maillage sémantique croisé ville↔service -->
        <nav aria-label="Liens thématiques ramonage par ville" class="pt-8 border-t border-[#EEEEEE] mb-6">
          <p class="text-[9px] font-semibold tracking-widest uppercase text-[#1A1A1A]/20 mb-3">Ramonage par secteur</p>
          <ul class="flex flex-wrap gap-x-5 gap-y-1.5">
            {[
              { href: '/ramonage',        label: 'Ramonage certifié Martigues'          },
              { href: '/debistrage',      label: 'Débistrage conduit Istres'            },
              { href: '/entretien-poele', label: 'Entretien poêle Fos-sur-Mer'         },
              { href: '/ramonage',        label: 'Ramonage cheminée Sausset-les-Pins'  },
              { href: '/debistrage',      label: 'Débistrage bistre Carry-le-Rouet'    },
              { href: '/entretien-poele', label: 'Entretien poêle Châteauneuf'         },
              { href: '/ramonage',        label: 'Ramonage conduit Gignac-la-Nerthe'   },
              { href: '/villes/martigues',              label: 'Tubage inox Martigues'             },
              { href: '/villes/istres',                 label: 'Tirage thermique Istres'           },
              { href: '/villes/fos-sur-mer',            label: 'Test de vacuité Fos-sur-Mer'       },
              { href: '/villes/sausset-les-pins',       label: 'RSD 13 Sausset-les-Pins'           },
              { href: '/villes/carry-le-rouet',         label: 'Calcin cheminée Carry-le-Rouet'   },
              { href: '/villes/chateauneuf-les-martigues', label: 'Ramonage RSD Châteauneuf'      },
              { href: '/villes/gignac-la-nerthe',       label: 'Conduit inox Gignac-la-Nerthe'     },
            ].map(({ href, label }) => (
              <li>
                <a href={href} class="text-[10px] text-[#1A1A1A]/25 hover:text-[#E65100] transition-colors duration-200">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <!-- Bas du footer -->
        <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-[#1A1A1A]/30">
          <span>&copy; {new Date().getFullYear()} Sud Ramonage — Artisan ramoneur certifié à Martigues</span>
          <span>Conforme RSD 13 — Bouches-du-Rhône</span>
        </div>

      </div>
    </footer>

  </body>
</html>
