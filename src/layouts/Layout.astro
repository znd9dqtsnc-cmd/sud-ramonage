---
import '../styles/global.css';
import ContactButton from '../components/ContactButton.astro';
import EmailButton from '../components/EmailButton.astro';
import SEO from '../components/SEO.astro';
import COSTICBadge from '../components/COSTICBadge.astro';
import { ClientRouter } from 'astro:transitions';
import { villes } from '../data/villes';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  breadcrumbs?: { name: string; url: string }[];
  pageSchema?: object;
  preloadImageHref?: string;
}

const {
  title = 'SUD RAMONAGE — Ramonage Professionnel à Martigues',
  description = 'Artisan ramoneur certifié à Martigues. Ramonage cheminée, poêle à bois et granulés. Certificat immédiat. Assurance pro. Conforme RSD 13.',
  canonical,
  ogImage,
  breadcrumbs,
  pageSchema,
  preloadImageHref,
} = Astro.props;

const particuliersMenu = [
  { href: '/particuliers#ramonage',   label: 'Ramonage & Entretien' },
  { href: '/particuliers#poeles',     label: 'Poêles & Granulés' },
  { href: '/particuliers#chaudieres', label: 'Chaudières' },
  { href: '/particuliers#audit',      label: 'Audit & Diagnostic' },
];

const proMenu = [
  { href: '/pro-syndics#pro',     label: 'Professionnels & CHR' },
  { href: '/pro-syndics#syndics', label: 'Syndics & Immobilier' },
];

const expertiseMenu = [
  { href: '/expertise#reglementation', label: 'Guide réglementaire' },
  { href: '/expertise#conseils',       label: "Conseils d'entretien" },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Sud Ramonage" />

    {preloadImageHref && (
      <link rel="preload" as="image" href={preloadImageHref} fetchpriority="high" />
    )}

    <title>{title}</title>
    <ClientRouter />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      breadcrumbs={breadcrumbs}
      pageSchema={pageSchema}
    />
  </head>
  <body class="bg-[#FFFDF9] text-[#1A1A1A] font-sans antialiased">

    <!-- HEADER -->
    <header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-[#1A1A1A] backdrop-blur-sm border-b border-white/8 transition-shadow duration-300">
      <div class="max-w-6xl mx-auto px-6 md:px-10 h-16 flex items-center justify-between gap-6">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 shrink-0 group" aria-label="Sud Ramonage - Ramonage à Martigues">
          <span class="w-7 h-7 rounded-md bg-[#C0622F] flex items-center justify-center shrink-0" aria-hidden="true">
            <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/>
            </svg>
          </span>
          <span class="text-sm font-extrabold tracking-tight text-white group-hover:text-[#C0622F] transition-colors duration-200">
            SUD RAMONAGE
          </span>
        </a>

        <!-- Nav Desktop -->
        <nav class="hidden lg:flex items-center gap-0.5 flex-1" aria-label="Navigation principale">
          <ul class="flex items-center gap-0.5">

            <li>
              <a href="/" class="px-3 py-2 rounded-lg text-xs font-medium text-white/60 hover:text-white hover:bg-white/8 transition-all duration-150">
                Accueil
              </a>
            </li>

            <!-- Particuliers -->
            <li class="relative group/part">
              <a href="/particuliers" class="flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium text-white/60 hover:text-white hover:bg-white/8 transition-all duration-150">
                Particuliers
                <svg class="w-3 h-3 group-hover/part:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </a>
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover/part:opacity-100 group-hover/part:visible transition-all duration-200 pointer-events-none group-hover/part:pointer-events-auto z-50">
                <div class="bg-[#1A1A1A] border border-white/10 rounded-xl shadow-2xl shadow-black/40 p-2 w-52">
                  <ul>
                    {particuliersMenu.map(({ href, label }) => (
                      <li>
                        <a href={href} class="flex items-center gap-2 px-4 py-2.5 rounded-lg hover:bg-white/8 transition-colors duration-150">
                          <span class="w-1.5 h-1.5 rounded-full bg-[#C0622F] shrink-0"></span>
                          <span class="text-xs font-medium text-white/75">{label}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </li>

            <!-- Pro & Syndics -->
            <li class="relative group/pro">
              <a href="/pro-syndics" class="flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium text-white/60 hover:text-white hover:bg-white/8 transition-all duration-150">
                Pro &amp; Syndics
                <svg class="w-3 h-3 group-hover/pro:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </a>
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover/pro:opacity-100 group-hover/pro:visible transition-all duration-200 pointer-events-none group-hover/pro:pointer-events-auto z-50">
                <div class="bg-[#1A1A1A] border border-white/10 rounded-xl shadow-2xl shadow-black/40 p-2 w-52">
                  <ul>
                    {proMenu.map(({ href, label }) => (
                      <li>
                        <a href={href} class="flex items-center gap-2 px-4 py-2.5 rounded-lg hover:bg-white/8 transition-colors duration-150">
                          <span class="w-1.5 h-1.5 rounded-full bg-[#C0622F] shrink-0"></span>
                          <span class="text-xs font-medium text-white/75">{label}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </li>

            <!-- Expertise -->
            <li class="relative group/exp">
              <a href="/expertise" class="flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium text-white/60 hover:text-white hover:bg-white/8 transition-all duration-150">
                Expertise
                <svg class="w-3 h-3 group-hover/exp:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </a>
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover/exp:opacity-100 group-hover/exp:visible transition-all duration-200 pointer-events-none group-hover/exp:pointer-events-auto z-50">
                <div class="bg-[#1A1A1A] border border-white/10 rounded-xl shadow-2xl shadow-black/40 p-2 w-52">
                  <ul>
                    {expertiseMenu.map(({ href, label }) => (
                      <li>
                        <a href={href} class="flex items-center gap-2 px-4 py-2.5 rounded-lg hover:bg-white/8 transition-colors duration-150">
                          <span class="w-1.5 h-1.5 rounded-full bg-[#C0622F] shrink-0"></span>
                          <span class="text-xs font-medium text-white/75">{label}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </li>

          </ul>
        </nav>

        <!-- CTA + Burger -->
        <div class="flex items-center gap-2 shrink-0">

          <a
            href="tel:+33664729600"
            class="lg:hidden inline-flex items-center gap-2 bg-[#C0622F] text-white text-xs font-bold px-4 py-2.5 rounded-lg hover:bg-[#A85228] active:scale-[0.97] transition-all duration-150 touch-manipulation"
            aria-label="Appeler le 06 64 72 96 00"
          >
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Appeler
          </a>

          <a
            href="tel:+33664729600"
            class="hidden lg:inline-flex items-center gap-2 bg-[#C0622F] text-white text-xs font-bold px-4 py-2.5 rounded-lg hover:bg-[#A85228] transition-colors duration-200 shadow-sm shadow-[#C0622F]/25"
          >
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            06 64 72 96 00
          </a>

          <button
            id="burger-btn"
            type="button"
            class="lg:hidden flex items-center justify-center w-10 h-10 rounded-lg text-white/70 hover:bg-white/8 transition-colors duration-150"
            aria-label="Ouvrir le menu"
            aria-controls="mobile-menu"
            aria-expanded="false"
          >
            <svg id="burger-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="burger-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

      </div>
    </header>

    <!-- MENU MOBILE -->
    <div id="mobile-menu" class="fixed inset-0 z-40 lg:hidden hidden" aria-hidden="true">
      <div id="mobile-overlay" class="absolute inset-0 bg-[#1A1A1A]/70 backdrop-blur-sm"></div>
      <nav
        class="absolute top-0 right-0 h-full w-80 max-w-full bg-[#1A1A1A] shadow-2xl flex flex-col translate-x-full transition-transform duration-300 ease-in-out"
        id="mobile-panel"
        aria-label="Menu mobile"
      >
        <div class="flex items-center justify-between px-6 h-16 border-b border-white/10 shrink-0">
          <div class="flex items-center gap-2">
            <span class="w-6 h-6 rounded-md bg-[#C0622F] flex items-center justify-center" aria-hidden="true">
              <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/>
              </svg>
            </span>
            <span class="text-sm font-extrabold tracking-tight text-white">SUD RAMONAGE</span>
          </div>
          <button
            id="mobile-close"
            type="button"
            class="flex items-center justify-center w-9 h-9 rounded-lg text-white/50 hover:bg-white/8 transition-colors duration-150"
            aria-label="Fermer le menu"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <div class="flex-1 overflow-y-auto px-4 py-6 space-y-1">
          <ul class="space-y-1">
            <li>
              <a href="/" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-white/75 hover:bg-white/8 hover:text-white transition-colors duration-150">
                <svg class="w-4 h-4 text-[#C0622F] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                Accueil
              </a>
            </li>
          </ul>

          <div>
            <button type="button" id="mobile-part-btn" class="w-full flex items-center justify-between px-4 py-3 rounded-xl text-sm font-medium text-white/75 hover:bg-white/8 transition-colors duration-150" aria-expanded="false" aria-controls="mobile-part">
              <span class="flex items-center gap-3">
                <svg class="w-4 h-4 text-[#C0622F] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                Particuliers
              </span>
              <svg id="mobile-part-arrow" class="w-4 h-4 text-white/30 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <ul id="mobile-part" class="hidden mt-1 ml-4 space-y-0.5 border-l-2 border-[#C0622F]/30 pl-3">
              {particuliersMenu.map(({ href, label }) => (
                <li><a href={href} class="block px-3 py-2 text-xs font-medium text-white/55 hover:bg-white/8 hover:text-white rounded-lg transition-colors">{label}</a></li>
              ))}
            </ul>
          </div>

          <div>
            <button type="button" id="mobile-pro-btn" class="w-full flex items-center justify-between px-4 py-3 rounded-xl text-sm font-medium text-white/75 hover:bg-white/8 transition-colors duration-150" aria-expanded="false" aria-controls="mobile-pro">
              <span class="flex items-center gap-3">
                <svg class="w-4 h-4 text-[#C0622F] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                Pro &amp; Syndics
              </span>
              <svg id="mobile-pro-arrow" class="w-4 h-4 text-white/30 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <ul id="mobile-pro" class="hidden mt-1 ml-4 space-y-0.5 border-l-2 border-[#C0622F]/30 pl-3">
              {proMenu.map(({ href, label }) => (
                <li><a href={href} class="block px-3 py-2 text-xs font-medium text-white/55 hover:bg-white/8 hover:text-white rounded-lg transition-colors">{label}</a></li>
              ))}
            </ul>
          </div>

          <div>
            <button type="button" id="mobile-exp-btn" class="w-full flex items-center justify-between px-4 py-3 rounded-xl text-sm font-medium text-white/75 hover:bg-white/8 transition-colors duration-150" aria-expanded="false" aria-controls="mobile-exp">
              <span class="flex items-center gap-3">
                <svg class="w-4 h-4 text-[#C0622F] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                Expertise
              </span>
              <svg id="mobile-exp-arrow" class="w-4 h-4 text-white/30 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <ul id="mobile-exp" class="hidden mt-1 ml-4 space-y-0.5 border-l-2 border-[#C0622F]/30 pl-3">
              {expertiseMenu.map(({ href, label }) => (
                <li><a href={href} class="block px-3 py-2 text-xs font-medium text-white/55 hover:bg-white/8 hover:text-white rounded-lg transition-colors">{label}</a></li>
              ))}
            </ul>
          </div>
        </div>

        <div class="px-6 py-5 border-t border-white/10 bg-black/20 shrink-0 space-y-3">
          <a
            href="tel:+33664729600"
            class="flex items-center justify-center gap-2 w-full bg-[#C0622F] text-white text-sm font-bold px-5 py-3.5 rounded-xl hover:bg-[#A85228] transition-colors duration-200"
          >
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Prendre RDV — 06 64 72 96 00
          </a>
          <ContactButton variant="email" class="w-full justify-center" />
        </div>

      </nav>
    </div>

    <!-- CONTENU -->
    <main>
      <slot />
    </main>

    <!-- FOOTER -->
    <footer id="site-footer" class="border-t border-[#F0EDE8] mt-24 bg-[#1A1A1A] text-white">
      <div class="max-w-6xl mx-auto px-6 md:px-10 py-14">

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

          <div class="space-y-4">
            <div class="flex items-center gap-2">
              <span class="w-7 h-7 rounded-md bg-[#C0622F] flex items-center justify-center shrink-0" aria-hidden="true">
                <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/>
                </svg>
              </span>
              <p class="text-sm font-extrabold tracking-tight text-white">SUD RAMONAGE</p>
            </div>
            <p class="text-xs text-white/40 leading-relaxed max-w-xs">
              Artisan ramoneur certifié. Ramonage, débistrage et entretien sur Martigues, la Côte Bleue et l'Étang de Berre. Certificat RSD 13 immédiat.
            </p>
            <address class="not-italic text-xs text-white/35 space-y-1">
              <p>31 chemin des tamaris, 13500 Martigues</p>
              <a href="tel:+33664729600" class="block hover:text-[#C0622F] transition-colors duration-200">06 64 72 96 00</a>
              <EmailButton size="sm" class="mt-1" />
            </address>
          </div>

          <div class="space-y-3">
            <p class="text-[10px] font-semibold tracking-widest uppercase text-white/30 mb-3">Particuliers</p>
            <ul class="space-y-2">
              {[
                { href: '/particuliers#ramonage',   label: 'Ramonage & Entretien' },
                { href: '/particuliers#poeles',     label: 'Poêles & Granulés' },
                { href: '/particuliers#chaudieres', label: 'Chaudières' },
                { href: '/particuliers#audit',      label: 'Audit & Diagnostic' },
                { href: '/particuliers#tarifs',     label: 'Tarifs' },
              ].map(({ href, label }) => (
                <li><a href={href} class="text-xs text-white/45 hover:text-[#C0622F] transition-colors duration-200">{label}</a></li>
              ))}
            </ul>
          </div>

          <div class="space-y-3">
            <p class="text-[10px] font-semibold tracking-widest uppercase text-white/30 mb-3">Pro &amp; Syndics</p>
            <ul class="space-y-2">
              {[
                { href: '/pro-syndics#pro',     label: 'Professionnels & CHR' },
                { href: '/pro-syndics#syndics', label: 'Syndics & Immobilier' },
                { href: '/restauration',        label: 'Restauration' },
                { href: '/zones',               label: "Zones d'intervention" },
              ].map(({ href, label }) => (
                <li><a href={href} class="text-xs text-white/45 hover:text-[#C0622F] transition-colors duration-200">{label}</a></li>
              ))}
            </ul>
          </div>

          <div class="space-y-3">
            <p class="text-[10px] font-semibold tracking-widest uppercase text-white/30 mb-3">Expertise</p>
            <ul class="space-y-2">
              {[
                { href: '/expertise#reglementation', label: 'Guide réglementaire RSD 13' },
                { href: '/expertise#conseils',       label: "Conseils d'entretien" },
                { href: '/reglementation',           label: 'Réglementation' },
                { href: '/conseils',                 label: 'Blog & Conseils' },
                { href: '/lexique',                  label: 'Lexique fumisterie' },
                { href: '/realisations',             label: 'Réalisations' },
              ].map(({ href, label }) => (
                <li><a href={href} class="text-xs text-white/45 hover:text-[#C0622F] transition-colors duration-200">{label}</a></li>
              ))}
            </ul>
          </div>

        </div>

        <nav aria-label="Liens thématiques ramonage par ville" class="pt-8 border-t border-white/8 mb-6">
          <p class="text-[9px] font-semibold tracking-widest uppercase text-white/15 mb-3">Ramonage par secteur</p>
          <ul class="flex flex-wrap gap-x-5 gap-y-1.5">
            {[
              { href: '/ramonage',                         label: 'Ramonage certifié Martigues'              },
              { href: '/debistrage',                       label: 'Débistrage conduit Istres'                },
              { href: '/villes/salon-de-provence',         label: 'Ramonage Salon-de-Provence'               },
              { href: '/villes/aix-en-provence',           label: 'Ramonage Aix-en-Provence'                 },
              { href: '/villes/vitrolles',                 label: 'Ramonage certifié Vitrolles'              },
              { href: '/villes/marignane',                 label: 'Ramonage Marignane'                       },
              { href: '/villes/berre-letang',              label: "Ramonage Berre-l'Étang"                   },
              { href: '/villes/port-de-bouc',              label: 'Ramonage Port-de-Bouc'                    },
              { href: '/villes/sausset-les-pins',          label: 'RSD 13 Sausset-les-Pins'                  },
              { href: '/villes/carry-le-rouet',            label: 'Carry-le-Rouet'                           },
              { href: '/villes/chateauneuf-les-martigues', label: 'Ramonage RSD Châteauneuf'                 },
              { href: '/zones',                            label: "Toutes nos zones →"                       },
            ].map(({ href, label }) => (
              <li>
                <a href={href} class="text-[10px] text-white/20 hover:text-[#C0622F] transition-colors duration-200">{label}</a>
              </li>
            ))}
