---
import '../styles/global.css';
import ContactButton from '../components/ContactButton.astro';
import EmailButton from '../components/EmailButton.astro';
import SEO from '../components/SEO.astro';
import COSTICBadge from '../components/COSTICBadge.astro';
import { ClientRouter } from 'astro:transitions';
import { villes } from '../data/villes';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  breadcrumbs?: { name: string; url: string }[];
  pageSchema?: object;
  /** URL de l'image hero à précharger (LCP) — passer getImage().src depuis la page */
  preloadImageHref?: string;
}

const {
  title = 'SUD RAMONAGE — Ramonage Professionnel à Martigues',
  description = 'Artisan ramoneur certifié à Martigues. Ramonage cheminée, poêle à bois et granulés. Certificat immédiat. Assurance pro. Conforme RSD 13.',
  canonical,
  ogImage,
  breadcrumbs,
  pageSchema,
  preloadImageHref,
} = Astro.props;

const particuliersMenu = [
  { href: '/ramonage',          label: 'Ramonage certifié',            desc: 'NF DTU 24.1 & 24.2 — certificat RSD 13 immédiat' },
  { href: '/debistrage',        label: 'Débistrage',                   desc: 'Élimination bistre & goudron — traitement chimique & mécanique' },
  { href: '/entretien-poele',   label: 'Entretien poêle & chaudière',  desc: 'Corps de chauffe fioul, bois, granulés' },
  { href: '/inspection-camera', label: 'Audit & Diagnostic',           desc: 'Caméra HD, test de vacuité, essai fumigène' },
];

const proCHRMenu = [
  { href: '/restauration', label: 'Restaurants & Pizzerias', desc: 'Fours à bois, conduits et hottes CHR' },
  { href: '/restauration', label: 'Boulangeries & Fours',   desc: 'Fours à sole, nettoyage conduits pro' },
  { href: '/restauration', label: 'Hottes & Ventilation',   desc: 'Entretien et dégraissage hottes professionnelles' },
];

const immobilierMenu = [
  { href: '/syndics',               label: 'Syndics & Collectifs',    desc: 'Conduits shunt, 3CE, alvéolaires — NF EN 13384-2' },
  { href: '/aide-vente-immobilier', label: 'Aide à la vente',         desc: 'Rapport certifié pour acte notarié' },
  { href: '/gestion-locative',      label: 'Gestion locative',        desc: 'Charge récupérable — Décret 87-713' },
  { href: '/audit-immobilier',      label: 'Carnet de santé conduit', desc: 'Audit certifié pour diagnostiqueurs & notaires' },
];

const expertiseMenu = [
  { href: '/conseils',       label: 'Blog & Conseils',      desc: 'Guides techniques, entretien, sécurité' },
  { href: '/reglementation', label: 'Réglementation',       desc: 'RSD 13, Décret 2023-641, NF DTU 24.1' },
  { href: '/realisations',   label: 'Réalisations',         desc: 'Chantiers et photos d\'interventions' },
  { href: '/lexique',        label: 'Lexique fumisterie',   desc: '50 termes techniques expliqués' },
];

const zonesGroupes = [
  {
    label: 'Côte Bleue & Martigues',
    villes: villes.filter(v => ['martigues','sausset-les-pins','carry-le-rouet','chateauneuf-les-martigues'].includes(v.slug)),
  },
  {
    label: 'Étang de Berre',
    villes: villes.filter(v => ['istres','fos-sur-mer','gignac-la-nerthe'].includes(v.slug)),
  },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Sud Ramonage" />

    <!-- Preload image LCP si fournie par la page -->
    {preloadImageHref && (
      <link rel="preload" as="image" href={preloadImageHref} fetchpriority="high" />
    )}

    <!-- Inter Variable — hébergé localement via @fontsource-variable/inter (LCP optimisé, zéro DNS externe) -->

    <title>{title}</title>

    <!-- Transitions de page fluides (SPA-like avec prefetch) -->
    <ClientRouter />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      breadcrumbs={breadcrumbs}
      pageSchema={pageSchema}
    />
  </head>
  <body class="bg-white text-[#1A1A1A] font-sans antialiased">

    <!-- ═══════════════════════════════════════════
         HEADER
    ═══════════════════════════════════════════ -->
    <header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-[#EEEEEE] transition-shadow duration-300">
      <div class="max-w-6xl mx-auto px-6 md:px-10 h-16 flex items-center justify-between gap-6">

        <!-- ── Logo ── -->
        <a href="/" class="flex items-center gap-2.5 shrink-0 group" aria-label="Sud Ramonage - Ramonage à Martigues">
          <span class="w-7 h-7 rounded-md bg-[#2563EB] flex items-center justify-center shrink-0" aria-hidden="true">
            <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/>
            </svg>
          </span>
          <span class="text-sm font-extrabold tracking-tight text-[#1A1A1A] group-hover:text-[#2563EB] transition-colors duration-200">
            SUD RAMONAGE
          </span>
        </a>

        <!-- ── Nav Desktop ── -->
        <nav class="hidden lg:flex items-center gap-0.5 flex-1" aria-label="Navigation principale">
          <ul class="flex items-center gap-0.5">

            <!-- Accueil -->
            <li>
              <a href="/" class="px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150">
                Accueil
              </a>
            </li>

            <!-- Particuliers -->
            <li class="relative group/part">
              <button type="button" class="flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150" aria-haspopup="true">
                Particuliers
                <svg class="w-3 h-3 group-hover/part:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover/part:opacity-100 group-hover/part:visible transition-all duration-200 pointer-events-none group-hover/part:pointer-events-auto z-50">
                <div class="bg-white border border-[#EEEEEE] rounded-2xl shadow-2xl shadow-black/10 p-5 w-[560px] grid grid-cols-2 gap-5">
                  <div>
                    <p class="text-[9px] font-bold tracking-widest uppercase text-[#1A1A1A]/30 mb-3">Prestations</p>
                    <ul class="space-y-0.5">
                      {particuliersMenu.map(({ href, label, desc }) => (
                        <li>
                          <a href={href} class="flex flex-col gap-0.5 px-3 py-2.5 rounded-lg hover:bg-[#EFF6FF] group/item transition-colors duration-150">
                            <span class="text-xs font-semibold text-[#1A1A1A] group-hover/item:text-[#2563EB] transition-colors flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-[#2563EB] shrink-0"></span>{label}</span>
                            <span class="text-[10px] text-[#1A1A1A]/40 pl-2.5">{desc}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div class="bg-[#EFF6FF] rounded-xl p-4 flex flex-col justify-between">
                    <div>
                      <p class="text-[10px] font-bold tracking-widest uppercase text-[#2563EB]/60 mb-2">Certifié COSTIC</p>
                      <p class="text-sm font-bold text-[#1E293B] leading-snug mb-2">Ramonage certifié RSD 13<br/>Certificat le jour même</p>
                      <p class="text-[11px] text-[#1E293B]/60 leading-relaxed">À partir de 75 € · Bouches-du-Rhône · Déplacement inclus</p>
                    </div>
                    <a href="tel:+33664729600" class="mt-4 inline-flex items-center gap-1.5 bg-[#2563EB] text-white text-xs font-bold px-3 py-2 rounded-lg hover:bg-[#1D4ED8] transition-colors">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                      06 64 72 96 00
                    </a>
                  </div>
                </div>
              </div>
            </li>

            <!-- Pro & CHR -->
            <li class="relative group/chr">
              <button type="button" class="flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150" aria-haspopup="true">
                Pro & CHR
                <svg class="w-3 h-3 group-hover/chr:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover/chr:opacity-100 group-hover/chr:visible transition-all duration-200 pointer-events-none group-hover/chr:pointer-events-auto z-50">
                <div class="bg-white border border-[#EEEEEE] rounded-xl shadow-xl shadow-black/8 p-2 w-64">
                  <ul>
                    {proCHRMenu.map(({ href, label, desc }) => (
                      <li>
                        <a href={href} class="flex flex-col gap-0.5 px-4 py-3 rounded-lg hover:bg-[#EFF6FF] group/item transition-colors duration-150">
                          <span class="text-xs font-semibold text-[#1A1A1A] group-hover/item:text-[#2563EB] transition-colors flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#2563EB] shrink-0"></span>{label}</span>
                          <span class="text-[11px] text-[#1A1A1A]/45 pl-3.5">{desc}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </li>

            <!-- Immobilier & Syndics -->
            <li class="relative group/immo">
              <button type="button" class="flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150" aria-haspopup="true">
                Immobilier &amp; Syndics
                <svg class="w-3 h-3 group-hover/immo:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover/immo:opacity-100 group-hover/immo:visible transition-all duration-200 pointer-events-none group-hover/immo:pointer-events-auto z-50">
                <div class="bg-white border border-[#EEEEEE] rounded-xl shadow-xl shadow-black/8 p-2 w-72">
                  <ul>
                    {immobilierMenu.map(({ href, label, desc }) => (
                      <li>
                        <a href={href} class="flex flex-col gap-0.5 px-4 py-3 rounded-lg hover:bg-[#EFF6FF] group/item transition-colors duration-150">
                          <span class="text-xs font-semibold text-[#1A1A1A] group-hover/item:text-[#2563EB] transition-colors flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#2563EB] shrink-0"></span>{label}</span>
                          <span class="text-[11px] text-[#1A1A1A]/45 pl-3.5">{desc}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </li>

            <!-- Expertise -->
            <li class="relative group/exp">
              <button type="button" class="flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150" aria-haspopup="true">
                Expertise
                <svg class="w-3 h-3 group-hover/exp:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover/exp:opacity-100 group-hover/exp:visible transition-all duration-200 pointer-events-none group-hover/exp:pointer-events-auto z-50">
                <div class="bg-white border border-[#EEEEEE] rounded-xl shadow-xl shadow-black/8 p-2 w-64">
                  <ul>
                    {expertiseMenu.map(({ href, label, desc }) => (
                      <li>
                        <a href={href} class="flex flex-col gap-0.5 px-4 py-3 rounded-lg hover:bg-[#EFF6FF] group/item transition-colors duration-150">
                          <span class="text-xs font-semibold text-[#1A1A1A] group-hover/item:text-[#2563EB] transition-colors flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#2563EB] shrink-0"></span>{label}</span>
                          <span class="text-[11px] text-[#1A1A1A]/45 pl-3.5">{desc}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </li>

            <!-- Zones d'intervention dropdown -->
            <li class="relative group/zones">
              <button type="button" class="flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium text-[#1A1A1A]/55 hover:text-[#1A1A1A] hover:bg-[#F5F5F5] transition-all duration-150" aria-haspopup="true">
                Zones
                <svg class="w-3 h-3 group-hover/zones:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover/zones:opacity-100 group-hover/zones:visible transition-all duration-200 pointer-events-none group-hover/zones:pointer-events-auto z-50">
                <div class="bg-white border border-[#EEEEEE] rounded-xl shadow-xl shadow-black/8 p-4 w-72">
                  <ul class="space-y-4">
                    {zonesGroupes.map(({ label, villes: vs }) => (
                      <li>
                        <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/30 mb-2">{label}</p>
                        <ul class="space-y-0.5">
                          {vs.map(v => (
                            <li>
                              <a href={`/villes/${v.slug}`} class="flex items-center justify-between px-3 py-2 rounded-lg hover:bg-[#EFF6FF] group/vlink transition-colors duration-150">
                                <span class="text-xs font-medium text-[#1A1A1A]/70 group-hover/vlink:text-[#2563EB] transition-colors">Ramonage {v.nom}</span>
                                <span class="text-[10px] text-[#1A1A1A]/30 font-mono">{v.codePostal}</span>
                              </a>
                            </li>
                          ))}
                        </ul>
                      </li>
                    ))}
                    <li>
                      <a href="/zones" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-[#EFF6FF] text-[#2563EB] text-xs font-semibold hover:bg-[#DBEAFE] transition-colors">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                        Toutes les zones →
                      </a>
                    </li>
                  </ul>
                </div>
              </div>
            </li>

          </ul>
        </nav>

        <!-- ── CTA Desktop + Téléphone Mobile + Burger ── -->
        <div class="flex items-center gap-2 shrink-0">

          <!-- Bouton téléphone MOBILE (lg:hidden) — élément de contact principal -->
          <a
            href="tel:+33664729600"
            class="lg:hidden inline-flex items-center gap-2 bg-[#2563EB] text-white text-xs font-bold px-4 py-2.5 rounded-lg hover:bg-[#1D4ED8] active:bg-[#1E40AF] active:scale-[0.97] transition-all duration-150 touch-manipulation"
            aria-label="Appeler le 06 64 72 96 00"
          >
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Appeler
          </a>

          <!-- Bouton "Prendre RDV" DESKTOP uniquement -->
          <a
            href="tel:+33664729600"
            class="hidden lg:inline-flex items-center gap-2 bg-[#2563EB] text-white text-xs font-bold px-4 py-2.5 rounded-lg hover:bg-[#1D4ED8] transition-colors duration-200 shadow-sm shadow-[#2563EB]/25"
          >
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Prendre RDV
          </a>

          <!-- Bouton burger mobile -->
          <button
            id="burger-btn"
            type="button"
            class="lg:hidden flex items-center justify-center w-10 h-10 rounded-lg text-[#1A1A1A] hover:bg-[#F5F5F5] transition-colors duration-150"
            aria-label="Ouvrir le menu"
            aria-controls="mobile-menu"
            aria-expanded="false"
          >
            <!-- Icône hamburger -->
            <svg id="burger-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <!-- Icône close (masquée par défaut) -->
            <svg id="burger-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

      </div>
    </header>

    <!-- ═══════════════════════════════════════════
         MENU MOBILE (panneau overlay)
    ═══════════════════════════════════════════ -->
    <div
      id="mobile-menu"
      class="fixed inset-0 z-40 lg:hidden hidden"
      aria-hidden="true"
    >
      <!-- Overlay sombre -->
      <div id="mobile-overlay" class="absolute inset-0 bg-[#1A1A1A]/50 backdrop-blur-sm"></div>

      <!-- Panneau latéral -->
      <nav
        class="absolute top-0 right-0 h-full w-80 max-w-full bg-white shadow-2xl flex flex-col translate-x-full transition-transform duration-300 ease-in-out"
        id="mobile-panel"
        aria-label="Menu mobile"
      >
        <!-- En-tête panneau -->
        <div class="flex items-center justify-between px-6 h-16 border-b border-[#EEEEEE] shrink-0">
          <div class="flex items-center gap-2">
            <span class="w-6 h-6 rounded-md bg-[#2563EB] flex items-center justify-center" aria-hidden="true">
              <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C9.5 6 7 8 7 12a5 5 0 0010 0c0-4-2.5-6-5-10zm0 18a3 3 0 01-3-3c0-2 1.5-3.5 3-5 1.5 1.5 3 3 3 5a3 3 0 01-3 3z"/>
              </svg>
            </span>
            <span class="text-sm font-extrabold tracking-tight text-[#1A1A1A]">SUD RAMONAGE</span>
          </div>
          <button
            id="mobile-close"
            type="button"
            class="flex items-center justify-center w-9 h-9 rounded-lg text-[#1A1A1A]/50 hover:bg-[#F5F5F5] transition-colors duration-150"
            aria-label="Fermer le menu"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Liens mobile -->
        <div class="flex-1 overflow-y-auto px-4 py-6 space-y-1">

          <ul class="space-y-1">
            <li>
              <a href="/" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-[#1A1A1A] hover:bg-[#EFF6FF] hover:text-[#2563EB] transition-colors duration-150">
                <svg class="w-4 h-4 text-[#2563EB] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                Accueil
              </a>
            </li>
          </ul>

          <!-- Particuliers mobile (accordéon) -->
          <div>
            <button type="button" id="mobile-part-btn" class="w-full flex items-center justify-between px-4 py-3 rounded-xl text-sm font-medium text-[#1A1A1A] hover:bg-[#F5F5F5] transition-colors duration-150" aria-expanded="false" aria-controls="mobile-part">
              <span class="flex items-center gap-3">
                <svg class="w-4 h-4 text-[#2563EB] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                Particuliers
              </span>
