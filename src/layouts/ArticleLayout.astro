---
import '../styles/article.css';
import Layout from './Layout.astro';
import ContactButton from '../components/ContactButton.astro';

export interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  readTime: string;
  datePublished: string;
  relatedService: { href: string; label: string };
  articleSchema: object;
  howToSchema?: object;
}

const {
  title,
  description,
  slug,
  category,
  readTime,
  datePublished,
  relatedService,
  articleSchema,
  howToSchema,
} = Astro.props;

const siteUrl = 'https://www.sud-ramonage.fr';

const schemas = howToSchema
  ? [articleSchema, howToSchema]
  : [articleSchema];
---

<Layout
  title={`${title} — Sud Ramonage`}
  description={description}
  canonical={`${siteUrl}/conseils/${slug}`}
  breadcrumbs={[
    { name: 'Accueil', url: '/' },
    { name: 'Conseils d\'Experts', url: '/conseils' },
    { name: title, url: `/conseils/${slug}` },
  ]}
>
  <!-- JSON-LD supplémentaires via Fragment inline -->
  {schemas.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  <!-- ═══ BARRE DE PROGRESSION DE LECTURE ═══ -->
  <div
    id="reading-progress"
    aria-hidden="true"
    style="position:fixed;top:64px;left:0;right:0;z-index:49;height:2px;background-color:#E65100;transform:scaleX(0);transform-origin:left;transition:transform 80ms linear;will-change:transform;"
  ></div>
  <script>
    (function () {
      const bar = document.getElementById('reading-progress');
      const article = document.querySelector('article');
      if (!bar || !article) return;

      function update() {
        const winH   = window.innerHeight;
        const top    = article.getBoundingClientRect().top + window.scrollY;
        const height = article.offsetHeight;
        const progress = Math.max(0, Math.min(1,
          (window.scrollY - top + winH * 0.15) / (height - winH * 0.7)
        ));
        bar.style.transform = `scaleX(${progress})`;
      }

      window.addEventListener('scroll', update, { passive: true });
      update();
    })();
  </script>

  <!-- ═══ HERO ARTICLE ═══ -->
  <section class="pt-32 pb-12 px-6 md:px-10 bg-[#FAFAFA] border-b border-[#EEEEEE]">
    <div class="max-w-6xl mx-auto">
      <nav class="flex items-center gap-2 text-xs text-[#1A1A1A]/35 mb-6" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-[#C0622F] transition-colors duration-200">Accueil</a>
        <span>/</span>
        <a href="/conseils" class="hover:text-[#C0622F] transition-colors duration-200">Conseils d'Experts</a>
        <span>/</span>
        <span class="text-[#1A1A1A]/55 line-clamp-1">{title}</span>
      </nav>
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-[10px] font-semibold tracking-widest uppercase text-white bg-[#C0622F] px-2.5 py-1 rounded-md">{category}</span>
          <span class="text-xs text-[#1A1A1A]/35">{readTime} de lecture</span>
          <span class="text-xs text-[#1A1A1A]/35">·</span>
          <time datetime={datePublished} class="text-xs text-[#1A1A1A]/35">
            {new Date(datePublished).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
          </time>
        </div>
        <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight text-[#1A1A1A] leading-tight mb-4">
          {title}
        </h1>
        <p class="text-base text-[#1A1A1A]/55 font-light leading-relaxed max-w-2xl">
          {description}
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ CONTENU + SIDEBAR ═══ -->
  <div class="max-w-6xl mx-auto px-6 md:px-10 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

      <!-- Article principal -->
      <article class="lg:col-span-8">
        <div class="prose-serif">
          <slot />
        </div>

        <!-- Lien service correspondant -->
        <div class="mt-12 p-6 bg-[#FFF5EF] rounded-xl border border-[#C0622F]/15">
          <p class="text-xs font-semibold tracking-widest uppercase text-[#C0622F] mb-2">Service correspondant</p>
          <a
            href={relatedService.href}
            class="flex items-center justify-between group"
          >
            <span class="text-base font-bold text-[#1A1A1A] group-hover:text-[#C0622F] transition-colors duration-200">
              {relatedService.label}
            </span>
            <svg class="w-5 h-5 text-[#C0622F] group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <p class="text-xs text-[#1A1A1A]/45 mt-1 font-light">Découvrez notre prestation complète avec certificat officiel</p>
        </div>

        <!-- Navigation entre articles -->
        <div class="mt-8 pt-8 border-t border-[#EEEEEE]">
          <a href="/conseils" class="inline-flex items-center gap-2 text-xs font-medium text-[#1A1A1A]/45 hover:text-[#C0622F] transition-colors duration-200">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Tous les articles Conseils d'Experts
          </a>
        </div>
      </article>

      <!-- Sidebar sticky -->
      <aside class="lg:col-span-4">
        <div class="sticky top-24 space-y-5">

          <!-- CTA principal -->
          <div class="bg-[#1A1A1A] rounded-xl p-7 text-center">
            <div class="w-10 h-10 rounded-full bg-[#C0622F] flex items-center justify-center mx-auto mb-4">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <p class="text-sm font-bold text-white mb-1">Besoin d'un diagnostic ?</p>
            <p class="text-xs text-white/45 font-light mb-5 leading-relaxed">Appelez-moi directement — devis gratuit sous 24h, intervention rapide sur Martigues et la Côte Bleue.</p>
            <a
              href="tel:+33664729600"
              class="flex items-center justify-center gap-2 bg-[#C0622F] text-white text-sm font-bold px-5 py-3.5 rounded-lg hover:bg-[#A85228] transition-colors duration-200 w-full"
            >
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              06 64 72 96 00
            </a>
          </div>

          <!-- Garanties -->
          <div class="bg-[#FAFAFA] border border-[#EEEEEE] rounded-xl p-6 space-y-3">
            <p class="text-[10px] font-semibold tracking-widest uppercase text-[#1A1A1A]/35 mb-4">Pourquoi Sud Ramonage ?</p>
            {[
              { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', txt: 'Artisan certifié & assuré' },
              { icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', txt: 'Certificat remis sur place (RSD 13)' },
              { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z', txt: 'Martigues & Côte Bleue' },
              { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', txt: 'Réponse sous 24h' },
            ].map(({ icon, txt }) => (
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 text-[#C0622F] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
                </svg>
                <span class="text-xs text-[#1A1A1A]/65 font-light">{txt}</span>
              </div>
            ))}
          </div>

          <!-- Lien service -->
          <a
            href={relatedService.href}
            class="flex items-center justify-between bg-[#FFF5EF] border border-[#C0622F]/20 rounded-xl px-5 py-4 group hover:bg-[#FFE4D0] transition-colors duration-200"
          >
            <div>
              <p class="text-[10px] font-semibold tracking-widest uppercase text-[#C0622F] mb-0.5">Service associé</p>
              <p class="text-sm font-bold text-[#1A1A1A] group-hover:text-[#C0622F] transition-colors duration-200">{relatedService.label}</p>
            </div>
            <svg class="w-4 h-4 text-[#C0622F] group-hover:translate-x-0.5 transition-transform duration-200 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>

        </div>
      </aside>

    </div>
  </div>

</Layout>
